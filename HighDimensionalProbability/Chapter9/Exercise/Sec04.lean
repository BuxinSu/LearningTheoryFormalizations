/-- **Exercise 9.27 (Gaussian width of sparse vectors).** Both the sparse
set and its truncated convex surrogate receive the requested sharp two-sided
comparison, with universal constants and the valid range `1 ≤ s ≤ n`.

**Book Exercise 9.27.** -/
theorem exercise_9_27 :
    ∃ c C : ℝ, 0 < c ∧ 0 < C ∧
      ∀ {n s : ℕ}, 1 ≤ s → s ≤ n →
        let scale := Real.sqrt (s * Real.log (Real.exp 1 * n / s))
        c * scale ≤ setGaussianWidth (sparseUnitSet n s) ∧
        setGaussianWidth (sparseUnitSet n s) ≤ C * scale ∧
        c * scale ≤ setGaussianWidth (truncatedL1Ball n s) ∧
        setGaussianWidth (truncatedL1Ball n s) ≤ C * scale := by
  -- EXERCISE-SORRY: Category A, non-load-bearing Exercise 9.27.
  sorry

/-- **Exercise 9.28 (Garnaev--Gluskin).** The source suppresses the random
subspace's dimension; `E` is here a Haar subspace of codimension `m`.

**Book Exercise 9.28.** -/
theorem exercise_9_28 :
    ∃ C : ℝ, 0 < C ∧
      ∀ {m n : ℕ}, 0 < m → m < n → 2 ≤ n →
        Measurable (fun P : HDP.Chapter5.Grassmannian n (n - m) =>
          setDiameter (grassmannSection P (lpUnitBall n 1))) →
        Integrable (fun P : HDP.Chapter5.Grassmannian n (n - m) =>
          setDiameter (grassmannSection P (lpUnitBall n 1)))
            (HDP.Chapter5.grassmannHaarMeasure n (n - m)) →
        (∫ P, setDiameter (grassmannSection P (lpUnitBall n 1))
          ∂HDP.Chapter5.grassmannHaarMeasure n (n - m)) ≤
            C * Real.sqrt (Real.log (Real.exp 1 * n / m) / m) := by
