/-- **Exercise 9.18 (recovery by norm minimization).** The seminorm is
assumed definite, and minimizer attainment is expressed pointwise rather than
hidden behind an `argmin`.

**Book Exercise 9.18.** -/
theorem exercise_9_18 :
    ∃ C : ℝ, 0 < C ∧
      ∀ {m n : ℕ} {Ω : Type*} {mΩ : MeasurableSpace Ω}
        {μ : Measure Ω} [IsProbabilityMeasure μ]
        (A : HDP.RandomMatrix (Fin m) (Fin n) Ω)
        (q : Seminorm ℝ (Euc n)) (x : Euc n)
        (xhat : Ω → Euc n) (K : ℝ),
        0 < m → 0 < n → (∀ z, q z = 0 → z = 0) → q x ≤ 1 →
        1 ≤ K → A.AEMeasurableEntries μ → A.IsotropicRows μ →
        iIndepFun (fun i ω => HDP.randomMatrixRow A i ω) μ →
        A.RowPsi2Bound μ K →
        (∀ ω, matrixApply (A ω) (xhat ω) = matrixApply (A ω) x) →
        (∀ ω z, matrixApply (A ω) z = matrixApply (A ω) x →
          q (xhat ω) ≤ q z) →
        Measurable xhat → Integrable (fun ω => ‖xhat ω - x‖) μ →
        (∫ ω, ‖xhat ω - x‖ ∂μ) ≤
          C * K ^ 2 * setGaussianWidth (seminormUnitBall q) /
            Real.sqrt m := by
  -- EXERCISE-SORRY: Category A, non-load-bearing Exercise 9.18.
  sorry

/-- **Exercise 9.21 (Lasso).** The printed display drops the signal scale.
Here the homogeneous factor `‖x‖₂` is restored, the zero tuning denominator
is excluded explicitly, and possibly data-dependent noise is controlled by a
deterministic bound `η`.

**Book Exercise 9.21 (Lasso).** -/
theorem exercise_9_21 :
    ∃ c C : ℝ, 0 < c ∧ 0 < C ∧
      ∀ {m n s : ℕ} {Ω : Type*} {mΩ : MeasurableSpace Ω}
        {μ : Measure Ω} [IsProbabilityMeasure μ]
        (A : HDP.RandomMatrix (Fin m) (Fin n) Ω)
        (x : Euc n) (w : Ω → Euc m) (xhat : Ω → Euc n)
        (K η lam : ℝ),
        0 < m → 2 ≤ n → 1 ≤ s → s ≤ n → IsSparse s x → x ≠ 0 →
        1 ≤ K → 0 ≤ η → 0 < lam →
        c * η ^ 2 / ellOneNorm x ≤ lam →
        lam ≤ C * η ^ 2 / ellOneNorm x →
        A.AEMeasurableEntries μ → A.IsotropicRows μ →
        iIndepFun (fun i ω => HDP.randomMatrixRow A i ω) μ →
        A.RowPsi2Bound μ K → (∀ ω, ‖w ω‖ ≤ η) →
        (∀ ω z,
          lassoObjective (A ω) (matrixApply (A ω) x + w ω) lam (xhat ω) ≤
            lassoObjective (A ω) (matrixApply (A ω) x + w ω) lam z) →
        Measurable xhat → Integrable (fun ω => ‖xhat ω - x‖) μ →
        (∫ ω, ‖xhat ω - x‖ ∂μ) ≤
          C * (K ^ 2 * Real.sqrt (s * Real.log n) * ‖x‖ + η) /
            Real.sqrt m := by
  -- EXERCISE-SORRY: Category A, non-load-bearing Exercise 9.21.
  sorry

/-- **Exercise 9.24(a) (basis-pursuit recovery of a sparse signal).**.

**Book Exercise 9.24(a).** -/
theorem exercise_9_24_part_a :
    ∃ C : ℝ, 0 < C ∧
      ∀ {m n s : ℕ} {Ω : Type*} {mΩ : MeasurableSpace Ω}
