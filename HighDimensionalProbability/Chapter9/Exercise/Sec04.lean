noncomputable section

/-- Coordinate `ℓ¹` norm.

**Lean implementation helper.** -/
def ellOneNorm {n : ℕ} (x : Euc n) : ℝ :=
  ∑ i, |x i|

/-- Number of nonzero coordinates.

**Lean implementation helper.** -/
def supportCard {n : ℕ} (x : Euc n) : ℕ :=
  (Finset.univ.filter fun i => x i ≠ 0).card

/-- `ell0` counts nonzero coordinates and defines sparsity. Predicate for an `s`-sparse vector.

**Book Equation (9.21).** -/
def IsSparse {n : ℕ} (s : ℕ) (x : Euc n) : Prop :=
  supportCard x ≤ s

/-- Best `s`-term approximation error in `ℓ¹`.

**Lean implementation helper.** -/
def bestSparseL1Error {n : ℕ} (s : ℕ) (x : Euc n) : ℝ :=
  sInf {r : ℝ | ∃ z : Euc n, IsSparse s z ∧ r = ellOneNorm (x - z)}

/-- Truncated `l1` ball. Unit `ℓ¹` ball truncated by the Euclidean unit ball.

**Book Equation (9.47), Exercise 9.25.** -/
def truncatedL1Ball (n s : ℕ) : Set (Euc n) :=
  {x | ellOneNorm x ≤ Real.sqrt s ∧ ‖x‖ ≤ 1}

/-- Unit `s`-sparse set. Euclidean-unit `s`-sparse vectors.

**Book Equation (9.46), Exercise 9.25.** -/
def sparseUnitSet (n s : ℕ) : Set (Euc n) :=
  {x | IsSparse s x ∧ ‖x‖ ≤ 1}

/-- Unit ball of a seminorm, used with a definiteness hypothesis below.

**Lean implementation helper.** -/
def seminormUnitBall {n : ℕ} (q : Seminorm ℝ (Euc n)) : Set (Euc n) :=
  {x | q x ≤ 1}

/-- Pointwise least-squares-plus-`ℓ¹` objective.

**Lean implementation helper.** -/
def lassoObjective {m n : ℕ}
    (A : Matrix (Fin m) (Fin n) ℝ) (y : Euc m)
    (lam : ℝ) (z : Euc n) : ℝ :=
  ‖y - matrixApply A z‖ ^ 2 + lam * ellOneNorm z

/-- Low-rank matrix measurements are Frobenius inner products. Frobenius measurement vector generated by a family of sensing matrices.

**Book Equation (9.25).** -/
def matrixMeasurements {m d₁ d₂ : ℕ}
    (A : Fin m → Matrix (Fin d₁) (Fin d₂) ℝ)
    (X : Matrix (Fin d₁) (Fin d₂) ℝ) : Euc m :=
  WithLp.toLp 2 (fun i => HDP.matrixFrobeniusInner (A i) X)

/-- Nuclear norm of a rectangular real matrix.

**Lean implementation helper.** -/
def rectangularNuclearNorm {d₁ d₂ : ℕ}
    (X : Matrix (Fin d₁) (Fin d₂) ℝ) : ℝ :=
  ∑ i : Fin (min d₁ d₂), HDP.matrixSingularValue X i

/-- Best rank-`r` nuclear-norm approximation error.

**Lean implementation helper.** -/
def bestRankNuclearError {d₁ d₂ : ℕ} (r : ℕ)
    (X : Matrix (Fin d₁) (Fin d₂) ℝ) : ℝ :=
  sInf {a : ℝ | ∃ Z : Matrix (Fin d₁) (Fin d₂) ℝ,
    HDP.matrixRank Z ≤ r ∧ a = rectangularNuclearNorm (X - Z)}

/-- Independent standard-Gaussian sensing matrices.

**Lean implementation helper.** -/
def IsGaussianMatrixMeasurementFamily {m d₁ d₂ : ℕ}
    {Ω : Type*} [MeasurableSpace Ω] (μ : Measure Ω)
    (A : Fin m → Ω → Matrix (Fin d₁) (Fin d₂) ℝ) : Prop :=
  (∀ i j k, HasLaw (fun ω => A i ω j k) (gaussianReal 0 1) μ) ∧
    iIndepFun (fun q : (Fin m × Fin d₁) × Fin d₂ =>
      fun ω => A q.1.1 ω q.1.2 q.2) μ

/-- **Exercise 9.17 (constrained recovery, mean squared error).** The source
prints only “extend” and no target bound. This is the quantitative square-
error endpoint obtained by integrating the same deviation tail.

**Book Exercise 9.17.** -/
theorem exercise_9_17 :
    ∃ C : ℝ, 0 < C ∧
      ∀ {m n : ℕ} {Ω : Type*} {mΩ : MeasurableSpace Ω}
        {μ : Measure Ω} [IsProbabilityMeasure μ]
        (A : HDP.RandomMatrix (Fin m) (Fin n) Ω)
        (T : Set (Euc n)) (x : Euc n) (xhat : Ω → Euc n) (K : ℝ),
        0 < m → 0 < n → x ∈ T → T.Nonempty → Bornology.IsBounded T →
        1 ≤ K → A.AEMeasurableEntries μ → A.IsotropicRows μ →
        iIndepFun (fun i ω => HDP.randomMatrixRow A i ω) μ →
        A.RowPsi2Bound μ K →
        (∀ ω, xhat ω ∈ T) →
        (∀ ω, matrixApply (A ω) (xhat ω) = matrixApply (A ω) x) →
        Measurable xhat → Integrable (fun ω => ‖xhat ω - x‖ ^ 2) μ →
        (∫ ω, ‖xhat ω - x‖ ^ 2 ∂μ) ≤
          C * K ^ 4 * setGaussianWidth T ^ 2 / m := by
