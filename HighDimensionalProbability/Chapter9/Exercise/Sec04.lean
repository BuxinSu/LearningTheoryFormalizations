/-- **Exercise 9.29(a) (nuclear-norm recovery program).**.

**Book Exercise 9.29(a).** -/
theorem exercise_9_29_part_a :
    ∃ C : ℝ, 0 < C ∧
      ∀ {m d r : ℕ} {Ω : Type*} {mΩ : MeasurableSpace Ω}
        {μ : Measure Ω} [IsProbabilityMeasure μ]
        (A : Fin m → Ω → Matrix (Fin d) (Fin d) ℝ)
        (X : Matrix (Fin d) (Fin d) ℝ)
        (Xhat : Ω → Matrix (Fin d) (Fin d) ℝ),
        0 < m → 0 < d → 1 ≤ r → r ≤ d → HDP.matrixRank X ≤ r →
        HDP.matrixFrobeniusNorm X ≤ 1 →
        IsGaussianMatrixMeasurementFamily μ A →
        (∀ ω, matrixMeasurements (fun i => A i ω) (Xhat ω) =
          matrixMeasurements (fun i => A i ω) X) →
        (∀ ω Z, matrixMeasurements (fun i => A i ω) Z =
            matrixMeasurements (fun i => A i ω) X →
          rectangularNuclearNorm (Xhat ω) ≤ rectangularNuclearNorm Z) →
        Measurable Xhat →
        Integrable (fun ω => HDP.matrixFrobeniusNorm (Xhat ω - X)) μ →
        (∫ ω, HDP.matrixFrobeniusNorm (Xhat ω - X) ∂μ) ≤
          C * Real.sqrt (r * d / m) := by
  -- EXERCISE-SORRY: Category A, non-load-bearing Exercise 9.29(a).
  sorry

/-- **Exercise 9.29(b) (approximately low-rank matrices).** The approximation
term is the standard nuclear-norm tail divided by `√r`; a best Frobenius tail
would give a stronger statement that does not follow from the usual stable
low-rank recovery argument.

**Book Exercise 9.29(b).** -/
theorem exercise_9_29_part_b :
    ∃ C : ℝ, 0 < C ∧
      ∀ {m d r : ℕ} {Ω : Type*} {mΩ : MeasurableSpace Ω}
        {μ : Measure Ω} [IsProbabilityMeasure μ]
        (A : Fin m → Ω → Matrix (Fin d) (Fin d) ℝ)
        (X : Matrix (Fin d) (Fin d) ℝ)
        (Xhat : Ω → Matrix (Fin d) (Fin d) ℝ),
        0 < m → 0 < d → 1 ≤ r → r ≤ d →
        IsGaussianMatrixMeasurementFamily μ A →
        (∀ ω, matrixMeasurements (fun i => A i ω) (Xhat ω) =
          matrixMeasurements (fun i => A i ω) X) →
        (∀ ω Z, matrixMeasurements (fun i => A i ω) Z =
            matrixMeasurements (fun i => A i ω) X →
          rectangularNuclearNorm (Xhat ω) ≤ rectangularNuclearNorm Z) →
        Measurable Xhat →
        Integrable (fun ω => HDP.matrixFrobeniusNorm (Xhat ω - X)) μ →
        (∫ ω, HDP.matrixFrobeniusNorm (Xhat ω - X) ∂μ) ≤
          C * (Real.sqrt (r * d / m) * HDP.matrixFrobeniusNorm X +
            bestRankNuclearError r X / Real.sqrt r) := by
  -- EXERCISE-SORRY: Category A, non-load-bearing Exercise 9.29(b).
  sorry

/-- **Exercise 9.29(c) (rectangular matrices).** The rate uses the correct
sum `d₁+d₂`, rather than silently identifying the two dimensions.

**Book Exercise 9.29(c).** -/
theorem exercise_9_29_part_c :
    ∃ C : ℝ, 0 < C ∧
      ∀ {m d₁ d₂ r : ℕ} {Ω : Type*} {mΩ : MeasurableSpace Ω}
        {μ : Measure Ω} [IsProbabilityMeasure μ]
        (A : Fin m → Ω → Matrix (Fin d₁) (Fin d₂) ℝ)
        (X : Matrix (Fin d₁) (Fin d₂) ℝ)
        (Xhat : Ω → Matrix (Fin d₁) (Fin d₂) ℝ),
        0 < m → 0 < d₁ → 0 < d₂ → 1 ≤ r → r ≤ min d₁ d₂ →
        HDP.matrixRank X ≤ r → HDP.matrixFrobeniusNorm X ≤ 1 →
        IsGaussianMatrixMeasurementFamily μ A →
        (∀ ω, matrixMeasurements (fun i => A i ω) (Xhat ω) =
          matrixMeasurements (fun i => A i ω) X) →
        (∀ ω Z, matrixMeasurements (fun i => A i ω) Z =
            matrixMeasurements (fun i => A i ω) X →
          rectangularNuclearNorm (Xhat ω) ≤ rectangularNuclearNorm Z) →
        Measurable Xhat →
        Integrable (fun ω => HDP.matrixFrobeniusNorm (Xhat ω - X)) μ →
        (∫ ω, HDP.matrixFrobeniusNorm (Xhat ω - X) ∂μ) ≤
          C * Real.sqrt (r * (d₁ + d₂) / m) := by
