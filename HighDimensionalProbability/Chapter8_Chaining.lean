    {T : Set (EuclideanSpace ℝ (Fin n))}
    (U : NonemptyFiniteSubset T) {C : ℝ}
    (hC : ∀ x ∈ T, ‖x‖ ≤ C) :
    HDP.Chapter7.finiteEuclideanDiameter U.carrier ≤ 2 * C := by
  rw [HDP.Chapter7.finiteEuclideanDiameter_eq_sup' U.carrier U.nonempty]
  apply Finset.sup'_le
  intro p hp
  rcases Finset.mem_product.mp hp with ⟨hp1, hp2⟩
  calc
    ‖p.1 - p.2‖ ≤ ‖p.1‖ + ‖p.2‖ := norm_sub_le _ _
    _ ≤ C + C := add_le_add (hC p.1 (U.subset hp1))
      (hC p.2 (U.subset hp2))
    _ = 2 * C := by ring

