/-! ## Exercise 8.36: iid empirical processes -/

/-- The centered empirical process of a finite function family, written as an
average of centered summands. This form makes the iid sum structure used in
the source proof definitionally visible.

**Lean implementation helper.** -/
def iidCenteredEmpiricalProcess {alpha : Type*} [MeasurableSpace alpha]
    {n : ℕ} (nu : Measure alpha) (X : Fin n → Ω → alpha)
    (f : T → alpha → ℝ) : HDP.RandomProcess T Ω :=
  fun t omega => (n : ℝ)⁻¹ *
    ∑ i, (f t (X i omega) - ∫ x, f t x ∂nu)

omit [Fintype T] [Nonempty T] in
/-- For a nonempty sample, the centered-summand definition is exactly the
usual empirical average minus the population mean.

**Lean implementation helper.** -/
theorem iidCenteredEmpiricalProcess_eq_empiricalProcessValue
    {alpha : Type*} [MeasurableSpace alpha] {n : ℕ} (hn : 0 < n)
    (nu : Measure alpha) (X : Fin n → Ω → alpha) (f : T → alpha → ℝ)
    (t : T) (omega : Ω) :
    iidCenteredEmpiricalProcess nu X f t omega =
      empiricalProcessValue nu (fun i => X i omega) (f t) := by
  rw [iidCenteredEmpiricalProcess, empiricalProcessValue, empiricalAverage,
    Finset.sum_sub_distrib]
  simp only [Finset.sum_const, Finset.card_univ, Fintype.card_fin,
    nsmul_eq_mul]
  have hn0 : (n : ℝ) ≠ 0 := by exact_mod_cast hn.ne'
  field_simp [hn0]

/-- The maximum absolute coordinate of a nonempty finite process.

**Lean implementation helper.** -/
def finiteProcessAbsoluteSup (Z : HDP.RandomProcess T Ω) (omega : Ω) : ℝ :=
  Finset.univ.sup' Finset.univ_nonempty fun t => |Z t omega|

