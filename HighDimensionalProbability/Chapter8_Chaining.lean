  have hosc :
      (∫ ω, finiteProcessAbsoluteSup (finiteEuclideanProcess T X) ω ∂μ) ≤
        ∫ ω, finiteProcessOscillation Z ω ∂μ := by
    have hTint : ∀ x : ↥T, Integrable (finiteEuclideanProcess T X x) μ := by
      intro x
