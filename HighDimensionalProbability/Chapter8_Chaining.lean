    (A : Fin m → Ω → EuclideanSpace ℝ (Fin n))
    (u w : EuclideanSpace ℝ (Fin n))
    (v z : EuclideanSpace ℝ (Fin m)) (ω : Ω) :
    rowBilinearProcess A u v ω - rowBilinearProcess A w z ω =
      rowBilinearProcess A (u - w) v ω +
        rowBilinearProcess A w (v - z) ω := by
  simp only [rowBilinearProcess, inner_sub_right, PiLp.sub_apply]
  rw [← Finset.sum_sub_distrib, ← Finset.sum_add_distrib]
  apply Finset.sum_congr rfl
  intro i hi
