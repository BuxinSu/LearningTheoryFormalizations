theorem exercise_8_36_of_scaledIncrements [IsProbabilityMeasure μ]
    (Z : HDP.RandomProcess T Ω) (hZm : ∀ t, Measurable (Z t))
    (hZint : ∀ t, Integrable (Z t) μ)
    (hcenter : HDP.IsCenteredProcess Z μ)
    (d : T → T → ℝ) (hd : ∀ s t, 0 ≤ d s t)
    (hsymm : ∀ s t, d s t = d t s)
