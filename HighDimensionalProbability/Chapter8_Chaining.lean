section Source_13_TalagrandComparison

/-!
# Book Chapter 8, §8.5.4: Talagrand's comparison inequality

The main comparison is the upper generic-chaining estimate followed by the
lower half of the majorizing-measure theorem.  The last part of the file
exposes a product-Gaussian comparison process; this is the reusable process
which occurs in the proof of Chevet's inequality in §8.6.
-/

open MeasureTheory ProbabilityTheory Real InnerProductSpace
open scoped BigOperators ENNReal NNReal RealInnerProductSpace

namespace HDP.Chapter8

noncomputable section

/- Every theorem below that uses the omitted lower half of the
majorizing-measure theorem records that dependency explicitly. -/
variable [hMM : MajorizingMeasureLowerPrinciple]

/-- A concrete universal constant in Theorem 8.5.6.

**Book Theorem 8.5.6.** -/
def talagrandComparisonConstant : ℝ :=
  genericChainingConstant * majorizingMeasureLowerConstant

/-- Shows that the talagrand comparison constant is strictly positive.

**Lean implementation helper.** -/
theorem talagrandComparisonConstant_pos :
    0 < talagrandComparisonConstant := by
  exact mul_pos genericChainingConstant_pos majorizingMeasureLowerConstant_pos

/-- Talagrand comparison: a subgaussian process is controlled by a Gaussian process with dominating canonical increments. If the `ψ₂` increment metric of the centered process `X` is bounded by `K`
times the canonical `L²` metric of the centered Gaussian process `Y`, then
the expected maximum of `X` is bounded by a universal constant times `K`
times the expected maximum of `Y`.

**Book Corollary 8.5.6.** -/
theorem talagrandComparison
    {I ΩX ΩY : Type} [Fintype I] [Nonempty I]
    [MeasurableSpace ΩX] [MeasurableSpace ΩY]
    (μX : Measure ΩX) (μY : Measure ΩY)
    [IsProbabilityMeasure μX] [IsProbabilityMeasure μY]
    (X : HDP.RandomProcess I ΩX) (Y : HDP.RandomProcess I ΩY)
    (hXm : ∀ i, Measurable (X i))
    (hXint : ∀ i, Integrable (X i) μX)
    (hXcenter : HDP.IsCenteredProcess X μX)
    (hYGaussian : IsGaussianProcess Y μY)
    (hYcenter : HDP.IsCenteredProcess Y μY)
    (hYL2 : HDP.IsL2Process Y μY)
    {K : ℝ} (hK : 0 ≤ K)
    (hinc : ∀ s t,
      HDP.SubGaussian (fun ω => X t ω - X s ω) μX ∧
        HDP.psi2Norm (fun ω => X t ω - X s ω) μX ≤
          K * HDP.processIncrement Y μY t s) :
    HDP.Chapter7.expectedFiniteSupremum μX X ≤
      talagrandComparisonConstant * K *
        HDP.Chapter7.expectedFiniteSupremum μY Y := by
  let d : I → I → ℝ := HDP.processIncrement Y μY
  have hd : ∀ s t, 0 ≤ d s t := fun s t =>
    HDP.processIncrement_nonneg (hYL2 s) (hYL2 t)
  have hsymm : ∀ s t, d s t = d t s := fun s t =>
    HDP.processIncrement_comm (hYL2 s) (hYL2 t)
  have htri : ∀ r s t, d r t ≤ d r s + d s t :=
    HDP.processIncrement_triangle hYL2
  have hd0 : ∀ t, d t t = 0 := fun t =>
    HDP.processIncrement_self t (hYL2 t)
  have hSG : HDP.HasSubGaussianIncrementsWith X μX d K := by
    exact ⟨hK, hinc⟩
  have hupper := genericChainingBound X hXm hXint hXcenter
    d hd hsymm htri hd0 hSG
  have hfinite : HDP.gamma2 (canonicalProcessEDistance Y μY) ≠ ⊤ := by
    change HDP.gamma2
      (fun s t => ENNReal.ofReal (HDP.processIncrement Y μY s t)) ≠ ⊤
    exact gamma2_ofReal_ne_top d hd
  have hlower := majorizingMeasure_lower μY Y hYGaussian hYcenter hYL2 hfinite
  have hcoef : 0 ≤ genericChainingConstant * K :=
    mul_nonneg genericChainingConstant_pos.le hK
  calc
    HDP.Chapter7.expectedFiniteSupremum μX X ≤
        genericChainingConstant * K *
          (HDP.gamma2 (canonicalProcessEDistance Y μY)).toReal := by
      change HDP.Chapter7.expectedFiniteSupremum μX X ≤
        genericChainingConstant * K *
          (HDP.gamma2
            (fun s t => ENNReal.ofReal
              (HDP.processIncrement Y μY s t))).toReal
      exact hupper
    _ ≤ genericChainingConstant * K *
          (majorizingMeasureLowerConstant *
            HDP.Chapter7.expectedFiniteSupremum μY Y) :=
      mul_le_mul_of_nonneg_left hlower hcoef
    _ = talagrandComparisonConstant * K *
          HDP.Chapter7.expectedFiniteSupremum μY Y := by
      simp only [talagrandComparisonConstant]
      ring

omit hMM in
/-- For two Gaussian processes, Talagrand comparison reduces to Sudakov--Fernique with constant one. For two centered Gaussian processes, comparison
of their squared canonical increments gives the sharper constant-one
Sudakov--Fernique inequality.

**Book Remark 8.5.7.** -/
theorem talagrandComparison_gaussian_constant_one
    {I ΩX ΩY : Type*} [Fintype I] [Nonempty I]
    [MeasurableSpace ΩX] [MeasurableSpace ΩY]
    (μX : Measure ΩX) (μY : Measure ΩY)
    [IsProbabilityMeasure μX] [IsProbabilityMeasure μY]
    (X : I → ΩX → ℝ) (Y : I → ΩY → ℝ)
    (hX : IsGaussianProcess X μX) (hY : IsGaussianProcess Y μY)
    (hX0 : HDP.IsCenteredProcess X μX)
    (hY0 : HDP.IsCenteredProcess Y μY)
    (hinc : ∀ i j,
      HDP.Chapter7.processIncrementSecondMoment μX X i j ≤
        HDP.Chapter7.processIncrementSecondMoment μY Y i j) :
    HDP.Chapter7.expectedFiniteSupremum μX X ≤
      HDP.Chapter7.expectedFiniteSupremum μY Y :=
  HDP.Chapter7.sudakovFernique μX μY X Y hX hY hX0 hY0 hinc

/-! ## Geometric Talagrand comparison -/

/-- Restriction of a Euclidean-indexed process to a finite set.

**Lean implementation helper.** -/
def finiteEuclideanProcess {n : ℕ} {Ω : Type*}
    (T : Finset (EuclideanSpace ℝ (Fin n)))
    (X : EuclideanSpace ℝ (Fin n) → Ω → ℝ) :
    HDP.RandomProcess ↥T Ω :=
  fun x => X x.1

omit hMM in
/-- The expected maximum of the canonical Gaussian process indexed by a
nonempty finite Euclidean set is exactly its Gaussian width.

**Lean implementation helper.** -/
theorem expectedFiniteSupremum_canonicalGaussian_finset
    {n : ℕ} (T : Finset (EuclideanSpace ℝ (Fin n)))
    [Nonempty ↥T] (hT : T.Nonempty) :
    HDP.Chapter7.expectedFiniteSupremum
        (stdGaussian (EuclideanSpace ℝ (Fin n)))
        (HDP.Chapter7.canonicalGaussianProcess
          (fun x : ↥T => (x.1 : EuclideanSpace ℝ (Fin n)))) =
      HDP.Chapter7.gaussianWidth T := by
  classical
  let a : ↥T → EuclideanSpace ℝ (Fin n) := fun x => x.1
  let Y := HDP.Chapter7.canonicalGaussianProcess a
  have hmax (g : EuclideanSpace ℝ (Fin n)) :
      HDP.Chapter5.finiteMaximum Y g =
        HDP.Chapter7.finiteGaussianSupport T g := by
    rw [HDP.Chapter7.finiteGaussianSupport_eq_sup' T hT]
    unfold HDP.Chapter5.finiteMaximum Y
    apply le_antisymm
    · apply Finset.sup'_le
      intro x hx
      exact (by
        simpa [a, HDP.Chapter7.canonicalGaussianProcess, real_inner_comm] using
          Finset.le_sup' (fun y => inner ℝ g y) x.2)
    · apply Finset.sup'_le
      intro x hx
      let y : ↥T := ⟨x, hx⟩
      simpa [Y, a, HDP.Chapter7.canonicalGaussianProcess,
        real_inner_comm, y] using
        Finset.le_sup'
          (fun z : ↥T => HDP.Chapter7.canonicalGaussianProcess a z g)
          (Finset.mem_univ y)
  unfold HDP.Chapter7.expectedFiniteSupremum HDP.Chapter7.gaussianWidth
  change (∫ g, HDP.Chapter5.finiteMaximum Y g
    ∂stdGaussian (EuclideanSpace ℝ (Fin n))) = _
  exact integral_congr_ae (ae_of_all _ hmax)

/-- Geometric Talagrand comparison bounds a subgaussian process by Gaussian width. The process is indexed by a nonempty finite subset of Euclidean space. Its
centered coordinates and `ψ₂` increments are compared with the canonical
Gaussian process on the same set, whose expected maximum is exactly the
Gaussian width.

**Book Corollary 8.5.8.** -/
theorem corollary_8_5_8_geometric
    {n : ℕ} {Ω : Type} [MeasurableSpace Ω]
    (μ : Measure Ω) [IsProbabilityMeasure μ]
    (T : Finset (EuclideanSpace ℝ (Fin n))) [Nonempty ↥T]
    (hT : T.Nonempty)
    (X : EuclideanSpace ℝ (Fin n) → Ω → ℝ)
    (hXm : ∀ x ∈ T, Measurable (X x))
    (hXint : ∀ x ∈ T, Integrable (X x) μ)
    (hXcenter : ∀ x ∈ T, ∫ ω, X x ω ∂μ = 0)
    {K : ℝ} (hK : 0 ≤ K)
    (hinc : ∀ x ∈ T, ∀ y ∈ T,
      HDP.SubGaussian (fun ω => X x ω - X y ω) μ ∧
        HDP.psi2Norm (fun ω => X x ω - X y ω) μ ≤ K * ‖x - y‖) :
    HDP.Chapter7.expectedFiniteSupremum μ
        (finiteEuclideanProcess T X) ≤
      talagrandComparisonConstant * K * HDP.Chapter7.gaussianWidth T := by
  let a : ↥T → EuclideanSpace ℝ (Fin n) := fun x => x.1
  let Y := HDP.Chapter7.canonicalGaussianProcess a
  have hcomp := talagrandComparison μ
    (stdGaussian (EuclideanSpace ℝ (Fin n)))
    (finiteEuclideanProcess T X) Y
    (fun x => hXm x.1 x.2)
    (fun x => hXint x.1 x.2)
    (fun x => hXcenter x.1 x.2)
    (HDP.Chapter7.canonicalGaussianProcess_isGaussian a)
    (HDP.Chapter7.canonicalGaussianProcess_centered a)
    (HDP.Chapter7.canonicalGaussianProcess_memLp_two a)
    hK (fun s t => by
      have h := hinc t.1 t.2 s.1 s.2
      simpa [finiteEuclideanProcess, Y, a,
        HDP.Chapter7.canonicalGaussianProcess_increment] using h)
  rw [show HDP.Chapter7.expectedFiniteSupremum
      (stdGaussian (EuclideanSpace ℝ (Fin n))) Y =
        HDP.Chapter7.gaussianWidth T by
    simpa [Y, a] using expectedFiniteSupremum_canonicalGaussian_finset T hT]
    at hcomp
  exact hcomp

/-- Subgaussian width is at most a universal multiple of Gaussian width. Centering is explicit: without it the printed conclusion is
false already for a deterministic nonzero vector and a singleton set.

**Book Remark 8.5.9.** -/
theorem remark_8_5_9_subgaussian_width
    {n : ℕ} [NeZero n]
    {Ω : Type} [MeasurableSpace Ω]
    (μ : Measure Ω) [IsProbabilityMeasure μ]
    (T : Finset (EuclideanSpace ℝ (Fin n))) [Nonempty ↥T]
    (hT : T.Nonempty)
    (X : Ω → EuclideanSpace ℝ (Fin n))
    (hXm : Measurable X)
    (hsub : HDP.SubGaussianVector X μ)
    (hbounded : BddAbove {r : ℝ |
      ∃ u : EuclideanSpace ℝ (Fin n), ‖u‖ = 1 ∧
        r = HDP.psi2Norm (fun ω => inner ℝ (X ω) u) μ})
    (hcenter : ∀ v : EuclideanSpace ℝ (Fin n),
      ∫ ω, inner ℝ (X ω) v ∂μ = 0) :
    HDP.Chapter7.expectedFiniteSupremum μ
        (finiteEuclideanProcess T
          (fun v ω => inner ℝ (X ω) v)) ≤
      talagrandComparisonConstant * HDP.psi2NormVector X μ *
        HDP.Chapter7.gaussianWidth T := by
  let i : Fin n := Classical.choice inferInstance
  let e : EuclideanSpace ℝ (Fin n) := EuclideanSpace.single i 1
  have he : ‖e‖ = 1 := by simp [e]
  have hK : 0 ≤ HDP.psi2NormVector X μ :=
    (HDP.psi2Norm_nonneg (fun ω => inner ℝ (X ω) e) μ).trans
      (HDP.psi2Norm_marginal_le_vector hbounded he)
  apply corollary_8_5_8_geometric μ T hT
    (fun v ω => inner ℝ (X ω) v)
    (fun v hv => by fun_prop)
    (fun v hv => by
      exact ((hsub v).memLp (by fun_prop :
        AEMeasurable (fun ω => inner ℝ (X ω) v) μ)
        (show (1 : ℝ) ≤ 1 by rfl)).integrable (by norm_num))
    (fun v hv => hcenter v) hK
  intro x hx y hy
  have hsg := hsub (x - y)
  have hpsi := HDP.Chapter3.psi2Norm_marginal_le_norm_mul_vector
    hbounded (x - y)
  simpa only [inner_sub_right, mul_comm] using And.intro hsg hpsi

/-! ## Exercise 8.37: anchored geometric forms -/

omit hMM in
/-- Shows that the maximum absolute value of a finite process is measurable.

**Lean implementation helper.** -/
theorem measurable_finiteProcessAbsoluteSup
    {I Ω : Type*} [Fintype I] [Nonempty I] [MeasurableSpace Ω]
    (Z : HDP.RandomProcess I Ω) (hZm : ∀ i, Measurable (Z i)) :
