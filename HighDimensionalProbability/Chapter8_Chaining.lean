section Source_02_DudleyInequality

/-!
# Book Chapter 8, §8.1: Dudley chaining

The source first proves Dudley's inequality for a finite index set and then
passes to general processes by approximation.  This module develops the
measurable finite API and then implements the book's arbitrary-set convention
as extended suprema over nonempty finite subfamilies.  `FiniteDudleyChain`
contains only the selected finite chain; the telescoping, pointwise supremum,
expectation, and union-bound steps are proved below.  The source-facing finite
theorems construct the adjacent projection pairs and derive their maximal
estimate from `HasSubGaussianIncrementsWith`; the final Euclidean endpoints
use Mathlib's actual covering numbers and safe `ℝ≥0∞` functionals, with real
wrappers exposed only after boundedness proves finiteness.
-/

open MeasureTheory ProbabilityTheory Set InnerProductSpace Filter
open scoped BigOperators ENNReal NNReal RealInnerProductSpace

namespace HDP.Chapter8

noncomputable section

variable {T Ω : Type*} [Fintype T] [Nonempty T]
  {mΩ : MeasurableSpace Ω} {μ : Measure Ω}

/-! ## Finite measurable suprema -/

/-- Maximum of a finite nonempty process.

**Lean implementation helper.** -/
def finiteProcessSup (X : HDP.RandomProcess T Ω) (ω : Ω) : ℝ :=
  Finset.univ.sup' Finset.univ_nonempty fun t => X t ω

/-- Maximum absolute increment from a fixed anchor.

**Lean implementation helper.** -/
def finiteProcessIncrementSup (X : HDP.RandomProcess T Ω) (t0 : T)
    (ω : Ω) : ℝ :=
  Finset.univ.sup' Finset.univ_nonempty fun t => |X t ω - X t0 ω|

/-- Diameter of the finite sample path.

**Lean implementation helper.** -/
def finiteProcessOscillation (X : HDP.RandomProcess T Ω) (ω : Ω) : ℝ :=
  (Finset.univ.product Finset.univ).sup'
    (Finset.univ_nonempty.product Finset.univ_nonempty)
    fun p => |X p.1 ω - X p.2 ω|

/-- Shows that the maximum of the finite process is measurable.

**Lean implementation helper.** -/
theorem measurable_finiteProcessSup (X : HDP.RandomProcess T Ω)
    (hXm : ∀ t, Measurable (X t)) : Measurable (finiteProcessSup X) := by
  have h1 : Measurable
      (Finset.univ.sup' Finset.univ_nonempty fun t => X t) :=
    Finset.measurable_sup' Finset.univ_nonempty fun t _ => hXm t
  have h2 : (Finset.univ.sup' Finset.univ_nonempty fun t => X t) =
      finiteProcessSup X := by
    funext ω
    simp only [finiteProcessSup, Finset.sup'_apply]
  rwa [h2] at h1

/-- Shows that the maximum absolute increment from the anchor is measurable.

**Lean implementation helper.** -/
theorem measurable_finiteProcessIncrementSup (X : HDP.RandomProcess T Ω)
    (t0 : T) (hXm : ∀ t, Measurable (X t)) :
    Measurable (finiteProcessIncrementSup X t0) := by
  have h1 : Measurable (Finset.univ.sup' Finset.univ_nonempty fun t =>
      fun ω => |X t ω - X t0 ω|) :=
    Finset.measurable_sup' Finset.univ_nonempty fun t _ =>
      continuous_abs.measurable.comp ((hXm t).sub (hXm t0))
  have h2 : (Finset.univ.sup' Finset.univ_nonempty fun t =>
      fun ω => |X t ω - X t0 ω|) = finiteProcessIncrementSup X t0 := by
    funext ω
    simp only [finiteProcessIncrementSup, Finset.sup'_apply]
  rwa [h2] at h1

/-- Shows that the sample-path oscillation is measurable.

**Lean implementation helper.** -/
theorem measurable_finiteProcessOscillation (X : HDP.RandomProcess T Ω)
    (hXm : ∀ t, Measurable (X t)) :
    Measurable (finiteProcessOscillation X) := by
  have h1 : Measurable
      ((Finset.univ.product Finset.univ).sup'
        (Finset.univ_nonempty.product Finset.univ_nonempty) fun p =>
          fun ω => |X p.1 ω - X p.2 ω|) :=
    Finset.measurable_sup'
      (Finset.univ_nonempty.product Finset.univ_nonempty) fun p _ =>
        continuous_abs.measurable.comp ((hXm p.1).sub (hXm p.2))
  have h2 : ((Finset.univ.product Finset.univ).sup'
      (Finset.univ_nonempty.product Finset.univ_nonempty) fun p =>
        fun ω => |X p.1 ω - X p.2 ω|) = finiteProcessOscillation X := by
    funext ω
    simp only [finiteProcessOscillation, Finset.sup'_apply]
  rwa [h2] at h1

/-- Shows that the maximum absolute increment from the anchor is nonnegative.

**Lean implementation helper.** -/
theorem finiteProcessIncrementSup_nonneg
    (X : HDP.RandomProcess T Ω) (t0 : T) (ω : Ω) :
    0 ≤ finiteProcessIncrementSup X t0 ω := by
  exact (abs_nonneg (X t0 ω - X t0 ω)).trans
    (Finset.le_sup' (fun t => |X t ω - X t0 ω|) (Finset.mem_univ t0))

/-- Shows that the sample-path oscillation is nonnegative.

**Lean implementation helper.** -/
theorem finiteProcessOscillation_nonneg
    (X : HDP.RandomProcess T Ω) (ω : Ω) :
    0 ≤ finiteProcessOscillation X ω := by
  let t : T := Classical.choice inferInstance
  unfold finiteProcessOscillation
  exact (abs_nonneg (X t ω - X t ω)).trans
    (Finset.le_sup' (fun p : T × T => |X p.1 ω - X p.2 ω|)
      (show (t, t) ∈ Finset.univ.product Finset.univ by simp))

/-- The path diameter is at most twice the largest increment from an anchor.

**Lean implementation helper.** -/
theorem finiteProcessOscillation_le_two_incrementSup
    (X : HDP.RandomProcess T Ω) (t0 : T) (ω : Ω) :
    finiteProcessOscillation X ω ≤ 2 * finiteProcessIncrementSup X t0 ω := by
  unfold finiteProcessOscillation
  apply Finset.sup'_le
  intro p hp
  have hp' := Finset.mem_product.mp hp
  have h1 := Finset.le_sup' (fun t => |X t ω - X t0 ω|) hp'.1
  have h2 := Finset.le_sup' (fun t => |X t ω - X t0 ω|) hp'.2
  calc
    |X p.1 ω - X p.2 ω| ≤
        |X p.1 ω - X t0 ω| + |X p.2 ω - X t0 ω| := by
      calc
        |X p.1 ω - X p.2 ω| =
            |(X p.1 ω - X t0 ω) - (X p.2 ω - X t0 ω)| := by ring_nf
        _ ≤ |X p.1 ω - X t0 ω| + |X p.2 ω - X t0 ω| :=
          abs_sub _ _
    _ ≤ finiteProcessIncrementSup X t0 ω +
        finiteProcessIncrementSup X t0 ω := add_le_add h1 h2
    _ = 2 * finiteProcessIncrementSup X t0 ω := by ring

/-! ## A finite Dudley chain -/

/-- A finite chain whose level `0` is a single anchor and whose level `steps`
is exact.  Values beyond `steps` are irrelevant. -/
structure FiniteDudleyChain (T : Type*) (steps : ℕ) where
  anchor : T
  projection : ℕ → T → T
  coarse : ∀ t, projection 0 t = anchor
  exact : ∀ t, projection steps t = t

/-- The increment connecting two adjacent levels of a chain.

**Lean implementation helper.** -/
def dudleyScaleIncrement {steps : ℕ} (C : FiniteDudleyChain T steps)
    (X : HDP.RandomProcess T Ω) (k : ℕ) (t : T) (ω : Ω) : ℝ :=
  X (C.projection (k + 1) t) ω - X (C.projection k t) ω

/-- The maximum absolute increment at one scale.

**Lean implementation helper.** -/
def dudleyScaleSup {steps : ℕ} (C : FiniteDudleyChain T steps)
    (X : HDP.RandomProcess T Ω) (k : ℕ) (ω : Ω) : ℝ :=
  Finset.univ.sup' Finset.univ_nonempty fun t =>
    |dudleyScaleIncrement C X k t ω|

/-- Shows that the largest process increment at a chaining scale is measurable.

**Lean implementation helper.** -/
theorem measurable_dudleyScaleSup {steps : ℕ}
    (C : FiniteDudleyChain T steps) (X : HDP.RandomProcess T Ω)
    (hXm : ∀ t, Measurable (X t)) (k : ℕ) :
    Measurable (dudleyScaleSup C X k) := by
  have h1 : Measurable (Finset.univ.sup' Finset.univ_nonempty fun t =>
      fun ω => |dudleyScaleIncrement C X k t ω|) :=
    Finset.measurable_sup' Finset.univ_nonempty fun t _ =>
      continuous_abs.measurable.comp
        ((hXm (C.projection (k + 1) t)).sub (hXm (C.projection k t)))
  have h2 : (Finset.univ.sup' Finset.univ_nonempty fun t =>
      fun ω => |dudleyScaleIncrement C X k t ω|) = dudleyScaleSup C X k := by
    funext ω
    simp only [dudleyScaleSup, Finset.sup'_apply]
  rwa [h2] at h1

/-- Shows that the largest process increment at a chaining scale is nonnegative.

**Lean implementation helper.** -/
theorem dudleyScaleSup_nonneg {steps : ℕ}
    (C : FiniteDudleyChain T steps) (X : HDP.RandomProcess T Ω)
    (k : ℕ) (ω : Ω) : 0 ≤ dudleyScaleSup C X k ω := by
  let t : T := Classical.choice inferInstance
  exact (abs_nonneg (dudleyScaleIncrement C X k t ω)).trans
    (Finset.le_sup' (fun s => |dudleyScaleIncrement C X k s ω|)
      (Finset.mem_univ t))

omit [Fintype T] [Nonempty T] in
/-- Finite telescoping chain expansion. The algebraic telescoping identity underlying chaining.

**Book Equation (8.8).** -/
theorem finiteDudleyChain_telescope {steps : ℕ}
    (C : FiniteDudleyChain T steps) (X : HDP.RandomProcess T Ω)
    (t : T) (ω : Ω) :
    X t ω - X C.anchor ω =
      ∑ k ∈ Finset.range steps, dudleyScaleIncrement C X k t ω := by
  calc
    X t ω - X C.anchor ω =
        X (C.projection steps t) ω - X (C.projection 0 t) ω := by
      rw [C.exact t, C.coarse t]
    _ = ∑ k ∈ Finset.range steps, dudleyScaleIncrement C X k t ω := by
      change X (C.projection steps t) ω - X (C.projection 0 t) ω =
        ∑ k ∈ Finset.range steps,
          (X (C.projection (k + 1) t) ω - X (C.projection k t) ω)
      exact (Finset.sum_range_sub
        (fun k => X (C.projection k t) ω) steps).symm

/-- Expected anchored supremum is bounded by the sum of expected scale suprema. Pointwise deterministic chaining: the largest anchored increment is at
most the sum of the largest increments on all levels.

**Book Equation (8.10).** -/
theorem finiteProcessIncrementSup_le_sum_dudleyScaleSup {steps : ℕ}
    (C : FiniteDudleyChain T steps) (X : HDP.RandomProcess T Ω) (ω : Ω) :
    finiteProcessIncrementSup X C.anchor ω ≤
      ∑ k ∈ Finset.range steps, dudleyScaleSup C X k ω := by
  unfold finiteProcessIncrementSup
  apply Finset.sup'_le
  intro t _ht
  rw [finiteDudleyChain_telescope C X t ω]
  calc
    |∑ k ∈ Finset.range steps, dudleyScaleIncrement C X k t ω| ≤
        ∑ k ∈ Finset.range steps, |dudleyScaleIncrement C X k t ω| :=
      Finset.abs_sum_le_sum_abs _ _
    _ ≤ ∑ k ∈ Finset.range steps, dudleyScaleSup C X k ω := by
      apply Finset.sum_le_sum
      intro k hk
      exact Finset.le_sup'
        (fun s => |dudleyScaleIncrement C X k s ω|) (Finset.mem_univ t)

/-- Integrability of the anchored supremum follows from integrability of all
finite scale suprema.

**Lean implementation helper.** -/
theorem integrable_finiteProcessIncrementSup_of_chain {steps : ℕ}
    (C : FiniteDudleyChain T steps) (X : HDP.RandomProcess T Ω)
    (hXm : ∀ t, Measurable (X t))
    (hscale : ∀ k ∈ Finset.range steps, Integrable (dudleyScaleSup C X k) μ) :
    Integrable (finiteProcessIncrementSup X C.anchor) μ := by
  have hsum : Integrable
      (fun ω => ∑ k ∈ Finset.range steps, dudleyScaleSup C X k ω) μ :=
    integrable_finsetSum _ hscale
  refine hsum.mono'
    (measurable_finiteProcessIncrementSup X C.anchor hXm).aestronglyMeasurable ?_
  filter_upwards [] with ω
  rw [Real.norm_eq_abs,
    abs_of_nonneg (finiteProcessIncrementSup_nonneg X C.anchor ω)]
  exact finiteProcessIncrementSup_le_sum_dudleyScaleSup C X ω

/-- The expectation step of finite chaining.

**Lean implementation helper.** -/
theorem dudleyChainingBound {steps : ℕ}
    (C : FiniteDudleyChain T steps) (X : HDP.RandomProcess T Ω)
    (hXm : ∀ t, Measurable (X t)) (B : ℕ → ℝ)
    (hscale : ∀ k ∈ Finset.range steps,
      Integrable (dudleyScaleSup C X k) μ ∧
        ∫ ω, dudleyScaleSup C X k ω ∂μ ≤ B k) :
    ∫ ω, finiteProcessIncrementSup X C.anchor ω ∂μ ≤
      ∑ k ∈ Finset.range steps, B k := by
  have hleft := integrable_finiteProcessIncrementSup_of_chain C X hXm
    (fun k hk => (hscale k hk).1)
  have hsum : Integrable
      (fun ω => ∑ k ∈ Finset.range steps, dudleyScaleSup C X k ω) μ :=
    integrable_finsetSum _ fun k hk => (hscale k hk).1
  calc
    (∫ ω, finiteProcessIncrementSup X C.anchor ω ∂μ) ≤
        ∫ ω, ∑ k ∈ Finset.range steps, dudleyScaleSup C X k ω ∂μ :=
      integral_mono hleft hsum
        (finiteProcessIncrementSup_le_sum_dudleyScaleSup C X)
    _ = ∑ k ∈ Finset.range steps,
        ∫ ω, dudleyScaleSup C X k ω ∂μ := by
      rw [integral_finsetSum (Finset.range steps)
        (fun k hk => (hscale k hk).1)]
    _ ≤ ∑ k ∈ Finset.range steps, B k :=
      Finset.sum_le_sum fun k hk => (hscale k hk).2

/-! ## Scale geometry and the subgaussian maximum step -/

/-- Expectation bound for the maximum absolute value of a nonempty finite
subgaussian family. Unlike the fixed-`Fin (N + 2)` maximal inequality, this
form also handles a zero common ψ₂ bound: all variables then vanish almost
surely.

**Lean implementation helper.** -/
theorem expectation_finset_sup_abs_le [IsProbabilityMeasure μ]
    {ι : Type*} (A : Finset ι) (hA : A.Nonempty)
    (Y : ι → Ω → ℝ) (hYm : ∀ a ∈ A, Measurable (Y a))
    (hYsub : ∀ a ∈ A, HDP.SubGaussian (Y a) μ)
    {K : ℝ} (hK : 0 ≤ K)
    (hYpsi : ∀ a ∈ A, HDP.psi2Norm (Y a) μ ≤ K) :
    (∫ ω, A.sup' hA (fun a => |Y a ω|) ∂μ) ≤
      2 * Real.sqrt (Real.log ((A.card : ℝ) + 2)) * K := by
  classical
  rcases hK.eq_or_lt with hK0 | hKpos
  · have hcoord : ∀ a ∈ A, Y a =ᵐ[μ] 0 := by
      intro a ha
      have hpsi : HDP.psi2Norm (Y a) μ = 0 := by
        apply le_antisymm
        · simpa [hK0] using hYpsi a ha
        · exact HDP.psi2Norm_nonneg _ _
      exact (HDP.psi2Norm_eq_zero_iff
        (hYm a ha).aemeasurable (hYsub a ha)).mp hpsi
    have hall : ∀ᵐ ω ∂μ, ∀ a ∈ A, Y a ω = 0 :=
      A.eventually_all.2 hcoord
    have hsup : (fun ω => A.sup' hA (fun a => |Y a ω|)) =ᵐ[μ] 0 := by
      filter_upwards [hall] with ω hω
      apply le_antisymm
      · apply Finset.sup'_le
        intro a ha
        simp [hω a ha]
      · obtain ⟨a, ha⟩ := hA
        exact (abs_nonneg (Y a ω)).trans
          (Finset.le_sup' (fun b => |Y b ω|) ha)
    rw [integral_congr_ae hsup, ← hK0]
    simp
  · let Z : Fin (A.card + 2) → Ω → ℝ := fun i =>
      if hi : i.val < A.card then Y (A.equivFin.symm ⟨i.val, hi⟩ : A).1
      else 0
    have hA' := hA
    obtain ⟨a0, ha0⟩ := hA'
    have hzeroSub : HDP.SubGaussian (fun _ : Ω => (0 : ℝ)) μ := by
      simpa using (hYsub a0 ha0).const_mul 0
    have hzeroPsi : HDP.psi2Norm (fun _ : Ω => (0 : ℝ)) μ = 0 := by
      simpa using HDP.psi2Norm_const_mul (μ := μ) (Y a0) 0
    have hZm (i : Fin (A.card + 2)) : Measurable (Z i) := by
      by_cases hi : i.val < A.card
      · simpa [Z, hi] using
          hYm (A.equivFin.symm ⟨i.val, hi⟩ : A).1
            (A.equivFin.symm ⟨i.val, hi⟩ : A).2
      · have hZi : Z i = fun _ => (0 : ℝ) := by
          funext ω
          simp [Z, hi]
        rw [hZi]
        exact measurable_const
    have hZsub (i : Fin (A.card + 2)) : HDP.SubGaussian (Z i) μ := by
      by_cases hi : i.val < A.card
      · simpa [Z, hi] using
          hYsub (A.equivFin.symm ⟨i.val, hi⟩ : A).1
            (A.equivFin.symm ⟨i.val, hi⟩ : A).2
      · have hZi : Z i = fun _ => (0 : ℝ) := by
          funext ω
          simp [Z, hi]
        rw [hZi]
        exact hzeroSub
    have hZpsi (i : Fin (A.card + 2)) : HDP.psi2Norm (Z i) μ ≤ K := by
      by_cases hi : i.val < A.card
      · simpa [Z, hi] using
          hYpsi (A.equivFin.symm ⟨i.val, hi⟩ : A).1
            (A.equivFin.symm ⟨i.val, hi⟩ : A).2
      · have hZi : Z i = fun _ => (0 : ℝ) := by
          funext ω
          simp [Z, hi]
        rw [hZi, hzeroPsi]
        exact hK
    have hmax := HDP.Chapter4.expectation_max_abs_le hZm hZsub hKpos hZpsi
    have hsup (ω : Ω) :
        A.sup' hA (fun a => |Y a ω|) =
          Finset.univ.sup' Finset.univ_nonempty (fun i => |Z i ω|) := by
      apply le_antisymm
      · apply Finset.sup'_le
        intro a ha
        let k : Fin A.card := A.equivFin ⟨a, ha⟩
        let i : Fin (A.card + 2) := ⟨k.val, by omega⟩
        have hi : i.val < A.card := k.isLt
        have hZa : Z i = Y a := by
          simp only [Z, dif_pos hi]
          exact congrArg (fun b : A => Y b.1)
            (A.equivFin.symm_apply_apply ⟨a, ha⟩)
        calc
          |Y a ω| = |Z i ω| := by rw [hZa]
          _ ≤ Finset.univ.sup' Finset.univ_nonempty (fun j => |Z j ω|) :=
            Finset.le_sup' (fun j => |Z j ω|) (Finset.mem_univ i)
      · apply Finset.sup'_le
        intro i _hi
        by_cases hi : i.val < A.card
        · let a : A := A.equivFin.symm ⟨i.val, hi⟩
          have hZi : Z i = Y a.1 := by simp [Z, hi, a]
          simpa [hZi] using Finset.le_sup' (fun b => |Y b ω|) a.2
        · have hZi : Z i = 0 := by simp [Z, hi]
          rw [hZi]
          simp only [Pi.zero_apply, abs_zero]
          exact (abs_nonneg (Y a0 ω)).trans
            (Finset.le_sup' (fun b => |Y b ω|) ha0)
    rw [integral_congr_ae (Filter.Eventually.of_forall hsup)]
    exact hmax

/-- Adjacent projection pairs which actually occur at scale `k`. Taking an
image removes duplicate edges before the finite maximum estimate is applied.

**Lean implementation helper.** -/
def dudleyScalePairs {steps : ℕ} (C : FiniteDudleyChain T steps)
    (k : ℕ) : Finset (T × T) := by
  classical
  exact Finset.univ.image fun t =>
    (C.projection (k + 1) t, C.projection k t)

/-- Shows that the set of adjacent projection pairs is nonempty.

**Lean implementation helper.** -/
theorem dudleyScalePairs_nonempty {steps : ℕ}
    (C : FiniteDudleyChain T steps) (k : ℕ) :
    (dudleyScalePairs C k).Nonempty := by
  classical
  let t : T := Classical.choice inferInstance
  exact ⟨(C.projection (k + 1) t, C.projection k t),
    Finset.mem_image.mpr ⟨t, Finset.mem_univ t, rfl⟩⟩

/-- Largest metric length of an adjacent projection pair at scale `k`.

**Lean implementation helper.** -/
def dudleyScaleRadius {steps : ℕ} (C : FiniteDudleyChain T steps)
    (d : T → T → ℝ) (k : ℕ) : ℝ :=
  (dudleyScalePairs C k).sup' (dudleyScalePairs_nonempty C k)
    fun p => d p.1 p.2

/-- Number of distinct adjacent projection pairs at scale `k`.

**Lean implementation helper.** -/
def dudleyScaleCard {steps : ℕ} (C : FiniteDudleyChain T steps)
    (k : ℕ) : ℕ :=
  (dudleyScalePairs C k).card

/-- The scale supremum is the maximum absolute process increment over adjacent projection pairs.

**Lean implementation helper.** -/
theorem dudleyScaleSup_eq_pairSup {steps : ℕ}
    (C : FiniteDudleyChain T steps) (X : HDP.RandomProcess T Ω)
    (k : ℕ) (ω : Ω) :
    dudleyScaleSup C X k ω =
      (dudleyScalePairs C k).sup' (dudleyScalePairs_nonempty C k)
        (fun p => |X p.1 ω - X p.2 ω|) := by
  classical
  change
    Finset.univ.sup' Finset.univ_nonempty (fun t =>
      |X (C.projection (k + 1) t) ω - X (C.projection k t) ω|) =
    (Finset.univ.image fun t =>
      (C.projection (k + 1) t, C.projection k t)).sup' _
        (fun p => |X p.1 ω - X p.2 ω|)
  symm
  exact Finset.sup'_image _ _

/-- Every adjacent projection pair has `d`-distance at most the radius of its chaining scale.

**Lean implementation helper.** -/
theorem pair_distance_le_dudleyScaleRadius {steps : ℕ}
    (C : FiniteDudleyChain T steps) (d : T → T → ℝ)
    (k : ℕ) {p : T × T} (hp : p ∈ dudleyScalePairs C k) :
    d p.1 p.2 ≤ dudleyScaleRadius C d k := by
  exact Finset.le_sup' (fun q : T × T => d q.1 q.2) hp

/-- Shows that the largest index distance at a chaining scale is nonnegative.

**Lean implementation helper.** -/
theorem dudleyScaleRadius_nonneg {steps : ℕ}
    (C : FiniteDudleyChain T steps) (d : T → T → ℝ)
    (hd : ∀ s t, 0 ≤ d s t) (k : ℕ) :
    0 ≤ dudleyScaleRadius C d k := by
  obtain ⟨p, hp⟩ := dudleyScalePairs_nonempty C k
  exact (hd p.1 p.2).trans (pair_distance_le_dudleyScaleRadius C d k hp)

/-- Each scale maximum is bounded by radius times square-root log cardinality. The expected scale maximum derived from subgaussian increments and the
chain's actual adjacent-edge family. In particular, this theorem does not
take its displayed expectation bound as a hypothesis.

**Book Equation (8.11).** -/
theorem expected_dudleyScaleSup_le_of_subGaussianIncrements
    [IsProbabilityMeasure μ] {steps : ℕ}
    (C : FiniteDudleyChain T steps) (X : HDP.RandomProcess T Ω)
    (hXm : ∀ t, Measurable (X t)) (d : T → T → ℝ)
    (hd : ∀ s t, 0 ≤ d s t) {K : ℝ}
    (hinc : HDP.HasSubGaussianIncrementsWith X μ d K) (k : ℕ) :
    Integrable (dudleyScaleSup C X k) μ ∧
      ∫ ω, dudleyScaleSup C X k ω ∂μ ≤
        2 * K * (Real.sqrt
          (Real.log ((dudleyScaleCard C k : ℝ) + 2)) *
            dudleyScaleRadius C d k) := by
  classical
  let A := dudleyScalePairs C k
  let Y : T × T → Ω → ℝ := fun p ω => X p.1 ω - X p.2 ω
  have hA : A.Nonempty := dudleyScalePairs_nonempty C k
  have hYm : ∀ p ∈ A, Measurable (Y p) := by
    intro p hp
    exact (hXm p.1).sub (hXm p.2)
  have hYsub : ∀ p ∈ A, HDP.SubGaussian (Y p) μ := by
    intro p hp
    exact (hinc.2 p.2 p.1).1
  have hYpsi : ∀ p ∈ A,
      HDP.psi2Norm (Y p) μ ≤ K * dudleyScaleRadius C d k := by
    intro p hp
    exact (hinc.2 p.2 p.1).2.trans
      (mul_le_mul_of_nonneg_left
        (pair_distance_le_dudleyScaleRadius C d k hp) hinc.1)
  have hKradius : 0 ≤ K * dudleyScaleRadius C d k :=
    mul_nonneg hinc.1 (dudleyScaleRadius_nonneg C d hd k)
  have hmax := expectation_finset_sup_abs_le A hA Y hYm hYsub
    hKradius hYpsi
  have hraw : Integrable (A.sup' hA fun p ω => |Y p ω|) μ :=
    Finset.sup'_induction hA (fun p ω => |Y p ω|)
      (p := fun f : Ω → ℝ => Integrable f μ)
      (fun _ hf _ hg => hf.sup hg) (fun p hp => by
        have hpint := ((hYsub p hp).memLp (hYm p hp).aemeasurable
          (le_refl (1 : ℝ))).integrable (by norm_num)
        simpa only [Y, Real.norm_eq_abs] using hpint.norm)
  have heq : (A.sup' hA fun p ω => |Y p ω|) = dudleyScaleSup C X k := by
    funext ω
    simpa only [A, Y, Finset.sup'_apply] using
      (dudleyScaleSup_eq_pairSup C X k ω).symm
  constructor
  · rwa [heq] at hraw
  · rw [← heq]
    calc
      (∫ ω, A.sup' hA (fun p ω => |Y p ω|) ω ∂μ) ≤
          2 * Real.sqrt (Real.log ((A.card : ℝ) + 2)) *
            (K * dudleyScaleRadius C d k) := by
        simpa only [Finset.sup'_apply] using hmax
      _ = 2 * K * (Real.sqrt
          (Real.log ((dudleyScaleCard C k : ℝ) + 2)) *
            dudleyScaleRadius C d k) := by
        simp only [A, dudleyScaleCard]
        ring

/-- Entropy sum formed from the distinct edges and metric radii actually
present in a finite chain.

**Lean implementation helper.** -/
def dudleyActualEntropySum {steps : ℕ} (C : FiniteDudleyChain T steps)
    (d : T → T → ℝ) : ℝ :=
  ∑ k ∈ Finset.range steps,
    Real.sqrt (Real.log ((dudleyScaleCard C k : ℝ) + 2)) *
      dudleyScaleRadius C d k

/-! ## The source-facing Dudley bounds -/

/-- `hscale` is the finite-scale maximal inequality and
`hsum_to_integral` is the dyadic Riemann-sum comparison. Both are strictly
upstream of the desired process supremum.

**Book Theorem 8.1.3.** -/
theorem dudleyIntegralInequality {steps : ℕ}
    (C : FiniteDudleyChain T steps) (X : HDP.RandomProcess T Ω)
    (hXm : ∀ t, Measurable (X t)) (hXint : ∀ t, Integrable (X t) μ)
    (hcenter : HDP.IsCenteredProcess X μ)
    (B : ℕ → ℝ) (entropyIntegral : ℝ)
    (hscale : ∀ k ∈ Finset.range steps,
      Integrable (dudleyScaleSup C X k) μ ∧
        ∫ ω, dudleyScaleSup C X k ω ∂μ ≤ B k)
    (hsum_to_integral :
      (∑ k ∈ Finset.range steps, B k) ≤ entropyIntegral) :
    ∫ ω, finiteProcessSup X ω ∂μ ≤ entropyIntegral := by
  have hinc := integrable_finiteProcessIncrementSup_of_chain C X hXm
    (fun k hk => (hscale k hk).1)
  have hsup : Integrable (finiteProcessSup X) μ := by
    have hraw : Integrable
        (Finset.univ.sup' Finset.univ_nonempty fun t => X t) μ :=
      Finset.sup'_induction Finset.univ_nonempty (fun t => X t)
      (p := fun f : Ω → ℝ => Integrable f μ)
      (fun _ hf _ hg => hf.sup hg) (fun t _ => hXint t)
    have heq : (Finset.univ.sup' Finset.univ_nonempty fun t => X t) =
        finiteProcessSup X := by
      funext ω
      simp only [finiteProcessSup, Finset.sup'_apply]
    rwa [heq] at hraw
  have hdom : ∀ ω,
      finiteProcessSup X ω ≤ X C.anchor ω +
        finiteProcessIncrementSup X C.anchor ω := by
    intro ω
    unfold finiteProcessSup
    apply Finset.sup'_le
    intro t ht
    have hle := Finset.le_sup' (fun s => |X s ω - X C.anchor ω|) ht
    calc
      X t ω = X C.anchor ω + (X t ω - X C.anchor ω) := by ring
      _ ≤ X C.anchor ω + |X t ω - X C.anchor ω| :=
        add_le_add (le_refl _) (le_abs_self _)
      _ ≤ X C.anchor ω + finiteProcessIncrementSup X C.anchor ω :=
        add_le_add (le_refl _) hle
  have hrhs : Integrable
      (fun ω => X C.anchor ω + finiteProcessIncrementSup X C.anchor ω) μ :=
    (hXint C.anchor).add hinc
  calc
    (∫ ω, finiteProcessSup X ω ∂μ) ≤
        ∫ ω, (X C.anchor ω + finiteProcessIncrementSup X C.anchor ω) ∂μ :=
      integral_mono hsup hrhs hdom
    _ = ∫ ω, finiteProcessIncrementSup X C.anchor ω ∂μ := by
      rw [integral_add (hXint C.anchor) hinc, hcenter C.anchor, zero_add]
    _ ≤ ∑ k ∈ Finset.range steps, B k :=
      dudleyChainingBound C X hXm B hscale
    _ ≤ entropyIntegral := hsum_to_integral

/-- Dudley bounds the expected supremum of a centered subgaussian-increment process by the entropy integral. The scale maxima are consequences of
`HasSubGaussianIncrementsWith` and the chain's actual edge radii and
cardinalities; callers provide no probabilistic scale certificate.

**Book Theorem 8.1.3.** -/
theorem dudleyIntegralInequality_of_subGaussianIncrements
    [IsProbabilityMeasure μ] {steps : ℕ}
    (C : FiniteDudleyChain T steps) (X : HDP.RandomProcess T Ω)
    (hXm : ∀ t, Measurable (X t)) (hXint : ∀ t, Integrable (X t) μ)
    (hcenter : HDP.IsCenteredProcess X μ) (d : T → T → ℝ)
    (hd : ∀ s t, 0 ≤ d s t) {K : ℝ}
    (hinc : HDP.HasSubGaussianIncrementsWith X μ d K) :
    ∫ ω, finiteProcessSup X ω ∂μ ≤
      2 * K * dudleyActualEntropySum C d := by
  let B : ℕ → ℝ := fun k =>
    2 * K * (Real.sqrt (Real.log ((dudleyScaleCard C k : ℝ) + 2)) *
      dudleyScaleRadius C d k)
  apply dudleyIntegralInequality C X hXm hXint hcenter B
    (2 * K * dudleyActualEntropySum C d)
  · intro k hk
    exact expected_dudleyScaleSup_le_of_subGaussianIncrements
      C X hXm d hd hinc k
  · simp only [B, dudleyActualEntropySum, Finset.mul_sum]
    exact le_rfl

/-- The finite dyadic entropy sum occurring in Theorem 8.1.4.

**Book Theorem 8.1.4.** -/
def dudleyDiscreteEntropySum (steps : ℕ) (ε : ℕ → ℝ)
    (coverCard : ℕ → ℕ) : ℝ :=
  ∑ k ∈ Finset.range steps,
    ε k * Real.sqrt (Real.log (coverCard k : ℝ))

/-- The nontrivial probabilistic input is exposed scale by scale; deterministic
chaining combines it into the displayed entropy sum.

**Book Theorem 8.1.4.** -/
theorem discreteDudleyInequality {steps : ℕ}
    (C : FiniteDudleyChain T steps) (X : HDP.RandomProcess T Ω)
    (hXm : ∀ t, Measurable (X t)) (ε : ℕ → ℝ)
    (coverCard : ℕ → ℕ) (A : ℝ)
    (hscale : ∀ k ∈ Finset.range steps,
      Integrable (dudleyScaleSup C X k) μ ∧
        ∫ ω, dudleyScaleSup C X k ω ∂μ ≤
          A * (ε k * Real.sqrt (Real.log (coverCard k : ℝ)))) :
    ∫ ω, finiteProcessIncrementSup X C.anchor ω ∂μ ≤
      A * dudleyDiscreteEntropySum steps ε coverCard := by
  calc
    (∫ ω, finiteProcessIncrementSup X C.anchor ω ∂μ) ≤
        ∑ k ∈ Finset.range steps,
          A * (ε k * Real.sqrt (Real.log (coverCard k : ℝ))) :=
      dudleyChainingBound C X hXm _ hscale
    _ = A * dudleyDiscreteEntropySum steps ε coverCard := by
      simp [dudleyDiscreteEntropySum, Finset.mul_sum]

/-- Discrete Dudley bounds the expected supremum by a dyadic entropy sum. The right side uses the distinct adjacent pairs and their maximum
metric lengths, and the expected maximum on every scale is proved from the
subgaussian-increment hypothesis.

**Book Theorem 8.1.4.** -/
theorem discreteDudleyInequality_of_subGaussianIncrements
    [IsProbabilityMeasure μ] {steps : ℕ}
    (C : FiniteDudleyChain T steps) (X : HDP.RandomProcess T Ω)
    (hXm : ∀ t, Measurable (X t)) (d : T → T → ℝ)
    (hd : ∀ s t, 0 ≤ d s t) {K : ℝ}
    (hinc : HDP.HasSubGaussianIncrementsWith X μ d K) :
    ∫ ω, finiteProcessIncrementSup X C.anchor ω ∂μ ≤
      2 * K * dudleyActualEntropySum C d := by
  let B : ℕ → ℝ := fun k =>
    2 * K * (Real.sqrt (Real.log ((dudleyScaleCard C k : ℝ) + 2)) *
      dudleyScaleRadius C d k)
  have hscale : ∀ k ∈ Finset.range steps,
      Integrable (dudleyScaleSup C X k) μ ∧
        ∫ ω, dudleyScaleSup C X k ω ∂μ ≤ B k := by
    intro k hk
    exact expected_dudleyScaleSup_le_of_subGaussianIncrements
      C X hXm d hd hinc k
  calc
    (∫ ω, finiteProcessIncrementSup X C.anchor ω ∂μ) ≤
        ∑ k ∈ Finset.range steps, B k :=
      dudleyChainingBound C X hXm B hscale
    _ = 2 * K * dudleyActualEntropySum C d := by
      simp only [B, dudleyActualEntropySum, Finset.mul_sum]

/-! ## §8.1.1: variations and examples -/

/-- Dudley also bounds anchored and pairwise suprema of increments without centering. Anchored-increment form.

**Book Remark 8.1.5.** -/
theorem dudleySupremumOfIncrements {steps : ℕ}
    (C : FiniteDudleyChain T steps) (X : HDP.RandomProcess T Ω)
    (hXm : ∀ t, Measurable (X t)) (B : ℕ → ℝ)
    (hscale : ∀ k ∈ Finset.range steps,
      Integrable (dudleyScaleSup C X k) μ ∧
        ∫ ω, dudleyScaleSup C X k ω ∂μ ≤ B k) :
    ∫ ω, finiteProcessIncrementSup X C.anchor ω ∂μ ≤
      ∑ k ∈ Finset.range steps, B k :=
  dudleyChainingBound C X hXm B hscale

/-- Dudley also bounds anchored and pairwise suprema of increments without centering. Pairwise-increment form.

**Book Remark 8.1.5.** -/
theorem dudleySupremumOfPairwiseIncrements {steps : ℕ}
    (C : FiniteDudleyChain T steps) (X : HDP.RandomProcess T Ω)
    (hXm : ∀ t, Measurable (X t)) (B : ℕ → ℝ)
    (hscale : ∀ k ∈ Finset.range steps,
      Integrable (dudleyScaleSup C X k) μ ∧
        ∫ ω, dudleyScaleSup C X k ω ∂μ ≤ B k) :
    ∫ ω, finiteProcessOscillation X ω ∂μ ≤
      2 * ∑ k ∈ Finset.range steps, B k := by
  have hinc := integrable_finiteProcessIncrementSup_of_chain C X hXm
    (fun k hk => (hscale k hk).1)
  have hosc : Integrable (finiteProcessOscillation X) μ := by
    refine (hinc.const_mul 2).mono'
      (measurable_finiteProcessOscillation X hXm).aestronglyMeasurable ?_
    filter_upwards [] with ω
    rw [Real.norm_eq_abs,
      abs_of_nonneg (finiteProcessOscillation_nonneg X ω)]
    exact finiteProcessOscillation_le_two_incrementSup X C.anchor ω
  calc
    (∫ ω, finiteProcessOscillation X ω ∂μ) ≤
        ∫ ω, 2 * finiteProcessIncrementSup X C.anchor ω ∂μ :=
      integral_mono hosc (hinc.const_mul 2)
        (finiteProcessOscillation_le_two_incrementSup X C.anchor)
    _ = 2 * ∫ ω, finiteProcessIncrementSup X C.anchor ω ∂μ := by
      rw [integral_const_mul]
    _ ≤ 2 * ∑ k ∈ Finset.range steps, B k := by
      gcongr
      exact dudleyChainingBound C X hXm B hscale

/-- The deterministic bad-event inclusion used in the high-probability
version of chaining.

**Lean implementation helper.** -/
theorem dudley_badEvent_subset_scaleUnion {steps : ℕ}
    (C : FiniteDudleyChain T steps) (X : HDP.RandomProcess T Ω)
    (threshold : ℕ → ℝ) :
    {ω | 2 * (∑ k ∈ Finset.range steps, threshold k) <
        finiteProcessOscillation X ω} ⊆
      ⋃ k ∈ Finset.range steps,
        {ω | threshold k < dudleyScaleSup C X k ω} := by
  intro ω hω
  change 2 * (∑ k ∈ Finset.range steps, threshold k) <
    finiteProcessOscillation X ω at hω
  by_contra hnot
  simp only [mem_iUnion, not_exists, mem_setOf_eq] at hnot
  have hscale : ∀ k ∈ Finset.range steps,
      dudleyScaleSup C X k ω ≤ threshold k := by
    intro k hk
    exact le_of_not_gt (hnot k hk)
  have hchain := finiteProcessIncrementSup_le_sum_dudleyScaleSup C X ω
  have hosc := finiteProcessOscillation_le_two_incrementSup X C.anchor ω
  have hsum := Finset.sum_le_sum hscale
  linarith

/-- Dudley admits a high-probability bound with an added `u diam(T)` term. Finite high-probability chaining wrapper.

**Book Remark 8.1.6.** -/
theorem dudleyHighProbabilityBound {steps : ℕ}
    (C : FiniteDudleyChain T steps) (X : HDP.RandomProcess T Ω)
    (threshold : ℕ → ℝ) (q : ℕ → ℝ≥0∞)
    (hTail : ∀ k ∈ Finset.range steps,
      μ {ω | threshold k < dudleyScaleSup C X k ω} ≤ q k) :
    μ {ω | 2 * (∑ k ∈ Finset.range steps, threshold k) <
        finiteProcessOscillation X ω} ≤
      ∑ k ∈ Finset.range steps, q k := by
  calc
    μ {ω | 2 * (∑ k ∈ Finset.range steps, threshold k) <
        finiteProcessOscillation X ω} ≤
        μ (⋃ k ∈ Finset.range steps,
          {ω | threshold k < dudleyScaleSup C X k ω}) :=
      measure_mono (dudley_badEvent_subset_scaleUnion C X threshold)
    _ ≤ ∑ k ∈ Finset.range steps,
        μ {ω | threshold k < dudleyScaleSup C X k ω} :=
      measure_biUnion_finset_le _ _
    _ ≤ ∑ k ∈ Finset.range steps, q k :=
      Finset.sum_le_sum hTail

/-- The entropy integral can be truncated at the diameter because larger balls cover the set singly. Above the (extended) diameter a nonempty set has
covering number one, hence zero logarithmic entropy.

**Book Remark 8.1.7.** -/
theorem coveringEntropy_eq_zero_above_ediam
    {α : Type*} [PseudoEMetricSpace α] {A : Set α} (hA : A.Nonempty)
    {ε : ℝ≥0} (hdiam : Metric.ediam A ≤ ε) :
    Real.log ((Metric.coveringNumber ε A).toNat : ℝ) = 0 := by
  rw [Metric.coveringNumber_eq_one_of_ediam_le hA hdiam]
  norm_num

/-! ## The Euclidean specialization -/

/-- Gaussian width of a finite indexed family. When the family enumerates a
`Finset`, this is Chapter 7's finite Gaussian width (up to duplicate indices,
which do not affect the maximum).

**Lean implementation helper.** -/
def finiteGaussianFamilyWidth
    {E : Type*} [NormedAddCommGroup E] [InnerProductSpace ℝ E]
    [FiniteDimensional ℝ E] [MeasurableSpace E] [BorelSpace E]
    (a : T → E) : ℝ :=
  ∫ g, finiteProcessSup (HDP.Chapter7.canonicalGaussianProcess a) g
    ∂stdGaussian E

/-- Finite Euclidean form.

**Book Theorem 8.1.8.** -/
theorem dudleyInequalityEuclidean
    {E : Type*} [NormedAddCommGroup E] [InnerProductSpace ℝ E]
    [FiniteDimensional ℝ E] [MeasurableSpace E] [BorelSpace E]
    {steps : ℕ} (C : FiniteDudleyChain T steps) (a : T → E)
    (B : ℕ → ℝ) (entropyIntegral : ℝ)
    (hscale : ∀ k ∈ Finset.range steps,
      Integrable (dudleyScaleSup C
        (HDP.Chapter7.canonicalGaussianProcess a) k) (stdGaussian E) ∧
      ∫ g, dudleyScaleSup C
        (HDP.Chapter7.canonicalGaussianProcess a) k g ∂stdGaussian E ≤ B k)
    (hsum_to_integral :
      (∑ k ∈ Finset.range steps, B k) ≤ entropyIntegral) :
    finiteGaussianFamilyWidth a ≤ entropyIntegral := by
  apply dudleyIntegralInequality C
    (HDP.Chapter7.canonicalGaussianProcess a)
  · intro t
    exact ((innerSL ℝ) (a t)).continuous.measurable
  · intro t
    change Integrable (fun g : E => inner ℝ (a t) g) (stdGaussian E)
    simpa [innerSL_apply_apply] using
      ((innerSL ℝ) (a t)).integrable_comp
        (isGaussian_stdGaussian (E := E)).integrable_id
  · exact HDP.Chapter7.canonicalGaussianProcess_centered a
  · exact hscale
  · exact hsum_to_integral

/-- Finite Euclidean source-facing form. Its metric
is the actual Euclidean distance between indexed vectors, and its scale
maxima are obtained from the canonical Gaussian process's subgaussian
increments rather than supplied as hypotheses.

**Book Theorem 8.1.8.** -/
theorem dudleyInequalityEuclidean_of_chain
    {E : Type*} [NormedAddCommGroup E] [InnerProductSpace ℝ E]
    [FiniteDimensional ℝ E] [MeasurableSpace E] [BorelSpace E]
    {steps : ℕ} (C : FiniteDudleyChain T steps) (a : T → E) :
    finiteGaussianFamilyWidth a ≤
      2 * Real.sqrt (8 / 3) *
        dudleyActualEntropySum C (fun s t => ‖a s - a t‖) := by
  let X := HDP.Chapter7.canonicalGaussianProcess a
  have hXm : ∀ t, Measurable (X t) := by
    intro t
    exact ((innerSL ℝ) (a t)).continuous.measurable
  have hXint : ∀ t, Integrable (X t) (stdGaussian E) := by
    intro t
    change Integrable (fun g : E => inner ℝ (a t) g) (stdGaussian E)
    simpa [innerSL_apply_apply] using
      ((innerSL ℝ) (a t)).integrable_comp
        (isGaussian_stdGaussian (E := E)).integrable_id
  have hinc : HDP.HasSubGaussianIncrementsWith X (stdGaussian E)
      (fun s t => ‖a s - a t‖) (Real.sqrt (8 / 3)) := by
    have hbase :=
      HDP.Chapter7.canonicalGaussianProcess_hasSubGaussianIncrementsWith a
    refine ⟨hbase.1, fun s t => ?_⟩
    simpa only [X, HDP.Chapter7.canonicalGaussianProcess_increment] using
      hbase.2 s t
  exact dudleyIntegralInequality_of_subGaussianIncrements C X hXm hXint
    (HDP.Chapter7.canonicalGaussianProcess_centered a)
    (fun s t => ‖a s - a t‖) (fun s t => norm_nonneg _) hinc

/-- Dudley is sharp on the Euclidean ball at scale `sqrt n`. Finite unit-ball form. Every finite subset of the
Euclidean unit ball has Gaussian width at most `sqrt n`, the sharp scale from
the source example.

**Book Example 8.1.9.** -/
theorem euclideanUnitBall_gaussianWidth_le_sqrt_card {n : ℕ}
    (S : Finset (EuclideanSpace ℝ (Fin n))) (hS : S.Nonempty)
    (hunit : ∀ x ∈ S, ‖x‖ ≤ 1) :
    HDP.Chapter7.gaussianWidth S ≤ Real.sqrt n := by
  have hdiam : HDP.Chapter7.finiteEuclideanDiameter S ≤ 2 := by
    rw [HDP.Chapter7.finiteEuclideanDiameter_eq_sup' S hS]
    apply Finset.sup'_le
    intro p hp
    rcases Finset.mem_product.mp hp with ⟨hp1, hp2⟩
    calc
      ‖p.1 - p.2‖ ≤ ‖p.1‖ + ‖p.2‖ := norm_sub_le _ _
      _ ≤ 1 + 1 := add_le_add (hunit p.1 hp1) (hunit p.2 hp2)
      _ = 2 := by norm_num
  calc
    HDP.Chapter7.gaussianWidth S ≤
        Real.sqrt n / 2 * HDP.Chapter7.finiteEuclideanDiameter S :=
      HDP.Chapter7.gaussianWidth_le_sqrt_card_mul_diameter S hS
    _ ≤ Real.sqrt n / 2 * 2 :=
      mul_le_mul_of_nonneg_left hdiam (by positivity)
    _ = Real.sqrt n := by ring

/-- Finite active-scale form. The Dudley sum is at
most the number of active scales times its largest single-scale contribution;
thus a logarithmic number of relevant scales produces at most a logarithmic
loss.

**Book Remark 8.1.10.** -/
theorem dudleyEntropySum_le_activeScale_mul_max {steps : ℕ}
    (hne : (Finset.range steps).Nonempty) (term : ℕ → ℝ) :
    (∑ k ∈ Finset.range steps, term k) ≤
      (steps : ℝ) * (Finset.range steps).sup' hne term := by
  calc
    (∑ k ∈ Finset.range steps, term k) ≤
        ∑ _k ∈ Finset.range steps,
          (Finset.range steps).sup' hne term :=
      Finset.sum_le_sum fun k hk => Finset.le_sup' term hk
    _ = (steps : ℝ) * (Finset.range steps).sup' hne term := by simp

/-! ## Core-promoted exercises -/

/-- Reusable union-bound form. The scale thresholds can
be instantiated with the source's `z_k`; summability is the only requirement.

**Book Exercise 8.1.** -/
theorem exercise_8_1_highProbabilityDudley {steps : ℕ}
    (C : FiniteDudleyChain T steps) (X : HDP.RandomProcess T Ω)
    (threshold : ℕ → ℝ) (q : ℕ → ℝ≥0∞)
    (hTail : ∀ k ∈ Finset.range steps,
      μ {ω | threshold k < dudleyScaleSup C X k ω} ≤ q k)
    {failure : ℝ≥0∞}
    (hq : (∑ k ∈ Finset.range steps, q k) ≤ failure) :
    μ {ω | 2 * (∑ k ∈ Finset.range steps, threshold k) <
        finiteProcessOscillation X ω} ≤ failure :=
  (dudleyHighProbabilityBound C X threshold q hTail).trans hq

/-- Finite dyadic-shell aggregation. Pointwise
two-sided comparisons between each shell integral and its dyadic term sum to
the asserted equivalence with the same constants.

**Book Exercise 8.3.** -/
theorem exercise_8_3_dudleySumIntegral_equiv {steps : ℕ}
    (term shell : ℕ → ℝ) {c C : ℝ}
    (hlower : ∀ k ∈ Finset.range steps, c * term k ≤ shell k)
    (hupper : ∀ k ∈ Finset.range steps, shell k ≤ C * term k) :
    c * (∑ k ∈ Finset.range steps, term k) ≤
        ∑ k ∈ Finset.range steps, shell k ∧
      (∑ k ∈ Finset.range steps, shell k) ≤
        C * (∑ k ∈ Finset.range steps, term k) := by
  constructor
  · rw [Finset.mul_sum]
    exact Finset.sum_le_sum hlower
  · rw [Finset.mul_sum]
    exact Finset.sum_le_sum hupper

/-- The uniform weighted-maximum estimate that drives
the source's example where Dudley's integral is loose. No independence is
needed and the bound is uniform in the number of coordinates.

**Book Exercise 8.4(a).** -/
theorem exercise_8_4a_weightedMaximum_uniform
    [IsProbabilityMeasure μ] {n : ℕ}
    {X : Fin (n + 2) → Ω → ℝ} (hXm : ∀ i, Measurable (X i))
    (hX : ∀ i, HDP.SubGaussian (X i) μ) {K : ℝ} (hK : 0 < K)
    (hKb : ∀ i, HDP.psi2Norm (X i) μ ≤ K) :
    ∫ ω, HDP.Chapter2.logWeightedMax X ω ∂μ ≤
      Real.sqrt 5 * (2 * K / Real.sqrt (Real.log 2)) := by
  have hZm : Measurable (HDP.Chapter2.logWeightedMax X) := by
    have h1 : Measurable (Finset.univ.sup' Finset.univ_nonempty fun i =>
        fun ω => |X i ω| /
          Real.sqrt (Real.log (2 * ((i : ℕ) + 1 : ℝ)))) :=
      Finset.measurable_sup' Finset.univ_nonempty fun i _ =>
        (continuous_abs.measurable.comp (hXm i)).div_const _
    have h2 : (Finset.univ.sup' Finset.univ_nonempty fun i =>
        fun ω => |X i ω| /
          Real.sqrt (Real.log (2 * ((i : ℕ) + 1 : ℝ)))) =
        HDP.Chapter2.logWeightedMax X := by
      funext ω
      simp only [HDP.Chapter2.logWeightedMax, Finset.sup'_apply]
    rwa [h2] at h1
  have hnonneg : ∀ ω, 0 ≤ HDP.Chapter2.logWeightedMax X ω := by
    intro ω
    let i : Fin (n + 2) := ⟨0, by omega⟩
    have hden : 0 ≤ Real.sqrt
        (Real.log (2 * ((i : ℕ) + 1 : ℝ))) := Real.sqrt_nonneg _
    exact (div_nonneg (abs_nonneg _) hden).trans
      (Finset.le_sup' (fun j => |X j ω| /
        Real.sqrt (Real.log (2 * ((j : ℕ) + 1 : ℝ)))) (Finset.mem_univ i))
  obtain ⟨hsub, hpsi⟩ :=
    HDP.Chapter2.exercise_2_37 hXm hX hK hKb
  have hm := hsub.moment_bound hZm.aemeasurable
    (show (1 : ℝ) ≤ 1 by rfl)
  calc
    (∫ ω, HDP.Chapter2.logWeightedMax X ω ∂μ) ≤
        HDP.Chapter1.lpNormRV (HDP.Chapter2.logWeightedMax X) 1 μ := by
      rw [HDP.Chapter1.lpNormRV]
      simp_rw [Real.rpow_one, abs_of_nonneg (hnonneg _)]
      rw [show (1 : ℝ) / 1 = 1 by norm_num, Real.rpow_one]
    _ ≤ HDP.psi2Norm (HDP.Chapter2.logWeightedMax X) μ * Real.sqrt 1 := hm
    _ = HDP.psi2Norm (HDP.Chapter2.logWeightedMax X) μ := by norm_num
    _ ≤ Real.sqrt 5 * (2 * K / Real.sqrt (Real.log 2)) := hpsi

/-- Divergence-transfer form. The geometric part of
the source example supplies the displayed lower bound; this theorem verifies
that such a lower bound forces the Dudley entropy integrals to diverge.

**Book Exercise 8.4(b).** -/
theorem exercise_8_4b_entropyLowerBound_diverges (I : ℕ → ℝ)
    (hI : ∀ n : ℕ,
      Real.sqrt (Real.log ((n : ℝ) + 1)) ≤ I n) :
    Tendsto I atTop atTop := by
  have hn : Tendsto (fun n : ℕ => (n : ℝ) + 1) atTop atTop :=
    tendsto_atTop_add_const_right _ _
      (tendsto_natCast_atTop_atTop :
        Tendsto (fun n : ℕ => (n : ℝ)) atTop atTop)
  have hbase : Tendsto
      (fun n : ℕ => Real.sqrt (Real.log ((n : ℝ) + 1))) atTop atTop :=
    Real.tendsto_sqrt_atTop.comp (Real.tendsto_log_atTop.comp hn)
  exact tendsto_atTop_mono hI hbase

/-- Finite active-scale form. A nonnegative entropy sum
lies between its largest scale contribution and the number of active scales
times that contribution; if the active scale count is logarithmic, this is
exactly the source's logarithmic loss.

**Book Exercise 8.5.** -/
theorem exercise_8_5_logFactor {steps : ℕ} (hsteps : 0 < steps)
    (term : ℕ → ℝ)
    (hterm : ∀ k ∈ Finset.range steps, 0 ≤ term k) :
    let s := (Finset.range steps).sup'
      (by exact ⟨0, Finset.mem_range.mpr hsteps⟩) term
    s ≤ (∑ k ∈ Finset.range steps, term k) ∧
      (∑ k ∈ Finset.range steps, term k) ≤ (steps : ℝ) * s := by
  have hne : (Finset.range steps).Nonempty :=
    ⟨0, Finset.mem_range.mpr hsteps⟩
  change (Finset.range steps).sup' hne term ≤
      (∑ k ∈ Finset.range steps, term k) ∧
    (∑ k ∈ Finset.range steps, term k) ≤
      (steps : ℝ) * (Finset.range steps).sup' hne term
  constructor
  · obtain ⟨k, hk, hks⟩ := Finset.exists_mem_eq_sup' hne term
    calc
      (Finset.range steps).sup' hne term = term k := hks
      _ ≤ ∑ j ∈ Finset.range steps, term j :=
        Finset.single_le_sum (fun j hj => hterm j hj) hk
  · calc
      (∑ k ∈ Finset.range steps, term k) ≤
          (steps : ℝ) * (Finset.range steps).sup' hne term :=
        dudleyEntropySum_le_activeScale_mul_max hne term


/-! ## Exact finite covering-number Dudley endpoints -/

section CoveringNumberDudley

variable [PseudoMetricSpace T]

variable {T : Type*} [Fintype T] [Nonempty T] [PseudoMetricSpace T]

/-- Defines the least cardinality of a finite cover of the whole index space at radius `ε`.

**Lean implementation helper.** -/
def finiteCoverCard (ε : ℝ≥0) : ℕ :=
  (Metric.coveringNumber ε (Set.univ : Set T)).toNat

omit [Fintype T] [Nonempty T] in
/-- The finite covering cardinality agrees, after coercion, with the metric covering number of the whole space.

**Lean implementation helper.** -/
lemma finiteCoverCard_coe [Finite T] (ε : ℝ≥0) :
    (finiteCoverCard (T := T) ε : ℕ∞) =
      Metric.coveringNumber ε (Set.univ : Set T) := by
  apply ENat.coe_toNat
  exact (HDP.finite_covering_packing_of_finite Set.finite_univ ε).1

omit [Fintype T] in
/-- Shows that the finite covering cardinality is strictly positive.

**Lean implementation helper.** -/
lemma finiteCoverCard_pos [Finite T] (ε : ℝ≥0) :
    0 < finiteCoverCard (T := T) ε := by
  have h : (0 : ℕ∞) < (finiteCoverCard (T := T) ε : ℕ∞) := by
    rw [finiteCoverCard_coe]
    exact Metric.coveringNumber_pos_iff.mpr Set.univ_nonempty
  exact_mod_cast h

omit [Fintype T] [Nonempty T] in
/-- Increasing the covering radius cannot increase the minimum cardinality of a finite cover.

**Lean implementation helper.** -/
lemma finiteCoverCard_anti [Finite T] :
    Antitone (finiteCoverCard (T := T)) := by
  intro ε δ hεδ
  apply ENat.toNat_le_toNat (Metric.coveringNumber_anti hεδ)
  exact (HDP.finite_covering_packing_of_finite Set.finite_univ ε).1

/-- Defines the square root of the logarithm of the finite covering number at a real radius.

**Lean implementation helper.** -/
def finiteCoverEntropy (x : ℝ) : ℝ :=
  Real.sqrt (Real.log (finiteCoverCard (T := T) x.toNNReal : ℝ))

omit [Fintype T] [Nonempty T] in
/-- Shows that the finite covering entropy is nonnegative.

**Lean implementation helper.** -/
lemma finiteCoverEntropy_nonneg (x : ℝ) :
    0 ≤ finiteCoverEntropy (T := T) x :=
  Real.sqrt_nonneg _

omit [Fintype T] in
/-- Shows that the finite covering entropy is antitone.

**Lean implementation helper.** -/
lemma finiteCoverEntropy_antitone [Finite T] :
    Antitone (finiteCoverEntropy (T := T)) := by
  intro x y hxy
  unfold finiteCoverEntropy
  have hc : finiteCoverCard (T := T) y.toNNReal ≤
      finiteCoverCard (T := T) x.toNNReal :=
    finiteCoverCard_anti (T := T) (Real.toNNReal_mono hxy)
  have hxpos : (0 : ℝ) < finiteCoverCard (T := T) x.toNNReal := by
    exact_mod_cast finiteCoverCard_pos (T := T) x.toNNReal
  have hypos : (0 : ℝ) < finiteCoverCard (T := T) y.toNNReal := by
    exact_mod_cast finiteCoverCard_pos (T := T) y.toNNReal
  gcongr

/-- Dyadic scales `epsilon_k=2^{-k}`.

**Book Equation (8.4).** -/
def dyadicRadius (R : ℝ≥0) (k : ℕ) : ℝ≥0 := R / (2 : ℝ≥0) ^ k

/-- The initial dyadic radius is the prescribed radius `R`.

**Lean implementation helper.** -/
@[simp] lemma dyadicRadius_zero (R : ℝ≥0) : dyadicRadius R 0 = R := by
  simp [dyadicRadius]

/-- Each successor dyadic radius is half the preceding radius.

**Lean implementation helper.** -/
lemma dyadicRadius_succ (R : ℝ≥0) (k : ℕ) :
    dyadicRadius R (k + 1) = dyadicRadius R k / 2 := by
  simp [dyadicRadius, pow_succ, div_eq_mul_inv]
  ring

/-- Dyadic radii decrease as the scale index increases.

**Lean implementation helper.** -/
lemma dyadicRadius_antitone (R : ℝ≥0) : Antitone (dyadicRadius R) :=
  antitone_nat_of_succ_le fun k => by
    rw [dyadicRadius_succ]
    exact div_le_self bot_le (by norm_num)

/-- Defines the truncated dyadic sum of covering entropies used in the finite Dudley bound.

**Lean implementation helper.** -/
def finiteDyadicEntropySum (R : ℝ≥0) (steps : ℕ) : ℝ :=
  ∑ k ∈ Finset.range steps,
    (dyadicRadius R (k + 1) : ℝ) *
      finiteCoverEntropy (T := T) (dyadicRadius R (k + 1) : ℝ)

/-- Chooses a minimum-cardinality finite cover of the index space at the prescribed radius.

**Lean implementation helper.** -/
noncomputable def optimalCoverFinset (ε : ℝ≥0) : Finset T :=
  (HDP.minimalFiniteNet ε (Set.univ : Set T)
    (HDP.finite_covering_packing_of_finite Set.finite_univ ε).1).toFinset

omit [Nonempty T] in
/-- The selected optimal cover has exactly the minimum finite covering cardinality.

**Lean implementation helper.** -/
lemma optimalCoverFinset_card (ε : ℝ≥0) :
    (optimalCoverFinset (T := T) ε).card = finiteCoverCard (T := T) ε := by
  apply Nat.cast_injective (R := ℕ∞)
  rw [finiteCoverCard_coe]
  let N := HDP.minimalFiniteNet ε (Set.univ : Set T)
    (HDP.finite_covering_packing_of_finite
      (K := (Set.univ : Set T)) Set.finite_univ ε).1
  calc
    ((optimalCoverFinset (T := T) ε).card : ℕ∞) =
        (N.toFinset.card : ℕ∞) := by rfl
    _ = N.points.encard := N.coe_card_toFinset
    _ = Metric.coveringNumber ε (Set.univ : Set T) := by
      exact Metric.encard_minimalCover
        (HDP.finite_covering_packing_of_finite
          (K := (Set.univ : Set T)) Set.finite_univ ε).1

omit [Nonempty T] in
/-- Shows that the selected optimal finite cover is a cover at the stated radius.

**Lean implementation helper.** -/
lemma optimalCoverFinset_isCover (ε : ℝ≥0) :
    Metric.IsCover ε (Set.univ : Set T) (optimalCoverFinset (T := T) ε : Set T) := by
  simpa [optimalCoverFinset] using
    (HDP.minimalFiniteNet ε (Set.univ : Set T)
      (HDP.finite_covering_packing_of_finite Set.finite_univ ε).1).isCover_toFinset

/-- Chooses, for each index, a point of the selected finite cover within the covering radius.

**Lean implementation helper.** -/
noncomputable def optimalCoverProjection (ε : ℝ≥0) (t : T) : T :=
  Classical.choose (optimalCoverFinset_isCover (T := T) ε (Set.mem_univ t))

omit [Nonempty T] in
/-- Every selected cover projection lies in the corresponding optimal finite cover.

**Lean implementation helper.** -/
lemma optimalCoverProjection_mem (ε : ℝ≥0) (t : T) :
    optimalCoverProjection (T := T) ε t ∈ optimalCoverFinset (T := T) ε :=
  (Classical.choose_spec
    (optimalCoverFinset_isCover (T := T) ε (Set.mem_univ t))).1

omit [Nonempty T] in
/-- Chosen projections are within the covering radius.

**Book Equation (8.7).** -/
lemma dist_optimalCoverProjection_le (ε : ℝ≥0) (t : T) :
    dist t (optimalCoverProjection (T := T) ε t) ≤ ε := by
  have h := (Classical.choose_spec
    (optimalCoverFinset_isCover (T := T) ε (Set.mem_univ t))).2
  simpa [optimalCoverProjection, edist_dist] using h

/-- Chooses a fixed base point in the nonempty index space.

**Lean implementation helper.** -/
noncomputable def dyadicAnchor : T := Classical.choice inferInstance

/-- Projects an index to the selected cover at a dyadic scale, using the anchor at collapsed scales.

**Lean implementation helper.** -/
noncomputable def optimalDyadicProjection (R : ℝ≥0) (steps k : ℕ) (t : T) : T :=
  if k = 0 then dyadicAnchor (T := T)
  else if steps ≤ k then t
  else if finiteCoverCard (T := T) (dyadicRadius R k) = 1 then dyadicAnchor (T := T)
  else optimalCoverProjection (T := T) (dyadicRadius R k) t

/-- Each chain level has covering-number cardinality.

**Book Equation (8.5).** -/
noncomputable def optimalDyadicLevel (R : ℝ≥0) (steps k : ℕ) : Finset T :=
  if k = 0 then {dyadicAnchor (T := T)}
  else if steps ≤ k then Finset.univ
  else if finiteCoverCard (T := T) (dyadicRadius R k) = 1 then
    {dyadicAnchor (T := T)}
  else optimalCoverFinset (T := T) (dyadicRadius R k)

/-- Every dyadic projection lies in the corresponding level of the optimal chain.

**Lean implementation helper.** -/
lemma optimalDyadicProjection_mem_level (R : ℝ≥0) (steps k : ℕ) (t : T) :
    optimalDyadicProjection (T := T) R steps k t ∈
      optimalDyadicLevel (T := T) R steps k := by
  unfold optimalDyadicProjection optimalDyadicLevel
  split_ifs <;> simp_all [optimalCoverProjection_mem]

/-- Each chain level has covering-number cardinality.

**Book Equation (8.5).** -/
lemma optimalDyadicLevel_card_le_coverCard (R : ℝ≥0) (steps k : ℕ)
    (hk : k ≤ steps)
    (hcoarse : finiteCoverCard (T := T) R = 1)
    (hfine : finiteCoverCard (T := T) (dyadicRadius R steps) = Fintype.card T) :
    (optimalDyadicLevel (T := T) R steps k).card ≤
      finiteCoverCard (T := T) (dyadicRadius R k) := by
  unfold optimalDyadicLevel
  by_cases hk0 : k = 0
  · subst k
    simp [hcoarse]
  · simp only [hk0, if_false]
    by_cases hsk : steps ≤ k
    · have hks : k = steps := Nat.le_antisymm hk hsk
      subst k
      simp [hfine]
    · simp only [hsk, if_false]
      by_cases hc : finiteCoverCard (T := T) (dyadicRadius R k) = 1
      · simp [hc]
      · simp [hc, optimalCoverFinset_card]

/-- Chaining starts at a singleton and terminates at the full finite set.

**Book Equation (8.6).** -/
noncomputable def optimalDyadicChain (R : ℝ≥0) (steps : ℕ) :
    FiniteDudleyChain T (steps + 1) where
  anchor := dyadicAnchor (T := T)
  projection := optimalDyadicProjection (T := T) R (steps + 1)
  coarse := by intro t; simp [optimalDyadicProjection]
  exact := by
    intro t
    simp [optimalDyadicProjection]

omit [Nonempty T] in
/-- If the optimal cover has one point, all nearest-cover projections coincide.

**Lean implementation helper.** -/
lemma optimalCoverProjection_eq_of_card_one (ε : ℝ≥0)
    (hcard : finiteCoverCard (T := T) ε = 1) (s t : T) :
    optimalCoverProjection (T := T) ε s = optimalCoverProjection (T := T) ε t := by
  have hc : (optimalCoverFinset (T := T) ε).card = 1 := by
    rw [optimalCoverFinset_card, hcard]
  obtain ⟨a, ha⟩ := Finset.card_eq_one.mp hc
  have hs := optimalCoverProjection_mem (T := T) ε s
  have ht := optimalCoverProjection_mem (T := T) ε t
  have hs' : optimalCoverProjection (T := T) ε s = a := by
    simpa [ha] using hs
  have ht' : optimalCoverProjection (T := T) ε t = a := by
    simpa [ha] using ht
  exact hs'.trans ht'.symm

/-- An index lies within twice the current dyadic radius of its optimal dyadic projection.

**Lean implementation helper.** -/
lemma dist_optimalDyadicProjection_le_two (R : ℝ≥0) (steps k : ℕ)
    (hdiam : Metric.diam (Set.univ : Set T) ≤ (R : ℝ)) (t : T) :
    dist t (optimalDyadicProjection (T := T) R steps k t) ≤
      2 * (dyadicRadius R k : ℝ) := by
  by_cases hk0 : k = 0
  · subst k
    simp only [optimalDyadicProjection, if_pos, dyadicRadius_zero]
    calc
      dist t (dyadicAnchor (T := T)) ≤ Metric.diam (Set.univ : Set T) :=
        Metric.dist_le_diam_of_mem Set.finite_univ.isBounded (Set.mem_univ _) (Set.mem_univ _)
      _ ≤ (R : ℝ) := hdiam
      _ ≤ 2 * (R : ℝ) := by
        have hR : 0 ≤ (R : ℝ) := NNReal.coe_nonneg _
        linarith
  · simp only [optimalDyadicProjection, if_neg hk0]
    by_cases hsk : steps ≤ k
    · rw [if_pos hsk]
      simp
    · rw [if_neg hsk]
      by_cases hc : finiteCoverCard (T := T) (dyadicRadius R k) = 1
      · simp only [hc, if_pos]
        let a := optimalCoverProjection (T := T) (dyadicRadius R k)
          (dyadicAnchor (T := T))
        calc
          dist t (dyadicAnchor (T := T)) ≤
              dist t (a) + dist a (dyadicAnchor (T := T)) := dist_triangle _ _ _
          _ = dist t (optimalCoverProjection (T := T) (dyadicRadius R k) t) +
              dist (optimalCoverProjection (T := T) (dyadicRadius R k)
                (dyadicAnchor (T := T))) (dyadicAnchor (T := T)) := by
            dsimp [a]
            rw [optimalCoverProjection_eq_of_card_one (T := T) _ hc t
              (dyadicAnchor (T := T))]
          _ ≤ (dyadicRadius R k : ℝ) + (dyadicRadius R k : ℝ) := by
            apply add_le_add
            · exact dist_optimalCoverProjection_le (T := T) _ _
            · have hproj := dist_optimalCoverProjection_le (T := T)
                (dyadicRadius R k) (dyadicAnchor (T := T))
              simpa [dist_comm] using hproj
          _ = 2 * (dyadicRadius R k : ℝ) := by ring
      · simp only [hc]
        exact (dist_optimalCoverProjection_le (T := T) _ _).trans (by
          have hnonneg : 0 ≤ (dyadicRadius R k : ℝ) := NNReal.coe_nonneg _
          linarith)

/-- The number of adjacent projection pairs at a scale is at most the square of the next covering number.

**Lean implementation helper.** -/
lemma optimalDyadicScaleCard_le_sq (R : ℝ≥0) (steps k : ℕ)
    (hk : k < steps + 1)
    (hcoarse : finiteCoverCard (T := T) R = 1)
    (hfine : finiteCoverCard (T := T) (dyadicRadius R (steps + 1)) =
      Fintype.card T) :
    dudleyScaleCard (optimalDyadicChain (T := T) R steps) k ≤
      (finiteCoverCard (T := T) (dyadicRadius R (k + 1))) ^ 2 := by
  classical
  let C := optimalDyadicChain (T := T) R steps
  let L₁ := optimalDyadicLevel (T := T) R (steps + 1) (k + 1)
  let L₀ := optimalDyadicLevel (T := T) R (steps + 1) k
  have hsubset : dudleyScalePairs C k ⊆ L₁.product L₀ := by
    intro p hp
    rcases Finset.mem_image.mp hp with ⟨t, _ht, rfl⟩
    exact Finset.mem_product.mpr ⟨
      optimalDyadicProjection_mem_level (T := T) R (steps + 1) (k + 1) t,
      optimalDyadicProjection_mem_level (T := T) R (steps + 1) k t⟩
  have hk1 : k + 1 ≤ steps + 1 := hk
  have hk0 : k ≤ steps + 1 := hk.le
  have hL₁ : L₁.card ≤ finiteCoverCard (T := T) (dyadicRadius R (k + 1)) :=
    optimalDyadicLevel_card_le_coverCard (T := T) R (steps + 1) (k + 1)
      hk1 hcoarse hfine
  have hL₀ : L₀.card ≤ finiteCoverCard (T := T) (dyadicRadius R k) :=
    optimalDyadicLevel_card_le_coverCard (T := T) R (steps + 1) k
      hk0 hcoarse hfine
  have hr : dyadicRadius R (k + 1) ≤ dyadicRadius R k := by
    rw [dyadicRadius_succ]
    exact div_le_self bot_le (by norm_num)
  have hN : finiteCoverCard (T := T) (dyadicRadius R k) ≤
      finiteCoverCard (T := T) (dyadicRadius R (k + 1)) :=
    finiteCoverCard_anti (T := T) hr
  calc
    dudleyScaleCard C k ≤ (L₁.product L₀).card := Finset.card_le_card hsubset
    _ = L₁.card * L₀.card := Finset.card_product _ _
    _ ≤ finiteCoverCard (T := T) (dyadicRadius R (k + 1)) *
        finiteCoverCard (T := T) (dyadicRadius R k) :=
      Nat.mul_le_mul hL₁ hL₀
    _ ≤ finiteCoverCard (T := T) (dyadicRadius R (k + 1)) *
        finiteCoverCard (T := T) (dyadicRadius R (k + 1)) :=
      Nat.mul_le_mul_left _ hN
    _ = (finiteCoverCard (T := T) (dyadicRadius R (k + 1))) ^ 2 := by ring

/-- Chosen projections are within the covering radius.

**Book Equation (8.7).** -/
lemma optimalDyadicScaleRadius_le (R : ℝ≥0) (steps k : ℕ)
    (hdiam : Metric.diam (Set.univ : Set T) ≤ (R : ℝ)) :
    dudleyScaleRadius (optimalDyadicChain (T := T) R steps) dist k ≤
      6 * (dyadicRadius R (k + 1) : ℝ) := by
  classical
  let C := optimalDyadicChain (T := T) R steps
  unfold dudleyScaleRadius
  apply Finset.sup'_le
  intro p hp
  rcases Finset.mem_image.mp hp with ⟨t, _ht, rfl⟩
  have hnext := dist_optimalDyadicProjection_le_two (T := T) R (steps + 1)
    (k + 1) hdiam t
  have hcurr := dist_optimalDyadicProjection_le_two (T := T) R (steps + 1)
    k hdiam t
  have hr : (dyadicRadius R k : ℝ) =
      2 * (dyadicRadius R (k + 1) : ℝ) := by
    rw [dyadicRadius_succ]
    push_cast
    ring
  calc
    dist (C.projection (k + 1) t) (C.projection k t) ≤
        dist (C.projection (k + 1) t) t + dist t (C.projection k t) :=
      dist_triangle _ _ _
    _ ≤ 2 * (dyadicRadius R (k + 1) : ℝ) +
        2 * (dyadicRadius R k : ℝ) :=
      add_le_add (by simpa [C, optimalDyadicChain, dist_comm] using hnext)
        (by simpa [C, optimalDyadicChain] using hcurr)
    _ = 6 * (dyadicRadius R (k + 1) : ℝ) := by rw [hr]; ring

/-- Once the relevant optimal cover is a singleton, every dyadic projection equals the chain anchor.

**Lean implementation helper.** -/
lemma optimalDyadicProjection_eq_anchor_of_card_one (R : ℝ≥0)
    (terminal k : ℕ) (hk : k ≤ terminal)
    (hfine : finiteCoverCard (T := T) (dyadicRadius R terminal) = Fintype.card T)
    (hcard : finiteCoverCard (T := T) (dyadicRadius R k) = 1) (t : T) :
    optimalDyadicProjection (T := T) R terminal k t = dyadicAnchor (T := T) := by
  unfold optimalDyadicProjection
  by_cases hk0 : k = 0
  · simp [hk0]
  · simp only [hk0, if_false]
    by_cases hterm : terminal ≤ k
    · have hkt : k = terminal := Nat.le_antisymm hk hterm
      subst k
      simp only [le_rfl, if_true]
      have hTcard : Fintype.card T = 1 := by
        rw [← hfine]
        exact hcard
      letI : Subsingleton T := Fintype.card_le_one_iff_subsingleton.mp hTcard.le
      exact Subsingleton.elim _ _
    · simp [hterm, hcard]

/-- A scale whose relevant optimal cover is a singleton has zero projection radius.

**Lean implementation helper.** -/
lemma optimalDyadicScaleRadius_eq_zero_of_coverCard_one (R : ℝ≥0)
    (steps k : ℕ) (hk : k < steps + 1)
    (hfine : finiteCoverCard (T := T) (dyadicRadius R (steps + 1)) =
      Fintype.card T)
    (hcard : finiteCoverCard (T := T) (dyadicRadius R (k + 1)) = 1) :
    dudleyScaleRadius (optimalDyadicChain (T := T) R steps) dist k = 0 := by
  classical
  have hr : dyadicRadius R (k + 1) ≤ dyadicRadius R k := by
    rw [dyadicRadius_succ]
    exact div_le_self bot_le (by norm_num)
  have hprevle : finiteCoverCard (T := T) (dyadicRadius R k) ≤ 1 := by
    simpa [hcard] using finiteCoverCard_anti (T := T) hr
  have hprevpos := finiteCoverCard_pos (T := T) (dyadicRadius R k)
  have hprev : finiteCoverCard (T := T) (dyadicRadius R k) = 1 := by omega
  unfold dudleyScaleRadius
  apply le_antisymm
  · apply Finset.sup'_le
    intro p hp
    rcases Finset.mem_image.mp hp with ⟨t, _ht, rfl⟩
    rw [show (optimalDyadicChain (T := T) R steps).projection (k + 1) t =
        dyadicAnchor (T := T) from
      optimalDyadicProjection_eq_anchor_of_card_one (T := T) R (steps + 1)
        (k + 1) hk hfine hcard t]
    rw [show (optimalDyadicChain (T := T) R steps).projection k t =
        dyadicAnchor (T := T) from
      optimalDyadicProjection_eq_anchor_of_card_one (T := T) R (steps + 1)
        k hk.le hfine hprev t]
    simp
  · exact dudleyScaleRadius_nonneg _ dist (fun _ _ => dist_nonneg) _

/-- If `2 ≤ N` and `M ≤ N²`, then `√log(M + 2) ≤ 2 √log N`.

**Lean implementation helper.** -/
lemma sqrt_log_card_add_two_le_two_sqrt_log {M N : ℕ}
    (hN : 2 ≤ N) (hM : M ≤ N ^ 2) :
    Real.sqrt (Real.log ((M : ℝ) + 2)) ≤
      2 * Real.sqrt (Real.log (N : ℝ)) := by
  have hNreal : (2 : ℝ) ≤ N := by exact_mod_cast hN
  have hMreal : (M : ℝ) ≤ (N : ℝ) ^ 2 := by exact_mod_cast hM
  have harg : (M : ℝ) + 2 ≤ 2 * (N : ℝ) ^ 2 := by
    nlinarith [sq_nonneg ((N : ℝ) - 2)]
  have hargpos : 0 < (M : ℝ) + 2 := by positivity
  have hupperpos : 0 < 2 * (N : ℝ) ^ 2 := by positivity
  have hlog : Real.log ((M : ℝ) + 2) ≤ Real.log (2 * (N : ℝ) ^ 2) :=
    Real.log_le_log hargpos harg
  have hlogN0 : 0 ≤ Real.log (N : ℝ) := Real.log_nonneg (by linarith)
  have hlog2N : Real.log (2 * (N : ℝ) ^ 2) ≤ 4 * Real.log (N : ℝ) := by
    rw [Real.log_mul (by norm_num : (2 : ℝ) ≠ 0) (by positivity), Real.log_pow]
    have hlog2 : Real.log (2 : ℝ) ≤ Real.log (N : ℝ) :=
      Real.log_le_log (by norm_num) hNreal
    norm_num
    linarith
  have hM0 : (0 : ℝ) ≤ M := by positivity
  have hlogarg0 : 0 ≤ Real.log ((M : ℝ) + 2) :=
    Real.log_nonneg (by linarith)
  have hsqa := Real.sq_sqrt hlogarg0
  have hsqb := Real.sq_sqrt hlogN0
  have hsqrta := Real.sqrt_nonneg (Real.log ((M : ℝ) + 2))
  have hsqrtb := Real.sqrt_nonneg (Real.log (N : ℝ))
  nlinarith

/-- The actual entropy sum of the optimal dyadic chain is at most twelve times its dyadic covering-entropy sum.

**Lean implementation helper.** -/
lemma optimalDyadicActualEntropySum_le (R : ℝ≥0) (steps : ℕ)
    (hcoarse : finiteCoverCard (T := T) R = 1)
    (hfine : finiteCoverCard (T := T) (dyadicRadius R (steps + 1)) =
      Fintype.card T)
    (hdiam : Metric.diam (Set.univ : Set T) ≤ (R : ℝ)) :
    dudleyActualEntropySum (optimalDyadicChain (T := T) R steps) dist ≤
      12 * finiteDyadicEntropySum (T := T) R (steps + 1) := by
  unfold dudleyActualEntropySum finiteDyadicEntropySum
  rw [Finset.mul_sum]
  apply Finset.sum_le_sum
  intro k hk
  have hklt : k < steps + 1 := Finset.mem_range.mp hk
  let N := finiteCoverCard (T := T) (dyadicRadius R (k + 1))
  by_cases hN1 : N = 1
  · have hrzero := optimalDyadicScaleRadius_eq_zero_of_coverCard_one
      (T := T) R steps k hklt hfine hN1
    rw [hrzero, mul_zero]
    exact mul_nonneg (by norm_num) <|
      mul_nonneg (NNReal.coe_nonneg _) (finiteCoverEntropy_nonneg (T := T) _)
  · have hNpos : 0 < N := finiteCoverCard_pos (T := T) _
    have hNtwo : 2 ≤ N := by omega
    have hcard := optimalDyadicScaleCard_le_sq (T := T) R steps k hklt
      hcoarse hfine
    have hsqrt : Real.sqrt
        (Real.log ((dudleyScaleCard (optimalDyadicChain (T := T) R steps) k : ℝ) + 2)) ≤
        2 * Real.sqrt (Real.log (N : ℝ)) :=
      sqrt_log_card_add_two_le_two_sqrt_log hNtwo hcard
    have hradius := optimalDyadicScaleRadius_le (T := T) R steps k hdiam
    have hsqrt0 : 0 ≤ Real.sqrt
        (Real.log ((dudleyScaleCard (optimalDyadicChain (T := T) R steps) k : ℝ) + 2)) :=
      Real.sqrt_nonneg _
    have hentropy0 : 0 ≤ Real.sqrt (Real.log (N : ℝ)) := Real.sqrt_nonneg _
    have hr0 : 0 ≤ (dyadicRadius R (k + 1) : ℝ) := NNReal.coe_nonneg _
    calc
      Real.sqrt
            (Real.log ((dudleyScaleCard (optimalDyadicChain (T := T) R steps) k : ℝ) + 2)) *
          dudleyScaleRadius (optimalDyadicChain (T := T) R steps) dist k ≤
        (2 * Real.sqrt (Real.log (N : ℝ))) *
          (6 * (dyadicRadius R (k + 1) : ℝ)) :=
        mul_le_mul hsqrt hradius
          (dudleyScaleRadius_nonneg _ dist (fun _ _ => dist_nonneg) _)
          (mul_nonneg (by norm_num) hentropy0)
      _ = 12 * ((dyadicRadius R (k + 1) : ℝ) *
          finiteCoverEntropy (T := T) (dyadicRadius R (k + 1) : ℝ)) := by
        simp [finiteCoverEntropy, N]
        ring

omit [Fintype T] in
/-- The truncated dyadic entropy sum is at most twice the covering-entropy integral over the corresponding radii.

**Lean implementation helper.** -/
lemma finiteDyadicEntropySum_le_integral [Finite T] (R : ℝ≥0) (steps : ℕ) :
    finiteDyadicEntropySum (T := T) R steps ≤
      2 * ∫ x in (dyadicRadius R (steps + 1) : ℝ)..(dyadicRadius R 1 : ℝ),
        finiteCoverEntropy (T := T) x := by
  induction steps with
  | zero => simp [finiteDyadicEntropySum]
  | succ n ih =>
      rw [finiteDyadicEntropySum, Finset.sum_range_succ]
      have ih' :
          (∑ k ∈ Finset.range n,
              (dyadicRadius R (k + 1) : ℝ) *
                finiteCoverEntropy (T := T) (dyadicRadius R (k + 1) : ℝ)) ≤
            2 * ∫ x in (dyadicRadius R (n + 1) : ℝ)..
              (dyadicRadius R 1 : ℝ), finiteCoverEntropy (T := T) x := ih
      have hhalf : (dyadicRadius R (n + 2) : ℝ) =
          (dyadicRadius R (n + 1) : ℝ) / 2 := by
        rw [show n + 2 = (n + 1) + 1 by omega, dyadicRadius_succ]
        rfl
      have hrad : (dyadicRadius R (n + 2) : ℝ) ≤
          (dyadicRadius R (n + 1) : ℝ) := by
        rw [hhalf]
        exact div_le_self (NNReal.coe_nonneg _) (by norm_num)
      have hint : IntervalIntegrable (finiteCoverEntropy (T := T)) volume
          (dyadicRadius R (n + 2) : ℝ) (dyadicRadius R (n + 1) : ℝ) :=
        finiteCoverEntropy_antitone (T := T) |>.intervalIntegrable
      have hshell :
          (dyadicRadius R (n + 1) : ℝ) *
              finiteCoverEntropy (T := T) (dyadicRadius R (n + 1) : ℝ) ≤
            2 * ∫ x in (dyadicRadius R (n + 2) : ℝ)..
                (dyadicRadius R (n + 1) : ℝ),
              finiteCoverEntropy (T := T) x := by
        have hmono : ∀ x ∈ Set.Icc (dyadicRadius R (n + 2) : ℝ)
            (dyadicRadius R (n + 1) : ℝ),
            finiteCoverEntropy (T := T) (dyadicRadius R (n + 1) : ℝ) ≤
              finiteCoverEntropy (T := T) x := by
          intro x hx
          exact finiteCoverEntropy_antitone (T := T) hx.2
        have hconst : IntervalIntegrable
            (fun _ : ℝ => finiteCoverEntropy (T := T)
              (dyadicRadius R (n + 1) : ℝ)) volume
            (dyadicRadius R (n + 2) : ℝ) (dyadicRadius R (n + 1) : ℝ) := by
          simp
        have hle := intervalIntegral.integral_mono_on hrad hconst hint hmono
        rw [intervalIntegral.integral_const] at hle
        calc
          (dyadicRadius R (n + 1) : ℝ) *
                finiteCoverEntropy (T := T) (dyadicRadius R (n + 1) : ℝ) =
              2 * (((dyadicRadius R (n + 1) : ℝ) -
                (dyadicRadius R (n + 2) : ℝ)) *
                  finiteCoverEntropy (T := T) (dyadicRadius R (n + 1) : ℝ)) := by
            rw [hhalf]
            ring
          _ ≤ 2 * ∫ x in (dyadicRadius R (n + 2) : ℝ)..
                (dyadicRadius R (n + 1) : ℝ),
              finiteCoverEntropy (T := T) x :=
            mul_le_mul_of_nonneg_left hle (by norm_num)
      calc
        (∑ k ∈ Finset.range n,
            (dyadicRadius R (k + 1) : ℝ) *
              finiteCoverEntropy (T := T) (dyadicRadius R (k + 1) : ℝ)) +
            (dyadicRadius R (n + 1) : ℝ) *
              finiteCoverEntropy (T := T) (dyadicRadius R (n + 1) : ℝ) ≤
            2 * (∫ x in (dyadicRadius R (n + 1) : ℝ)..
                (dyadicRadius R 1 : ℝ), finiteCoverEntropy (T := T) x) +
              2 * (∫ x in (dyadicRadius R (n + 2) : ℝ)..
                (dyadicRadius R (n + 1) : ℝ), finiteCoverEntropy (T := T) x) :=
          add_le_add ih' hshell
        _ = 2 * (∫ x in (dyadicRadius R (n + 2) : ℝ)..
              (dyadicRadius R 1 : ℝ), finiteCoverEntropy (T := T) x) := by
          rw [← mul_add]
          congr 1
          rw [add_comm]
          exact intervalIntegral.integral_add_adjacent_intervals
            (finiteCoverEntropy_antitone (T := T) |>.intervalIntegrable)
            (finiteCoverEntropy_antitone (T := T) |>.intervalIntegrable)

omit [Fintype T] in
/-- The reverse Riemann-sum comparison missing from the original helper API.
For a decreasing entropy profile, each shell integral is bounded above by its
left-endpoint dyadic rectangle.

**Lean implementation helper.** -/
lemma finiteDudleyEntropyIntegral_segment_le_sum [Finite T]
    (R : ℝ≥0) (steps : ℕ) :
    (∫ x in (dyadicRadius R steps : ℝ)..(R : ℝ),
        finiteCoverEntropy (T := T) x) ≤
      finiteDyadicEntropySum (T := T) R steps := by
  induction steps with
  | zero => simp [finiteDyadicEntropySum]
  | succ n ih =>
      rw [finiteDyadicEntropySum, Finset.sum_range_succ]
      have hrad : (dyadicRadius R (n + 1) : ℝ) ≤
          (dyadicRadius R n : ℝ) := by
        exact_mod_cast dyadicRadius_antitone R (Nat.le_succ n)
      have hint : IntervalIntegrable (finiteCoverEntropy (T := T)) volume
          (dyadicRadius R (n + 1) : ℝ) (dyadicRadius R n : ℝ) :=
        finiteCoverEntropy_antitone (T := T) |>.intervalIntegrable
      have hconst : IntervalIntegrable
          (fun _ : ℝ => finiteCoverEntropy (T := T)
            (dyadicRadius R (n + 1) : ℝ)) volume
          (dyadicRadius R (n + 1) : ℝ) (dyadicRadius R n : ℝ) := by
        simp
      have hmono : ∀ x ∈ Set.Icc (dyadicRadius R (n + 1) : ℝ)
          (dyadicRadius R n : ℝ),
          finiteCoverEntropy (T := T) x ≤
            finiteCoverEntropy (T := T) (dyadicRadius R (n + 1) : ℝ) := by
        intro x hx
        exact finiteCoverEntropy_antitone (T := T) hx.1
      have hshell := intervalIntegral.integral_mono_on hrad hint hconst hmono
      rw [intervalIntegral.integral_const] at hshell
      have hlength : (dyadicRadius R n : ℝ) -
            (dyadicRadius R (n + 1) : ℝ) =
          (dyadicRadius R (n + 1) : ℝ) := by
        rw [dyadicRadius_succ]
        push_cast
        ring
      rw [hlength] at hshell
      calc
        (∫ x in (dyadicRadius R (n + 1) : ℝ)..(R : ℝ),
            finiteCoverEntropy (T := T) x) =
            (∫ x in (dyadicRadius R (n + 1) : ℝ)..
                (dyadicRadius R n : ℝ), finiteCoverEntropy (T := T) x) +
              ∫ x in (dyadicRadius R n : ℝ)..(R : ℝ),
                finiteCoverEntropy (T := T) x :=
          (intervalIntegral.integral_add_adjacent_intervals
            (finiteCoverEntropy_antitone (T := T) |>.intervalIntegrable)
            (finiteCoverEntropy_antitone (T := T) |>.intervalIntegrable)).symm
        _ ≤ (dyadicRadius R (n + 1) : ℝ) *
              finiteCoverEntropy (T := T) (dyadicRadius R (n + 1) : ℝ) +
            finiteDyadicEntropySum (T := T) R n := add_le_add hshell ih
        _ = finiteDyadicEntropySum (T := T) R n +
            (dyadicRadius R (n + 1) : ℝ) *
              finiteCoverEntropy (T := T) (dyadicRadius R (n + 1) : ℝ) :=
          add_comm _ _

omit [Fintype T] in
/-- Discrete Dudley entropy sum is equivalent to the entropy integral. Exact finite covering-number form. This is the source's dyadic-sum/integral equivalence with explicit constants,
stated on the finite truncations used by the formal Dudley proof. The lower
integral stops at the last dyadic radius; the upper integral includes the one
additional shell. Hence both converge to the same integral over `(0,R]` as
the truncation tends to infinity. Unlike
`exercise_8_3_dudleySumIntegral_equiv`, this theorem is about the actual
Mathlib covering numbers of the metric space, not caller-supplied shell data.

**Book Exercise 8.3.** -/
theorem exercise_8_3_dudleyCoveringSumIntegral_equiv [Finite T]
    (R : ℝ≥0) (steps : ℕ) :
    (∫ x in (dyadicRadius R steps : ℝ)..(R : ℝ),
        finiteCoverEntropy (T := T) x) ≤
        finiteDyadicEntropySum (T := T) R steps ∧
      finiteDyadicEntropySum (T := T) R steps ≤
        2 * ∫ x in (dyadicRadius R (steps + 1) : ℝ)..(R : ℝ),
          finiteCoverEntropy (T := T) x := by
  constructor
  · exact finiteDudleyEntropyIntegral_segment_le_sum R steps
  · have hsum := finiteDyadicEntropySum_le_integral (T := T) R steps
    have hR1 : (dyadicRadius R 1 : ℝ) ≤ (R : ℝ) := by
      rw [dyadicRadius_succ, dyadicRadius_zero]
      exact div_le_self (NNReal.coe_nonneg _) (by norm_num)
    have hlow : (dyadicRadius R (steps + 1) : ℝ) ≤
        (dyadicRadius R 1 : ℝ) := by
      exact_mod_cast dyadicRadius_antitone R (by omega : 1 ≤ steps + 1)
    have hmono : (∫ x in (dyadicRadius R (steps + 1) : ℝ)..
          (dyadicRadius R 1 : ℝ), finiteCoverEntropy (T := T) x) ≤
        ∫ x in (dyadicRadius R (steps + 1) : ℝ)..(R : ℝ),
          finiteCoverEntropy (T := T) x := by
      apply intervalIntegral.integral_mono_interval le_rfl hlow hR1
      · exact Filter.Eventually.of_forall fun x =>
          finiteCoverEntropy_nonneg (T := T) x
      · exact finiteCoverEntropy_antitone (T := T) |>.intervalIntegrable
    exact hsum.trans (mul_le_mul_of_nonneg_left hmono (by norm_num))

section ProbabilisticEndpoints

variable {Ω : Type*} {mΩ : MeasurableSpace Ω} {μ : Measure Ω}

/-- Discrete Dudley bounds the expected supremum by a dyadic entropy sum. Exact finite dyadic covering-number form. The chain is constructed from Mathlib's cardinality-minimizing internal
covers. `hfine` says that the last positive dyadic scale separates the finite
metric space, so the final level is exact.

**Book Theorem 8.1.4.** -/
theorem discreteDudleyInequality_coveringNumber [IsProbabilityMeasure μ]
    (R : ℝ≥0) (steps : ℕ)
    (X : HDP.RandomProcess T Ω) (hXm : ∀ t, Measurable (X t))
    (hXint : ∀ t, Integrable (X t) μ) (hcenter : HDP.IsCenteredProcess X μ)
    {K : ℝ} (hinc : HDP.HasSubGaussianIncrementsWith X μ dist K)
    (hcoarse : finiteCoverCard (T := T) R = 1)
    (hfine : finiteCoverCard (T := T) (dyadicRadius R (steps + 1)) =
      Fintype.card T)
    (hdiam : Metric.diam (Set.univ : Set T) ≤ (R : ℝ)) :
    ∫ ω, finiteProcessSup X ω ∂μ ≤
      24 * K * finiteDyadicEntropySum (T := T) R (steps + 1) := by
  have hchain := dudleyIntegralInequality_of_subGaussianIncrements
    (optimalDyadicChain (T := T) R steps) X hXm hXint hcenter dist
      (fun _ _ => dist_nonneg) hinc
  have hentropy := optimalDyadicActualEntropySum_le (T := T) R steps
    hcoarse hfine hdiam
  calc
    (∫ ω, finiteProcessSup X ω ∂μ) ≤
        2 * K * dudleyActualEntropySum
          (optimalDyadicChain (T := T) R steps) dist := hchain
    _ ≤ 2 * K * (12 * finiteDyadicEntropySum (T := T) R (steps + 1)) :=
      mul_le_mul_of_nonneg_left hentropy (mul_nonneg (by norm_num) hinc.1)
    _ = 24 * K * finiteDyadicEntropySum (T := T) R (steps + 1) := by ring

/-- The finite covering-entropy integral over `[0,R]`.

**Lean implementation helper.** -/
def finiteDudleyEntropyIntegral (R : ℝ≥0) : ℝ :=
  ∫ x in (0 : ℝ)..(R : ℝ), finiteCoverEntropy (T := T) x

/-- Dudley bounds the expected supremum of a centered subgaussian-increment process by the entropy integral. Exact finite covering-number integral form.

**Book Theorem 8.1.3.** -/
theorem dudleyIntegralInequality_coveringNumber [IsProbabilityMeasure μ]
    (R : ℝ≥0) (steps : ℕ)
    (X : HDP.RandomProcess T Ω) (hXm : ∀ t, Measurable (X t))
    (hXint : ∀ t, Integrable (X t) μ) (hcenter : HDP.IsCenteredProcess X μ)
    {K : ℝ} (hinc : HDP.HasSubGaussianIncrementsWith X μ dist K)
    (hcoarse : finiteCoverCard (T := T) R = 1)
    (hfine : finiteCoverCard (T := T) (dyadicRadius R (steps + 1)) =
      Fintype.card T)
    (hdiam : Metric.diam (Set.univ : Set T) ≤ (R : ℝ)) :
    ∫ ω, finiteProcessSup X ω ∂μ ≤
      48 * K * finiteDudleyEntropyIntegral (T := T) R := by
  have hdisc := discreteDudleyInequality_coveringNumber (T := T) R steps X
    hXm hXint hcenter hinc hcoarse hfine hdiam
  have hsum := finiteDyadicEntropySum_le_integral (T := T) R (steps + 1)
  have hlower : (0 : ℝ) ≤ (dyadicRadius R (steps + 2) : ℝ) := NNReal.coe_nonneg _
  have hmid : (dyadicRadius R 1 : ℝ) ≤ (R : ℝ) := by
    rw [dyadicRadius_succ, dyadicRadius_zero]
    exact div_le_self (NNReal.coe_nonneg _) (by norm_num)
  have hinterval :
      (∫ x in (dyadicRadius R (steps + 2) : ℝ)..(dyadicRadius R 1 : ℝ),
        finiteCoverEntropy (T := T) x) ≤ finiteDudleyEntropyIntegral (T := T) R := by
    apply intervalIntegral.integral_mono_interval hlower
    · exact_mod_cast dyadicRadius_antitone R (by omega : 1 ≤ steps + 2)
    · exact hmid
    · exact Filter.Eventually.of_forall fun x => finiteCoverEntropy_nonneg (T := T) x
    · exact finiteCoverEntropy_antitone (T := T) |>.intervalIntegrable
  calc
    (∫ ω, finiteProcessSup X ω ∂μ) ≤
        24 * K * finiteDyadicEntropySum (T := T) R (steps + 1) := hdisc
    _ ≤ 24 * K * (2 * ∫ x in (dyadicRadius R (steps + 2) : ℝ)..
        (dyadicRadius R 1 : ℝ), finiteCoverEntropy (T := T) x) :=
      mul_le_mul_of_nonneg_left hsum (mul_nonneg (by norm_num) hinc.1)
    _ ≤ 24 * K * (2 * finiteDudleyEntropyIntegral (T := T) R) := by
      exact mul_le_mul_of_nonneg_left
        (mul_le_mul_of_nonneg_left hinterval (by norm_num))
        (mul_nonneg (by norm_num) hinc.1)
    _ = 48 * K * finiteDudleyEntropyIntegral (T := T) R := by ring

/-! ## High-probability scale bounds derived from the increment hypothesis -/

omit [Fintype T] [Nonempty T] [PseudoMetricSpace T] in
/-- Chapter 2's subgaussian tail estimate for one ordered process increment.
The deliberately generous factor `8` makes the statement uniform, including
the zero-distance branch.

**Lean implementation helper.** -/
theorem processIncrement_tail_of_subGaussianIncrements
    [IsProbabilityMeasure μ]
    (X : HDP.RandomProcess T Ω) (hXm : ∀ t, Measurable (X t))
    (d : T → T → ℝ) (hd : ∀ s t, 0 ≤ d s t)
    {K u : ℝ} (hK : 0 < K) (hu : 0 ≤ u)
    (hinc : HDP.HasSubGaussianIncrementsWith X μ d K)
    (p : T × T) :
    μ {ω | 8 * K * u * d p.1 p.2 < |X p.1 ω - X p.2 ω|} ≤
      ENNReal.ofReal (2 * Real.exp (-(8 * u) ^ 2)) := by
  let Y : Ω → ℝ := fun ω => X p.1 ω - X p.2 ω
  have hYm : Measurable Y := (hXm p.1).sub (hXm p.2)
  by_cases hp0 : d p.1 p.2 = 0
  · have hsub : HDP.SubGaussian Y μ := (hinc.2 p.2 p.1).1
    have hpsi : HDP.psi2Norm Y μ = 0 := by
      apply le_antisymm
      · exact (hinc.2 p.2 p.1).2.trans_eq (by simp [hp0])
      · exact HDP.psi2Norm_nonneg _ _
    have hae : Y =ᵐ[μ] 0 :=
      (HDP.psi2Norm_eq_zero_iff hYm.aemeasurable hsub).mp hpsi
    have hz :
        μ {ω | 8 * K * u * d p.1 p.2 < |X p.1 ω - X p.2 ω|} = 0 := by
      apply measure_mono_null (t := {ω | Y ω ≠ 0})
      · intro ω hω
        simp only [Set.mem_setOf_eq, hp0, mul_zero, abs_pos] at hω
        exact hω
      · rw [measure_eq_zero_iff_ae_notMem]
        filter_upwards [hae] with ω hω
        simp [Y, hω]
    rw [hz]
    exact bot_le
  · have hdp : 0 < d p.1 p.2 := lt_of_le_of_ne (hd _ _) (Ne.symm hp0)
    have hKd : 0 < K * d p.1 p.2 := mul_pos hK hdp
    have hmgf := HDP.psi2MGF_le_two_of_ge hYm.aemeasurable
      (hinc.2 p.2 p.1).1 (hinc.2 p.2 p.1).2 hKd
    have htail := HDP.subgaussian_iii_to_i hYm.aemeasurable hKd hmgf
      (show 0 ≤ 8 * K * u * d p.1 p.2 by positivity)
    refine (measure_mono (show
      {ω | 8 * K * u * d p.1 p.2 < |X p.1 ω - X p.2 ω|} ⊆
        {ω | 8 * K * u * d p.1 p.2 ≤ |Y ω|} by
          intro ω hω
          change 8 * K * u * d p.1 p.2 < |X p.1 ω - X p.2 ω| at hω
          change 8 * K * u * d p.1 p.2 ≤ |Y ω|
          exact hω.le)).trans ?_
    convert htail using 1
    · congr 3
    · field_simp [hK.ne', hp0]

omit [PseudoMetricSpace T] in
/-- A scale maximum exceeds a threshold only if one of its distinct adjacent
projection pairs does.

**Lean implementation helper.** -/
theorem dudleyScaleSup_bad_subset_pairUnion {chainSteps : ℕ}
    (C : FiniteDudleyChain T chainSteps) (X : HDP.RandomProcess T Ω)
    (k : ℕ) (a : ℝ) :
    {ω | a < dudleyScaleSup C X k ω} ⊆
      ⋃ p ∈ dudleyScalePairs C k,
        {ω | a < |X p.1 ω - X p.2 ω|} := by
  intro ω hω
  change a < dudleyScaleSup C X k ω at hω
  rw [dudleyScaleSup_eq_pairSup] at hω
  obtain ⟨p, hp, heq⟩ := Finset.exists_mem_eq_sup'
    (dudleyScalePairs_nonempty C k) (fun p => |X p.1 ω - X p.2 ω|)
  have hpa : a < |X p.1 ω - X p.2 ω| := by
    rw [← heq]
    exact hω
  exact Set.mem_iUnion_of_mem p (Set.mem_iUnion_of_mem hp hpa)

omit [PseudoMetricSpace T] in
/-- The one-scale high-probability estimate used in Exercise 8.1, proved
directly from the subgaussian-increment hypothesis. There is no caller-
supplied tail certificate.

**Book Exercise 8.1.** -/
theorem measure_dudleyScaleSup_gt_of_subGaussianIncrements
    [IsProbabilityMeasure μ] {chainSteps : ℕ}
    (C : FiniteDudleyChain T chainSteps)
    (X : HDP.RandomProcess T Ω) (hXm : ∀ t, Measurable (X t))
    (d : T → T → ℝ) (hd : ∀ s t, 0 ≤ d s t)
    {K u : ℝ} (hK : 0 < K) (hu : 0 ≤ u)
    (hinc : HDP.HasSubGaussianIncrementsWith X μ d K) (k : ℕ) :
    μ {ω | 8 * K * u * dudleyScaleRadius C d k < dudleyScaleSup C X k ω} ≤
      ENNReal.ofReal
        ((dudleyScaleCard C k : ℝ) * (2 * Real.exp (-(8 * u) ^ 2))) := by
  let q : ℝ := 2 * Real.exp (-(8 * u) ^ 2)
  have hq0 : 0 ≤ q := by positivity
  calc
    μ {ω | 8 * K * u * dudleyScaleRadius C d k < dudleyScaleSup C X k ω} ≤
        μ (⋃ p ∈ dudleyScalePairs C k,
          {ω | 8 * K * u * dudleyScaleRadius C d k <
            |X p.1 ω - X p.2 ω|}) :=
      measure_mono (dudleyScaleSup_bad_subset_pairUnion C X k _)
    _ ≤ ∑ p ∈ dudleyScalePairs C k,
        μ {ω | 8 * K * u * dudleyScaleRadius C d k <
          |X p.1 ω - X p.2 ω|} := measure_biUnion_finset_le _ _
    _ ≤ ∑ _p ∈ dudleyScalePairs C k, ENNReal.ofReal q := by
      apply Finset.sum_le_sum
      intro p hp
      have hdist := pair_distance_le_dudleyScaleRadius C d k hp
      have hcoef : 0 ≤ 8 * K * u := by positivity
      have hthreshold :
          8 * K * u * d p.1 p.2 ≤
            8 * K * u * dudleyScaleRadius C d k :=
        mul_le_mul_of_nonneg_left hdist hcoef
      calc
        μ {ω | 8 * K * u * dudleyScaleRadius C d k <
              |X p.1 ω - X p.2 ω|} ≤
            μ {ω | 8 * K * u * d p.1 p.2 <
              |X p.1 ω - X p.2 ω|} := by
          apply measure_mono
          intro ω hω
          exact hthreshold.trans_lt hω
        _ ≤ ENNReal.ofReal q :=
          processIncrement_tail_of_subGaussianIncrements X hXm d hd hK hu hinc p
    _ = ENNReal.ofReal
        ((dudleyScaleCard C k : ℝ) * q) := by
      rw [← ENNReal.ofReal_sum_of_nonneg (fun _ _ => hq0)]
      simp [q, dudleyScaleCard]
    _ = ENNReal.ofReal
        ((dudleyScaleCard C k : ℝ) *
          (2 * Real.exp (-(8 * u) ^ 2))) := by rfl

omit [PseudoMetricSpace T] in
/-- Exact finite-chain high-probability form derived
from `HasSubGaussianIncrementsWith`. The sequence `z` is the source's choice
of scale deviations; unlike the older reusable union-bound wrapper, this
theorem has no probabilistic scale assumptions.

**Book Exercise 8.1.** -/
theorem exercise_8_1_highProbabilityDudley_of_subGaussianIncrements
    [IsProbabilityMeasure μ] {chainSteps : ℕ}
    (C : FiniteDudleyChain T chainSteps)
    (X : HDP.RandomProcess T Ω) (hXm : ∀ t, Measurable (X t))
    (d : T → T → ℝ) (hd : ∀ s t, 0 ≤ d s t)
    {K : ℝ} (hK : 0 < K)
    (hinc : HDP.HasSubGaussianIncrementsWith X μ d K)
    (z : ℕ → ℝ) (hz : ∀ k ∈ Finset.range chainSteps, 0 ≤ z k) :
    μ {ω | 16 * K *
          (∑ k ∈ Finset.range chainSteps,
            z k * dudleyScaleRadius C d k) <
        finiteProcessOscillation X ω} ≤
      ∑ k ∈ Finset.range chainSteps,
        ENNReal.ofReal ((dudleyScaleCard C k : ℝ) *
          (2 * Real.exp (-(8 * z k) ^ 2))) := by
  let threshold : ℕ → ℝ := fun k =>
    8 * K * z k * dudleyScaleRadius C d k
  have htail : ∀ k ∈ Finset.range chainSteps,
      μ {ω | threshold k < dudleyScaleSup C X k ω} ≤
        ENNReal.ofReal ((dudleyScaleCard C k : ℝ) *
          (2 * Real.exp (-(8 * z k) ^ 2))) := by
    intro k hk
    exact measure_dudleyScaleSup_gt_of_subGaussianIncrements
      C X hXm d hd hK (hz k hk) hinc k
  have h := dudleyHighProbabilityBound C X threshold
    (fun k => ENNReal.ofReal ((dudleyScaleCard C k : ℝ) *
      (2 * Real.exp (-(8 * z k) ^ 2)))) htail
  have hevent :
      {ω | 16 * K *
          (∑ k ∈ Finset.range chainSteps,
            z k * dudleyScaleRadius C d k) <
          finiteProcessOscillation X ω} =
        {ω | 2 * (∑ k ∈ Finset.range chainSteps, threshold k) <
          finiteProcessOscillation X ω} := by
    have hleft : 16 * K *
          (∑ k ∈ Finset.range chainSteps,
            z k * dudleyScaleRadius C d k) =
        2 * (∑ k ∈ Finset.range chainSteps, threshold k) := by
      simp only [threshold]
      rw [Finset.mul_sum, Finset.mul_sum]
      apply Finset.sum_congr rfl
      intro k hk
      ring
    ext ω
    simp only [Set.mem_setOf_eq, threshold]
    rw [hleft]
  rw [hevent]
  exact h

/-! ### Summable scale deviations and the source-facing endpoint -/

/-- The sum of the positive dyadic radii through any finite scale is at most the initial radius.

**Lean implementation helper.** -/
lemma sum_dyadicRadius_le (R : ℝ≥0) (m : ℕ) :
    (∑ k ∈ Finset.range m, (dyadicRadius R (k + 1) : ℝ)) ≤ (R : ℝ) := by
  have hs : Summable (fun k : ℕ => (R : ℝ) / 2 / 2 ^ k) :=
    summable_geometric_two' (R : ℝ)
  calc
    (∑ k ∈ Finset.range m, (dyadicRadius R (k + 1) : ℝ)) =
        ∑ k ∈ Finset.range m, (R : ℝ) / 2 / 2 ^ k := by
      apply Finset.sum_congr rfl
      intro k _hk
      simp only [dyadicRadius, NNReal.coe_div, pow_succ]
      norm_num [Nat.cast_pow]
      ring
    _ ≤ ∑' k : ℕ, (R : ℝ) / 2 / 2 ^ k := by
      exact hs.sum_le_tsum (Finset.range m) (fun k hk => by positivity)
    _ = (R : ℝ) := tsum_geometric_two' (R : ℝ)

/-- The weighted dyadic-radius sum has the closed form `R · (2 - (m + 2) / 2^m)`.

**Lean implementation helper.** -/
lemma sum_weighted_dyadicRadius_eq (R : ℝ≥0) (m : ℕ) :
    (∑ k ∈ Finset.range m,
        ((k + 1 : ℕ) : ℝ) * (dyadicRadius R (k + 1) : ℝ)) =
      (R : ℝ) * (2 - ((m + 2 : ℕ) : ℝ) / 2 ^ m) := by
  induction m with
  | zero => simp
  | succ m ih =>
      rw [Finset.sum_range_succ, ih]
      simp only [dyadicRadius, NNReal.coe_div, Nat.cast_add, Nat.cast_one, pow_succ]
      norm_num [Nat.cast_pow]
      ring

/-- The weighted dyadic-radius sum is at most twice the initial radius.

**Lean implementation helper.** -/
lemma sum_weighted_dyadicRadius_le (R : ℝ≥0) (m : ℕ) :
    (∑ k ∈ Finset.range m,
        ((k + 1 : ℕ) : ℝ) * (dyadicRadius R (k + 1) : ℝ)) ≤
      2 * (R : ℝ) := by
  rw [sum_weighted_dyadicRadius_eq]
  have hR : 0 ≤ (R : ℝ) := NNReal.coe_nonneg _
  have hq : 0 ≤ (((m + 2 : ℕ) : ℝ) / 2 ^ m) := by positivity
  nlinarith

omit [PseudoMetricSpace T] in
/-- Shows that the number of adjacent pairs at a chaining scale is strictly positive.

**Lean implementation helper.** -/
lemma dudleyScaleCard_pos {steps : ℕ} (C : FiniteDudleyChain T steps) (k : ℕ) :
    0 < dudleyScaleCard C k := by
  exact Finset.card_pos.mpr (dudleyScalePairs_nonempty C k)

omit [PseudoMetricSpace T] in
/-- The source's scale choice `z_k`: entropy, the requested deviation `u`,
and a summable linear scale penalty.

**Lean implementation helper.** -/
def highProbabilityDyadicDeviation {steps : ℕ}
    (C : FiniteDudleyChain T steps) (u : ℝ) (k : ℕ) : ℝ :=
  (Real.sqrt (Real.log (dudleyScaleCard C k : ℝ)) + u + (k + 1 : ℕ)) / 8

omit [PseudoMetricSpace T] in
/-- Shows that the dyadic deviation threshold is nonnegative.

**Lean implementation helper.** -/
lemma highProbabilityDyadicDeviation_nonneg {steps : ℕ}
    (C : FiniteDudleyChain T steps) {u : ℝ} (hu : 0 ≤ u) (k : ℕ) :
    0 ≤ highProbabilityDyadicDeviation C u k := by
  have hM : (1 : ℝ) ≤ dudleyScaleCard C k := by
    exact_mod_cast dudleyScaleCard_pos C k
  have hlog : 0 ≤ Real.log (dudleyScaleCard C k : ℝ) := Real.log_nonneg hM
  unfold highProbabilityDyadicDeviation
  positivity

/-- The elementary estimate `exp(-1) ≤ 1/2` holds.

**Lean implementation helper.** -/
lemma exp_neg_one_le_half : Real.exp (-1) ≤ (1 / 2 : ℝ) := by
  rw [Real.exp_neg]
  have he : (2 : ℝ) ≤ Real.exp 1 := by
    nlinarith [Real.add_one_le_exp 1]
  rw [le_div_iff₀ (by norm_num : (0 : ℝ) < 2)]
  exact (inv_mul_le_one₀ (Real.exp_pos 1)).2 he

/-- For every natural number `m`, `exp(-m) ≤ 2⁻ᵐ`.

**Lean implementation helper.** -/
lemma exp_neg_nat_le_inv_two_pow (m : ℕ) :
    Real.exp (-(m : ℝ)) ≤ (1 / 2 : ℝ) ^ m := by
  rw [show -(m : ℝ) = (m : ℝ) * (-1 : ℝ) by ring, Real.exp_nat_mul]
  exact pow_le_pow_left₀ (Real.exp_pos (-1)).le exp_neg_one_le_half m

omit [PseudoMetricSpace T] in
/-- At scale `k`, the cardinality-weighted subgaussian tail is at most `2 exp(-u²) / 2^(k+1)`.

**Lean implementation helper.** -/
lemma highProbabilityDyadicDeviation_tail {steps : ℕ}
    (C : FiniteDudleyChain T steps) {u : ℝ} (hu : 0 ≤ u) (k : ℕ) :
    (dudleyScaleCard C k : ℝ) *
        (2 * Real.exp (-(8 * highProbabilityDyadicDeviation C u k) ^ 2)) ≤
      (2 * Real.exp (-u ^ 2)) / 2 ^ (k + 1) := by
  let M := dudleyScaleCard C k
  have hMnat : 0 < M := dudleyScaleCard_pos C k
  have hM : (0 : ℝ) < M := by exact_mod_cast hMnat
  have hMone : (1 : ℝ) ≤ M := by
    have hMoneNat : 1 ≤ M := hMnat
    exact_mod_cast hMoneNat
  have hlog : 0 ≤ Real.log (M : ℝ) := Real.log_nonneg hMone
  have hsqrt := Real.sq_sqrt hlog
  have hsqrtnonneg := Real.sqrt_nonneg (Real.log (M : ℝ))
  have hk : (1 : ℝ) ≤ (k + 1 : ℕ) := by norm_num
  have hsq : Real.log (M : ℝ) + u ^ 2 + (k + 1 : ℕ) ≤
      (8 * highProbabilityDyadicDeviation C u k) ^ 2 := by
    unfold highProbabilityDyadicDeviation
    change Real.log (M : ℝ) + u ^ 2 + (k + 1 : ℕ) ≤
      (8 * ((Real.sqrt (Real.log (M : ℝ)) + u + (k + 1 : ℕ)) / 8)) ^ 2
    nlinarith [sq_nonneg (u + (k + 1 : ℕ)),
      sq_nonneg (Real.sqrt (Real.log (M : ℝ)) + u)]
  have hexp : Real.exp (-(8 * highProbabilityDyadicDeviation C u k) ^ 2) ≤
      Real.exp (-(Real.log (M : ℝ) + u ^ 2 + (k + 1 : ℕ))) := by
    rw [Real.exp_le_exp]
    linarith
  have hcancel : (M : ℝ) * Real.exp (-Real.log (M : ℝ)) = 1 := by
    rw [Real.exp_neg, Real.exp_log hM]
    field_simp
  have hfactor :
      Real.exp (-(Real.log (M : ℝ) + u ^ 2 + (k + 1 : ℕ))) =
        Real.exp (-Real.log (M : ℝ)) * Real.exp (-u ^ 2) *
          Real.exp (-(k + 1 : ℕ)) := by
    rw [show -(Real.log (M : ℝ) + u ^ 2 + (k + 1 : ℕ)) =
      -Real.log (M : ℝ) + (-u ^ 2) + (-(k + 1 : ℕ) : ℝ) by ring,
      Real.exp_add, Real.exp_add]
  have hkexp := exp_neg_nat_le_inv_two_pow (k + 1)
  calc
    (M : ℝ) *
        (2 * Real.exp (-(8 * highProbabilityDyadicDeviation C u k) ^ 2)) ≤
        (M : ℝ) * (2 *
          Real.exp (-(Real.log (M : ℝ) + u ^ 2 + (k + 1 : ℕ)))) := by
      gcongr
    _ = 2 * Real.exp (-u ^ 2) * Real.exp (-(k + 1 : ℕ)) := by
      rw [hfactor]
      calc
        (M : ℝ) * (2 * (Real.exp (-Real.log (M : ℝ)) * Real.exp (-u ^ 2) *
            Real.exp (-(k + 1 : ℕ)))) =
            2 * Real.exp (-u ^ 2) * Real.exp (-(k + 1 : ℕ)) *
              ((M : ℝ) * Real.exp (-Real.log (M : ℝ))) := by ring
        _ = 2 * Real.exp (-u ^ 2) * Real.exp (-(k + 1 : ℕ)) := by
          rw [hcancel]
          ring
    _ ≤ 2 * Real.exp (-u ^ 2) * (1 / 2 : ℝ) ^ (k + 1) := by
      gcongr
    _ = (2 * Real.exp (-u ^ 2)) / 2 ^ (k + 1) := by
      rw [one_div_pow]
      ring

/-- For `A ≥ 0`, every finite sum of `A / 2^(k+1)` is at most `A`.

**Lean implementation helper.** -/
lemma sum_div_two_pow_succ_le (A : ℝ) (hA : 0 ≤ A) (m : ℕ) :
    (∑ k ∈ Finset.range m, A / 2 ^ (k + 1)) ≤ A := by
  have hs : Summable (fun k : ℕ => A / 2 / 2 ^ k) :=
    summable_geometric_two' A
  calc
    (∑ k ∈ Finset.range m, A / 2 ^ (k + 1)) =
        ∑ k ∈ Finset.range m, A / 2 / 2 ^ k := by
      apply Finset.sum_congr rfl
      intro k _hk
      rw [pow_succ]
      ring
    _ ≤ ∑' k : ℕ, A / 2 / 2 ^ k := by
      exact hs.sum_le_tsum (Finset.range m) (fun k hk => by positivity)
    _ = A := tsum_geometric_two' A

omit [PseudoMetricSpace T] in
/-- The sum of all scale-wise failure bounds is at most `2 exp(-u²)`.

**Lean implementation helper.** -/
lemma highProbabilityFailureSum_le {steps : ℕ}
    (C : FiniteDudleyChain T steps) {u : ℝ} (hu : 0 ≤ u) :
    (∑ k ∈ Finset.range steps,
        ENNReal.ofReal ((dudleyScaleCard C k : ℝ) *
          (2 * Real.exp (-(8 * highProbabilityDyadicDeviation C u k) ^ 2)))) ≤
      ENNReal.ofReal (2 * Real.exp (-u ^ 2)) := by
  let A : ℝ := 2 * Real.exp (-u ^ 2)
  have hA : 0 ≤ A := by positivity
  calc
    (∑ k ∈ Finset.range steps,
        ENNReal.ofReal ((dudleyScaleCard C k : ℝ) *
          (2 * Real.exp (-(8 * highProbabilityDyadicDeviation C u k) ^ 2)))) ≤
        ∑ k ∈ Finset.range steps, ENNReal.ofReal (A / 2 ^ (k + 1)) := by
      apply Finset.sum_le_sum
      intro k _hk
      exact ENNReal.ofReal_le_ofReal
        (by simpa [A] using highProbabilityDyadicDeviation_tail C hu k)
    _ = ENNReal.ofReal (∑ k ∈ Finset.range steps, A / 2 ^ (k + 1)) := by
      rw [ENNReal.ofReal_sum_of_nonneg]
      intro k hk
      positivity
    _ ≤ ENNReal.ofReal A :=
      ENNReal.ofReal_le_ofReal (sum_div_two_pow_succ_le A hA steps)
    _ = ENNReal.ofReal (2 * Real.exp (-u ^ 2)) := rfl

omit [PseudoMetricSpace T] in
/-- The radius-weighted sum of `√log` scale cardinalities is bounded by the chain's actual entropy sum.

**Lean implementation helper.** -/
lemma sqrt_log_scaleCard_sum_le_actual {steps : ℕ}
    (C : FiniteDudleyChain T steps) (d : T → T → ℝ)
    (hd : ∀ s t, 0 ≤ d s t) :
    (∑ k ∈ Finset.range steps,
        Real.sqrt (Real.log (dudleyScaleCard C k : ℝ)) *
          dudleyScaleRadius C d k) ≤
      dudleyActualEntropySum C d := by
  unfold dudleyActualEntropySum
  apply Finset.sum_le_sum
  intro k _hk
  have hMnat : 0 < dudleyScaleCard C k := dudleyScaleCard_pos C k
  have hM : (0 : ℝ) < dudleyScaleCard C k := by exact_mod_cast hMnat
  have harg : (dudleyScaleCard C k : ℝ) ≤
      (dudleyScaleCard C k : ℝ) + 2 := by linarith
  have hlog := Real.log_le_log hM harg
  have hsqrt := Real.sqrt_le_sqrt hlog
  exact mul_le_mul_of_nonneg_right hsqrt
    (dudleyScaleRadius_nonneg C d hd k)

/-- The sum of the optimal-chain scale radii is at most six times the ambient radius.

**Lean implementation helper.** -/
lemma optimalDyadicRadiusSum_le (R : ℝ≥0) (steps : ℕ)
    (hdiam : Metric.diam (Set.univ : Set T) ≤ (R : ℝ)) :
    (∑ k ∈ Finset.range (steps + 1),
        dudleyScaleRadius (optimalDyadicChain (T := T) R steps) dist k) ≤
      6 * (R : ℝ) := by
  calc
    (∑ k ∈ Finset.range (steps + 1),
        dudleyScaleRadius (optimalDyadicChain (T := T) R steps) dist k) ≤
        ∑ k ∈ Finset.range (steps + 1),
          6 * (dyadicRadius R (k + 1) : ℝ) := by
      apply Finset.sum_le_sum
      intro k _hk
      exact optimalDyadicScaleRadius_le R steps k hdiam
    _ = 6 * (∑ k ∈ Finset.range (steps + 1),
        (dyadicRadius R (k + 1) : ℝ)) := by rw [Finset.mul_sum]
    _ ≤ 6 * (R : ℝ) := by
      gcongr
      exact sum_dyadicRadius_le R (steps + 1)

/-- The index-weighted sum of optimal-chain scale radii is at most twelve times the ambient radius.

**Lean implementation helper.** -/
lemma optimalDyadicWeightedRadiusSum_le (R : ℝ≥0) (steps : ℕ)
    (hdiam : Metric.diam (Set.univ : Set T) ≤ (R : ℝ)) :
    (∑ k ∈ Finset.range (steps + 1),
        ((k + 1 : ℕ) : ℝ) *
          dudleyScaleRadius (optimalDyadicChain (T := T) R steps) dist k) ≤
      12 * (R : ℝ) := by
  calc
    (∑ k ∈ Finset.range (steps + 1),
        ((k + 1 : ℕ) : ℝ) *
          dudleyScaleRadius (optimalDyadicChain (T := T) R steps) dist k) ≤
        ∑ k ∈ Finset.range (steps + 1),
          ((k + 1 : ℕ) : ℝ) * (6 * (dyadicRadius R (k + 1) : ℝ)) := by
      apply Finset.sum_le_sum
      intro k _hk
      exact mul_le_mul_of_nonneg_left
        (optimalDyadicScaleRadius_le R steps k hdiam) (by positivity)
    _ = 6 * (∑ k ∈ Finset.range (steps + 1),
        ((k + 1 : ℕ) : ℝ) * (dyadicRadius R (k + 1) : ℝ)) := by
      rw [Finset.mul_sum]
      apply Finset.sum_congr rfl
      intro k _hk
      ring
    _ ≤ 6 * (2 * (R : ℝ)) := by
      gcongr
      exact sum_weighted_dyadicRadius_le R (steps + 1)
    _ = 12 * (R : ℝ) := by ring

omit [Fintype T] [Nonempty T] in
/-- Shows that the finite Dudley entropy integral is nonnegative.

**Lean implementation helper.** -/
lemma finiteDudleyEntropyIntegral_nonneg (R : ℝ≥0) :
    0 ≤ finiteDudleyEntropyIntegral (T := T) R := by
  unfold finiteDudleyEntropyIntegral
  exact intervalIntegral.integral_nonneg (NNReal.coe_nonneg _) fun x hx =>
    finiteCoverEntropy_nonneg (T := T) x

/-- The total dyadic deviation contribution is bounded by `60` times the entropy integral plus `u` times the ambient radius.

**Lean implementation helper.** -/
lemma highProbabilityDyadicDeviationSum_le (R : ℝ≥0) (steps : ℕ) {u : ℝ}
    (hu : 1 / 2 < u)
    (hcoarse : finiteCoverCard (T := T) R = 1)
    (hfine : finiteCoverCard (T := T) (dyadicRadius R (steps + 1)) =
      Fintype.card T)
    (hdiam : Metric.diam (Set.univ : Set T) ≤ (R : ℝ)) :
    16 * (∑ k ∈ Finset.range (steps + 1),
        highProbabilityDyadicDeviation
          (optimalDyadicChain (T := T) R steps) u k *
          dudleyScaleRadius (optimalDyadicChain (T := T) R steps) dist k) ≤
      60 * (finiteDudleyEntropyIntegral (T := T) R + u * (R : ℝ)) := by
  let C := optimalDyadicChain (T := T) R steps
  let A : ℝ := ∑ k ∈ Finset.range (steps + 1),
    Real.sqrt (Real.log (dudleyScaleCard C k : ℝ)) * dudleyScaleRadius C dist k
  let B : ℝ := ∑ k ∈ Finset.range (steps + 1), dudleyScaleRadius C dist k
  let D : ℝ := ∑ k ∈ Finset.range (steps + 1),
    ((k + 1 : ℕ) : ℝ) * dudleyScaleRadius C dist k
  have hdecomp :
      (∑ k ∈ Finset.range (steps + 1),
        highProbabilityDyadicDeviation C u k * dudleyScaleRadius C dist k) =
        (A + u * B + D) / 8 := by
    calc
      (∑ k ∈ Finset.range (steps + 1),
          highProbabilityDyadicDeviation C u k * dudleyScaleRadius C dist k) =
          ∑ k ∈ Finset.range (steps + 1),
            (Real.sqrt (Real.log (dudleyScaleCard C k : ℝ)) *
                dudleyScaleRadius C dist k +
              u * dudleyScaleRadius C dist k +
              ((k + 1 : ℕ) : ℝ) * dudleyScaleRadius C dist k) / 8 := by
        apply Finset.sum_congr rfl
        intro k _hk
        unfold highProbabilityDyadicDeviation
        ring
      _ = (A + u * B + D) / 8 := by
        unfold A B D
        rw [Finset.mul_sum, ← Finset.sum_add_distrib,
          ← Finset.sum_add_distrib, ← Finset.sum_div]
  have hAactual : A ≤ dudleyActualEntropySum C dist := by
    exact sqrt_log_scaleCard_sum_le_actual C dist (fun _ _ => dist_nonneg)
  have hAdyadic : dudleyActualEntropySum C dist ≤
      12 * finiteDyadicEntropySum (T := T) R (steps + 1) := by
    exact optimalDyadicActualEntropySum_le R steps hcoarse hfine hdiam
  have hsumint := finiteDyadicEntropySum_le_integral (T := T) R (steps + 1)
  have hsegment :
      (∫ x in (dyadicRadius R (steps + 2) : ℝ)..(dyadicRadius R 1 : ℝ),
        finiteCoverEntropy (T := T) x) ≤ finiteDudleyEntropyIntegral (T := T) R := by
    have hlower : (0 : ℝ) ≤ (dyadicRadius R (steps + 2) : ℝ) := NNReal.coe_nonneg _
    have hmid : (dyadicRadius R 1 : ℝ) ≤ (R : ℝ) := by
      rw [dyadicRadius_succ, dyadicRadius_zero]
      exact div_le_self (NNReal.coe_nonneg _) (by norm_num)
    apply intervalIntegral.integral_mono_interval hlower
    · exact_mod_cast dyadicRadius_antitone R (by omega : 1 ≤ steps + 2)
    · exact hmid
    · exact Filter.Eventually.of_forall fun x => finiteCoverEntropy_nonneg (T := T) x
    · exact finiteCoverEntropy_antitone (T := T) |>.intervalIntegrable
  have hA : A ≤ 24 * finiteDudleyEntropyIntegral (T := T) R := by
    calc
      A ≤ dudleyActualEntropySum C dist := hAactual
      _ ≤ 12 * finiteDyadicEntropySum (T := T) R (steps + 1) := hAdyadic
      _ ≤ 12 * (2 * ∫ x in (dyadicRadius R (steps + 2) : ℝ)..
          (dyadicRadius R 1 : ℝ), finiteCoverEntropy (T := T) x) := by gcongr
      _ ≤ 12 * (2 * finiteDudleyEntropyIntegral (T := T) R) := by gcongr
      _ = 24 * finiteDudleyEntropyIntegral (T := T) R := by ring
  have hB : B ≤ 6 * (R : ℝ) := by
    exact optimalDyadicRadiusSum_le R steps hdiam
  have hD : D ≤ 12 * (R : ℝ) := by
    exact optimalDyadicWeightedRadiusSum_le R steps hdiam
  have hB0 : 0 ≤ B := Finset.sum_nonneg fun k hk =>
    dudleyScaleRadius_nonneg C dist (fun _ _ => dist_nonneg) k
  have hR0 : 0 ≤ (R : ℝ) := NNReal.coe_nonneg _
  have hI0 := finiteDudleyEntropyIntegral_nonneg (T := T) R
  rw [hdecomp]
  have hu0 : 0 ≤ u := by linarith
  have huB : u * B ≤ u * (6 * (R : ℝ)) := mul_le_mul_of_nonneg_left hB hu0
  nlinarith

/-- The source's final high-probability Dudley bound
for a finite metric space. The displayed `60` is an explicit universal
constant. The hypotheses on the first and last covers are exactly the finite
dyadic truncation certificate; the entropy integral is the actual Mathlib
covering-number profile, and no centering assumption is needed for the
oscillation.

**Book Exercise 8.1.** -/
theorem exercise_8_1_highProbabilityDudley_coveringNumber
    [IsProbabilityMeasure μ]
    (R : ℝ≥0) (steps : ℕ)
    (X : HDP.RandomProcess T Ω) (hXm : ∀ t, Measurable (X t))
    {K u : ℝ} (hK : 0 < K) (hu : 0 ≤ u)
    (hinc : HDP.HasSubGaussianIncrementsWith X μ dist K)
    (hcoarse : finiteCoverCard (T := T) R = 1)
    (hfine : finiteCoverCard (T := T) (dyadicRadius R (steps + 1)) =
      Fintype.card T)
    (hdiam : Metric.diam (Set.univ : Set T) ≤ (R : ℝ)) :
    μ {ω | 60 * K *
          (finiteDudleyEntropyIntegral (T := T) R + u * (R : ℝ)) <
        finiteProcessOscillation X ω} ≤
      ENNReal.ofReal (2 * Real.exp (-u ^ 2)) := by
  by_cases husmall : u ≤ 1 / 2
  · calc
      μ {ω | 60 * K *
            (finiteDudleyEntropyIntegral (T := T) R + u * (R : ℝ)) <
          finiteProcessOscillation X ω} ≤ μ (Set.univ : Set Ω) :=
        measure_mono (Set.subset_univ _)
      _ = 1 := IsProbabilityMeasure.measure_univ
      _ ≤ ENNReal.ofReal (2 * Real.exp (-u ^ 2)) := by
        apply ENNReal.one_le_ofReal.mpr
        have hexp := Real.add_one_le_exp (-u ^ 2)
        nlinarith [sq_nonneg u]
  · have huBig : 1 / 2 < u := lt_of_not_ge husmall
    let C := optimalDyadicChain (T := T) R steps
    let z : ℕ → ℝ := fun k => highProbabilityDyadicDeviation C u k
    have hz : ∀ k ∈ Finset.range (steps + 1), 0 ≤ z k := by
      intro k _hk
      exact highProbabilityDyadicDeviation_nonneg C hu k
    have hchain := exercise_8_1_highProbabilityDudley_of_subGaussianIncrements
      C X hXm dist (fun _ _ => dist_nonneg) hK hinc z hz
    have hfail := highProbabilityFailureSum_le C hu
    have hdev := highProbabilityDyadicDeviationSum_le (T := T) R steps huBig
      hcoarse hfine hdiam
    have hthreshold :
        16 * K * (∑ k ∈ Finset.range (steps + 1),
            z k * dudleyScaleRadius C dist k) ≤
          60 * K *
            (finiteDudleyEntropyIntegral (T := T) R + u * (R : ℝ)) := by
      simpa [C, z, mul_assoc, mul_comm, mul_left_comm] using
        (mul_le_mul_of_nonneg_right hdev hK.le)
    calc
      μ {ω | 60 * K *
            (finiteDudleyEntropyIntegral (T := T) R + u * (R : ℝ)) <
          finiteProcessOscillation X ω} ≤
          μ {ω | 16 * K * (∑ k ∈ Finset.range (steps + 1),
              z k * dudleyScaleRadius C dist k) <
            finiteProcessOscillation X ω} := by
        apply measure_mono
        intro ω hω
        exact hthreshold.trans_lt hω
      _ ≤ ∑ k ∈ Finset.range (steps + 1),
          ENNReal.ofReal ((dudleyScaleCard C k : ℝ) *
            (2 * Real.exp (-(8 * z k) ^ 2))) := hchain
      _ ≤ ENNReal.ofReal (2 * Real.exp (-u ^ 2)) := hfail

end ProbabilisticEndpoints

end CoveringNumberDudley

/-! ### Automatic finite-metric truncation

The source statement of Exercise 8.1 has no auxiliary truncation data.  For a
finite genuine metric space the diameter is a one-point covering scale, while
a sufficiently small dyadic radius is below half the positive separation of
distinct points.  The next lemmas construct those two certificates.
-/

section AutomaticFiniteMetricTruncation

variable {T : Type*} [Fintype T] [Nonempty T] [MetricSpace T]

/-- The real diameter of a nonempty finite metric space, bundled as an
`NNReal` radius.

**Lean implementation helper.** -/
def finiteMetricDiameter : ℝ≥0 :=
  ⟨Metric.diam (Set.univ : Set T), Metric.diam_nonneg⟩

omit [Fintype T] in
/-- One point covers the finite metric space at its full diameter.

**Lean implementation helper.** -/
lemma finiteCoverCard_finiteMetricDiameter [Finite T] :
    finiteCoverCard (T := T) (finiteMetricDiameter (T := T)) = 1 := by
  apply Nat.cast_injective (R := ℕ∞)
  rw [finiteCoverCard_coe]
  apply Metric.coveringNumber_eq_one_of_ediam_le Set.univ_nonempty
  rw [Metric.ediam_le_iff]
  intro x hx y hy
  have hd := Metric.dist_le_diam_of_mem Set.finite_univ.isBounded hx hy
  exact_mod_cast hd

omit [Nonempty T] in
/-- Below half the minimum separation, every cover must contain as many points as the whole finite space.

**Lean implementation helper.** -/
lemma finiteCoverCard_eq_card_of_two_mul_lt_infsep
    (ε : ℝ≥0) (hε : 2 * (ε : ℝ) < (Set.univ : Set T).infsep) :
    finiteCoverCard (T := T) ε = Fintype.card T := by
  have hsep : Metric.IsSeparated (2 * ε : ℝ≥0∞) (Set.univ : Set T) := by
    intro x hx y hy hxy
    have hle := Set.infsep_le_dist_of_mem hx hy hxy
    have hreal : 2 * (ε : ℝ) < dist x y := hε.trans_le hle
    rw [edist_dist]
    have hof := (ENNReal.ofReal_lt_ofReal_iff (dist_pos.mpr hxy)).2 hreal
    simpa only [ENNReal.ofReal_mul (by norm_num : (0 : ℝ) ≤ 2),
      ENNReal.ofReal_ofNat, ENNReal.ofReal_coe_nnreal] using hof
  have hlower : ((Fintype.card T : ℕ) : ℕ∞) ≤
      Metric.coveringNumber ε (Set.univ : Set T) := by
    calc
      ((Fintype.card T : ℕ) : ℕ∞) = (Set.univ : Set T).encard := by simp
      _ ≤ Metric.packingNumber (2 * ε) (Set.univ : Set T) :=
        hsep.encard_le_packingNumber (by simp)
      _ ≤ Metric.externalCoveringNumber ε (Set.univ : Set T) :=
        Metric.packingNumber_two_mul_le_externalCoveringNumber ε _
      _ ≤ Metric.coveringNumber ε (Set.univ : Set T) :=
        Metric.externalCoveringNumber_le_coveringNumber ε _
  have hupper :=
    Metric.coveringNumber_le_encard_self (ε := ε) (Set.univ : Set T)
  have hupper' : Metric.coveringNumber ε (Set.univ : Set T) ≤
      (Fintype.card T : ℕ∞) := by simpa using hupper
  have heq : (finiteCoverCard (T := T) ε : ℕ∞) =
      (Fintype.card T : ℕ∞) := by
    rw [finiteCoverCard_coe]
    exact le_antisymm hupper' hlower
  exact_mod_cast heq

omit [Nonempty T] in
/-- The minimum covering cardinality never exceeds the cardinality of the finite space.

**Lean implementation helper.** -/
lemma finiteCoverCard_le_fintypeCard (ε : ℝ≥0) :
    finiteCoverCard (T := T) ε ≤ Fintype.card T := by
  have h : (finiteCoverCard (T := T) ε : ℕ∞) ≤
      (Fintype.card T : ℕ∞) := by
    rw [finiteCoverCard_coe]
    simpa using Metric.coveringNumber_le_encard_self
      (ε := ε) (Set.univ : Set T)
  exact_mod_cast h

/-- At some sufficiently fine dyadic radius, the optimal cover contains every point of the finite space.

**Lean implementation helper.** -/
lemma exists_dyadicRadius_coverCard_eq_fintypeCard :
    ∃ steps : ℕ,
      finiteCoverCard (T := T)
          (dyadicRadius (finiteMetricDiameter (T := T)) (steps + 1)) =
        Fintype.card T := by
  by_cases hcard : Fintype.card T = 1
  · refine ⟨0, le_antisymm (finiteCoverCard_le_fintypeCard _) ?_⟩
    have hp := finiteCoverCard_pos (T := T)
      (dyadicRadius (finiteMetricDiameter (T := T)) (0 + 1))
    omega
  · have hcardgt : 1 < Fintype.card T := by
      have hpos : 0 < Fintype.card T := Fintype.card_pos
      omega
    letI : Nontrivial T := Fintype.one_lt_card_iff_nontrivial.mp hcardgt
    have hinf : 0 < (Set.univ : Set T).infsep :=
      Set.infsep_pos_iff_nontrivial_of_finite.mpr Set.nontrivial_univ
    have hD : 0 < (finiteMetricDiameter (T := T) : ℝ) := by
      obtain ⟨x, y, hxy⟩ := exists_pair_ne T
      have hdist : 0 < dist x y := dist_pos.mpr hxy
      exact hdist.trans_le
        (Metric.dist_le_diam_of_mem Set.finite_univ.isBounded
          (Set.mem_univ x) (Set.mem_univ y))
    obtain ⟨m, hm⟩ := exists_pow_lt_of_lt_one (div_pos hinf hD)
      (by norm_num : (1 / 2 : ℝ) < 1)
    refine ⟨m, finiteCoverCard_eq_card_of_two_mul_lt_infsep _ ?_⟩
    have hscale :
        2 * (dyadicRadius (finiteMetricDiameter (T := T)) (m + 1) : ℝ) =
          (finiteMetricDiameter (T := T) : ℝ) * (1 / 2 : ℝ) ^ m := by
      rw [dyadicRadius_succ]
      norm_num [dyadicRadius]
      rw [one_div_pow]
      field_simp
    rw [hscale]
    simpa [mul_comm] using (lt_div_iff₀ hD).mp hm

/-- Automatic finite-metric form of (8.15). Unlike the
proof-engine theorem above, the public source wrapper has no caller-supplied
chain length or endpoint-cover certificates; its radius is exactly the metric
diameter appearing in the book.

**Book Exercise 8.1.** -/
theorem exercise_8_1_highProbabilityDudley_finiteMetric_of_pos
    {Ω : Type*} {mΩ : MeasurableSpace Ω} {μ : Measure Ω}
    [IsProbabilityMeasure μ]
    (X : HDP.RandomProcess T Ω) (hXm : ∀ t, Measurable (X t))
    {K u : ℝ} (hK : 0 < K) (hu : 0 ≤ u)
    (hinc : HDP.HasSubGaussianIncrementsWith X μ dist K) :
    μ {ω | 60 * K *
          (finiteDudleyEntropyIntegral (T := T)
              (finiteMetricDiameter (T := T)) +
            u * Metric.diam (Set.univ : Set T)) <
        finiteProcessOscillation X ω} ≤
      ENNReal.ofReal (2 * Real.exp (-u ^ 2)) := by
  obtain ⟨steps, hfine⟩ :=
    exists_dyadicRadius_coverCard_eq_fintypeCard (T := T)
  exact exercise_8_1_highProbabilityDudley_coveringNumber
    (finiteMetricDiameter (T := T)) steps X hXm hK hu hinc
    (finiteCoverCard_finiteMetricDiameter (T := T)) hfine le_rfl

/-- Dudley admits a high-probability bound with an added `u diam(T)` term. Exact source endpoint (8.15). The nonnegative
increment constant is part of `HasSubGaussianIncrementsWith`; no additional
strict-positivity assumption is imposed. When `K = 0`, every one of the
finitely many increments vanishes almost surely, so the oscillation does too.

**Book Remark 8.1.6.** -/
theorem exercise_8_1_highProbabilityDudley_finiteMetric
    {Ω : Type*} {mΩ : MeasurableSpace Ω} {μ : Measure Ω}
    [IsProbabilityMeasure μ]
    (X : HDP.RandomProcess T Ω) (hXm : ∀ t, Measurable (X t))
    {K u : ℝ} (hu : 0 ≤ u)
    (hinc : HDP.HasSubGaussianIncrementsWith X μ dist K) :
    μ {ω | 60 * K *
          (finiteDudleyEntropyIntegral (T := T)
              (finiteMetricDiameter (T := T)) +
            u * Metric.diam (Set.univ : Set T)) <
        finiteProcessOscillation X ω} ≤
      ENNReal.ofReal (2 * Real.exp (-u ^ 2)) := by
  by_cases hK0 : K = 0
  · subst K
    have hpair : ∀ p : T × T,
        (fun ω => X p.1 ω - X p.2 ω) =ᵐ[μ] 0 := by
      intro p
      let Y : Ω → ℝ := fun ω => X p.1 ω - X p.2 ω
      have hsub : HDP.SubGaussian Y μ := (hinc.2 p.2 p.1).1
      have hpsi : HDP.psi2Norm Y μ = 0 := by
        apply le_antisymm
        · exact (hinc.2 p.2 p.1).2.trans_eq (by simp)
        · exact HDP.psi2Norm_nonneg _ _
      exact (HDP.psi2Norm_eq_zero_iff
        ((hXm p.1).sub (hXm p.2)).aemeasurable hsub).mp hpsi
    have hall : ∀ᵐ ω ∂μ, ∀ p : T × T,
        X p.1 ω - X p.2 ω = 0 := by
      rw [ae_all_iff]
      exact hpair
    have hosc : finiteProcessOscillation X =ᵐ[μ] 0 := by
      filter_upwards [hall] with ω hω
      unfold finiteProcessOscillation
      apply le_antisymm
      · apply Finset.sup'_le
        intro p _hp
        simp [hω p]
      · exact finiteProcessOscillation_nonneg X ω
    have hnull : μ {ω | 60 * 0 *
            (finiteDudleyEntropyIntegral (T := T)
                (finiteMetricDiameter (T := T)) +
              u * Metric.diam (Set.univ : Set T)) <
          finiteProcessOscillation X ω} = 0 := by
      apply measure_mono_null (t := {ω | finiteProcessOscillation X ω ≠ 0})
      · intro ω hω
        norm_num at hω
        exact ne_of_gt hω
      · rw [measure_eq_zero_iff_ae_notMem]
        filter_upwards [hosc] with ω hω
        simpa using hω
    rw [hnull]
    exact bot_le
  · have hKpos : 0 < K := lt_of_le_of_ne hinc.1 (Ne.symm hK0)
    exact exercise_8_1_highProbabilityDudley_finiteMetric_of_pos
      X hXm hKpos hu hinc

end AutomaticFiniteMetricTruncation

/-! ### Euclidean finite sets and volumetric control -/

section EuclideanFiniteDudley

variable {n : ℕ}

/-- The indexed Gaussian width of the subtype of a nonempty finset is exactly
Chapter 7's Gaussian width of that finset.

**Lean implementation helper.** -/
lemma finiteGaussianFamilyWidth_subtype_eq_gaussianWidth
    (S : Finset (EuclideanSpace ℝ (Fin n))) [Nonempty ↥S]
    (hS : S.Nonempty) :
    finiteGaussianFamilyWidth
        (fun x : ↥S => (x : EuclideanSpace ℝ (Fin n))) =
      HDP.Chapter7.gaussianWidth S := by
  unfold finiteGaussianFamilyWidth HDP.Chapter7.gaussianWidth
  apply integral_congr_ae
  filter_upwards [] with g
  rw [HDP.Chapter7.finiteGaussianSupport_eq_sup' S hS]
  unfold finiteProcessSup
  apply le_antisymm
  · apply Finset.sup'_le
    intro x _hx
    change inner ℝ (x : EuclideanSpace ℝ (Fin n)) g ≤ _
    rw [real_inner_comm]
    exact Finset.le_sup'
      (fun y : EuclideanSpace ℝ (Fin n) => inner ℝ g y) x.property
  · apply Finset.sup'_le
    intro x hx
    let y : ↥S := ⟨x, hx⟩
    have hy := Finset.le_sup'
      (fun z : ↥S => inner ℝ (z : EuclideanSpace ℝ (Fin n)) g)
      (Finset.mem_univ y)
    simpa [y, real_inner_comm,
      HDP.Chapter7.canonicalGaussianProcess] using hy

/-- Exact finite-set proof engine. The entropy is the
actual Mathlib internal covering number of the subtype, integrated up to its
diameter; the dyadic truncation data are constructed internally.

**Book Theorem 8.1.8.** -/
theorem dudleyInequalityEuclidean_finiteSet
    (S : Finset (EuclideanSpace ℝ (Fin n))) (hS : S.Nonempty) :
    HDP.Chapter7.gaussianWidth S ≤
      48 * Real.sqrt (8 / 3) *
        finiteDudleyEntropyIntegral (T := ↥S)
          (finiteMetricDiameter (T := ↥S)) := by
  letI : Nonempty ↥S := hS.to_subtype
  let a : ↥S → EuclideanSpace ℝ (Fin n) := fun x => x
  let X := HDP.Chapter7.canonicalGaussianProcess a
  have hXm : ∀ t, Measurable (X t) := by
    intro t
    exact ((innerSL ℝ) (a t)).continuous.measurable
  have hXint : ∀ t, Integrable (X t)
      (stdGaussian (EuclideanSpace ℝ (Fin n))) := by
    intro t
    change Integrable
      (fun g : EuclideanSpace ℝ (Fin n) => inner ℝ (a t) g)
      (stdGaussian (EuclideanSpace ℝ (Fin n)))
    simpa [innerSL_apply_apply] using
      ((innerSL ℝ) (a t)).integrable_comp
        (isGaussian_stdGaussian
          (E := EuclideanSpace ℝ (Fin n))).integrable_id
  have hinc : HDP.HasSubGaussianIncrementsWith X
      (stdGaussian (EuclideanSpace ℝ (Fin n))) dist
      (Real.sqrt (8 / 3)) := by
    have hbase :=
      HDP.Chapter7.canonicalGaussianProcess_hasSubGaussianIncrementsWith a
    refine ⟨hbase.1, fun s t => ?_⟩
    simpa only [X, a,
      HDP.Chapter7.canonicalGaussianProcess_increment,
      Subtype.dist_eq, dist_eq_norm] using hbase.2 s t
  obtain ⟨steps, hfine⟩ :=
    exists_dyadicRadius_coverCard_eq_fintypeCard (T := ↥S)
  have h := dudleyIntegralInequality_coveringNumber
    (T := ↥S) (finiteMetricDiameter (T := ↥S)) steps X hXm hXint
    (HDP.Chapter7.canonicalGaussianProcess_centered a) hinc
    (finiteCoverCard_finiteMetricDiameter (T := ↥S)) hfine le_rfl
  change finiteGaussianFamilyWidth a ≤
    48 * Real.sqrt (8 / 3) *
      finiteDudleyEntropyIntegral (T := ↥S)
        (finiteMetricDiameter (T := ↥S)) at h
  have hwidth : finiteGaussianFamilyWidth a =
      HDP.Chapter7.gaussianWidth S := by
    simpa [a] using
      finiteGaussianFamilyWidth_subtype_eq_gaussianWidth S hS
  rw [← hwidth]
  exact h

/-- Adding a radius-`ε/2` ball to a set contained in a radius-`R` ball stays
inside the radius-`R+ε/2` ball with the same center.

**Lean implementation helper.** -/
lemma minkowskiSum_subset_closedBall {ε R : ℝ≥0}
    {c : EuclideanSpace ℝ (Fin n)}
    {K : Set (EuclideanSpace ℝ (Fin n))}
    (hK : K ⊆ Metric.closedBall c R) :
    HDP.minkowskiSum K
        (Metric.closedBall (0 : EuclideanSpace ℝ (Fin n))
          ((ε : ℝ) / 2)) ⊆
      Metric.closedBall c ((R : ℝ) + (ε : ℝ) / 2) := by
  intro x hx
  obtain ⟨a, haK, b, hb, rfl⟩ := HDP.mem_minkowskiSum.mp hx
  have ha := hK haK
  rw [Metric.mem_closedBall, dist_eq_norm] at ha ⊢
  rw [Metric.mem_closedBall, dist_zero_right] at hb
  calc
    ‖a + b - c‖ = ‖(a - c) + b‖ := by abel_nf
    _ ≤ ‖a - c‖ + ‖b‖ := norm_add_le _ _
    _ ≤ (R : ℝ) + (ε : ℝ) / 2 := add_le_add ha hb

/-- Volumetric covering estimate for an arbitrary subset of a Euclidean
ball. This is the translated-and-scaled form of Corollary 4.2.11 needed by
the actual-set Dudley and Sudakov functionals.

**Lean implementation helper.** -/
theorem coveringNumber_subset_closedBall_upper [NeZero n]
    {ε R : ℝ≥0} (hε : 0 < ε)
    {c : EuclideanSpace ℝ (Fin n)}
    {K : Set (EuclideanSpace ℝ (Fin n))}
    (hK : K ⊆ Metric.closedBall c R) :
    (Metric.coveringNumber ε K : ℝ≥0∞) ≤
      (((2 * R / ε + 1 : ℝ≥0) : ℝ≥0∞) ^ n) := by
  have hp :=
    (HDP.Chapter4.proposition_4_2_10 (n := n) (K := K) hε).2.2
  have hM : volume (HDP.minkowskiSum K
        (Metric.closedBall (0 : EuclideanSpace ℝ (Fin n))
          ((ε : ℝ) / 2))) ≤
      volume (Metric.closedBall c ((R : ℝ) + (ε : ℝ) / 2)) :=
    measure_mono (minkowskiSum_subset_closedBall (n := n) (ε := ε) hK)
  have hp' : (Metric.packingNumber ε K : ℝ≥0∞) *
        volume (Metric.closedBall (0 : EuclideanSpace ℝ (Fin n))
          ((ε : ℝ) / 2)) ≤
      volume (Metric.closedBall c ((R : ℝ) + (ε : ℝ) / 2)) :=
    hp.trans hM
  let q : ℝ≥0∞ := ENNReal.ofReal
    (Real.sqrt Real.pi ^ n / Real.Gamma ((n : ℝ) / 2 + 1))
  have hq0 : q ≠ 0 := by dsimp [q]; positivity
  have hqt : q ≠ ⊤ := by simp [q]
  rw [EuclideanSpace.volume_closedBall,
    EuclideanSpace.volume_closedBall] at hp'
  simp only [Fintype.card_fin] at hp'
  rw [← mul_assoc] at hp'
  change (Metric.packingNumber ε K : ℝ≥0∞) *
      ENNReal.ofReal ((ε : ℝ) / 2) ^ n * q ≤
        ENNReal.ofReal ((R : ℝ) + (ε : ℝ) / 2) ^ n * q at hp'
  rw [ENNReal.mul_le_mul_iff_left hq0 hqt] at hp'
  have he : ENNReal.ofReal ((ε : ℝ) / 2) =
      ((ε / 2 : ℝ≥0) : ℝ≥0∞) := by
    rw [ENNReal.ofReal_eq_coe_nnreal (by positivity)]
    rfl
  have hR : ENNReal.ofReal ((R : ℝ) + (ε : ℝ) / 2) =
      ((R + ε / 2 : ℝ≥0) : ℝ≥0∞) := by
    rw [ENNReal.ofReal_eq_coe_nnreal (by positivity)]
    rfl
  rw [he, hR] at hp'
  have hden0 : (((ε / 2 : ℝ≥0) : ℝ≥0∞) ^ n) ≠ 0 := by positivity
  have hdent : (((ε / 2 : ℝ≥0) : ℝ≥0∞) ^ n) ≠ ⊤ :=
    ENNReal.pow_ne_top ENNReal.coe_ne_top
  have hpack : (Metric.packingNumber ε K : ℝ≥0∞) ≤
      (((R + ε / 2 : ℝ≥0) : ℝ≥0∞) ^ n) /
        (((ε / 2 : ℝ≥0) : ℝ≥0∞) ^ n) :=
    (ENNReal.le_div_iff_mul_le (Or.inl hden0) (Or.inl hdent)).2 hp'
  have hratio : (((R + ε / 2 : ℝ≥0) : ℝ≥0∞) ^ n) /
        (((ε / 2 : ℝ≥0) : ℝ≥0∞) ^ n) =
      (((2 * R / ε + 1 : ℝ≥0) : ℝ≥0∞) ^ n) := by
    have hbase : (R + ε / 2 : ℝ≥0) / (ε / 2) =
        2 * R / ε + 1 := by
      apply NNReal.eq
      simp only [NNReal.coe_div, NNReal.coe_add, NNReal.coe_mul,
        NNReal.coe_ofNat, NNReal.coe_one]
      have he0 : (ε : ℝ) ≠ 0 := by exact_mod_cast hε.ne'
      field_simp
    have hdenNN : (ε / 2 : ℝ≥0) ≠ 0 :=
      div_ne_zero hε.ne' (by norm_num)
    have hdenPow : (ε / 2 : ℝ≥0) ^ n ≠ 0 :=
      pow_ne_zero n hdenNN
    rw [← ENNReal.coe_pow, ← ENNReal.coe_pow,
      ← ENNReal.coe_div hdenPow]
    norm_cast
    rw [← div_pow, hbase]
  rw [hratio] at hpack
  exact (show (Metric.coveringNumber ε K : ℝ≥0∞) ≤
      (Metric.packingNumber ε K : ℝ≥0∞) by exact_mod_cast
        Metric.coveringNumber_le_packingNumber ε K).trans hpack

end EuclideanFiniteDudley

/-! ## Exact weighted-basis example (Exercises 8.4(a,b)) -/

/-- The `i`-th point is
`e_i / sqrt(1 + log (i.val + 1))`, using `i.val + 1` for the source's
one-based index. The harmless `n+2`
parameterization matches the Chapter 2 weighted-maximum theorem and is
cofinal in the source's sequence of all positive dimensions.

**Book Exercise 8.4.** -/
def exercise84Point (n : ℕ) (i : Fin (n + 2)) :
    EuclideanSpace ℝ (Fin (n + 2)) :=
  (1 / Real.sqrt (1 + Real.log ((i : ℕ) + 1 : ℝ))) •
    EuclideanSpace.single i 1

/-- The actual finite weighted-basis set in Exercise 8.4.

**Book Exercise 8.4.** -/
def exercise84WeightedSet (n : ℕ) :
    Finset (EuclideanSpace ℝ (Fin (n + 2))) :=
  Finset.univ.image (exercise84Point n)

/-- Gaussian width of the weighted-basis family. This indexed definition is
equal to Chapter 7's Gaussian width of `exercise84WeightedSet`; injectivity of
`exercise84Point` is proved below.

**Lean implementation helper.** -/
def exercise84GaussianWidth (n : ℕ) : ℝ :=
  finiteGaussianFamilyWidth (exercise84Point n)

/-- The Gaussian process supremum over the weighted coordinate vectors equals their finite Gaussian support function.

**Lean implementation helper.** -/
lemma exercise84_finiteProcessSup_eq_finiteGaussianSupport (n : ℕ) :
    finiteProcessSup
        (HDP.Chapter7.canonicalGaussianProcess (exercise84Point n)) =
      HDP.Chapter7.finiteGaussianSupport (exercise84WeightedSet n) := by
  funext g
  unfold exercise84WeightedSet
  rw [HDP.Chapter7.finiteGaussianSupport_eq_sup' _
    (Finset.univ_nonempty.image _)]
  unfold finiteProcessSup
  apply le_antisymm
  · apply Finset.sup'_le
    intro i hi
    simpa [HDP.Chapter7.canonicalGaussianProcess, real_inner_comm] using
      (Finset.le_sup' (fun x => inner ℝ g x)
        (Finset.mem_image.mpr ⟨i, hi, rfl⟩))
  · apply Finset.sup'_le
    intro x hx
    rcases Finset.mem_image.mp hx with ⟨i, hi, rfl⟩
    simpa [HDP.Chapter7.canonicalGaussianProcess, real_inner_comm] using
      (Finset.le_sup'
        (fun j => HDP.Chapter7.canonicalGaussianProcess
          (exercise84Point n) j g) hi)

/-- The indexed width used in the proof is exactly the Gaussian width of the
finite set printed in Exercise 8.4.

**Book Exercise 8.4.** -/
theorem exercise84GaussianWidth_eq_gaussianWidth (n : ℕ) :
    exercise84GaussianWidth n =
      HDP.Chapter7.gaussianWidth (exercise84WeightedSet n) := by
  unfold exercise84GaussianWidth finiteGaussianFamilyWidth
  rw [exercise84_finiteProcessSup_eq_finiteGaussianSupport]
  rfl

/-- Every logarithmic normalization denominator in the weighted-coordinate example is positive.

**Lean implementation helper.** -/
lemma exercise84_denominator_pos {n : ℕ} (i : Fin (n + 2)) :
    0 < Real.sqrt (1 + Real.log ((i : ℕ) + 1 : ℝ)) := by
  apply Real.sqrt_pos.mpr
  have hi : (1 : ℝ) ≤ ((i : ℕ) + 1 : ℝ) := by
    exact_mod_cast Nat.succ_le_succ (Nat.zero_le (i : ℕ))
  have := Real.log_nonneg hi
  linarith

/-- The logarithmic weight `√log(2(i+1))` is bounded by the chosen normalization denominator.

**Lean implementation helper.** -/
lemma exercise84_log_denominator_le {n : ℕ} (i : Fin (n + 2)) :
    Real.sqrt (Real.log (2 * ((i : ℕ) + 1 : ℝ))) ≤
      Real.sqrt (1 + Real.log ((i : ℕ) + 1 : ℝ)) := by
  have hi0 : (0 : ℝ) < ((i : ℕ) + 1 : ℝ) := by positivity
  have hlog2 : Real.log (2 : ℝ) ≤ 1 := by
    have h := Real.log_lt_sub_one_of_pos (by norm_num : (0 : ℝ) < 2)
      (by norm_num : (2 : ℝ) ≠ 1)
    linarith
  have harg : Real.log (2 * ((i : ℕ) + 1 : ℝ)) ≤
      1 + Real.log ((i : ℕ) + 1 : ℝ) := by
    rw [Real.log_mul (by norm_num : (2 : ℝ) ≠ 0) hi0.ne']
    linarith
  exact Real.sqrt_le_sqrt harg

/-- The support function of the weighted-coordinate set is dominated by the corresponding logarithmically weighted maximum.

**Lean implementation helper.** -/
lemma exercise84_support_le_logWeightedMax (n : ℕ)
    (g : EuclideanSpace ℝ (Fin (n + 2))) :
    finiteProcessSup
        (HDP.Chapter7.canonicalGaussianProcess (exercise84Point n)) g ≤
      HDP.Chapter2.logWeightedMax
        (fun i : Fin (n + 2) => fun z : EuclideanSpace ℝ (Fin (n + 2)) =>
          inner ℝ (EuclideanSpace.single i 1) z) g := by
  unfold finiteProcessSup
  apply Finset.sup'_le
  intro i _hi
  have hden := exercise84_log_denominator_le i
  have hsmallpos : 0 < Real.sqrt
      (Real.log (2 * ((i : ℕ) + 1 : ℝ))) := by
    apply Real.sqrt_pos.mpr
    apply Real.log_pos
    have : (1 : ℝ) ≤ ((i : ℕ) + 1 : ℝ) := by
      exact_mod_cast Nat.succ_le_succ (Nat.zero_le (i : ℕ))
    nlinarith
  have hbigpos := exercise84_denominator_pos i
  have hcoord : inner ℝ (EuclideanSpace.single i 1) g = g i := by
    simp [EuclideanSpace.inner_single_left]
  have hdiv : |inner ℝ (EuclideanSpace.single i 1) g| /
        Real.sqrt (1 + Real.log ((i : ℕ) + 1 : ℝ)) ≤
      |inner ℝ (EuclideanSpace.single i 1) g| /
        Real.sqrt (Real.log (2 * ((i : ℕ) + 1 : ℝ))) := by
    exact div_le_div_of_nonneg_left (abs_nonneg _) hsmallpos hden
  calc
    HDP.Chapter7.canonicalGaussianProcess (exercise84Point n) i g =
        g i / Real.sqrt (1 + Real.log ((i : ℕ) + 1 : ℝ)) := by
      simp [HDP.Chapter7.canonicalGaussianProcess, exercise84Point,
        inner_smul_left, EuclideanSpace.inner_single_left, div_eq_mul_inv,
        mul_comm]
    _ ≤ |inner ℝ (EuclideanSpace.single i 1) g| /
        Real.sqrt (1 + Real.log ((i : ℕ) + 1 : ℝ)) := by
      rw [hcoord]
      exact div_le_div_of_nonneg_right (le_abs_self _) hbigpos.le
    _ ≤ |inner ℝ (EuclideanSpace.single i 1) g| /
        Real.sqrt (Real.log (2 * ((i : ℕ) + 1 : ℝ))) := hdiv
    _ ≤ HDP.Chapter2.logWeightedMax
        (fun i : Fin (n + 2) => fun z : EuclideanSpace ℝ (Fin (n + 2)) =>
          inner ℝ (EuclideanSpace.single i 1) z) g := by
      exact Finset.le_sup'
        (fun j => |inner ℝ (EuclideanSpace.single j 1) g| /
          Real.sqrt (Real.log (2 * ((j : ℕ) + 1 : ℝ))))
        (Finset.mem_univ i)

/-- Exact weighted-basis Gaussian-width endpoint.
The right-hand side is an explicit absolute constant, independent of `n`.

**Book Exercise 8.4(a).** -/
theorem exercise_8_4a_weightedBasis_gaussianWidth (n : ℕ) :
    exercise84GaussianWidth n ≤
      Real.sqrt 5 * (4 / Real.sqrt (Real.log 2)) := by
  let E := EuclideanSpace ℝ (Fin (n + 2))
  let X : Fin (n + 2) → E → ℝ := fun i z =>
    inner ℝ (EuclideanSpace.single i 1) z
  have hXm : ∀ i, Measurable (X i) := by
    intro i
    exact ((innerSL ℝ) (EuclideanSpace.single i 1)).continuous.measurable
  have hX : ∀ i, HDP.SubGaussian (X i) (stdGaussian E) := by
    intro i
    exact (standardGaussian_inner_subGaussian (E := E)
      (EuclideanSpace.single i 1)).1
  have hKb : ∀ i, HDP.psi2Norm (X i) (stdGaussian E) ≤ (2 : ℝ) := by
    intro i
    have h := standardGaussian_inner_subGaussian (E := E)
      (EuclideanSpace.single i 1)
    have hsqrt : Real.sqrt (8 / 3 : ℝ) ≤ 2 := by
      have hs0 := Real.sqrt_nonneg (8 / 3 : ℝ)
      have hsq := Real.sq_sqrt (by norm_num : (0 : ℝ) ≤ 8 / 3)
      nlinarith
    have hnorm : ‖(EuclideanSpace.single i (1 : ℝ) : E)‖ = 1 := by simp
    change HDP.psi2Norm
      (fun z : E => inner ℝ (EuclideanSpace.single i 1) z)
      (stdGaussian E) ≤ 2
    rw [h.2, hnorm, one_mul]
    exact hsqrt
  have hmax := exercise_8_4a_weightedMaximum_uniform
    (μ := stdGaussian E) hXm hX (K := 2) (by norm_num) hKb
  calc
    exercise84GaussianWidth n =
        ∫ g, finiteProcessSup
          (HDP.Chapter7.canonicalGaussianProcess (exercise84Point n)) g
          ∂stdGaussian E := rfl
    _ ≤ ∫ g, HDP.Chapter2.logWeightedMax X g ∂stdGaussian E := by
      apply integral_mono
      · have hi := HDP.Chapter7.integrable_finiteGaussianSupport
          ((Finset.univ : Finset (Fin (n + 2))).image (exercise84Point n))
        have heq : finiteProcessSup
              (HDP.Chapter7.canonicalGaussianProcess (exercise84Point n)) =
            HDP.Chapter7.finiteGaussianSupport
              ((Finset.univ : Finset (Fin (n + 2))).image (exercise84Point n)) := by
          funext g
          rw [HDP.Chapter7.finiteGaussianSupport_eq_sup' _
            (Finset.univ_nonempty.image _)]
          unfold finiteProcessSup
          apply le_antisymm
          · apply Finset.sup'_le
            intro i hi
            simpa [HDP.Chapter7.canonicalGaussianProcess, real_inner_comm] using
              (Finset.le_sup' (fun x => inner ℝ g x)
                (Finset.mem_image.mpr ⟨i, hi, rfl⟩))
          · apply Finset.sup'_le
            intro x hx
            rcases Finset.mem_image.mp hx with ⟨i, hi, rfl⟩
            simpa [HDP.Chapter7.canonicalGaussianProcess, real_inner_comm] using
              (Finset.le_sup'
                (fun j => HDP.Chapter7.canonicalGaussianProcess
                  (exercise84Point n) j g) hi)
        rwa [heq]
      · have hsub := HDP.Chapter2.exercise_2_37 hXm hX
          (by norm_num : (0 : ℝ) < 2) hKb
        apply memLp_one_iff_integrable.mp
        simpa only [ENNReal.ofReal_one] using
          (hsub.1.memLp
            (by
              have h1 : Measurable (HDP.Chapter2.logWeightedMax X) := by
                have hm : Measurable (Finset.univ.sup' Finset.univ_nonempty fun i =>
                    fun z => |X i z| /
                      Real.sqrt (Real.log (2 * ((i : ℕ) + 1 : ℝ)))) :=
                  Finset.measurable_sup' Finset.univ_nonempty fun i _ =>
                    (continuous_abs.measurable.comp (hXm i)).div_const _
                have heq : (Finset.univ.sup' Finset.univ_nonempty fun i =>
                    fun z => |X i z| /
                      Real.sqrt (Real.log (2 * ((i : ℕ) + 1 : ℝ)))) =
                    HDP.Chapter2.logWeightedMax X := by
                  funext z
                  simp only [HDP.Chapter2.logWeightedMax, Finset.sup'_apply]
                rwa [heq] at hm
              exact h1.aemeasurable)
            (le_refl (1 : ℝ)))
      · exact exercise84_support_le_logWeightedMax n
    _ ≤ Real.sqrt 5 * (2 * 2 / Real.sqrt (Real.log 2)) := hmax
    _ = Real.sqrt 5 * (4 / Real.sqrt (Real.log 2)) := by ring

/-- Dudley can overestimate width, but by at most a logarithmic factor; a weighted-basis family exhibits divergence of the entropy integral with bounded width. In the source's literal finite-set notation.

**Book Remark 8.1.10.** -/
theorem exercise_8_4a_weightedBasis_actualGaussianWidth (n : ℕ) :
    HDP.Chapter7.gaussianWidth (exercise84WeightedSet n) ≤
      Real.sqrt 5 * (4 / Real.sqrt (Real.log 2)) := by
  rw [← exercise84GaussianWidth_eq_gaussianWidth]
  exact exercise_8_4a_weightedBasis_gaussianWidth n

/-- A weighted coordinate vector has value `1 / √(1 + log(i+1))` in its own coordinate.

**Lean implementation helper.** -/
@[simp] lemma exercise84Point_apply_same {n : ℕ} (i : Fin (n + 2)) :
    exercise84Point n i i =
      1 / Real.sqrt (1 + Real.log ((i : ℕ) + 1 : ℝ)) := by
  simp [exercise84Point]

/-- A weighted coordinate vector vanishes in every different coordinate.

**Lean implementation helper.** -/
lemma exercise84Point_apply_ne {n : ℕ} {i j : Fin (n + 2)} (hji : j ≠ i) :
    exercise84Point n j i = 0 := by
  simp [exercise84Point, hji]

/-- Shows that the weighted coordinate embedding is injective.

**Lean implementation helper.** -/
lemma exercise84Point_injective (n : ℕ) : Function.Injective (exercise84Point n) := by
  intro i j hij
  by_contra hne
  have hji : j ≠ i := Ne.symm hne
  have happ := congrFun (congrArg WithLp.ofLp hij) i
  rw [exercise84Point_apply_same, exercise84Point_apply_ne hji] at happ
  have hp := exercise84_denominator_pos i
  have : (1 : ℝ) / Real.sqrt (1 + Real.log ((i : ℕ) + 1 : ℝ)) ≠ 0 := by
    positivity
  exact this happ

/-- Two distinct weighted coordinate vectors among the first `m` points are separated by at least `1 / √(1 + log m)`.

**Lean implementation helper.** -/
lemma exercise84Point_dist_lower {n m : ℕ} {i j : Fin (n + 2)}
    (hi : (i : ℕ) < m) (hij : i ≠ j) (hm : 1 ≤ m) :
    1 / Real.sqrt (1 + Real.log (m : ℝ)) ≤
      dist (exercise84Point n i) (exercise84Point n j) := by
  have hmreal : (1 : ℝ) ≤ m := by exact_mod_cast hm
  have him : ((i : ℕ) + 1 : ℝ) ≤ m := by exact_mod_cast hi
  have hlog : Real.log (((i : ℕ) + 1 : ℝ)) ≤ Real.log (m : ℝ) := by
    exact Real.log_le_log (by positivity) him
  have hsmallpos := exercise84_denominator_pos i
  have hbigpos : 0 < Real.sqrt (1 + Real.log (m : ℝ)) := by
    apply Real.sqrt_pos.mpr
    have := Real.log_nonneg hmreal
    linarith
  have hden : Real.sqrt (1 + Real.log (((i : ℕ) + 1 : ℝ))) ≤
      Real.sqrt (1 + Real.log (m : ℝ)) := Real.sqrt_le_sqrt (by linarith)
  have hcoef : 1 / Real.sqrt (1 + Real.log (m : ℝ)) ≤
      1 / Real.sqrt (1 + Real.log (((i : ℕ) + 1 : ℝ))) := by
    exact one_div_le_one_div_of_le hsmallpos hden
  let z := exercise84Point n i - exercise84Point n j
  let L : EuclideanSpace ℝ (Fin (n + 2)) →L[ℝ] ℝ :=
    (innerSL ℝ) (EuclideanSpace.single i 1)
  have hproj := L.le_opNorm z
  have hprojNorm : ‖L‖ = 1 := by
    simp [L, innerSL_apply_norm]
  rw [hprojNorm, one_mul] at hproj
  have hzcoord : z i =
      1 / Real.sqrt (1 + Real.log (((i : ℕ) + 1 : ℝ))) := by
    simp [z, exercise84Point_apply_same,
      exercise84Point_apply_ne (Ne.symm hij)]
  have habs : |z i| =
      1 / Real.sqrt (1 + Real.log (((i : ℕ) + 1 : ℝ))) := by
    rw [hzcoord, abs_of_pos (by positivity)]
  have hznorm : 1 / Real.sqrt (1 + Real.log (((i : ℕ) + 1 : ℝ))) ≤ ‖z‖ := by
    have hLz : L z = z i := by
      simp [L, innerSL_apply_apply, EuclideanSpace.inner_single_left]
    rw [hLz, Real.norm_eq_abs, habs] at hproj
    exact hproj
  simpa [z, dist_eq_norm] using hcoef.trans hznorm

/-- Collects the first `m` weighted coordinate vectors in the Exercise 8.4 construction.

**Lean implementation helper.** -/
noncomputable def exercise84FirstSet (n m : ℕ) :
    Finset (EuclideanSpace ℝ (Fin (n + 2))) :=
  (Finset.univ.filter fun i : Fin (n + 2) => (i : ℕ) < m).image
    (exercise84Point n)

/-- Computes the cardinality of the first weighted-coordinate subset.

**Lean implementation helper.** -/
lemma exercise84FirstSet_card {n m : ℕ} (hmn : m ≤ n + 2) :
    (exercise84FirstSet n m).card = m := by
  rw [exercise84FirstSet,
    Finset.card_image_of_injective _ (exercise84Point_injective n),
    Fin.card_filter_val_lt, Nat.min_eq_right hmn]

/-- Shows that the first weighted-coordinate subset lies in the ambient source set.

**Lean implementation helper.** -/
lemma exercise84FirstSet_subset (n m : ℕ) :
    exercise84FirstSet n m ⊆ exercise84WeightedSet n := by
  intro x hx
  rcases Finset.mem_image.mp hx with ⟨i, hi, rfl⟩
  exact Finset.mem_image.mpr ⟨i, Finset.mem_univ _, rfl⟩

/-- The geometric assertion in the hint to Exercise 8.4(b), with the factor
`1/4` made explicit for Mathlib's radius-ball covering convention. The first
`m` weighted basis vectors form a separated family, hence any such cover has
at least `m` balls.

**Book Exercise 8.4(b).** -/
theorem exercise_8_4b_weightedBasis_coveringNumber_lower
    {n m : ℕ} (hm : 1 ≤ m) (hmn : m ≤ n + 2) :
    (m : ℕ∞) ≤ Metric.coveringNumber
      ⟨1 / (4 * Real.sqrt (1 + Real.log (m : ℝ))), by positivity⟩
      (exercise84WeightedSet n : Set (EuclideanSpace ℝ (Fin (n + 2)))) := by
  let r : ℝ≥0 :=
    ⟨1 / (4 * Real.sqrt (1 + Real.log (m : ℝ))), by positivity⟩
  let C : Set (EuclideanSpace ℝ (Fin (n + 2))) := exercise84FirstSet n m
  let A : Set (EuclideanSpace ℝ (Fin (n + 2))) := exercise84WeightedSet n
  have hmreal : (1 : ℝ) ≤ m := by exact_mod_cast hm
  have hden : 0 < Real.sqrt (1 + Real.log (m : ℝ)) := by
    apply Real.sqrt_pos.mpr
    have := Real.log_nonneg hmreal
    linarith
  have hCsep : Metric.IsSeparated (↑(2 * r) : ℝ≥0∞) C := by
    intro x hx y hy hxy
    change (↑(2 * r) : ℝ≥0∞) < edist x y
    rw [edist_nndist, ENNReal.coe_lt_coe]
    change ((2 * r : ℝ≥0) : ℝ) < dist x y
    rcases Finset.mem_image.mp hx with ⟨i, hi, rfl⟩
    rcases Finset.mem_image.mp hy with ⟨j, hj, rfl⟩
    have hij : i ≠ j := by
      intro hij
      subst j
      exact hxy rfl
    have hi' : (i : ℕ) < m := Finset.mem_filter.mp hi |>.2
    have hlower := exercise84Point_dist_lower hi' hij hm
    have hr : ((2 * r : ℝ≥0) : ℝ) =
        1 / (2 * Real.sqrt (1 + Real.log (m : ℝ))) := by
      change 2 * (1 / (4 * Real.sqrt (1 + Real.log (m : ℝ)))) =
        1 / (2 * Real.sqrt (1 + Real.log (m : ℝ)))
      field_simp
      norm_num
    rw [hr]
    have : 1 / (2 * Real.sqrt (1 + Real.log (m : ℝ))) <
        1 / Real.sqrt (1 + Real.log (m : ℝ)) := by
      rw [one_div_lt_one_div (by positivity) (by positivity)]
      linarith
    exact this.trans_le hlower
  have hCA : C ⊆ A := by
    simpa [C, A] using exercise84FirstSet_subset n m
  have hpack : C.encard ≤ Metric.packingNumber (2 * r) A :=
    hCsep.encard_le_packingNumber hCA
  have hcover : C.encard ≤ Metric.coveringNumber r A :=
    hpack.trans <| (Metric.packingNumber_two_mul_le_externalCoveringNumber r A).trans
      (Metric.externalCoveringNumber_le_coveringNumber r A)
  have hcard : C.encard = (m : ℕ∞) := by
    change Set.encard
      (↑(exercise84FirstSet n m) :
        Set (EuclideanSpace ℝ (Fin (n + 2)))) = (m : ℕ∞)
    rw [Set.encard_coe_eq_coe_finsetCard, exercise84FirstSet_card hmn]
  simpa [r, A, hcard] using hcover

/-- Safe natural cardinal for the covering number of a finite set.

**Lean implementation helper.** -/
def finiteFinsetCoverCard {E : Type*} [PseudoEMetricSpace E]
    (S : Finset E) (ε : ℝ≥0) : ℕ :=
  (Metric.coveringNumber ε (S : Set E)).toNat

/-- The finite-set covering cardinality agrees, after coercion, with the metric covering number of the underlying set.

**Lean implementation helper.** -/
@[simp, norm_cast] lemma finiteFinsetCoverCard_coe
    {E : Type*} [PseudoEMetricSpace E] (S : Finset E) (ε : ℝ≥0) :
    (finiteFinsetCoverCard S ε : ℕ∞) =
      Metric.coveringNumber ε (S : Set E) := by
  exact ENat.coe_toNat
    (HDP.finite_covering_packing_of_finite S.finite_toSet ε).1

/-- Actual finite-set covering entropy, retaining Mathlib's covering number as
the authoritative underlying cardinal.

**Lean implementation helper.** -/
def finiteFinsetCoverEntropy {E : Type*} [PseudoEMetricSpace E]
    (S : Finset E) (x : ℝ) : ℝ :=
  Real.sqrt (Real.log (finiteFinsetCoverCard S x.toNNReal : ℝ))

/-- Shows that the finite-set covering entropy is nonnegative.

**Lean implementation helper.** -/
lemma finiteFinsetCoverEntropy_nonneg {E : Type*} [PseudoEMetricSpace E]
    (S : Finset E) (x : ℝ) : 0 ≤ finiteFinsetCoverEntropy S x :=
  Real.sqrt_nonneg _

/-- Shows that the finite-set covering entropy is antitone.

**Lean implementation helper.** -/
lemma finiteFinsetCoverEntropy_antitone {E : Type*} [PseudoEMetricSpace E]
    (S : Finset E) (hS : S.Nonempty) : Antitone (finiteFinsetCoverEntropy S) := by
  intro x y hxy
  unfold finiteFinsetCoverEntropy
  have hcEN : Metric.coveringNumber y.toNNReal (S : Set E) ≤
      Metric.coveringNumber x.toNNReal (S : Set E) :=
    Metric.coveringNumber_anti (Real.toNNReal_mono hxy)
  have hfinx :=
    (HDP.finite_covering_packing_of_finite S.finite_toSet x.toNNReal).1
  have hc : finiteFinsetCoverCard S y.toNNReal ≤
      finiteFinsetCoverCard S x.toNNReal := by
    apply ENat.toNat_le_toNat hcEN
    exact hfinx
  have hxpos : (0 : ℝ) < finiteFinsetCoverCard S x.toNNReal := by
    have hx : (0 : ℕ∞) < Metric.coveringNumber x.toNNReal (S : Set E) := by
      rw [Metric.coveringNumber_pos_iff]
      simpa using hS
    rw [← finiteFinsetCoverCard_coe] at hx
    exact_mod_cast hx
  have hypos : (0 : ℝ) < finiteFinsetCoverCard S y.toNNReal := by
    have hy : (0 : ℕ∞) < Metric.coveringNumber y.toNNReal (S : Set E) := by
      rw [Metric.coveringNumber_pos_iff]
      simpa using hS
    rw [← finiteFinsetCoverCard_coe] at hy
    exact_mod_cast hy
  gcongr

/-- Actual entropy profile and Dudley integral of the weighted-basis set.

**Lean implementation helper.** -/
def exercise84Entropy (n : ℕ) (x : ℝ) : ℝ :=
  finiteFinsetCoverEntropy (exercise84WeightedSet n) x

/-- Defines the entropy integral of the weighted coordinate set from Exercise 8.4.

**Lean implementation helper.** -/
def exercise84EntropyIntegral (n : ℕ) : ℝ :=
  ∫ x in (0 : ℝ)..1, exercise84Entropy n x

/-- At radii below the first-`m` separation scale, the weighted-coordinate entropy is at least `√log m`.

**Lean implementation helper.** -/
lemma exercise84Entropy_ge_sqrt_log {n m : ℕ}
    (hm : 1 ≤ m) (hmn : m ≤ n + 2) {x : ℝ}
    (hx : x ≤ 1 / (4 * Real.sqrt (1 + Real.log (m : ℝ)))) :
    Real.sqrt (Real.log (m : ℝ)) ≤ exercise84Entropy n x := by
  let r : ℝ := 1 / (4 * Real.sqrt (1 + Real.log (m : ℝ)))
  have hr0 : 0 ≤ r := by dsimp [r]; positivity
  have hcover := exercise_8_4b_weightedBasis_coveringNumber_lower
    (n := n) hm hmn
  have hcardEN :
      (finiteFinsetCoverCard (exercise84WeightedSet n) r.toNNReal : ℕ∞) =
        Metric.coveringNumber r.toNNReal
          (exercise84WeightedSet n : Set (EuclideanSpace ℝ (Fin (n + 2)))) :=
    finiteFinsetCoverCard_coe _ _
  have hrNN : r.toNNReal =
      ⟨1 / (4 * Real.sqrt (1 + Real.log (m : ℝ))), by positivity⟩ := by
    apply NNReal.eq
    rw [Real.coe_toNNReal r hr0]
    rfl
  rw [hrNN] at hcardEN
  rw [← hcardEN] at hcover
  have hcard : m ≤ finiteFinsetCoverCard (exercise84WeightedSet n) r.toNNReal := by
    have hc : m ≤ finiteFinsetCoverCard (exercise84WeightedSet n)
        ⟨1 / (4 * Real.sqrt (1 + Real.log (m : ℝ))), by positivity⟩ := by
      exact_mod_cast hcover
    simpa [hrNN] using hc
  have hmreal : (0 : ℝ) < m := by
    exact_mod_cast (lt_of_lt_of_le Nat.zero_lt_one hm)
  have hcardreal : (m : ℝ) ≤
      finiteFinsetCoverCard (exercise84WeightedSet n) r.toNNReal := by
    exact_mod_cast hcard
  have hlog : Real.log (m : ℝ) ≤
      Real.log (finiteFinsetCoverCard
        (exercise84WeightedSet n) r.toNNReal : ℝ) :=
    Real.log_le_log hmreal hcardreal
  have hatr : Real.sqrt (Real.log (m : ℝ)) ≤ exercise84Entropy n r := by
    exact Real.sqrt_le_sqrt hlog
  have hne : (exercise84WeightedSet n).Nonempty :=
    Finset.univ_nonempty.image _
  exact hatr.trans
    (finiteFinsetCoverEntropy_antitone (exercise84WeightedSet n) hne hx)

/-! An explicit cofinal block sequence for the divergence proof.  At block
`k` we use radius `1/(16·2^k)` and at least `ceil(exp(4·4^k))` points. -/

/-- Defines the geometrically decreasing radius assigned to the `k`th entropy block.

**Lean implementation helper.** -/
def exercise84BlockRadius (k : ℕ) : ℝ :=
  1 / (16 * (2 : ℝ) ^ k)

/-- Defines the logarithmic entropy exponent assigned to the `k`th block.

**Lean implementation helper.** -/
def exercise84BlockExponent (k : ℕ) : ℝ :=
  4 * (4 : ℝ) ^ k

/-- Defines the integer block size obtained by exponentiating the block exponent.

**Lean implementation helper.** -/
noncomputable def exercise84BlockSize (k : ℕ) : ℕ :=
  ⌈Real.exp (exercise84BlockExponent k)⌉₊

/-- Shows that the entropy-block radius is strictly positive.

**Lean implementation helper.** -/
lemma exercise84BlockRadius_pos (k : ℕ) : 0 < exercise84BlockRadius k := by
  simp [exercise84BlockRadius]

/-- Each entropy-block radius is half the preceding block radius.

**Lean implementation helper.** -/
lemma exercise84BlockRadius_succ (k : ℕ) :
    exercise84BlockRadius (k + 1) = exercise84BlockRadius k / 2 := by
  simp [exercise84BlockRadius, pow_succ]
  ring

/-- The entropy-block radii decrease with the block index.

**Lean implementation helper.** -/
lemma exercise84BlockRadius_antitone : Antitone exercise84BlockRadius :=
  antitone_nat_of_succ_le fun k => by
    rw [exercise84BlockRadius_succ]
    exact div_le_self (exercise84BlockRadius_pos k).le (by norm_num)

/-- Every entropy-block radius is at most `1`.

**Lean implementation helper.** -/
lemma exercise84BlockRadius_le_one (k : ℕ) : exercise84BlockRadius k ≤ 1 := by
  have hp : (1 : ℝ) ≤ (2 : ℝ) ^ k := one_le_pow₀ (by norm_num)
  simp only [exercise84BlockRadius]
  rw [div_le_one (by positivity)]
  nlinarith

/-- Shows that the entropy-block exponent is nonnegative.

**Lean implementation helper.** -/
lemma exercise84BlockExponent_nonneg (k : ℕ) :
    0 ≤ exercise84BlockExponent k := by
  simp [exercise84BlockExponent]

/-- Shows that the entropy-block size is strictly positive.

**Lean implementation helper.** -/
lemma exercise84BlockSize_pos (k : ℕ) : 0 < exercise84BlockSize k := by
  rw [exercise84BlockSize, Nat.ceil_pos]
  exact Real.exp_pos _

/-- Shows that the entropy-block size is monotone.

**Lean implementation helper.** -/
lemma exercise84BlockSize_mono : Monotone exercise84BlockSize := by
  intro i j hij
  apply Nat.ceil_mono
  apply Real.exp_le_exp.mpr
  unfold exercise84BlockExponent
  gcongr
  norm_num

/-- Each block exponent is at most the logarithm of the corresponding integer block size.

**Lean implementation helper.** -/
lemma exercise84BlockExponent_le_log_size (k : ℕ) :
    exercise84BlockExponent k ≤ Real.log (exercise84BlockSize k : ℝ) := by
  have hceil : Real.exp (exercise84BlockExponent k) ≤
      (exercise84BlockSize k : ℝ) := Nat.le_ceil _
  have hlog := Real.log_le_log (Real.exp_pos _) hceil
  simpa [exercise84BlockSize] using hlog

/-- The logarithm of a block size is at most its defining exponent plus one.

**Lean implementation helper.** -/
lemma exercise84_log_size_le_exponent_add_one (k : ℕ) :
    Real.log (exercise84BlockSize k : ℝ) ≤ exercise84BlockExponent k + 1 := by
  have ha0 := exercise84BlockExponent_nonneg k
  have hceil : (exercise84BlockSize k : ℝ) <
      Real.exp (exercise84BlockExponent k) + 1 := by
    exact Nat.ceil_lt_add_one (Real.exp_pos _).le
  have hexp1 : (1 : ℝ) ≤ Real.exp (exercise84BlockExponent k) :=
    Real.one_le_exp ha0
  have hbound : (exercise84BlockSize k : ℝ) ≤
      2 * Real.exp (exercise84BlockExponent k) := by linarith
  have hmpos : (0 : ℝ) < exercise84BlockSize k := by
    exact_mod_cast exercise84BlockSize_pos k
  have hlog := Real.log_le_log hmpos hbound
  rw [Real.log_mul (by norm_num : (2 : ℝ) ≠ 0) (Real.exp_pos _).ne',
    Real.log_exp] at hlog
  have hlog2 : Real.log (2 : ℝ) ≤ 1 := by
    have h := Real.log_lt_sub_one_of_pos (by norm_num : (0 : ℝ) < 2)
      (by norm_num : (2 : ℝ) ≠ 1)
    linarith
  linarith

/-- The square root of the `k`th block exponent is exactly `2 · 2^k`.

**Lean implementation helper.** -/
lemma exercise84_sqrt_blockExponent (k : ℕ) :
    Real.sqrt (exercise84BlockExponent k) = 2 * (2 : ℝ) ^ k := by
  have hr : 0 ≤ 2 * (2 : ℝ) ^ k := by positivity
  have hs := Real.sq_sqrt (exercise84BlockExponent_nonneg k)
  have heq : (2 * (2 : ℝ) ^ k) ^ 2 = exercise84BlockExponent k := by
    unfold exercise84BlockExponent
    rw [show (4 : ℝ) = 2 ^ 2 by norm_num, ← pow_mul]
    ring
  nlinarith [Real.sqrt_nonneg (exercise84BlockExponent k)]

/-- The `k`th block radius lies below the covering threshold associated with its block size.

**Lean implementation helper.** -/
lemma exercise84BlockRadius_le_coverRadius (k : ℕ) :
    exercise84BlockRadius k ≤
      1 / (4 * Real.sqrt
        (1 + Real.log (exercise84BlockSize k : ℝ))) := by
  let q : ℝ := (2 : ℝ) ^ k
  have hq : 1 ≤ q := by
    dsimp [q]
    exact one_le_pow₀ (by norm_num)
  have ha : exercise84BlockExponent k = (2 * q) ^ 2 := by
    have hs := exercise84_sqrt_blockExponent k
    have hsquare := Real.sq_sqrt (exercise84BlockExponent_nonneg k)
    dsimp [q]
    nlinarith
  have hlog := exercise84_log_size_le_exponent_add_one k
  have harg : 1 + Real.log (exercise84BlockSize k : ℝ) ≤
      exercise84BlockExponent k + 2 := by linarith
  have harg0 : 0 ≤ 1 + Real.log (exercise84BlockSize k : ℝ) := by
    have hmreal : (1 : ℝ) ≤ exercise84BlockSize k := by
      exact_mod_cast exercise84BlockSize_pos k
    have := Real.log_nonneg hmreal
    linarith
  have ha2 : 0 ≤ exercise84BlockExponent k + 2 := by
    linarith [exercise84BlockExponent_nonneg k]
  have hsqrt1 : Real.sqrt (1 + Real.log (exercise84BlockSize k : ℝ)) ≤
      Real.sqrt (exercise84BlockExponent k + 2) := Real.sqrt_le_sqrt harg
  have hsqrt2 : Real.sqrt (exercise84BlockExponent k + 2) ≤ 2 * q + 2 := by
    have hs := Real.sq_sqrt ha2
    have hs0 := Real.sqrt_nonneg (exercise84BlockExponent k + 2)
    have ht0 : 0 ≤ 2 * q + 2 := by positivity
    have htSq : exercise84BlockExponent k + 2 ≤ (2 * q + 2) ^ 2 := by
      rw [ha]
      nlinarith
    nlinarith
  have hsqrt : Real.sqrt (1 + Real.log (exercise84BlockSize k : ℝ)) ≤
      2 * q + 2 := hsqrt1.trans hsqrt2
  have hbpos := exercise84BlockRadius_pos k
  have hprod : exercise84BlockRadius k * (4 *
      Real.sqrt (1 + Real.log (exercise84BlockSize k : ℝ))) ≤ 1 := by
    calc
      exercise84BlockRadius k * (4 *
          Real.sqrt (1 + Real.log (exercise84BlockSize k : ℝ))) ≤
          exercise84BlockRadius k * (4 * (2 * q + 2)) := by
        gcongr
      _ = (q + 1) / (2 * q) := by
        dsimp [exercise84BlockRadius, q]
        field_simp
        ring
      _ ≤ 1 := by
        rw [div_le_one (by positivity)]
        linarith
  have hdenpos : 0 < 4 *
      Real.sqrt (1 + Real.log (exercise84BlockSize k : ℝ)) := by
    have hmreal : (1 : ℝ) ≤ exercise84BlockSize k := by
      exact_mod_cast exercise84BlockSize_pos k
    have hargpos : 0 < 1 + Real.log (exercise84BlockSize k : ℝ) := by
      have := Real.log_nonneg hmreal
      linarith
    positivity
  apply (le_div_iff₀ hdenpos).2
  simpa [mul_assoc, mul_comm, mul_left_comm] using hprod

/-- Throughout the `k`th radius block, the covering entropy is at least `2 · 2^k`.

**Lean implementation helper.** -/
lemma exercise84Entropy_block_lower {n k : ℕ}
    (hsize : exercise84BlockSize k ≤ n + 2) {x : ℝ}
    (hx : x ≤ exercise84BlockRadius k) :
    2 * (2 : ℝ) ^ k ≤ exercise84Entropy n x := by
  have hm : 1 ≤ exercise84BlockSize k := exercise84BlockSize_pos k
  have hbase := exercise84Entropy_ge_sqrt_log hm hsize
    (hx.trans (exercise84BlockRadius_le_coverRadius k))
  have hsq : Real.sqrt (exercise84BlockExponent k) ≤
      Real.sqrt (Real.log (exercise84BlockSize k : ℝ)) :=
    Real.sqrt_le_sqrt (exercise84BlockExponent_le_log_size k)
  rw [exercise84_sqrt_blockExponent] at hsq
  exact hsq.trans hbase

/-- The weighted-coordinate covering entropy is integrable on every finite interval.

**Lean implementation helper.** -/
lemma exercise84Entropy_intervalIntegrable (n : ℕ) (a b : ℝ) :
    IntervalIntegrable (exercise84Entropy n) volume a b := by
  apply Antitone.intervalIntegrable
  exact finiteFinsetCoverEntropy_antitone (exercise84WeightedSet n)
    (Finset.univ_nonempty.image _)

/-- Every admissible entropy block contributes at least `1/16` to the entropy integral.

**Lean implementation helper.** -/
lemma exercise84Entropy_block_integral_lower {n k : ℕ}
    (hsize : exercise84BlockSize k ≤ n + 2) :
    (1 / 16 : ℝ) ≤
      ∫ x in exercise84BlockRadius (k + 1)..exercise84BlockRadius k,
        exercise84Entropy n x := by
  have hrad : exercise84BlockRadius (k + 1) ≤ exercise84BlockRadius k := by
    rw [exercise84BlockRadius_succ]
    exact div_le_self (exercise84BlockRadius_pos k).le (by norm_num)
  have hconst : IntervalIntegrable (fun _ : ℝ => 2 * (2 : ℝ) ^ k) volume
      (exercise84BlockRadius (k + 1)) (exercise84BlockRadius k) := by simp
  have hint := exercise84Entropy_intervalIntegrable n
    (exercise84BlockRadius (k + 1)) (exercise84BlockRadius k)
  have hmono := intervalIntegral.integral_mono_on hrad hconst hint (by
    intro x hx
    exact exercise84Entropy_block_lower hsize hx.2)
  rw [intervalIntegral.integral_const, exercise84BlockRadius_succ] at hmono
  have heq : (exercise84BlockRadius k - exercise84BlockRadius k / 2) *
      (2 * (2 : ℝ) ^ k) = 1 / 16 := by
    unfold exercise84BlockRadius
    field_simp
    ring
  rw [← heq]
  simpa [smul_eq_mul, exercise84BlockRadius_succ] using hmono

/-- The sum of consecutive block integrals equals the integral over their combined radius interval.

**Lean implementation helper.** -/
lemma exercise84_sum_block_integrals (n J : ℕ) :
    (∑ k ∈ Finset.range J,
        ∫ x in exercise84BlockRadius (k + 1)..exercise84BlockRadius k,
          exercise84Entropy n x) =
      ∫ x in exercise84BlockRadius J..exercise84BlockRadius 0,
        exercise84Entropy n x := by
  induction J with
  | zero => simp
  | succ J ih =>
      rw [Finset.sum_range_succ, ih]
      rw [add_comm]
      exact intervalIntegral.integral_add_adjacent_intervals
        (exercise84Entropy_intervalIntegrable n
          (exercise84BlockRadius (J + 1)) (exercise84BlockRadius J))
        (exercise84Entropy_intervalIntegrable n
          (exercise84BlockRadius J) (exercise84BlockRadius 0))

/-- Quantitative finite form of Exercise 8.4(b): every completed block adds
at least `1/16` to the actual covering-entropy integral.

**Book Exercise 8.4(b).** -/
theorem exercise_8_4b_weightedBasis_entropyIntegral_lower (n J : ℕ)
    (hsize : exercise84BlockSize J ≤ n + 2) :
    (J : ℝ) / 16 ≤ exercise84EntropyIntegral n := by
  have hsizes : ∀ k ∈ Finset.range J,
      exercise84BlockSize k ≤ n + 2 := by
    intro k hk
    exact (exercise84BlockSize_mono (Finset.mem_range.mp hk).le).trans hsize
  have hsum : (J : ℝ) / 16 ≤
      ∑ k ∈ Finset.range J,
        ∫ x in exercise84BlockRadius (k + 1)..exercise84BlockRadius k,
          exercise84Entropy n x := by
    calc
      (J : ℝ) / 16 = ∑ _k ∈ Finset.range J, (1 / 16 : ℝ) := by
        simp [div_eq_mul_inv]
      _ ≤ _ := Finset.sum_le_sum fun k hk =>
        exercise84Entropy_block_integral_lower (hsizes k hk)
  rw [exercise84_sum_block_integrals] at hsum
  have hJ0 : 0 ≤ exercise84BlockRadius J := (exercise84BlockRadius_pos J).le
  have hJle : exercise84BlockRadius J ≤ exercise84BlockRadius 0 :=
    exercise84BlockRadius_antitone (Nat.zero_le J)
  have h01 : exercise84BlockRadius 0 ≤ 1 := exercise84BlockRadius_le_one 0
  have hmono :
      (∫ x in exercise84BlockRadius J..exercise84BlockRadius 0,
          exercise84Entropy n x) ≤
        ∫ x in (0 : ℝ)..1, exercise84Entropy n x := by
    apply intervalIntegral.integral_mono_interval hJ0 hJle h01
    · exact Filter.Eventually.of_forall fun x =>
        finiteFinsetCoverEntropy_nonneg (exercise84WeightedSet n) x
    · exact exercise84Entropy_intervalIntegrable n 0 1
  exact hsum.trans hmono

/-- Dudley can overestimate width, but by at most a logarithmic factor; a weighted-basis family exhibits divergence of the entropy integral with bounded width. Exact conclusion for the actual weighted-basis
sets: their Dudley covering-entropy integrals diverge with the dimension.

**Book Remark 8.1.10.** -/
theorem exercise_8_4b_weightedBasis_entropyIntegral_diverges :
    Tendsto exercise84EntropyIntegral atTop atTop := by
  refine tendsto_atTop.2 ?_
  intro B
  obtain ⟨J : ℕ, hJ⟩ := exists_nat_ge (16 * B)
  filter_upwards [eventually_ge_atTop (exercise84BlockSize J)] with n hn
  have hsize : exercise84BlockSize J ≤ n + 2 := hn.trans (by omega)
  have hlower := exercise_8_4b_weightedBasis_entropyIntegral_lower n J hsize
  have hBJ : B ≤ (J : ℝ) / 16 := by linarith
  exact hBJ.trans hlower

/-! ## Actual Euclidean-set Dudley and Sudakov functionals -/

/-- Covering the subtype of a finite Euclidean set has the same covering cardinality as covering the set itself.

**Lean implementation helper.** -/
lemma finiteCoverCard_subtype_eq_finset {n : ℕ}
    (F : Finset (EuclideanSpace ℝ (Fin n))) (ε : ℝ≥0) :
    finiteCoverCard (T := ↥F) ε = finiteFinsetCoverCard F ε := by
  apply Nat.cast_injective (R := ℕ∞)
  rw [finiteCoverCard_coe, finiteFinsetCoverCard_coe]
  have h := isometry_subtype_coe.coveringNumber_image
    (ε := ε) (A := (Set.univ : Set ↥F))
  simpa using h.symm

/-- The covering entropy of a finite-set subtype equals the finite-set covering entropy.

**Lean implementation helper.** -/
lemma finiteCoverEntropy_subtype_eq_finset {n : ℕ}
    (F : Finset (EuclideanSpace ℝ (Fin n))) (x : ℝ) :
    finiteCoverEntropy (T := ↥F) x = finiteFinsetCoverEntropy F x := by
  simp [finiteCoverEntropy, finiteFinsetCoverEntropy,
    finiteCoverCard_subtype_eq_finset]

/-- The metric diameter of a nonempty finite-set subtype equals the finite Euclidean diameter of the set.

**Lean implementation helper.** -/
lemma finiteMetricDiameter_subtype_eq_finset {n : ℕ}
    (F : Finset (EuclideanSpace ℝ (Fin n))) (hF : F.Nonempty) :
    (finiteMetricDiameter (T := ↥F) : ℝ) =
      HDP.Chapter7.finiteEuclideanDiameter F := by
  letI : Nonempty ↥F := hF.to_subtype
  apply le_antisymm
  · apply Metric.diam_le_of_forall_dist_le
      (HDP.Chapter7.finiteEuclideanDiameter_nonneg F)
    intro x _hx y _hy
    simpa [Subtype.dist_eq, dist_eq_norm] using
      HDP.Chapter7.norm_sub_le_finiteEuclideanDiameter
        F hF x.property y.property
  · rw [HDP.Chapter7.finiteEuclideanDiameter_eq_sup' F hF]
    apply Finset.sup'_le
    intro p hp
    rcases Finset.mem_product.mp hp with ⟨hp1, hp2⟩
    let x : ↥F := ⟨p.1, hp1⟩
    let y : ↥F := ⟨p.2, hp2⟩
    have hd := Metric.dist_le_diam_of_mem Set.finite_univ.isBounded
      (Set.mem_univ x) (Set.mem_univ y)
    change ‖p.1 - p.2‖ ≤ Metric.diam (Set.univ : Set ↥F)
    simpa [x, y, Subtype.dist_eq, dist_eq_norm] using hd

/-- The finite-set Dudley entropy integral, written directly with Mathlib's
covering number of the Euclidean finset.

**Lean implementation helper.** -/
def finiteEuclideanDudleyFunctional {n : ℕ}
    (F : Finset (EuclideanSpace ℝ (Fin n))) : ℝ :=
  ∫ x in (0 : ℝ)..HDP.Chapter7.finiteEuclideanDiameter F,
    finiteFinsetCoverEntropy F x

/-- The Dudley entropy integral of a finite-set subtype equals the corresponding finite Euclidean functional.

**Lean implementation helper.** -/
lemma finiteDudleyEntropyIntegral_subtype_eq_finset {n : ℕ}
    (F : Finset (EuclideanSpace ℝ (Fin n))) (hF : F.Nonempty) :
    finiteDudleyEntropyIntegral (T := ↥F)
        (finiteMetricDiameter (T := ↥F)) =
      finiteEuclideanDudleyFunctional F := by
  letI : Nonempty ↥F := hF.to_subtype
  unfold finiteDudleyEntropyIntegral finiteEuclideanDudleyFunctional
  rw [finiteMetricDiameter_subtype_eq_finset F hF]
  apply intervalIntegral.integral_congr
  intro x _hx
  exact finiteCoverEntropy_subtype_eq_finset F x

/-- Finite Euclidean set in direct covering-number
notation.

**Book Theorem 8.1.8.** -/
theorem dudleyInequalityEuclidean_finiteSet_actualEntropy {n : ℕ}
    (F : Finset (EuclideanSpace ℝ (Fin n))) (hF : F.Nonempty) :
    HDP.Chapter7.gaussianWidth F ≤
      48 * Real.sqrt (8 / 3) * finiteEuclideanDudleyFunctional F := by
  rw [← finiteDudleyEntropyIntegral_subtype_eq_finset F hF]
  exact dudleyInequalityEuclidean_finiteSet F hF

variable {E : Type*} [PseudoMetricSpace E] [ProperSpace E]

/-- Shows that the bounded covering number is finite.

**Lean implementation helper.** -/
lemma bounded_coveringNumber_ne_top {T : Set E}
    (hT : Bornology.IsBounded T) {ε : ℝ≥0} (hε : ε ≠ 0) :
    Metric.coveringNumber ε T ≠ ⊤ := by
  obtain ⟨N, hNT, hNfin, hcover⟩ :=
    Metric.exists_finite_isCover_of_isCompact_closure hε hT.isCompact_closure
  exact ne_top_of_le_ne_top hNfin.encard_lt_top.ne
    (hcover.coveringNumber_le_encard hNT)

/-- Actual internal covering entropy of an arbitrary Euclidean set. At
positive radii boundedness makes the underlying `ℕ∞` cardinal finite.

**Lean implementation helper.** -/
def euclideanSetCoverEntropy {n : ℕ}
    (T : Set (EuclideanSpace ℝ (Fin n))) (x : ℝ) : ℝ :=
  Real.sqrt (Real.log
    ((Metric.coveringNumber x.toNNReal T).toNat : ℝ))

/-- A globally antitone extended entropy representative. Assigning `∞` at
nonpositive scales does not affect its integral over `(0, diam T]`.

**Lean implementation helper.** -/
def euclideanSetCoverEntropyENN {n : ℕ}
    (T : Set (EuclideanSpace ℝ (Fin n))) (x : ℝ) : ℝ≥0∞ :=
  if x ≤ 0 then ⊤ else ENNReal.ofReal (euclideanSetCoverEntropy T x)

/-- Authoritative arbitrary-set Dudley functional.

**Lean implementation helper.** -/
def euclideanSetDudleyFunctionalENN {n : ℕ}
    (T : Set (EuclideanSpace ℝ (Fin n))) : ℝ≥0∞ :=
  ∫⁻ x in Set.Ioc (0 : ℝ) (Metric.diam T),
    euclideanSetCoverEntropyENN T x

/-- Authoritative arbitrary-set Sudakov functional.

**Lean implementation helper.** -/
def euclideanSetSudakovFunctionalENN {n : ℕ}
    (T : Set (EuclideanSpace ℝ (Fin n))) : ℝ≥0∞ :=
  ⨆ ε : ℝ≥0, (ε : ℝ≥0∞) *
    euclideanSetCoverEntropyENN T (ε : ℝ)

/-- Safe ordinary-real wrapper for the arbitrary-set Dudley functional.
The extended-valued definition is authoritative; bounded-set finiteness is
proved below.

**Lean implementation helper.** -/
def euclideanSetDudleyFunctional {n : ℕ}
    (T : Set (EuclideanSpace ℝ (Fin n))) : ℝ :=
  (euclideanSetDudleyFunctionalENN T).toReal

/-- Safe ordinary-real wrapper for the arbitrary-set Sudakov functional.
The extended-valued definition is authoritative; bounded-set finiteness is
proved below.

**Lean implementation helper.** -/
def euclideanSetSudakovFunctional {n : ℕ}
    (T : Set (EuclideanSpace ℝ (Fin n))) : ℝ :=
  (euclideanSetSudakovFunctionalENN T).toReal

/-- Shows that the extended-valued Euclidean covering entropy is antitone.

**Lean implementation helper.** -/
lemma euclideanSetCoverEntropyENN_antitone
    {n : ℕ} {T : Set (EuclideanSpace ℝ (Fin n))}
    (hT : Bornology.IsBounded T) :
    Antitone (euclideanSetCoverEntropyENN T) := by
  by_cases hTe : T = ∅
  · subst T
    intro x y hxy
    by_cases hx : x ≤ 0
    · simp [euclideanSetCoverEntropyENN, hx]
    · have hy : ¬y ≤ 0 := fun hy => hx (hxy.trans hy)
      simp [euclideanSetCoverEntropyENN, euclideanSetCoverEntropy, hx, hy]
  · have hTne : T.Nonempty := Set.nonempty_iff_ne_empty.mpr hTe
    intro x y hxy
    unfold euclideanSetCoverEntropyENN
    by_cases hx : x ≤ 0
    · rw [if_pos hx]
      exact le_top
    · have hxpos : 0 < x := lt_of_not_ge hx
      have hypos : 0 < y := hxpos.trans_le hxy
      rw [if_neg hx, if_neg (not_le.mpr hypos)]
      apply ENNReal.ofReal_le_ofReal
      unfold euclideanSetCoverEntropy
      apply Real.sqrt_le_sqrt
      apply Real.log_le_log
      · exact_mod_cast ENat.toNat_pos
          (Metric.coveringNumber_pos_iff.mpr hTne).ne'
          (bounded_coveringNumber_ne_top hT
            (show y.toNNReal ≠ 0 by simpa using hypos))
      · exact_mod_cast ENat.toNat_le_toNat
          (Metric.coveringNumber_anti (Real.toNNReal_mono hxy))
          (bounded_coveringNumber_ne_top hT
            (show x.toNNReal ≠ 0 by simpa using hxpos))

/-- Shows that the extended-valued Euclidean covering entropy is measurable.

**Lean implementation helper.** -/
lemma measurable_euclideanSetCoverEntropyENN
    {n : ℕ} {T : Set (EuclideanSpace ℝ (Fin n))}
    (hT : Bornology.IsBounded T) :
    Measurable (euclideanSetCoverEntropyENN T) :=
  (euclideanSetCoverEntropyENN_antitone hT).measurable

/-- The extended covering entropy vanishes at every radius larger than the set diameter.

**Lean implementation helper.** -/
lemma euclideanSetCoverEntropyENN_eq_zero_of_diam_lt
    {n : ℕ} {T : Set (EuclideanSpace ℝ (Fin n))}
    (hT : Bornology.IsBounded T) {ε : ℝ≥0}
    (hε : Metric.diam T < (ε : ℝ)) :
    euclideanSetCoverEntropyENN T (ε : ℝ) = 0 := by
  have hεpos : 0 < (ε : ℝ) := Metric.diam_nonneg.trans_lt hε
  rw [euclideanSetCoverEntropyENN, if_neg (not_le.mpr hεpos)]
  unfold euclideanSetCoverEntropy
  by_cases hTe : T = ∅
  · subst T
    simp
  · have hTne : T.Nonempty := Set.nonempty_iff_ne_empty.mpr hTe
    have hed : Metric.ediam T ≤ (ε : ℝ≥0∞) := by
      have h := Metric.ediam_le_of_forall_dist_le (s := T) fun x hx y hy =>
        (Metric.dist_le_diam_of_mem hT hx hy).trans hε.le
      simpa using h
    have hto : (ε : ℝ).toNNReal = ε := by simp
    rw [hto, Metric.coveringNumber_eq_one_of_ediam_le hTne hed]
    norm_num

/-- The Euclidean Sudakov functional is bounded above by the Dudley entropy functional.

**Lean implementation helper.** -/
theorem euclideanSetSudakovFunctionalENN_le_dudley
    {n : ℕ} {T : Set (EuclideanSpace ℝ (Fin n))}
    (hT : Bornology.IsBounded T) :
    euclideanSetSudakovFunctionalENN T ≤
      euclideanSetDudleyFunctionalENN T := by
  unfold euclideanSetSudakovFunctionalENN
  apply iSup_le
  intro ε
  by_cases hε0 : ε = 0
  · subst ε
    simp
  have hεpos : 0 < (ε : ℝ) := by
    exact_mod_cast (pos_iff_ne_zero.mpr hε0)
  by_cases hdiam : Metric.diam T < (ε : ℝ)
  · rw [euclideanSetCoverEntropyENN_eq_zero_of_diam_lt hT hdiam]
    simp
  · have hεD : (ε : ℝ) ≤ Metric.diam T := le_of_not_gt hdiam
    let f := euclideanSetCoverEntropyENN T
    have hfanti : Antitone f := euclideanSetCoverEntropyENN_antitone hT
    calc
      (ε : ℝ≥0∞) * f (ε : ℝ) =
          ∫⁻ _x in Set.Ioc (0 : ℝ) (ε : ℝ), f (ε : ℝ) := by
        rw [MeasureTheory.setLIntegral_const]
        simp [mul_comm]
      _ ≤ ∫⁻ x in Set.Ioc (0 : ℝ) (ε : ℝ), f x := by
        apply MeasureTheory.setLIntegral_mono' measurableSet_Ioc
        intro x hx
        exact hfanti hx.2
      _ ≤ ∫⁻ x in Set.Ioc (0 : ℝ) (Metric.diam T), f x := by
        apply MeasureTheory.lintegral_mono_set
        exact Set.Ioc_subset_Ioc_right hεD
      _ = euclideanSetDudleyFunctionalENN T := rfl

/-- The substitution `x = 2y` converts the lower integral of `f(x/2)` on `(0,R]` into twice the integral of `f` on `(0,R/2]`.

**Lean implementation helper.** -/
lemma lintegral_Ioc_comp_div_two (f : ℝ → ℝ≥0∞) (hf : Measurable f)
    {R : ℝ} :
    (∫⁻ x in Set.Ioc (0 : ℝ) R, f (x / 2)) =
      2 * ∫⁻ y in Set.Ioc (0 : ℝ) (R / 2), f y := by
  let H : ℝ → ℝ≥0∞ := Set.indicator (Set.Ioc (0 : ℝ) (R / 2)) f
  have hH : Measurable H := hf.indicator measurableSet_Ioc
  have hmap := MeasureTheory.lintegral_map (μ := volume) hH
    (show Measurable (fun x : ℝ => (1 / 2 : ℝ) * x) by fun_prop)
  rw [Real.map_volume_mul_left (a := (1 / 2 : ℝ)) (by norm_num),
    MeasureTheory.lintegral_smul_measure] at hmap
  have hcoef : ENNReal.ofReal |(1 / 2 : ℝ)⁻¹| = 2 := by norm_num
  rw [hcoef] at hmap
  rw [← MeasureTheory.lintegral_indicator measurableSet_Ioc,
    ← MeasureTheory.lintegral_indicator measurableSet_Ioc]
  have hfun : Set.indicator (Set.Ioc (0 : ℝ) R) (fun x => f (x / 2)) =
      fun x => H ((1 / 2 : ℝ) * x) := by
    funext x
    by_cases hx : x ∈ Set.Ioc (0 : ℝ) R
    · rw [Set.indicator_of_mem hx]
      dsimp [H]
      rw [Set.indicator_of_mem]
      · congr 1
        ring
      · constructor <;> nlinarith [hx.1, hx.2]
    · rw [Set.indicator_of_notMem hx]
      dsimp [H]
      rw [Set.indicator_of_notMem]
      intro hhalf
      apply hx
      constructor <;> nlinarith [hhalf.1, hhalf.2]
  rw [hfun]
  exact hmap.symm

/-- A finite subset can be covered at radius `ε` using no more points than cover the ambient set at radius `ε/2`.

**Lean implementation helper.** -/
lemma finite_subset_coverCard_le_set_half
    {n : ℕ} {T : Set (EuclideanSpace ℝ (Fin n))}
    (hT : Bornology.IsBounded T)
    {F : Finset (EuclideanSpace ℝ (Fin n))}
    (hFT : (F : Set (EuclideanSpace ℝ (Fin n))) ⊆ T)
    {ε : ℝ≥0} (hε : 0 < ε) :
    finiteFinsetCoverCard F ε ≤
      (Metric.coveringNumber (ε / 2) T).toNat := by
  unfold finiteFinsetCoverCard
  exact ENat.toNat_le_toNat (Metric.coveringNumber_subset_le hFT)
    (bounded_coveringNumber_ne_top hT
      (div_ne_zero hε.ne' (by norm_num)))

/-- The covering entropy of a finite subset at radius `x` is bounded by the ambient-set entropy at radius `x/2`.

**Lean implementation helper.** -/
lemma finite_subset_coverEntropy_le_set_half
    {n : ℕ} {T : Set (EuclideanSpace ℝ (Fin n))}
    (hT : Bornology.IsBounded T)
    {F : Finset (EuclideanSpace ℝ (Fin n))}
    (hFT : (F : Set (EuclideanSpace ℝ (Fin n))) ⊆ T)
    {x : ℝ} (hx : 0 < x) :
    finiteFinsetCoverEntropy F x ≤
      euclideanSetCoverEntropy T (x / 2) := by
  by_cases hF : F.Nonempty
  swap
  · have hFe : F = ∅ := Finset.not_nonempty_iff_eq_empty.mp hF
    subst F
    simp [finiteFinsetCoverEntropy, finiteFinsetCoverCard,
      euclideanSetCoverEntropy]
  unfold finiteFinsetCoverEntropy euclideanSetCoverEntropy
  apply Real.sqrt_le_sqrt
  apply Real.log_le_log
  · have hpos : 0 < finiteFinsetCoverCard F x.toNNReal := by
      have hc : (0 : ℕ∞) <
          (finiteFinsetCoverCard F x.toNNReal : ℕ∞) := by
        rw [finiteFinsetCoverCard_coe]
        exact Metric.coveringNumber_pos_iff.mpr (by simpa using hF)
      exact_mod_cast hc
    exact_mod_cast hpos
  · have hnn : (x / 2).toNNReal = x.toNNReal / 2 := by
      ext
      simp only [NNReal.coe_div, NNReal.coe_ofNat]
      rw [Real.coe_toNNReal (x / 2) (div_nonneg hx.le (by norm_num)),
        Real.coe_toNNReal x hx.le]
    rw [hnn]
    exact_mod_cast finite_subset_coverCard_le_set_half hT hFT
      (show 0 < x.toNNReal by simpa using hx)

/-- The finite-subfamily entropy integral is bounded by twice the actual
arbitrary-set Dudley functional. The factor two is exactly the radius loss
in Mathlib's internal-cover monotonicity theorem.

**Lean implementation helper.** -/
theorem finiteDudleyFunctional_le_two_setDudleyFunctionalENN
    {n : ℕ} {T : Set (EuclideanSpace ℝ (Fin n))}
    (hT : Bornology.IsBounded T)
    (F : Finset (EuclideanSpace ℝ (Fin n)))
    (hFT : (F : Set (EuclideanSpace ℝ (Fin n))) ⊆ T) :
    ENNReal.ofReal (finiteEuclideanDudleyFunctional F) ≤
      2 * euclideanSetDudleyFunctionalENN T := by
  by_cases hF : F.Nonempty
  swap
  · have hFe : F = ∅ := Finset.not_nonempty_iff_eq_empty.mp hF
    subst F
    simp [finiteEuclideanDudleyFunctional,
      HDP.Chapter7.finiteEuclideanDiameter]
  let RF : ℝ := HDP.Chapter7.finiteEuclideanDiameter F
  have hRF : 0 ≤ RF := HDP.Chapter7.finiteEuclideanDiameter_nonneg F
  have hFi : IntervalIntegrable (finiteFinsetCoverEntropy F) volume 0 RF :=
    (finiteFinsetCoverEntropy_antitone F hF).intervalIntegrable
  have hFiOn : IntegrableOn (finiteFinsetCoverEntropy F)
      (Set.Ioc 0 RF) volume :=
    (intervalIntegrable_iff_integrableOn_Ioc_of_le hRF).mp hFi
  have hof := MeasureTheory.ofReal_integral_eq_lintegral_ofReal hFiOn
    (Filter.Eventually.of_forall fun x =>
      finiteFinsetCoverEntropy_nonneg F x)
  rw [← intervalIntegral.integral_of_le hRF] at hof
  change ENNReal.ofReal
      (∫ x in (0 : ℝ)..RF, finiteFinsetCoverEntropy F x) ≤ _
  rw [hof]
  calc
    (∫⁻ x in Set.Ioc (0 : ℝ) RF,
        ENNReal.ofReal (finiteFinsetCoverEntropy F x)) ≤
        ∫⁻ x in Set.Ioc (0 : ℝ) RF,
          euclideanSetCoverEntropyENN T (x / 2) := by
      apply MeasureTheory.lintegral_mono
      intro x
      by_cases hx : 0 < x
      · change ENNReal.ofReal (finiteFinsetCoverEntropy F x) ≤
          (if x / (2 : ℝ) ≤ 0 then ⊤ else
            ENNReal.ofReal (euclideanSetCoverEntropy T (x / 2)))
        rw [if_neg (not_le.mpr (div_pos hx (by norm_num)))]
        exact ENNReal.ofReal_le_ofReal
          (finite_subset_coverEntropy_le_set_half hT hFT hx)
      · change ENNReal.ofReal (finiteFinsetCoverEntropy F x) ≤
          (if x / (2 : ℝ) ≤ 0 then ⊤ else
            ENNReal.ofReal (euclideanSetCoverEntropy T (x / 2)))
        rw [if_pos (show x / (2 : ℝ) ≤ 0 by linarith)]
        exact le_top
    _ = 2 * ∫⁻ y in Set.Ioc (0 : ℝ) (RF / 2),
          euclideanSetCoverEntropyENN T y :=
      lintegral_Ioc_comp_div_two _
        (measurable_euclideanSetCoverEntropyENN hT)
    _ ≤ 2 * euclideanSetDudleyFunctionalENN T := by
      gcongr
      apply MeasureTheory.lintegral_mono_set
      intro x hx
      refine ⟨hx.1, ?_⟩
      have hdiamF : RF ≤ Metric.diam T := by
        dsimp [RF]
        rw [HDP.Chapter7.finiteEuclideanDiameter_eq_sup' F hF]
        apply Finset.sup'_le
        intro p hp
        rcases Finset.mem_product.mp hp with ⟨hp1, hp2⟩
        simpa [dist_eq_norm] using
          Metric.dist_le_diam_of_mem hT (hFT hp1) (hFT hp2)
      exact hx.2.trans ((div_le_self hRF (by norm_num)).trans hdiamF)

/-! ## Finiteness of the actual Euclidean entropy integral -/

/-- The real-valued covering number of a bounded Euclidean set satisfies the standard volumetric bound `(2R/x + 1)^n`.

**Lean implementation helper.** -/
lemma coveringNumber_toNat_real_upper [NeZero n]
    {T : Set (EuclideanSpace ℝ (Fin n))}
    {c : EuclideanSpace ℝ (Fin n)} (R : ℝ≥0)
    (hT : T ⊆ Metric.closedBall c (R : ℝ))
    {x : ℝ} (hx : 0 < x) :
    ((Metric.coveringNumber x.toNNReal T).toNat : ℝ) ≤
      ((2 * R / x.toNNReal + 1 : ℝ≥0) : ℝ) ^ n := by
  have hxNN : 0 < x.toNNReal := Real.toNNReal_pos.mpr hx
  have hupper := coveringNumber_subset_closedBall_upper
    (n := n) hxNN hT
  have hfin : Metric.coveringNumber x.toNNReal T ≠ ⊤ := by
    intro htop
    rw [htop] at hupper
    simp at hupper
  have hcoe : ((Metric.coveringNumber x.toNNReal T).toNat : ℝ≥0∞) =
      (Metric.coveringNumber x.toNNReal T : ℝ≥0∞) := by
    rw [← ENat.coe_toNat hfin]
    norm_cast
  rw [← hcoe] at hupper
  exact_mod_cast hupper

/-- The Euclidean covering entropy is bounded by the square root of the logarithmic volumetric estimate.

**Lean implementation helper.** -/
lemma euclideanSetCoverEntropy_le_sqrt_volumetric [NeZero n]
    {T : Set (EuclideanSpace ℝ (Fin n))} (hTne : T.Nonempty)
    {c : EuclideanSpace ℝ (Fin n)} (R : ℝ≥0)
    (hT : T ⊆ Metric.closedBall c (R : ℝ))
    {x : ℝ} (hx : 0 < x) :
    euclideanSetCoverEntropy T x ≤
      Real.sqrt ((n : ℝ) *
        ((2 * R / x.toNNReal + 1 : ℝ≥0) : ℝ)) := by
  let N : ℝ := ((Metric.coveringNumber x.toNNReal T).toNat : ℝ)
  let q : ℝ := ((2 * R / x.toNNReal + 1 : ℝ≥0) : ℝ)
  have hcard : N ≤ q ^ n := by
    exact coveringNumber_toNat_real_upper (n := n) R hT hx
  have hupper := coveringNumber_subset_closedBall_upper
    (n := n) (Real.toNNReal_pos.mpr hx) hT
  have hfin : Metric.coveringNumber x.toNNReal T ≠ ⊤ := by
    intro htop
    rw [htop] at hupper
    simp at hupper
  have hNpos : 0 < N := by
    have hp : (0 : ℕ∞) < Metric.coveringNumber x.toNNReal T := by
      rw [Metric.coveringNumber_pos_iff]
      exact hTne
    rw [← ENat.coe_toNat hfin] at hp
    dsimp [N]
    exact_mod_cast hp
  have hqpos : 0 < q := by
    dsimp [q]
    positivity
  have hlogcard : Real.log N ≤ Real.log (q ^ n) :=
    Real.strictMonoOn_log.monotoneOn (Set.mem_Ioi.mpr hNpos)
      (Set.mem_Ioi.mpr (pow_pos hqpos n)) hcard
  have hlogq : Real.log q ≤ q :=
    (Real.log_le_sub_one_of_pos hqpos).trans (by linarith)
  have hn : 0 ≤ (n : ℝ) := Nat.cast_nonneg n
  have hinside : Real.log N ≤ (n : ℝ) * q := by
    calc
      Real.log N ≤ Real.log (q ^ n) := hlogcard
      _ = (n : ℝ) * Real.log q := by rw [Real.log_pow]
      _ ≤ (n : ℝ) * q := mul_le_mul_of_nonneg_left hlogq hn
  exact Real.sqrt_le_sqrt hinside

/-- The nonnegative-real volumetric factor coerces to `2R/x + 1`.

**Lean implementation helper.** -/
lemma euclideanVolumetricFactor_eq (R : ℝ≥0)
    {x : ℝ} (hx : 0 < x) :
    ((2 * R / x.toNNReal + 1 : ℝ≥0) : ℝ) =
      2 * (R : ℝ) / x + 1 := by
  have hxcoe : (x.toNNReal : ℝ) = x := Real.coe_toNNReal x hx.le
  simp only [NNReal.coe_add, NNReal.coe_div, NNReal.coe_mul,
    NNReal.coe_ofNat, NNReal.coe_one, hxcoe]

/-- The actual covering entropy has an integrable `x⁻¹´²` majorant near
zero. This is the finiteness step that licenses ordinary-real wrappers.

**Lean implementation helper.** -/
lemma euclideanSetCoverEntropy_le_const_mul_rpow [NeZero n]
    {T : Set (EuclideanSpace ℝ (Fin n))} (hTne : T.Nonempty)
    {c : EuclideanSpace ℝ (Fin n)} (R : ℝ≥0)
    (hT : T ⊆ Metric.closedBall c (R : ℝ))
    {x : ℝ} (hx : 0 < x) (hx1 : x ≤ 1) :
    euclideanSetCoverEntropy T x ≤
      Real.sqrt ((n : ℝ) * (1 + 2 * (R : ℝ))) *
        x ^ (-(1 / 2 : ℝ)) := by
  have hfirst := euclideanSetCoverEntropy_le_sqrt_volumetric
    (n := n) hTne R hT hx
  rw [euclideanVolumetricFactor_eq R hx] at hfirst
  have hxinv : 1 ≤ x⁻¹ := (one_le_inv₀ hx).mpr hx1
  have hR0 : 0 ≤ (R : ℝ) := R.coe_nonneg
  have hq : 2 * (R : ℝ) / x + 1 ≤
      (1 + 2 * (R : ℝ)) / x := by
    rw [div_eq_mul_inv, div_eq_mul_inv]
    nlinarith
  have hn : 0 ≤ (n : ℝ) := Nat.cast_nonneg n
  have hsqrt : Real.sqrt ((n : ℝ) * (2 * (R : ℝ) / x + 1)) ≤
      Real.sqrt ((n : ℝ) * ((1 + 2 * (R : ℝ)) / x)) := by
    apply Real.sqrt_le_sqrt
    exact mul_le_mul_of_nonneg_left hq hn
  have hA : 0 ≤ (n : ℝ) * (1 + 2 * (R : ℝ)) := by positivity
  have hsqrt_eq :
      Real.sqrt ((n : ℝ) * ((1 + 2 * (R : ℝ)) / x)) =
        Real.sqrt ((n : ℝ) * (1 + 2 * (R : ℝ))) *
          x ^ (-(1 / 2 : ℝ)) := by
    calc
      Real.sqrt ((n : ℝ) * ((1 + 2 * (R : ℝ)) / x)) =
          Real.sqrt ((n : ℝ) * (1 + 2 * (R : ℝ))) * Real.sqrt x⁻¹ := by
        rw [div_eq_mul_inv, ← mul_assoc, Real.sqrt_mul hA]
      _ = Real.sqrt ((n : ℝ) * (1 + 2 * (R : ℝ))) *
          (Real.sqrt x)⁻¹ := by rw [Real.sqrt_inv]
      _ = Real.sqrt ((n : ℝ) * (1 + 2 * (R : ℝ))) *
          (x ^ (1 / 2 : ℝ))⁻¹ := by
        congr 1
        exact congrArg Inv.inv (Real.sqrt_eq_rpow x)
      _ = Real.sqrt ((n : ℝ) * (1 + 2 * (R : ℝ))) *
          x ^ (-(1 / 2 : ℝ)) := by rw [Real.rpow_neg hx.le]
  exact hfirst.trans (hsqrt.trans_eq hsqrt_eq)

/-- For positive radii `x ≤ y`, covering entropy at `y` is no larger than covering entropy at `x`.

**Lean implementation helper.** -/
lemma euclideanSetCoverEntropy_anti_of_pos [NeZero n]
    {T : Set (EuclideanSpace ℝ (Fin n))} (hTne : T.Nonempty)
    {c : EuclideanSpace ℝ (Fin n)} (R : ℝ≥0)
    (hT : T ⊆ Metric.closedBall c (R : ℝ))
    {x y : ℝ} (hx : 0 < x) (hxy : x ≤ y) :
    euclideanSetCoverEntropy T y ≤ euclideanSetCoverEntropy T x := by
  have hy : 0 < y := hx.trans_le hxy
  have hupperx := coveringNumber_subset_closedBall_upper
    (n := n) (Real.toNNReal_pos.mpr hx) hT
  have huppery := coveringNumber_subset_closedBall_upper
    (n := n) (Real.toNNReal_pos.mpr hy) hT
  have hfinx : Metric.coveringNumber x.toNNReal T ≠ ⊤ := by
    intro ht
    rw [ht] at hupperx
    simp at hupperx
  have hfiny : Metric.coveringNumber y.toNNReal T ≠ ⊤ := by
    intro ht
    rw [ht] at huppery
    simp at huppery
  unfold euclideanSetCoverEntropy
  apply Real.sqrt_le_sqrt
  apply Real.log_le_log
  · have hp : 0 < (Metric.coveringNumber y.toNNReal T).toNat :=
      ENat.toNat_pos (Metric.coveringNumber_pos_iff.mpr hTne).ne' hfiny
    exact_mod_cast hp
  · exact_mod_cast ENat.toNat_le_toNat
      (Metric.coveringNumber_anti (Real.toNNReal_mono hxy)) hfinx

/-- The extended Dudley functional of a bounded Euclidean set in positive dimension is finite.

**Lean implementation helper.** -/
theorem euclideanSetDudleyFunctionalENN_ne_top_posDim [NeZero n]
    {T : Set (EuclideanSpace ℝ (Fin n))}
    (hTne : T.Nonempty) (hTb : Bornology.IsBounded T) :
    euclideanSetDudleyFunctionalENN T ≠ ⊤ := by
  obtain ⟨Rreal, hRpos, hTR⟩ :=
    hTb.subset_closedBall_lt (0 : ℝ) (0 : EuclideanSpace ℝ (Fin n))
  let R : ℝ≥0 := ⟨Rreal, hRpos.le⟩
  let C : ℝ := Real.sqrt ((n : ℝ) * (1 + 2 * (R : ℝ)))
  let b : ℝ := euclideanSetCoverEntropy T 1
  let g : ℝ → ℝ := fun x => C * x ^ (-(1 / 2 : ℝ)) + b
  have hb : 0 ≤ b := Real.sqrt_nonneg _
  have hC : 0 ≤ C := Real.sqrt_nonneg _
  have hgint : IntervalIntegrable g volume 0 (Metric.diam T) := by
    have hp : IntervalIntegrable (fun x : ℝ => x ^ (-(1 / 2 : ℝ)))
        volume 0 (Metric.diam T) :=
      intervalIntegral.intervalIntegrable_rpow' (by norm_num)
    exact (hp.const_mul C).add intervalIntegrable_const
  have hD : 0 ≤ Metric.diam T := Metric.diam_nonneg
  have hgOn : IntegrableOn g (Set.Ioc 0 (Metric.diam T)) volume :=
    (intervalIntegrable_iff_integrableOn_Ioc_of_le hD).mp hgint
  have hfinite :
      (∫⁻ x in Set.Ioc (0 : ℝ) (Metric.diam T),
        ENNReal.ofReal (g x)) < ⊤ :=
    hgOn.setLIntegral_lt_top
  apply ne_top_of_le_ne_top hfinite.ne
  apply MeasureTheory.lintegral_mono_ae
  filter_upwards [ae_restrict_mem measurableSet_Ioc] with x hx
  change (if x ≤ 0 then ⊤ else
    ENNReal.ofReal (euclideanSetCoverEntropy T x)) ≤ ENNReal.ofReal (g x)
  rw [if_neg (not_le.mpr hx.1)]
  apply ENNReal.ofReal_le_ofReal
  by_cases hx1 : x ≤ 1
  · have hs := euclideanSetCoverEntropy_le_const_mul_rpow
      (n := n) hTne R hTR hx.1 hx1
    dsimp [g, C, b]
    exact hs.trans (le_add_of_nonneg_right hb)
  · have hs := euclideanSetCoverEntropy_anti_of_pos
      (n := n) hTne R hTR (by norm_num : (0 : ℝ) < 1)
        (le_of_not_ge hx1)
    dsimp [g, C, b]
    exact hs.trans
      (le_add_of_nonneg_left (mul_nonneg hC (Real.rpow_nonneg hx.1.le _)))

/-- The actual Euclidean Dudley integral is finite for every nonempty bounded
set, including the zero-dimensional degenerate case.

**Lean implementation helper.** -/
theorem euclideanSetDudleyFunctionalENN_ne_top
    {n : ℕ} {T : Set (EuclideanSpace ℝ (Fin n))}
    (hTne : T.Nonempty) (hTb : Bornology.IsBounded T) :
    euclideanSetDudleyFunctionalENN T ≠ ⊤ := by
  cases n with
  | zero =>
      have hsub : T.Subsingleton := fun _ _ _ _ => Subsingleton.elim _ _
      have hdiam : Metric.diam T = 0 := Metric.diam_subsingleton hsub
      simp [euclideanSetDudleyFunctionalENN, hdiam]
  | succ n =>
      letI : NeZero (n + 1) := ⟨by omega⟩
      exact euclideanSetDudleyFunctionalENN_ne_top_posDim hTne hTb

/-- The actual real covering entropy is integrable on the full Dudley range
for every nonempty bounded Euclidean set.

**Lean implementation helper.** -/
theorem integrableOn_euclideanSetCoverEntropy_Ioc
    {n : ℕ} {T : Set (EuclideanSpace ℝ (Fin n))}
    (hTne : T.Nonempty) (hTb : Bornology.IsBounded T) :
    IntegrableOn (euclideanSetCoverEntropy T)
      (Set.Ioc 0 (Metric.diam T)) volume := by
  let s : Set ℝ := Set.Ioc 0 (Metric.diam T)
  let ν : Measure ℝ := volume.restrict s
  have hne : euclideanSetDudleyFunctionalENN T ≠ ⊤ :=
    euclideanSetDudleyFunctionalENN_ne_top hTne hTb
  have hm : AEMeasurable (euclideanSetCoverEntropyENN T) ν :=
    (measurable_euclideanSetCoverEntropyENN hTb).aemeasurable
  have htop : Integrable
      (fun x => (euclideanSetCoverEntropyENN T x).toReal) ν := by
    apply integrable_toReal_of_lintegral_ne_top hm
    simpa [ν, s, euclideanSetDudleyFunctionalENN] using hne
  have hae : (fun x => (euclideanSetCoverEntropyENN T x).toReal) =ᵐ[ν]
      euclideanSetCoverEntropy T := by
    dsimp [ν]
    filter_upwards [ae_restrict_mem measurableSet_Ioc] with x hx
    rw [euclideanSetCoverEntropyENN, if_neg (not_le.mpr hx.1)]
    exact ENNReal.toReal_ofReal (Real.sqrt_nonneg _)
  exact htop.congr hae

/-- For a bounded nonempty Euclidean set, the safe real Dudley wrapper is
the displayed ordinary interval integral from the book.

**Lean implementation helper.** -/
theorem euclideanSetDudleyFunctional_eq_integral
    {n : ℕ} {T : Set (EuclideanSpace ℝ (Fin n))}
    (hTne : T.Nonempty) (hTb : Bornology.IsBounded T) :
    euclideanSetDudleyFunctional T =
      ∫ x in (0 : ℝ)..Metric.diam T, euclideanSetCoverEntropy T x := by
  let s : Set ℝ := Set.Ioc 0 (Metric.diam T)
  let ν : Measure ℝ := volume.restrict s
  have hreal : Integrable (euclideanSetCoverEntropy T) ν :=
    integrableOn_euclideanSetCoverEntropy_Ioc hTne hTb
  have hnonneg : 0 ≤ᵐ[ν] euclideanSetCoverEntropy T :=
    Filter.Eventually.of_forall fun _ => Real.sqrt_nonneg _
  have hlin :
      (∫ x, euclideanSetCoverEntropy T x ∂ν) =
        (euclideanSetDudleyFunctionalENN T).toReal := by
    rw [integral_eq_lintegral_of_nonneg_ae hnonneg
      hreal.aestronglyMeasurable]
    congr 1
    change (∫⁻ x in s, ENNReal.ofReal (euclideanSetCoverEntropy T x)) =
      ∫⁻ x in s, euclideanSetCoverEntropyENN T x
    apply lintegral_congr_ae
    filter_upwards [ae_restrict_mem measurableSet_Ioc] with x hx
    rw [euclideanSetCoverEntropyENN, if_neg (not_le.mpr hx.1)]
  rw [euclideanSetDudleyFunctional, ← hlin]
  rw [intervalIntegral.integral_of_le Metric.diam_nonneg]

/-- Boundedness also makes the authoritative Sudakov functional finite.

**Lean implementation helper.** -/
theorem euclideanSetSudakovFunctionalENN_ne_top
    {n : ℕ} {T : Set (EuclideanSpace ℝ (Fin n))}
    (hTne : T.Nonempty) (hTb : Bornology.IsBounded T) :
    euclideanSetSudakovFunctionalENN T ≠ ⊤ :=
  ne_top_of_le_ne_top (euclideanSetDudleyFunctionalENN_ne_top hTne hTb)
    (euclideanSetSudakovFunctionalENN_le_dudley hTb)

/-- For a bounded nonempty Euclidean set, the safe real Sudakov wrapper is
the displayed supremum `sup_{ε ≥ 0} ε sqrt(log N(T,ε))` from the book.

**Lean implementation helper.** -/
theorem euclideanSetSudakovFunctional_eq_iSup
    {n : ℕ} {T : Set (EuclideanSpace ℝ (Fin n))}
    (hTne : T.Nonempty) (hTb : Bornology.IsBounded T) :
    euclideanSetSudakovFunctional T =
      ⨆ ε : ℝ≥0, (ε : ℝ) *
        euclideanSetCoverEntropy T (ε : ℝ) := by
  have hsne := euclideanSetSudakovFunctionalENN_ne_top hTne hTb
  have hterm : ∀ ε : ℝ≥0,
      (ε : ℝ≥0∞) * euclideanSetCoverEntropyENN T (ε : ℝ) ≠ ⊤ := by
    intro ε
    apply ne_top_of_le_ne_top hsne
    unfold euclideanSetSudakovFunctionalENN
    exact le_iSup (fun δ : ℝ≥0 => (δ : ℝ≥0∞) *
      euclideanSetCoverEntropyENN T (δ : ℝ)) ε
  rw [euclideanSetSudakovFunctional,
    euclideanSetSudakovFunctionalENN, ENNReal.toReal_iSup hterm]
  congr 1
  funext ε
  by_cases hε : ε = 0
  · subst ε
    simp
  · have hεpos : 0 < (ε : ℝ) := by
      exact_mod_cast (pos_iff_ne_zero.mpr hε)
    have he0 : 0 ≤ euclideanSetCoverEntropy T (ε : ℝ) :=
      Real.sqrt_nonneg _
    rw [ENNReal.toReal_mul]
    simp only [ENNReal.coe_toReal]
    rw [euclideanSetCoverEntropyENN, if_neg (not_le.mpr hεpos),
      ENNReal.toReal_ofReal he0]

/-! ## The actual-set endpoint of Theorem 8.1.8 -/

/-- Gaussian width is the expected support of a set in a standard Gaussian direction. Gaussian width of an arbitrary Euclidean set, canonically defined as the
extended supremum over all nonempty finite subfamilies. Requiring the finite
subfamily to be nonempty matches Remark 7.2.1 and avoids identifying the
empty-set `EReal.bot` expectation with zero.

**Book Definition 7.5.1.** -/
def euclideanSetGaussianWidthENN {n : ℕ}
    (T : Set (EuclideanSpace ℝ (Fin n))) : ℝ≥0∞ :=
  ⨆ (F : Finset (EuclideanSpace ℝ (Fin n)))
    (_ : (F : Set (EuclideanSpace ℝ (Fin n))) ⊆ T)
    (_ : F.Nonempty), ENNReal.ofReal (HDP.Chapter7.gaussianWidth F)

/-- Gaussian width is the expected support of a set in a standard Gaussian direction. Safe ordinary-real wrapper for arbitrary-set Gaussian width.

**Book Definition 7.5.1.** -/
def euclideanSetGaussianWidth {n : ℕ}
    (T : Set (EuclideanSpace ℝ (Fin n))) : ℝ :=
  (euclideanSetGaussianWidthENN T).toReal

/-- Shows that the real-valued finite Euclidean Dudley functional is nonnegative.

**Lean implementation helper.** -/
lemma finiteEuclideanDudleyFunctional_nonneg {n : ℕ}
    (F : Finset (EuclideanSpace ℝ (Fin n))) :
    0 ≤ finiteEuclideanDudleyFunctional F := by
  unfold finiteEuclideanDudleyFunctional
  exact intervalIntegral.integral_nonneg
    (HDP.Chapter7.finiteEuclideanDiameter_nonneg F) fun x _ =>
      finiteFinsetCoverEntropy_nonneg F x

/-- Arbitrary bounded Euclidean-set Gaussian width is bounded by its Dudley entropy integral. Extended-valued arbitrary-set Dudley inequality. This is one theorem
about the actual finite-subfamily width envelope, not a schema quantified over
a single finite subset. Its right side uses Mathlib's actual `N(T, ε)`.

**Book Theorem 8.1.8.** -/
theorem dudleyInequalityEuclidean_arbitrarySet_ENN
    {n : ℕ} {T : Set (EuclideanSpace ℝ (Fin n))}
    (hTb : Bornology.IsBounded T) :
    euclideanSetGaussianWidthENN T ≤
      ENNReal.ofReal (96 * Real.sqrt (8 / 3)) *
        euclideanSetDudleyFunctionalENN T := by
  unfold euclideanSetGaussianWidthENN
  apply iSup_le
  intro F
  apply iSup_le
  intro hFT
  apply iSup_le
  intro hF
  have hfinite := dudleyInequalityEuclidean_finiteSet_actualEntropy F hF
  calc
    ENNReal.ofReal (HDP.Chapter7.gaussianWidth F) ≤
        ENNReal.ofReal
          (48 * Real.sqrt (8 / 3) * finiteEuclideanDudleyFunctional F) :=
      ENNReal.ofReal_le_ofReal hfinite
    _ = ENNReal.ofReal (48 * Real.sqrt (8 / 3)) *
        ENNReal.ofReal (finiteEuclideanDudleyFunctional F) := by
      rw [ENNReal.ofReal_mul]
      positivity
    _ ≤ ENNReal.ofReal (48 * Real.sqrt (8 / 3)) *
        (2 * euclideanSetDudleyFunctionalENN T) := by
      gcongr
      exact finiteDudleyFunctional_le_two_setDudleyFunctionalENN hTb F hFT
    _ = ENNReal.ofReal (96 * Real.sqrt (8 / 3)) *
        euclideanSetDudleyFunctionalENN T := by
      rw [← mul_assoc, ← ENNReal.ofReal_ofNat, ← ENNReal.ofReal_mul]
      · congr 1
        ring_nf
      · positivity

/-- The arbitrary-set Gaussian-width envelope is finite on every nonempty
bounded set.

**Lean implementation helper.** -/
theorem euclideanSetGaussianWidthENN_ne_top
    {n : ℕ} {T : Set (EuclideanSpace ℝ (Fin n))}
    (hTne : T.Nonempty) (hTb : Bornology.IsBounded T) :
    euclideanSetGaussianWidthENN T ≠ ⊤ := by
  exact ne_top_of_le_ne_top
    (ENNReal.mul_ne_top ENNReal.ofReal_ne_top
      (euclideanSetDudleyFunctionalENN_ne_top hTne hTb))
    (dudleyInequalityEuclidean_arbitrarySet_ENN hTb)

/-- Arbitrary bounded Euclidean-set Gaussian width is bounded by its Dudley entropy integral. Arbitrary bounded Euclidean set, safe real form.
Both sides are converted from their authoritative extended values only after
boundedness has certified finiteness.

**Book Theorem 8.1.8.** -/
theorem theorem_8_1_8_dudleyInequalityEuclidean_arbitrarySet
    {n : ℕ} {T : Set (EuclideanSpace ℝ (Fin n))}
    (hTne : T.Nonempty) (hTb : Bornology.IsBounded T) :
    euclideanSetGaussianWidth T ≤
      96 * Real.sqrt (8 / 3) * euclideanSetDudleyFunctional T := by
  have hbound := dudleyInequalityEuclidean_arbitrarySet_ENN hTb
  have hright : ENNReal.ofReal (96 * Real.sqrt (8 / 3)) *
      euclideanSetDudleyFunctionalENN T ≠ ⊤ :=
    ENNReal.mul_ne_top ENNReal.ofReal_ne_top
      (euclideanSetDudleyFunctionalENN_ne_top hTne hTb)
  have hreal := ENNReal.toReal_mono hright hbound
  have hcoef : (ENNReal.ofReal (96 * Real.sqrt (8 / 3))).toReal =
      96 * Real.sqrt (8 / 3) :=
    ENNReal.toReal_ofReal (by positivity)
  rw [ENNReal.toReal_mul, hcoef] at hreal
  exact hreal

