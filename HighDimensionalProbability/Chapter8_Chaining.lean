**Lean implementation helper.** -/
theorem expectedFiniteSupremum_chevetGaussianProcess {m n : ℕ}
    (T : Finset (EuclideanSpace ℝ (Fin n)))
    (S : Finset (EuclideanSpace ℝ (Fin m)))
    [Nonempty ↥T] [Nonempty ↥S]
    (hT : T.Nonempty) (hS : S.Nonempty)
    {rS rT : ℝ} (hrS : 0 ≤ rS) (hrT : 0 ≤ rT) :
    HDP.Chapter7.expectedFiniteSupremum
        ((stdGaussian (EuclideanSpace ℝ (Fin n))).prod
          (stdGaussian (EuclideanSpace ℝ (Fin m))))
        (finiteChevetGaussianProcess T S rS rT) =
      rS * HDP.Chapter7.gaussianWidth T +
        rT * HDP.Chapter7.gaussianWidth S := by
  have hTint := HDP.Chapter7.integrable_finiteGaussianSupport T
  have hSint := HDP.Chapter7.integrable_finiteGaussianSupport S
  have hTprod := hTint.comp_fst (stdGaussian (EuclideanSpace ℝ (Fin m)))
  have hSprod := hSint.comp_snd (stdGaussian (EuclideanSpace ℝ (Fin n)))
  unfold HDP.Chapter7.expectedFiniteSupremum
  change (∫ p, finiteProcessSup
      (finiteChevetGaussianProcess T S rS rT) p
      ∂(stdGaussian (EuclideanSpace ℝ (Fin n))).prod
        (stdGaussian (EuclideanSpace ℝ (Fin m)))) = _
