theorem exercise_8_37a_expectation
    {n : ℕ} {Ω : Type} [MeasurableSpace Ω]
    (μ : Measure Ω) [IsProbabilityMeasure μ]
    (T : Finset (EuclideanSpace ℝ (Fin n))) [Nonempty ↥T]
    (hT : T.Nonempty)
    (X : EuclideanSpace ℝ (Fin n) → Ω → ℝ)
    (hXm : ∀ x ∈ insert 0 T, Measurable (X x))
    (hzero : X 0 = 0)
    {K : ℝ} (hK : 0 ≤ K)
    (hinc : ∀ x ∈ insert 0 T, ∀ y ∈ insert 0 T,
      HDP.SubGaussian (fun ω => X x ω - X y ω) μ ∧
        HDP.psi2Norm (fun ω => X x ω - X y ω) μ ≤ K * ‖x - y‖) :
    (∫ ω, finiteProcessAbsoluteSup (finiteEuclideanProcess T X) ω ∂μ) ≤
      exercise837ExpectationConstant * K *
        HDP.Chapter7.gaussianComplexity T := by
  classical
  let A := insert (0 : EuclideanSpace ℝ (Fin n)) T
  letI : Nonempty ↥A := ⟨⟨0, by simp [A]⟩⟩
  let Z : HDP.RandomProcess ↥A Ω := finiteEuclideanProcess A X
  let d : ↥A → ↥A → ℝ := fun s t => dist s.1 t.1
  have hZm : ∀ z, Measurable (Z z) := fun z => hXm z.1 z.2
  have hZsub (z : ↥A) : HDP.SubGaussian (Z z) μ := by
    have hz := (hinc z.1 z.2 0 (by simp)).1
