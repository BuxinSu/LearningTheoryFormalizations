/-! ## Material formerly in `12_MajorizingMeasure.lean` -/

section Source_12_MajorizingMeasure

/-!
# Book Chapter 8, §8.5.3: the majorizing-measure theorem

The upper half is generic chaining.  The lower half is the deep
Fernique–Talagrand theorem which the source explicitly declines to prove.
Following the book-wide isolation policy, this core module exposes the lower
theorem as a named external principle.  Downstream comparison theorems carry
that principle as an explicit typeclass assumption.  The existence of such a
principle is stated, with its category-B placeholder, only in the isolated
book-level `Appendix.lean`; the root import graph never supplies it implicitly.
-/

open MeasureTheory ProbabilityTheory
open scoped ENNReal

namespace HDP.Chapter8

noncomputable section

/-- The canonical `L²` pseudometric of a real process, embedded into the
authoritative extended nonnegative reals used by `Book.gamma2`.

**Lean implementation helper.** -/
def canonicalProcessEDistance {I Ω : Type*} [MeasurableSpace Ω]
    (X : HDP.RandomProcess I Ω) (mu : Measure Ω) (s t : I) : ℝ≥0∞ :=
  ENNReal.ofReal (HDP.processIncrement X mu s t)

/-- Shows that the canonical extended process pseudometric vanishes on the diagonal.

**Lean implementation helper.** -/
theorem canonicalProcessEDistance_self {I Ω : Type*} [MeasurableSpace Ω]
    (X : HDP.RandomProcess I Ω) (mu : Measure Ω)
    (hX : HDP.IsL2Process X mu) (t : I) :
    canonicalProcessEDistance X mu t t = 0 := by
  simp [canonicalProcessEDistance, HDP.processIncrement_self t (hX t)]

/-- Shows that the canonical extended process pseudometric is symmetric in its arguments.

**Lean implementation helper.** -/
theorem canonicalProcessEDistance_comm {I Ω : Type*} [MeasurableSpace Ω]
    (X : HDP.RandomProcess I Ω) (mu : Measure Ω)
    (hX : HDP.IsL2Process X mu) (s t : I) :
    canonicalProcessEDistance X mu s t = canonicalProcessEDistance X mu t s := by
  rw [canonicalProcessEDistance, canonicalProcessEDistance,
    HDP.processIncrement_comm (hX s) (hX t)]

/-- Proves the triangle inequality for the canonical extended process pseudometric.

**Lean implementation helper.** -/
theorem canonicalProcessEDistance_triangle {I Ω : Type*} [MeasurableSpace Ω]
    (X : HDP.RandomProcess I Ω) (mu : Measure Ω)
    (hX : HDP.IsL2Process X mu) (r s t : I) :
    canonicalProcessEDistance X mu r t ≤
      canonicalProcessEDistance X mu r s + canonicalProcessEDistance X mu s t := by
  unfold canonicalProcessEDistance
  calc
    ENNReal.ofReal (HDP.processIncrement X mu r t) ≤
        ENNReal.ofReal
          (HDP.processIncrement X mu r s + HDP.processIncrement X mu s t) :=
      ENNReal.ofReal_le_ofReal (HDP.processIncrement_triangle hX r s t)
    _ = ENNReal.ofReal (HDP.processIncrement X mu r s) +
        ENNReal.ofReal (HDP.processIncrement X mu s t) :=
      ENNReal.ofReal_add
        (HDP.processIncrement_nonneg (hX r) (hX s))
        (HDP.processIncrement_nonneg (hX s) (hX t))

/-!
The source location is Book Theorem 8.5.5, PDF physical page 257 (printed
249).  The text explicitly omits the lower proof and cites Talagrand,
Theorem 2.4.1.  Mathlib v4.31.0 has no majorizing-measure theorem.  Encoding
the omitted input as a structure makes every logical dependency visible in
the type of a downstream theorem and avoids introducing an axiom or a hidden
placeholder into the main import graph.
-/

/-- The exact finite lower half of the Fernique--Talagrand
majorizing-measure theorem, packaged as an external principle.  The constant
is genuinely universal: it is chosen before the index type, probability
space, and Gaussian process. -/
class MajorizingMeasureLowerPrinciple : Type where
  constant : ℝ
  constant_pos : 0 < constant
  lower :
    ∀ {I Ω : Type} [Fintype I] [Nonempty I] [MeasurableSpace Ω]
      (mu : Measure Ω) [IsProbabilityMeasure mu]
      (X : HDP.RandomProcess I Ω),
      IsGaussianProcess X mu →
      HDP.IsCenteredProcess X mu →
      HDP.IsL2Process X mu →
      HDP.gamma2 (canonicalProcessEDistance X mu) ≠ ⊤ →
      (HDP.gamma2 (canonicalProcessEDistance X mu)).toReal ≤
        constant * HDP.Chapter7.expectedFiniteSupremum mu X

variable [majorizingMeasureLowerPrinciple : MajorizingMeasureLowerPrinciple]

/-- The universal constant supplied by an explicit lower-principle input.

**Lean implementation helper.** -/
def majorizingMeasureLowerConstant : ℝ :=
  MajorizingMeasureLowerPrinciple.constant

/-- Shows that the majorizing measure lower constant is strictly positive.

**Lean implementation helper.** -/
theorem majorizingMeasureLowerConstant_pos :
    0 < majorizingMeasureLowerConstant :=
  MajorizingMeasureLowerPrinciple.constant_pos

/-- Gaussian expected suprema are equivalent, up to universal constants, to `gamma2`. Specialized lower bound used by the comparison module.

**Book Theorem 8.5.5.** -/
theorem majorizingMeasure_lower
    {I Ω : Type} [Fintype I] [Nonempty I] [MeasurableSpace Ω]
    (mu : Measure Ω) [IsProbabilityMeasure mu]
    (X : HDP.RandomProcess I Ω)
    (hGaussian : IsGaussianProcess X mu)
    (hcentered : HDP.IsCenteredProcess X mu)
    (hL2 : HDP.IsL2Process X mu)
    (hfinite : HDP.gamma2 (canonicalProcessEDistance X mu) ≠ ⊤) :
    (HDP.gamma2 (canonicalProcessEDistance X mu)).toReal ≤
      majorizingMeasureLowerConstant *
        HDP.Chapter7.expectedFiniteSupremum mu X := by
  exact MajorizingMeasureLowerPrinciple.lower
    mu X hGaussian hcentered hL2 hfinite

end

end HDP.Chapter8

end Source_12_MajorizingMeasure

