/-- Generic-chaining bound for centered empirical processes.

**Book Exercise 8.36.** -/
theorem exercise_8_36_empiricalProcess
    {alpha : Type*} [MeasurableSpace alpha]
    {nu : Measure alpha} [IsProbabilityMeasure nu]
    [IsProbabilityMeasure μ]
    {n : ℕ} (hn : 0 < n)
    (X : Fin n → Ω → alpha) (hXm : ∀ i, Measurable (X i))
    (hXlaw : ∀ i, HasLaw (X i) nu μ) (hXind : iIndepFun X μ)
    (f : T → alpha → ℝ) (hfm : ∀ t, Measurable (f t))
    (t0 : T) (hanchor : f t0 = 0)
    (d : T → T → ℝ) (hd : ∀ s t, 0 ≤ d s t)
    (hsymm : ∀ s t, d s t = d t s)
    (htri : ∀ r s t, d r t ≤ d r s + d s t)
    (hd0 : ∀ t, d t t = 0)
    (hone : ∀ s t,
      HDP.SubGaussian (fun x => f t x - f s x) nu ∧
        HDP.psi2Norm (fun x => f t x - f s x) nu ≤ d t s) :
    (∫ omega, finiteProcessAbsoluteSup
        (iidCenteredEmpiricalProcess nu X f) omega ∂μ) ≤
      exercise836Constant / Real.sqrt n *
        (HDP.gamma2 (fun s t => ENNReal.ofReal (d s t))).toReal := by
  classical
  let Z : HDP.RandomProcess T Ω := iidCenteredEmpiricalProcess nu X f
  have hnR : (0 : ℝ) < n := by exact_mod_cast hn
  have hsqrtn : 0 < Real.sqrt (n : ℝ) := Real.sqrt_pos.2 hnR
  have hlog : 0 < Real.log (2 : ℝ) := Real.log_pos (by norm_num)
  let a : ℝ := 1 + 1 / Real.sqrt (Real.log 2)
  have ha : 0 < a := by
    dsimp [a]
    positivity
  have hfsub (t : T) : HDP.SubGaussian (f t) nu := by
    simpa [hanchor] using (hone t0 t).1
  have hfint (t : T) : Integrable (f t) nu := by
    exact ((hfsub t).memLp (hfm t).aemeasurable
      (show (1 : ℝ) ≤ 1 by rfl)).integrable (by norm_num)
  have hZm : ∀ t, Measurable (Z t) := by
    intro t
    dsimp [Z, iidCenteredEmpiricalProcess]
    exact (Finset.measurable_sum Finset.univ fun i _ =>
      ((hfm t).comp (hXm i)).sub measurable_const).const_mul _
  have hZanchor : Z t0 = 0 := by
    funext omega
    simp [Z, iidCenteredEmpiricalProcess, hanchor]
  have hinc : HDP.HasSubGaussianIncrementsWith Z μ d
      (exercise836IncrementConstant / Real.sqrt n) := by
    refine ⟨div_nonneg exercise836IncrementConstant_pos.le hsqrtn.le, ?_⟩
    intro s t
    let W : alpha → ℝ := fun x => f t x - f s x
    let C : alpha → ℝ := fun x => W x - ∫ y, W y ∂nu
    let Y : Fin n → Ω → ℝ := fun i omega => C (X i omega)
    have hWm : Measurable W := (hfm t).sub (hfm s)
    have hWsub : HDP.SubGaussian W nu := (hone s t).1
    have hWpsi : HDP.psi2Norm W nu ≤ d t s := (hone s t).2
    have hWint : Integrable W nu := by
      exact (hfint t).sub (hfint s)
    have hCm : Measurable C := hWm.sub measurable_const
    have hCcenter :
        HDP.SubGaussian C nu ∧ HDP.psi2Norm C nu ≤ a * d t s := by
      have hc := HDP.psi2Norm_centering hWm.aemeasurable hWsub
      refine ⟨hc.1, hc.2.trans ?_⟩
      exact mul_le_mul_of_nonneg_left hWpsi ha.le
    have hCmean : ∫ x, C x ∂nu = 0 := by
      rw [show C = fun x => W x - ∫ y, W y ∂nu by rfl,
        integral_sub hWint (integrable_const _), integral_const]
      simp
    have hYlaw (i : Fin n) :
        HasLaw (Y i) (Measure.map C nu) μ := by
      have hClaw : HasLaw C (Measure.map C nu) nu :=
        ⟨hCm.aemeasurable, rfl⟩
      simpa [Y, Function.comp_def] using hClaw.comp (hXlaw i)
    have hYm : ∀ i, AEMeasurable (Y i) μ := fun i => (hYlaw i).aemeasurable
    have hYsub : ∀ i, HDP.SubGaussian (Y i) μ := by
      intro i
      have hClaw : HasLaw C (Measure.map C nu) nu :=
        ⟨hCm.aemeasurable, rfl⟩
      exact subGaussian_of_sameLaw_aux (hYlaw i) hClaw hCcenter.1
    have hYpsi : ∀ i, HDP.psi2Norm (Y i) μ ≤ a * d t s := by
      intro i
      have hClaw : HasLaw C (Measure.map C nu) nu :=
        ⟨hCm.aemeasurable, rfl⟩
      calc
        HDP.psi2Norm (Y i) μ =
            HDP.psi2Norm (fun x : ℝ => x) (Measure.map C nu) :=
          HDP.psi2Norm_eq_of_hasLaw (hYlaw i)
        _ = HDP.psi2Norm C nu :=
          (HDP.psi2Norm_eq_of_hasLaw hClaw).symm
        _ ≤ a * d t s := hCcenter.2
    have hYmean : ∀ i, ∫ omega, Y i omega ∂μ = 0 := by
      intro i
      rw [show Y i = C ∘ X i by rfl,
        (hXlaw i).integral_comp hCm.aestronglyMeasurable, hCmean]
    have hYind : iIndepFun Y μ :=
      hXind.comp (fun _ x => C x) (fun _ => hCm)
    have hsum := HDP.psi2Norm_sum_sq_le hYm hYsub hYmean hYind
    have hsumPsi : HDP.psi2Norm (fun omega => ∑ i, Y i omega) μ ≤
        Real.sqrt 30 * Real.sqrt n * (a * d t s) := by
      have hsumEach : ∑ i, HDP.psi2Norm (Y i) μ ^ 2 ≤
          (n : ℝ) * (a * d t s) ^ 2 := by
        calc
          ∑ i, HDP.psi2Norm (Y i) μ ^ 2 ≤
              ∑ _i : Fin n, (a * d t s) ^ 2 := by
            apply Finset.sum_le_sum
            intro i hi
            exact (sq_le_sq₀ (HDP.psi2Norm_nonneg _ _)
              (mul_nonneg ha.le (hd t s))).2 (hYpsi i)
          _ = (n : ℝ) * (a * d t s) ^ 2 := by simp
      have hsumsq : HDP.psi2Norm (fun omega => ∑ i, Y i omega) μ ^ 2 ≤
          30 * (n : ℝ) * (a * d t s) ^ 2 := by
        calc
          _ ≤ 30 * ∑ i, HDP.psi2Norm (Y i) μ ^ 2 := hsum.2
          _ ≤ 30 * ((n : ℝ) * (a * d t s) ^ 2) := by gcongr
          _ = 30 * (n : ℝ) * (a * d t s) ^ 2 := by ring
      have hs30 : (Real.sqrt 30) ^ 2 = (30 : ℝ) :=
        Real.sq_sqrt (by norm_num)
      have hsn : (Real.sqrt (n : ℝ)) ^ 2 = (n : ℝ) :=
        Real.sq_sqrt hnR.le
      have hrhs : 0 ≤ Real.sqrt 30 * Real.sqrt n * (a * d t s) := by
        exact mul_nonneg
          (mul_nonneg (Real.sqrt_nonneg _) (Real.sqrt_nonneg _))
          (mul_nonneg ha.le (hd t s))
      apply (sq_le_sq₀ (HDP.psi2Norm_nonneg _ _) hrhs).1
      calc
        HDP.psi2Norm (fun omega => ∑ i, Y i omega) μ ^ 2 ≤
            30 * (n : ℝ) * (a * d t s) ^ 2 := hsumsq
        _ = (Real.sqrt 30 * Real.sqrt n * (a * d t s)) ^ 2 := by
          simp only [mul_pow, hs30, hsn]
    have hfun : (fun omega => Z t omega - Z s omega) =
        fun omega => (n : ℝ)⁻¹ * ∑ i, Y i omega := by
      funext omega
      dsimp [Z, iidCenteredEmpiricalProcess, Y, C, W]
      rw [← mul_sub, ← Finset.sum_sub_distrib]
      apply congrArg (fun z : ℝ => (n : ℝ)⁻¹ * z)
      apply Finset.sum_congr rfl
      intro i hi
      rw [integral_sub (hfint t) (hfint s)]
      ring
    constructor
    · rw [hfun]
      exact hsum.1.const_mul (n : ℝ)⁻¹
    · rw [hfun, HDP.psi2Norm_const_mul]
      have hinv : |(n : ℝ)⁻¹| = (n : ℝ)⁻¹ := abs_of_pos (inv_pos.mpr hnR)
      rw [hinv]
      calc
        (n : ℝ)⁻¹ * HDP.psi2Norm (fun omega => ∑ i, Y i omega) μ ≤
            (n : ℝ)⁻¹ *
              (Real.sqrt 30 * Real.sqrt n * (a * d t s)) := by
          gcongr
        _ = (exercise836IncrementConstant / Real.sqrt n) * d t s := by
          dsimp [exercise836IncrementConstant, a]
          rw [div_mul_eq_mul_div]
          field_simp [hnR.ne', hsqrtn.ne']
          rw [Real.sq_sqrt hnR.le]
  have hZint : ∀ t, Integrable (Z t) μ := by
    intro t
    have hsub : HDP.SubGaussian (Z t) μ := by
      have hi := (hinc.2 t0 t).1
      simpa [hZanchor] using hi
    exact (hsub.memLp (hZm t).aemeasurable
      (show (1 : ℝ) ≤ 1 by rfl)).integrable (by norm_num)
  have hpair := genericChainingSupremumOfIncrements
    Z hZm hZint d hd hsymm htri hd0 hinc
  rw [finiteProcessAbsoluteSup_eq_incrementSup_of_eq_zero Z t0 hZanchor]
  calc
    (∫ omega, finiteProcessIncrementSup Z t0 omega ∂μ) ≤
        ∫ omega, finiteProcessOscillation Z omega ∂μ := by
      apply integral_mono (integrable_finiteProcessIncrementSup Z t0 hZint)
        (integrable_finiteProcessOscillation Z hZint)
      intro omega
      unfold finiteProcessIncrementSup finiteProcessOscillation
      apply Finset.sup'_le
      intro t ht
      exact Finset.le_sup'
        (fun p : T × T => |Z p.1 omega - Z p.2 omega|)
        (show (t, t0) ∈ Finset.univ.product Finset.univ by simp)
    _ ≤ 2 * genericChainingConstant *
          (exercise836IncrementConstant / Real.sqrt n) *
          (HDP.gamma2 (fun s t => ENNReal.ofReal (d s t))).toReal := hpair
    _ = exercise836Constant / Real.sqrt n *
          (HDP.gamma2 (fun s t => ENNReal.ofReal (d s t))).toReal := by
      dsimp [exercise836Constant]
      ring

end

