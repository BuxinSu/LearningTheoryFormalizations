/-- Common-radius sharp Gaussian Chevet comparison, used as a proved helper
toward . The left family lies on its
outer sphere, or symmetrically the right family lies on its outer sphere;
the other family is an arbitrary finite subset of its enclosing Euclidean
ball. This is the direct fixed-radius Sudakov--Fernique specialization and
includes the sphere form used for Gaussian matrix operator norms. The full
arbitrary-set exercise requires a stronger comparison argument and is stated
separately below.

**Book Exercise 8.39(a).** -/
theorem exercise_8_39a_gaussian_chevet_of_one_constant_radius {m n : ℕ}
    (T : Finset (EuclideanSpace ℝ (Fin n)))
    (S : Finset (EuclideanSpace ℝ (Fin m)))
    [Nonempty ↥T] [Nonempty ↥S]
    (hT : T.Nonempty) (hS : S.Nonempty)
    (hcommon :
      (∀ x ∈ T, ‖x‖ = HDP.Chapter7.finiteRadius T) ∨
        (∀ y ∈ S, ‖y‖ = HDP.Chapter7.finiteRadius S)) :
    HDP.Chapter7.expectedFiniteSupremum
        (stdGaussian (EuclideanSpace ℝ (Fin m × Fin n)))
        (finiteGaussianMatrixChevetProcess T S) ≤
      HDP.Chapter7.gaussianWidth T * HDP.Chapter7.finiteRadius S +
        HDP.Chapter7.gaussianWidth S * HDP.Chapter7.finiteRadius T := by
  let u : ChevetIndex T S → EuclideanSpace ℝ (Fin n) := fun p => p.1.1
  let v : ChevetIndex T S → EuclideanSpace ℝ (Fin m) := fun p => p.2.1
  let rT := HDP.Chapter7.finiteRadius T
  let rS := HDP.Chapter7.finiteRadius S
  let X := rankOneCanonicalGaussianProcess u v
  let Y := sumCanonicalGaussianProcess (fun p => rS • u p) (fun p => rT • v p)
  have hXG : IsGaussianProcess X
      (stdGaussian (EuclideanSpace ℝ (Fin m × Fin n))) := by
    simpa [X, rankOneCanonicalGaussianProcess] using
      HDP.Chapter7.canonicalGaussianProcess_isGaussian
        (fun p : ChevetIndex T S => rankOneGaussianPoint (u p) (v p))
  have hX0 : HDP.IsCenteredProcess X
      (stdGaussian (EuclideanSpace ℝ (Fin m × Fin n))) := by
    simpa [X, rankOneCanonicalGaussianProcess] using
      HDP.Chapter7.canonicalGaussianProcess_centered
        (fun p : ChevetIndex T S => rankOneGaussianPoint (u p) (v p))
  have hYG := sumCanonicalGaussianProcess_isGaussian
    (fun p => rS • u p) (fun p => rT • v p)
  have hY0 := sumCanonicalGaussianProcess_centered
    (fun p => rS • u p) (fun p => rT • v p)
  have hinc : ∀ p q,
      HDP.Chapter7.processIncrementSecondMoment
          (stdGaussian (EuclideanSpace ℝ (Fin m × Fin n))) X p q ≤
        HDP.Chapter7.processIncrementSecondMoment
          ((stdGaussian (EuclideanSpace ℝ (Fin n))).prod
            (stdGaussian (EuclideanSpace ℝ (Fin m)))) Y p q := by
    intro p q
    rcases hcommon with hu | hv
    · exact
        rankOneCanonical_incrementSecondMoment_le_sumCanonical_of_left_norm_eq
          u v rT rS (finiteRadius_nonneg S hS)
          (fun z => hu z.1.1 z.1.2)
          (fun z => HDP.Chapter7.norm_le_finiteRadius S hS z.2.2) p q
    · exact
        rankOneCanonical_incrementSecondMoment_le_sumCanonical_of_right_norm_eq
          u v rT rS (finiteRadius_nonneg T hT)
          (fun z => HDP.Chapter7.norm_le_finiteRadius T hT z.1.2)
          (fun z => hv z.2.1 z.2.2) p q
  have hcomp := HDP.Chapter7.sudakovFernique
    (stdGaussian (EuclideanSpace ℝ (Fin m × Fin n)))
    ((stdGaussian (EuclideanSpace ℝ (Fin n))).prod
      (stdGaussian (EuclideanSpace ℝ (Fin m)))) X Y hXG hYG hX0 hY0 hinc
  have hrT : 0 ≤ rT := finiteRadius_nonneg T hT
  have hrS : 0 ≤ rS := finiteRadius_nonneg S hS
  have hYeq : Y = finiteChevetGaussianProcess T S rS rT := by
    funext p gh
    change inner ℝ (rS • p.1.1) gh.1 + inner ℝ (rT • p.2.1) gh.2 =
      rS * inner ℝ gh.1 p.1.1 + rT * inner ℝ gh.2 p.2.1
    rw [inner_smul_left, inner_smul_left,
      real_inner_comm p.1.1 gh.1, real_inner_comm p.2.1 gh.2]
    simp
  have hEY : HDP.Chapter7.expectedFiniteSupremum
      ((stdGaussian (EuclideanSpace ℝ (Fin n))).prod
        (stdGaussian (EuclideanSpace ℝ (Fin m)))) Y =
      rS * HDP.Chapter7.gaussianWidth T +
        rT * HDP.Chapter7.gaussianWidth S := by
    rw [hYeq]
    exact expectedFiniteSupremum_chevetGaussianProcess T S hT hS hrS hrT
  change HDP.Chapter7.expectedFiniteSupremum
      (stdGaussian (EuclideanSpace ℝ (Fin m × Fin n))) X ≤ _
  calc
    HDP.Chapter7.expectedFiniteSupremum
        (stdGaussian (EuclideanSpace ℝ (Fin m × Fin n))) X ≤
      HDP.Chapter7.expectedFiniteSupremum
        ((stdGaussian (EuclideanSpace ℝ (Fin n))).prod
          (stdGaussian (EuclideanSpace ℝ (Fin m)))) Y := hcomp
    _ = HDP.Chapter7.gaussianWidth T * HDP.Chapter7.finiteRadius S +
        HDP.Chapter7.gaussianWidth S * HDP.Chapter7.finiteRadius T := by
      rw [hEY]
      simp only [rT, rS]
      ring

