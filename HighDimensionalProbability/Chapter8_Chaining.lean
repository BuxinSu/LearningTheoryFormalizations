theorem theorem_8_6_1_subgaussian_chevet_arbitrary_bounded_real
    {m n : ℕ} [IsProbabilityMeasure μ]
    (A : Fin m → Ω → EuclideanSpace ℝ (Fin n))
    (hM : ∀ i x, Measurable (fun ω => inner ℝ (A i ω) x))
    (hsub : ∀ i, HDP.SubGaussianVector (A i) μ)
    (hmean : ∀ i x, ∫ ω, inner ℝ (A i ω) x ∂μ = 0)
    (hindep : iIndepFun A μ)
    (hbounded : ∀ i, BddAbove {r : ℝ |
      ∃ x : EuclideanSpace ℝ (Fin n), ‖x‖ = 1 ∧
        r = HDP.psi2Norm (fun ω => inner ℝ (A i ω) x) μ})
    {K : ℝ} (hK : 0 ≤ K)
    (hpsi : ∀ i, HDP.psi2NormVector (A i) μ ≤ K)
    (T : Set (EuclideanSpace ℝ (Fin n)))
    (S : Set (EuclideanSpace ℝ (Fin m)))
    (hT : T.Nonempty) (hS : S.Nonempty)
    (hTb : Bornology.IsBounded T) (hSb : Bornology.IsBounded S) :
    (subGaussianChevetExpectationEnvelope μ A T S).toReal ≤
      chevetConstant * K *
        ((setGaussianWidthEnvelope T).toReal *
            (setRadiusEnvelope S).toReal +
          (setGaussianWidthEnvelope S).toReal *
            (setRadiusEnvelope T).toReal) := by
  have hwT := setGaussianWidthEnvelope_ne_top_of_isBounded hTb
  have hwS := setGaussianWidthEnvelope_ne_top_of_isBounded hSb
  have hrT := setRadiusEnvelope_ne_top_of_isBounded hTb
  have hrS := setRadiusEnvelope_ne_top_of_isBounded hSb
  have hpTS : setGaussianWidthEnvelope T * setRadiusEnvelope S ≠ ⊤ :=
    ENNReal.mul_ne_top hwT hrS
  have hpST : setGaussianWidthEnvelope S * setRadiusEnvelope T ≠ ⊤ :=
    ENNReal.mul_ne_top hwS hrT
  have hsum : setGaussianWidthEnvelope T * setRadiusEnvelope S +
      setGaussianWidthEnvelope S * setRadiusEnvelope T ≠ ⊤ :=
    ENNReal.add_ne_top.mpr ⟨hpTS, hpST⟩
  have hcK : 0 ≤ chevetConstant * K :=
    mul_nonneg chevetConstant_pos.le hK
  have hrhs : ENNReal.ofReal (chevetConstant * K) *
      (setGaussianWidthEnvelope T * setRadiusEnvelope S +
        setGaussianWidthEnvelope S * setRadiusEnvelope T) ≠ ⊤ :=
    ENNReal.mul_ne_top ENNReal.ofReal_ne_top hsum
  have hlhs := subGaussianChevetExpectationEnvelope_ne_top_of_isBounded
    A hM hsub hmean hindep hbounded hK hpsi hT hS hTb hSb
  have hreal := (ENNReal.toReal_le_toReal hlhs hrhs).2
    (theorem_8_6_1_subgaussian_chevet_arbitrary
      A hM hsub hmean hindep hbounded hK hpsi T S hT hS)
  rw [ENNReal.toReal_mul, ENNReal.toReal_ofReal hcK,
    ENNReal.toReal_add hpTS hpST, ENNReal.toReal_mul,
    ENNReal.toReal_mul] at hreal
  exact hreal

/-- An `m × n` matrix with independent subgaussian columns is the row-wise setup
after exchanging the ambient dimensions. This wrapper records the source's
column clause at the same arbitrary-set finite-subfamily scope.

**Book Theorem 8.6.1.** -/
theorem theorem_8_6_1_subgaussian_chevet_columns_arbitrary {m n : ℕ}
    [IsProbabilityMeasure μ]
    (A : Fin n → Ω → EuclideanSpace ℝ (Fin m))
    (hM : ∀ j x, Measurable (fun ω => inner ℝ (A j ω) x))
    (hsub : ∀ j, HDP.SubGaussianVector (A j) μ)
    (hmean : ∀ j x, ∫ ω, inner ℝ (A j ω) x ∂μ = 0)
    (hindep : iIndepFun A μ)
    (hbounded : ∀ j, BddAbove {r : ℝ |
      ∃ x : EuclideanSpace ℝ (Fin m), ‖x‖ = 1 ∧
        r = HDP.psi2Norm (fun ω => inner ℝ (A j ω) x) μ})
    {K : ℝ} (hK : 0 ≤ K)
    (hpsi : ∀ j, HDP.psi2NormVector (A j) μ ≤ K)
    (S : Set (EuclideanSpace ℝ (Fin m)))
    (T : Set (EuclideanSpace ℝ (Fin n)))
    (hS : S.Nonempty) (hT : T.Nonempty) :
    subGaussianChevetExpectationEnvelope μ A S T ≤
      ENNReal.ofReal (chevetConstant * K) *
        (setGaussianWidthEnvelope S * setRadiusEnvelope T +
          setGaussianWidthEnvelope T * setRadiusEnvelope S) :=
  theorem_8_6_1_subgaussian_chevet_arbitrary
    A hM hsub hmean hindep hbounded hK hpsi S T hS hT

/-- This declaration formalizes the statement identified as Theorem 8.6.1 in the source.

**Book Theorem 8.6.1.** -/
theorem theorem_8_6_1_subgaussian_chevet_columns_arbitrary_bounded_real
    {m n : ℕ} [IsProbabilityMeasure μ]
    (A : Fin n → Ω → EuclideanSpace ℝ (Fin m))
    (hM : ∀ j x, Measurable (fun ω => inner ℝ (A j ω) x))
    (hsub : ∀ j, HDP.SubGaussianVector (A j) μ)
    (hmean : ∀ j x, ∫ ω, inner ℝ (A j ω) x ∂μ = 0)
    (hindep : iIndepFun A μ)
    (hbounded : ∀ j, BddAbove {r : ℝ |
      ∃ x : EuclideanSpace ℝ (Fin m), ‖x‖ = 1 ∧
        r = HDP.psi2Norm (fun ω => inner ℝ (A j ω) x) μ})
    {K : ℝ} (hK : 0 ≤ K)
    (hpsi : ∀ j, HDP.psi2NormVector (A j) μ ≤ K)
    (S : Set (EuclideanSpace ℝ (Fin m)))
    (T : Set (EuclideanSpace ℝ (Fin n)))
