      exact (by
        calc
          0 ≤ inner ℝ g y + |inner ℝ g y| := by
            linarith [neg_le_abs (inner ℝ g y)]
          _ ≤ HDP.Chapter7.finiteGaussianSupport T g +
              |inner ℝ g y| := add_le_add hymax (le_refl _))
    · exact (by
        have hxmax : inner ℝ g x ≤
            HDP.Chapter7.finiteGaussianSupport T g := by
          rw [HDP.Chapter7.finiteGaussianSupport_eq_sup' T hT']
