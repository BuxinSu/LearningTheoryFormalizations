/-- The product-Gaussian comparison process is centered.

**Lean implementation helper.** -/
theorem sumCanonicalGaussianProcess_centered
    {I E F : Type*}
    [NormedAddCommGroup E] [InnerProductSpace ℝ E]
    [FiniteDimensional ℝ E] [MeasurableSpace E] [BorelSpace E]
    [NormedAddCommGroup F] [InnerProductSpace ℝ F]
    [FiniteDimensional ℝ F] [MeasurableSpace F] [BorelSpace F]
    (u : I → E) (v : I → F) :
    HDP.IsCenteredProcess (sumCanonicalGaussianProcess u v)
      ((stdGaussian E).prod (stdGaussian F)) := by
  intro i
  have hu : Integrable (fun g : E => inner ℝ (u i) g) (stdGaussian E) :=
    (memLp_two_inner_stdGaussian (u i)).integrable (by norm_num)
  have hv : Integrable (fun z : F => inner ℝ (v i) z) (stdGaussian F) :=
    (memLp_two_inner_stdGaussian (v i)).integrable (by norm_num)
  have hEu : (∫ g : E, inner ℝ (u i) g ∂stdGaussian E) = 0 := by
    simpa only [innerSL_apply_apply] using
      integral_strongDual_stdGaussian ((innerSL ℝ) (u i))
  have hFv : (∫ z : F, inner ℝ (v i) z ∂stdGaussian F) = 0 := by
    simpa only [innerSL_apply_apply] using
      integral_strongDual_stdGaussian ((innerSL ℝ) (v i))
  change (∫ p : E × F, inner ℝ (u i) p.1 + inner ℝ (v i) p.2
    ∂(stdGaussian E).prod (stdGaussian F)) = 0
  rw [integral_add (hu.comp_fst _) (hv.comp_snd _)]
  rw [integral_prod _ (hu.comp_fst _), integral_prod _ (hv.comp_snd _)]
  simp [hEu, hFv]

