increment supremum.

**Lean implementation helper.** -/
theorem finiteProcessAbsoluteSup_eq_incrementSup_of_eq_zero
    (Z : HDP.RandomProcess T Ω) (t0 : T) (hzero : Z t0 = 0) :
    finiteProcessAbsoluteSup Z = finiteProcessIncrementSup Z t0 := by
  funext omega
  unfold finiteProcessAbsoluteSup finiteProcessIncrementSup
  apply Finset.sup'_congr
  · rfl
  · intro t ht
    rw [show Z t0 omega = 0 by simpa using congrFun hzero omega, sub_zero]

/-- Subgaussianity is invariant under replacing a random variable by another
with the same law.

**Lean implementation helper.** -/
private theorem subGaussian_of_sameLaw_aux
    {Omega1 Omega2 : Type*} [MeasurableSpace Omega1] [MeasurableSpace Omega2]
    {P1 : Measure Omega1} {P2 : Measure Omega2} {rho : Measure ℝ}
    {Y1 : Omega1 → ℝ} {Y2 : Omega2 → ℝ}
    (h1 : HasLaw Y1 rho P1) (h2 : HasLaw Y2 rho P2)
    (hsub : HDP.SubGaussian Y2 P2) : HDP.SubGaussian Y1 P1 := by
  obtain ⟨K, hK, hmgf⟩ := hsub
  refine ⟨K, hK, ?_⟩
  calc
    HDP.psi2MGF Y1 P1 K =
        HDP.psi2MGF (fun x : ℝ => x) rho K :=
      HDP.psi2MGF_eq_of_hasLaw h1 K
    _ = HDP.psi2MGF Y2 P2 K :=
      (HDP.psi2MGF_eq_of_hasLaw h2 K).symm
    _ ≤ 2 := hmgf

