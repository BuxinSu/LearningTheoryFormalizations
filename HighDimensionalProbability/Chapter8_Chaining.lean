/-! ## Material formerly in `14_ChevetInequality.lean` -/

section Source_14_ChevetInequality

/-!
# Book Chapter 8, §8.6: Chevet inequalities

This module starts with the row-wise bilinear process used in the proof of
Chevet's inequality.  Its increment estimate is proved directly from the
promoted Exercise 3.34 API; in particular, independence and centering are
assumptions on the rows rather than on the matrix entries.
-/

open MeasureTheory ProbabilityTheory Real InnerProductSpace
open scoped BigOperators ENNReal NNReal RealInnerProductSpace

namespace HDP.Chapter8

noncomputable section

/- Subgaussian Chevet and the Talagrand-comparison consequences are
conditional on the externally supplied lower majorizing-measure principle. -/
variable [hMM : MajorizingMeasureLowerPrinciple]

variable {Ω : Type} {mΩ : MeasurableSpace Ω} {μ : Measure Ω}

/-- The bilinear process `⟨Au,v⟩`, written in terms of the random rows of
`A`. This is the process denoted `X_{uv}` in the proof of Theorem 8.6.1.

**Book Theorem 8.6.1.** -/
def rowBilinearProcess {m n : ℕ}
    (A : Fin m → Ω → EuclideanSpace ℝ (Fin n))
    (u : EuclideanSpace ℝ (Fin n))
    (v : EuclideanSpace ℝ (Fin m)) (ω : Ω) : ℝ :=
  ∑ i, v i * inner ℝ (A i ω) u

/-- Finite Chevet index type attached to two finite Euclidean sets. -/
abbrev ChevetIndex {m n : ℕ}
    (T : Finset (EuclideanSpace ℝ (Fin n)))
    (S : Finset (EuclideanSpace ℝ (Fin m))) :=
  ↥T × ↥S

/-- The bilinear process indexed by the finite product `T × S`.

**Lean implementation helper.** -/
def finiteChevetProcess {m n : ℕ}
    (A : Fin m → Ω → EuclideanSpace ℝ (Fin n))
    (T : Finset (EuclideanSpace ℝ (Fin n)))
    (S : Finset (EuclideanSpace ℝ (Fin m))) :
    HDP.RandomProcess (ChevetIndex T S) Ω :=
  fun p => rowBilinearProcess A p.1.1 p.2.1

/-- The comparison process from the proof of Theorem 8.6.1, on two
independent standard Gaussian vectors. The two scale factors will be the
radii of `S` and `T`, respectively.

**Book Theorem 8.6.1.** -/
def finiteChevetGaussianProcess {m n : ℕ}
    (T : Finset (EuclideanSpace ℝ (Fin n)))
    (S : Finset (EuclideanSpace ℝ (Fin m)))
    (rS rT : ℝ) :
    HDP.RandomProcess (ChevetIndex T S)
      (EuclideanSpace ℝ (Fin n) × EuclideanSpace ℝ (Fin m)) :=
  fun p gh =>
    rS * inner ℝ gh.1 p.1.1 + rT * inner ℝ gh.2 p.2.1

omit hMM in
/-- The maximum of the product comparison process separates into the two
support functions. This is the pointwise identity used in the last line of
the proof of Chevet's inequality.

**Lean implementation helper.** -/
theorem finiteProcessSup_chevetGaussianProcess {m n : ℕ}
    (T : Finset (EuclideanSpace ℝ (Fin n)))
    (S : Finset (EuclideanSpace ℝ (Fin m)))
    [Nonempty ↥T] [Nonempty ↥S]
    (hT : T.Nonempty) (hS : S.Nonempty)
    {rS rT : ℝ} (hrS : 0 ≤ rS) (hrT : 0 ≤ rT)
    (g : EuclideanSpace ℝ (Fin n))
    (h : EuclideanSpace ℝ (Fin m)) :
    finiteProcessSup (finiteChevetGaussianProcess T S rS rT) (g, h) =
      rS * HDP.Chapter7.finiteGaussianSupport T g +
        rT * HDP.Chapter7.finiteGaussianSupport S h := by
  classical
  rw [HDP.Chapter7.finiteGaussianSupport_eq_sup' T hT,
    HDP.Chapter7.finiteGaussianSupport_eq_sup' S hS]
  apply le_antisymm
  · unfold finiteProcessSup
    apply Finset.sup'_le
    intro p hp
    dsimp [finiteChevetGaussianProcess]
    exact add_le_add
      (mul_le_mul_of_nonneg_left
        (Finset.le_sup' (fun x => inner ℝ g x) p.1.2) hrS)
      (mul_le_mul_of_nonneg_left
        (Finset.le_sup' (fun y => inner ℝ h y) p.2.2) hrT)
  · obtain ⟨uMax, huMax, hgu⟩ :=
      Finset.exists_mem_eq_sup' hT (fun x => inner ℝ g x)
    obtain ⟨vMax, hvMax, hhv⟩ :=
      Finset.exists_mem_eq_sup' hS (fun y => inner ℝ h y)
    let p : ChevetIndex T S := (⟨uMax, huMax⟩, ⟨vMax, hvMax⟩)
    calc
      rS * T.sup' hT (fun x => inner ℝ g x) +
          rT * S.sup' hS (fun y => inner ℝ h y) =
          finiteChevetGaussianProcess T S rS rT p (g, h) := by
        simp only [finiteChevetGaussianProcess, p, hgu, hhv]
      _ ≤ finiteProcessSup (finiteChevetGaussianProcess T S rS rT) (g, h) := by
        unfold finiteProcessSup
        exact Finset.le_sup'
          (fun q : ChevetIndex T S =>
            finiteChevetGaussianProcess T S rS rT q (g, h))
          (Finset.mem_univ p)

omit hMM in
/-- The supremum of the finite comparison Gaussian process splits into the weighted sum of the two finite Gaussian support functions.

**Lean implementation helper.** -/
