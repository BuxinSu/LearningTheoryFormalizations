    have hmul := mul_le_mul_of_nonneg_right hnA (pow_nonneg hε.le 4)
    have hAcancel : A * ε ^ 4 = 1024 * (d : ℝ) * r := by
      dsimp [A]
      field_simp [hε.ne']
    rw [hAcancel] at hmul
    nlinarith
  have hlog : Real.log ((100 : ℝ) * (m : ℝ) ^ 2) ≤
      (vcCoverSampleSize m d ε : ℝ) * ε ^ 4 / 8 :=
    hlogprod.trans hT
  have hexpLower : (100 : ℝ) * (m : ℝ) ^ 2 ≤
      Real.exp ((vcCoverSampleSize m d ε : ℝ) * ε ^ 4 / 8) :=
    (Real.log_le_iff_le_exp (by positivity)).mp hlog
  rw [show -(vcCoverSampleSize m d ε : ℝ) * ε ^ 4 / 8 =
      -((vcCoverSampleSize m d ε : ℝ) * ε ^ 4 / 8) by ring,
    Real.exp_neg]
  have hEpos : 0 < Real.exp
      ((vcCoverSampleSize m d ε : ℝ) * ε ^ 4 / 8) := Real.exp_pos _
  rw [← div_eq_mul_inv, div_le_iff₀ hEpos]
  nlinarith [hexpLower]

/-- The chosen VC sample size is at most `2048 ε⁻⁴ d m^(1/(2d))`.

**Lean implementation helper.** -/
private theorem vcCoverSampleSize_upper {m d : ℕ} {ε : ℝ}
    (hm : 2 ≤ m) (hd : 1 ≤ d) (hε : 0 < ε) (hε1 : ε < 1) :
    (vcCoverSampleSize m d ε : ℝ) ≤
      2048 * ε⁻¹ ^ 4 * (d : ℝ) *
        (m : ℝ) ^ (1 / (2 * (d : ℝ))) := by
  let r : ℝ := (m : ℝ) ^ (1 / (2 * (d : ℝ)))
  let A : ℝ := 1024 * ε⁻¹ ^ 4 * (d : ℝ) * r
  have hmR : (0 : ℝ) < m := by exact_mod_cast (lt_of_lt_of_le Nat.zero_lt_two hm)
  have hinv : 1 ≤ ε⁻¹ := (one_le_inv₀ hε).2 hε1.le
  have hr1 : 1 ≤ r := by
    dsimp [r]
    exact Real.one_le_rpow (by exact_mod_cast (show 1 ≤ m by omega)) (by positivity)
  have hdR1 : (1 : ℝ) ≤ d := by exact_mod_cast hd
  have hA1 : 1 ≤ A := by
    dsimp [A]
    have hpow : 1 ≤ ε⁻¹ ^ 4 := one_le_pow₀ hinv
    have hpd : (1 : ℝ) ≤ ε⁻¹ ^ 4 * (d : ℝ) := by
      simpa using mul_le_mul hpow hdR1 (by norm_num : (0 : ℝ) ≤ 1)
        (by positivity : (0 : ℝ) ≤ ε⁻¹ ^ 4)
    have hpdr : (1 : ℝ) ≤ ε⁻¹ ^ 4 * (d : ℝ) * r := by
      simpa using mul_le_mul hpd hr1 (by norm_num : (0 : ℝ) ≤ 1)
        (mul_nonneg (pow_nonneg (by positivity) 4) (Nat.cast_nonneg d))
    nlinarith
  have hceil := (Nat.ceil_lt_add_one (by linarith [hA1] : (0 : ℝ) ≤ A)).le
  change (⌈A⌉₊ : ℝ) ≤ 2048 * ε⁻¹ ^ 4 * (d : ℝ) * r
  calc
    (⌈A⌉₊ : ℝ) ≤ A + 1 := hceil
    _ ≤ 2 * A := by linarith
    _ = 2048 * ε⁻¹ ^ 4 * (d : ℝ) * r := by
      dsimp [A]
      ring

/-- Bounds the vc dim by the sample size used in the VC covering argument.

**Lean implementation helper.** -/
private theorem vcDim_le_vcCoverSampleSize {m d : ℕ} {ε : ℝ}
    (hm : 2 ≤ m) (hd : 1 ≤ d) (hε : 0 < ε) (hε1 : ε < 1) :
    d ≤ vcCoverSampleSize m d ε := by
  let r : ℝ := (m : ℝ) ^ (1 / (2 * (d : ℝ)))
  let A : ℝ := 1024 * ε⁻¹ ^ 4 * (d : ℝ) * r
  have hinv : 1 ≤ ε⁻¹ := (one_le_inv₀ hε).2 hε1.le
  have hr1 : 1 ≤ r := by
    dsimp [r]
    exact Real.one_le_rpow (by exact_mod_cast (show 1 ≤ m by omega)) (by positivity)
  have hA : (d : ℝ) ≤ A := by
    dsimp [A]
    have hd0 : (0 : ℝ) ≤ d := Nat.cast_nonneg d
    have hpow : (1 : ℝ) ≤ ε⁻¹ ^ 4 := one_le_pow₀ hinv
    have hfac : 1 ≤ 1024 * ε⁻¹ ^ 4 * r := by
      have hp : (1 : ℝ) ≤ ε⁻¹ ^ 4 * r := by
        simpa using mul_le_mul hpow hr1 (by norm_num : (0 : ℝ) ≤ 1)
          (pow_nonneg (by positivity) 4)
      nlinarith
    nlinarith
  have hceil : A ≤ (vcCoverSampleSize m d ε : ℝ) := Nat.le_ceil A
  exact_mod_cast hA.trans hceil

/-- For `0 < ε < 1`, a finite Boolean class of VC dimension `d` has internal
`L²(μ)` covering number at most
`ceil ((2/ε)^(26 d))`. Thus the source's unspecified universal constant may
be taken to be `C = 26` in this finite formalization. There is no sample-size or probability premise: the auxiliary dimension is
chosen and eliminated inside the proof.

**Book Theorem 8.3.13.** -/
theorem theorem_8_3_13_vc_covering [Finite α] [IsProbabilityMeasure μ]
    (F : BooleanFamily α) (ε : ℝ≥0) (hε : 0 < ε) (hε1 : ε < 1) :
    Metric.coveringNumber ε (booleanLpClass μ F) ≤
      (⌈((2 : ℝ) / (ε : ℝ)) ^ (26 * F.vcDim)⌉₊ : ℕ) := by
  letI := Fintype.ofFinite α
  let d : ℕ := F.vcDim
  let m : ℕ := booleanPackingNumber μ F ε
  have hcoverpack : Metric.coveringNumber ε (booleanLpClass μ F) ≤
      Metric.packingNumber ε (booleanLpClass μ F) :=
    Metric.coveringNumber_le_packingNumber ε _
  have hpackcoe : (m : ℕ∞) =
      Metric.packingNumber ε (booleanLpClass μ F) := by
    change (booleanPackingNumber μ F ε : ℕ∞) =
      Metric.packingNumber ε (booleanLpClass μ F)
    exact coe_booleanPackingNumber (μ := μ) F ε
  by_cases hd0 : d = 0
  · have hFone : F.card ≤ 1 := lemma_8_3_9_zero_vc F (by simpa [d] using hd0)
    have hKcard : (booleanLpClass μ F).encard ≤ (F.card : ℕ∞) := by
      simpa [booleanLpClass] using
        (Set.encard_image_le (booleanLp μ) (F : Set (Finset α)))
    calc
      Metric.coveringNumber ε (booleanLpClass μ F) ≤
          (booleanLpClass μ F).encard :=
        Metric.coveringNumber_le_encard_self _
      _ ≤ (F.card : ℕ∞) := hKcard
      _ ≤ (1 : ℕ) := by exact_mod_cast hFone
      _ = (⌈((2 : ℝ) / (ε : ℝ)) ^ (26 * F.vcDim)⌉₊ : ℕ) := by
        simp [d] at hd0
        simp [hd0]
  · have hd : 1 ≤ d := Nat.one_le_iff_ne_zero.mpr hd0
    by_cases hm : m < 2
    · have hm1 : m ≤ 1 := by omega
      have hRpos : 0 < ((2 : ℝ) / (ε : ℝ)) ^ (26 * F.vcDim) := by
        positivity
      have honeceil : 1 ≤ ⌈((2 : ℝ) / (ε : ℝ)) ^ (26 * F.vcDim)⌉₊ :=
        Nat.one_le_ceil_iff.mpr hRpos
      calc
        Metric.coveringNumber ε (booleanLpClass μ F) ≤
            Metric.packingNumber ε (booleanLpClass μ F) := hcoverpack
        _ = (m : ℕ∞) := hpackcoe.symm
        _ ≤ (1 : ℕ) := by exact_mod_cast hm1
        _ ≤ (⌈((2 : ℝ) / (ε : ℝ)) ^ (26 * F.vcDim)⌉₊ : ℕ) := by
          exact_mod_cast honeceil
    · have hm2 : 2 ≤ m := by omega
      let n : ℕ := vcCoverSampleSize m d (ε : ℝ)
      have hn : 0 < n := vcCoverSampleSize_pos (show 1 ≤ m by omega) hd
        (by exact_mod_cast hε)
      have hfailure : (m : ℝ) ^ 2 *
          Real.exp (-(n : ℝ) * (ε : ℝ) ^ 4 / 8) ≤ 1 / 100 := by
        simpa [n] using vcCoverSampleSize_failure_bound hm2 hd
          (by exact_mod_cast hε) (by exact_mod_cast hε1)
      have hpackbound := theorem_8_3_13_dimension_reduction_packing_bound
        (μ := μ) F (d := d) (n := n) (by simp [d]) hn ε hε (by
          simpa [m] using hfailure)
      have hmNat : m ≤ ∑ k ∈ Finset.range (d + 1), n.choose k := by
        have hcoe := hpackcoe.trans_le hpackbound
        exact_mod_cast hcoe
      have hdn : d ≤ n := by
        simpa [n] using vcDim_le_vcCoverSampleSize hm2 hd
          (by exact_mod_cast hε) (by exact_mod_cast hε1)
      have hbinom :
          ((∑ k ∈ Finset.range (d + 1), n.choose k : ℕ) : ℝ) ≤
            (Real.exp 1 * (n : ℝ) / (d : ℝ)) ^ d := by
        simpa [HDP.Chapter4.hammingBallVolume] using
          HDP.Chapter4.binomialPartialSum_le n d hd hdn
      have hnupper : (n : ℝ) ≤
          2048 * (ε : ℝ)⁻¹ ^ 4 * (d : ℝ) *
            (m : ℝ) ^ (1 / (2 * (d : ℝ))) := by
        simpa [n] using vcCoverSampleSize_upper hm2 hd
          (by exact_mod_cast hε) (by exact_mod_cast hε1)
      have hbase : Real.exp 1 * (n : ℝ) / (d : ℝ) ≤
          6144 * (ε : ℝ)⁻¹ ^ 4 *
            (m : ℝ) ^ (1 / (2 * (d : ℝ))) := by
        have he : Real.exp 1 ≤ 3 := Real.exp_one_lt_three.le
        have hdR : (0 : ℝ) < d := by exact_mod_cast (Nat.zero_lt_of_lt hd)
        apply (div_le_iff₀ hdR).2
        have hmul := mul_le_mul he hnupper (Nat.cast_nonneg n)
          (by norm_num : (0 : ℝ) ≤ 3)
        nlinarith
      have hmReal : (m : ℝ) ≤
          (6144 * (ε : ℝ)⁻¹ ^ 4 *
            (m : ℝ) ^ (1 / (2 * (d : ℝ)))) ^ d := by
        calc
          (m : ℝ) ≤ (∑ k ∈ Finset.range (d + 1), n.choose k : ℕ) := by
            exact_mod_cast hmNat
          _ ≤ (Real.exp 1 * (n : ℝ) / (d : ℝ)) ^ d := hbinom
          _ ≤ (6144 * (ε : ℝ)⁻¹ ^ 4 *
              (m : ℝ) ^ (1 / (2 * (d : ℝ)))) ^ d := by
            gcongr
      have hmR : (0 : ℝ) < m := by exact_mod_cast (lt_of_lt_of_le Nat.zero_lt_two hm2)
      let r : ℝ := (m : ℝ) ^ (1 / (2 * (d : ℝ)))
      let B : ℝ := 6144 * (ε : ℝ)⁻¹ ^ 4
      have hrpow : r ^ d = Real.sqrt (m : ℝ) := by
        dsimp [r]
        rw [← Real.rpow_natCast, ← Real.rpow_mul (le_of_lt hmR)]
        have hdR0 : (d : ℝ) ≠ 0 := by exact_mod_cast (Nat.ne_of_gt hd)
        rw [show (1 / (2 * (d : ℝ))) * (d : ℝ) = 1 / 2 by
          field_simp [hdR0]]
        exact Real.sqrt_eq_rpow (m : ℝ) |>.symm
      have hfactor : (B * r) ^ d = B ^ d * Real.sqrt (m : ℝ) := by
        rw [mul_pow, hrpow]
      have hmBR : (m : ℝ) ≤ B ^ d * Real.sqrt (m : ℝ) := by
        change (m : ℝ) ≤ (B * r) ^ d at hmReal
        rw [hfactor] at hmReal
        exact hmReal
      have hsqrtpos : 0 < Real.sqrt (m : ℝ) := Real.sqrt_pos.2 hmR
      have hsqrt : Real.sqrt (m : ℝ) ≤ B ^ d := by
        have hsq : (Real.sqrt (m : ℝ)) ^ 2 = (m : ℝ) := Real.sq_sqrt hmR.le
        nlinarith [hmBR]
      have hmB : (m : ℝ) ≤ B ^ (2 * d) := by
        have hsq : (Real.sqrt (m : ℝ)) ^ 2 = (m : ℝ) := Real.sq_sqrt hmR.le
        calc
          (m : ℝ) = (Real.sqrt (m : ℝ)) ^ 2 := hsq.symm
          _ ≤ (B ^ d) ^ 2 := by gcongr
          _ = B ^ (2 * d) := by rw [← pow_mul]; congr 1; omega
      have ht : (1 : ℝ) ≤ (ε : ℝ)⁻¹ :=
        (one_le_inv₀ (by exact_mod_cast hε)).2 (by exact_mod_cast hε1.le)
      have hBbase : B ^ 2 ≤ ((2 : ℝ) / (ε : ℝ)) ^ 26 := by
        have hpow826 : ((ε : ℝ)⁻¹) ^ 8 ≤ ((ε : ℝ)⁻¹) ^ 26 :=
          pow_le_pow_right₀ ht (by omega)
        dsimp [B]
        rw [show ((2 : ℝ) / (ε : ℝ)) ^ 26 =
            2 ^ 26 * ((ε : ℝ)⁻¹) ^ 26 by
          rw [div_eq_mul_inv, mul_pow]]
        nlinarith [hpow826, pow_nonneg (show (0 : ℝ) ≤ (ε : ℝ)⁻¹ by positivity) 8]
      have hmRbound : (m : ℝ) ≤
          ((2 : ℝ) / (ε : ℝ)) ^ (26 * d) := by
        calc
          (m : ℝ) ≤ B ^ (2 * d) := hmB
          _ = (B ^ 2) ^ d := by rw [← pow_mul]
          _ ≤ (((2 : ℝ) / (ε : ℝ)) ^ 26) ^ d := by gcongr
          _ = ((2 : ℝ) / (ε : ℝ)) ^ (26 * d) := by rw [pow_mul]
      have hmceil : m ≤ ⌈((2 : ℝ) / (ε : ℝ)) ^ (26 * d)⌉₊ := by
        have hcast := hmRbound.trans (Nat.le_ceil _)
        exact_mod_cast hcast
      calc
        Metric.coveringNumber ε (booleanLpClass μ F) ≤
            Metric.packingNumber ε (booleanLpClass μ F) := hcoverpack
        _ = (m : ℕ∞) := hpackcoe.symm
        _ ≤ (⌈((2 : ℝ) / (ε : ℝ)) ^ (26 * d)⌉₊ : ℕ) := by
          exact_mod_cast hmceil
        _ = (⌈((2 : ℝ) / (ε : ℝ)) ^ (26 * F.vcDim)⌉₊ : ℕ) := by
          rfl

/-! ## The source theorem for arbitrary measurable Boolean classes -/

/-- Represents a measurable set by its indicator as an element of `L²(μ)`.

**Lean implementation helper.** -/
def booleanSetLp (μ : Measure α) [IsFiniteMeasure μ]
    (u : Set α) (hu : MeasurableSet u) : Lp ℝ 2 μ :=
  indicatorConstLp 2 hu (by finiteness) 1

/-- Maps a measurable Boolean class to its set of indicator functions in `L²(μ)`.

**Lean implementation helper.** -/
def booleanClassLp (μ : Measure α) [IsFiniteMeasure μ]
    (F : HDP.BooleanClass α) (hF : ∀ u ∈ F, MeasurableSet u) : Set (Lp ℝ 2 μ) :=
  Set.range fun u : F => booleanSetLp μ u.1 (hF u.1 u.2)

omit [DecidableEq α] [MeasurableSingletonClass α] in
/-- The `L²` distance between two measurable-set indicators is the square root of the measure of their symmetric difference.

**Lean implementation helper.** -/
theorem dist_booleanSetLp (u v : Set α) (hu : MeasurableSet u)
    (hv : MeasurableSet v) :
    dist (booleanSetLp μ u hu) (booleanSetLp μ v hv) =
      Real.sqrt (μ.real (symmDiff u v)) := by
  rw [booleanSetLp, booleanSetLp, dist_indicatorConstLp_eq_norm,
    norm_indicatorConstLp (by norm_num) (by norm_num)]
  simp only [norm_one, one_mul, ENNReal.toReal_ofNat]
  rw [show (1 / (2 : ℝ)) = (1 / 2 : ℝ) by norm_num,
    ← Real.sqrt_eq_rpow]

/-- Records which sets in a finite family contain a given point.

**Lean implementation helper.** -/
noncomputable def membershipPattern (G : Finset (Set α)) (x : α) : ↑G → Bool := by
  classical
  exact fun u => if x ∈ (u.1 : Set α) then true else false

omit [DecidableEq α] [MeasurableSingletonClass α] in
/-- A membership pattern marks a family member as true exactly when the point lies in that set.

**Lean implementation helper.** -/
@[simp]
theorem membershipPattern_apply_eq_true (G : Finset (Set α)) (x : α) (u : ↑G) :
    membershipPattern G x u = true ↔ x ∈ (u.1 : Set α) := by
  classical
  simp [membershipPattern]

abbrev RealizedPattern (G : Finset (Set α)) :=
  {p : ↑G → Bool // p ∈ Set.range (membershipPattern G)}

/-- Packages a membership pattern together with a point that realizes it.

**Lean implementation helper.** -/
noncomputable def realizedPattern (G : Finset (Set α)) (x : α) :
    RealizedPattern G :=
  ⟨membershipPattern G x, x, rfl⟩

omit [DecidableEq α] [MeasurableSingletonClass α] in
/-- Shows that the membership pattern of a point is measurable.

**Lean implementation helper.** -/
theorem measurable_membershipPattern (G : Finset (Set α))
    (hG : ∀ u ∈ G, MeasurableSet u) : Measurable (membershipPattern G) := by
  rw [measurable_pi_iff]
  intro u
  exact Measurable.ite (hG u.1 u.2) measurable_const measurable_const

omit [DecidableEq α] [MeasurableSingletonClass α] in
/-- Shows that a realized membership pattern is measurable.

**Lean implementation helper.** -/
theorem measurable_realizedPattern (G : Finset (Set α))
    (hG : ∀ u ∈ G, MeasurableSet u) : Measurable (realizedPattern G) := by
  change Measurable (fun x =>
    (⟨membershipPattern G x, ⟨x, rfl⟩⟩ : RealizedPattern G))
  exact Measurable.subtype_mk (measurable_membershipPattern G hG)

/-- Returns the subfamily selected by a Boolean membership pattern.

**Lean implementation helper.** -/
noncomputable def patternSupport (G : Finset (Set α)) (u : ↑G) :
    Finset (RealizedPattern G) := by
  letI := Fintype.ofFinite (RealizedPattern G)
  exact Finset.univ.filter fun p => p.1 u = true

omit [DecidableEq α] [MeasurableSingletonClass α] in
/-- Characterizes membership in the support selected by a membership pattern.

**Lean implementation helper.** -/
@[simp]
theorem mem_patternSupport (G : Finset (Set α)) (u : ↑G)
    (p : RealizedPattern G) :
    p ∈ patternSupport G u ↔ p.1 u = true := by
  classical
  simp [patternSupport]

omit [DecidableEq α] [MeasurableSingletonClass α] in
/-- The pattern realized by `x` lies in the support of `u` exactly when `x ∈ u`.

**Lean implementation helper.** -/
@[simp]
theorem realizedPattern_mem_patternSupport (G : Finset (Set α))
    (u : ↑G) (x : α) :
    realizedPattern G x ∈ patternSupport G u ↔ x ∈ (u.1 : Set α) := by
  classical
  simp [realizedPattern]

omit [DecidableEq α] [MeasurableSingletonClass α] in
/-- Distinct sets in the original finite family induce distinct supports on realized membership patterns.

**Lean implementation helper.** -/
theorem patternSupport_injective (G : Finset (Set α)) :
    Function.Injective (patternSupport G) := by
  classical
  intro u v huv
  apply Subtype.ext
  ext x
  have hmem := Finset.ext_iff.mp huv (realizedPattern G x)
  simpa only [realizedPattern_mem_patternSupport] using hmem

/-- Forms the finite Boolean family of supports of all realized membership patterns.

**Lean implementation helper.** -/
noncomputable def patternBooleanFamily (G : Finset (Set α)) :
    BooleanFamily (RealizedPattern G) := by
  letI := Fintype.ofFinite (RealizedPattern G)
  exact Finset.univ.image (patternSupport G)

omit [DecidableEq α] [MeasurableSingletonClass α] in
/-- The Boolean family of pattern supports has the same cardinality as the original finite family.

**Lean implementation helper.** -/
theorem card_patternBooleanFamily (G : Finset (Set α)) :
    (patternBooleanFamily G).card = G.card := by
  classical
  rw [patternBooleanFamily,
    Finset.card_image_of_injective Finset.univ (patternSupport_injective G)]
  simp

omit [DecidableEq α] [MeasurableSingletonClass α] in
/-- Passing to realized membership patterns does not increase the VC-dimension bound inherited from the ambient class.

**Lean implementation helper.** -/
theorem patternBooleanFamily_vcDim_le {F : HDP.BooleanClass α}
    (G : Finset (Set α)) {d : ℕ} (hGF : ∀ u ∈ G, u ∈ F)
    (hd : F.VCDimLE d) : (patternBooleanFamily G).vcDim ≤ d := by
  classical
  unfold Finset.vcDim
  apply Finset.sup_le
  intro s hs
  rw [Finset.mem_shatterer] at hs
  let repr : RealizedPattern G → α := fun p => p.property.choose
  have hrepr (p : RealizedPattern G) : membershipPattern G (repr p) = p.1 :=
    p.property.choose_spec
  have hrepr_inj : Function.Injective repr := by
    intro p q hpq
    apply Subtype.ext
    rw [← hrepr p, ← hrepr q, hpq]
  let q : Finset α := s.image repr
  have hqcard : q.card = s.card := by
    simpa [q] using Finset.card_image_of_injective s hrepr_inj
  have hqsh : F.Shatters q := by
    intro t ht
    let r : Finset (RealizedPattern G) := s.filter fun p => repr p ∈ t
    have hrs : r ⊆ s := Finset.filter_subset _ _
    obtain ⟨w, hwF, hsw⟩ := hs hrs
    obtain ⟨u, -, rfl⟩ := Finset.mem_image.mp hwF
    refine ⟨u.1, hGF u.1 u.2, ?_⟩
    ext x
    simp only [HDP.BooleanClass.mem_trace]
    constructor
    · rintro ⟨hxq, hxu⟩
      obtain ⟨p, hps, rfl⟩ := Finset.mem_image.mp hxq
      have hp_eq : realizedPattern G (repr p) = p := Subtype.ext (hrepr p)
      have hpSupport : p ∈ patternSupport G u := by
        rw [← hp_eq]
        exact (realizedPattern_mem_patternSupport G u (repr p)).2 hxu
      have hpr : p ∈ r := by
        rw [← hsw]
        exact Finset.mem_inter.mpr ⟨hps, hpSupport⟩
      exact (Finset.mem_filter.mp hpr).2
    · intro hxt
      have hxq : x ∈ q := ht hxt
      obtain ⟨p, hps, rfl⟩ := Finset.mem_image.mp hxq
      have hpr : p ∈ r := Finset.mem_filter.mpr ⟨hps, hxt⟩
      have hpSupport : p ∈ patternSupport G u := by
        have : p ∈ s ∩ patternSupport G u := by rw [hsw]; exact hpr
        exact Finset.mem_inter.mp this |>.2
      have hp_eq : realizedPattern G (repr p) = p := Subtype.ext (hrepr p)
      refine ⟨Finset.mem_image.mpr ⟨p, hps, rfl⟩, ?_⟩
      apply (realizedPattern_mem_patternSupport G u (repr p)).1
      rw [hp_eq]
      exact hpSupport
  calc
    s.card = q.card := hqcard.symm
    _ ≤ d := hd q hqsh

omit [DecidableEq α] [MeasurableSingletonClass α] [IsFiniteMeasure μ] in
/-- The pushforward under realized patterns preserves the measure of symmetric differences between family members.

**Lean implementation helper.** -/
theorem map_realizedPattern_symmDiff (G : Finset (Set α))
    (hG : ∀ u ∈ G, MeasurableSet u) (u v : ↑G) :
    (μ.map (realizedPattern G))
        (symmDiff (patternSupport G u : Set (RealizedPattern G))
          (patternSupport G v : Set (RealizedPattern G))) =
      μ (symmDiff (u.1 : Set α) (v.1 : Set α)) := by
  rw [Measure.map_apply (measurable_realizedPattern G hG)
    ((patternSupport G u).measurableSet.symmDiff
      (patternSupport G v).measurableSet)]
  congr 1
  ext x
  simp [realizedPattern, membershipPattern, Set.mem_symmDiff]

omit [DecidableEq α] [MeasurableSingletonClass α] in
/-- The `L²` distance between two pattern supports equals the `L²` distance between the corresponding original set indicators.

**Lean implementation helper.** -/
theorem dist_patternSupport (G : Finset (Set α))
    (hG : ∀ u ∈ G, MeasurableSet u) (u v : ↑G) :
    dist (booleanLp (μ.map (realizedPattern G)) (patternSupport G u))
        (booleanLp (μ.map (realizedPattern G)) (patternSupport G v)) =
      dist (booleanSetLp μ u.1 (hG u.1 u.2))
        (booleanSetLp μ v.1 (hG v.1 v.2)) := by
  rw [(equation_8_31 (μ := μ.map (realizedPattern G))
      (patternSupport G u) (patternSupport G v)).1,
    dist_booleanSetLp]
  unfold booleanL2Dist booleanL2Sq
  rw [measureReal_def, map_realizedPattern_symmDiff G hG u v]
  rfl

omit [DecidableEq α] [MeasurableSingletonClass α] in
/-- An `ε`-separated finite subfamily of a VC class of dimension at most `d` has size at most `⌈(2/ε)^(52d)⌉`.

**Lean implementation helper.** -/
theorem finite_generalBoolean_separated_card_le
    [IsProbabilityMeasure μ] (F : HDP.BooleanClass α)
    (hF : ∀ u ∈ F, MeasurableSet u) {d : ℕ} (hd : F.VCDimLE d)
    (G : Finset (Set α)) (hGF : ∀ u ∈ G, u ∈ F)
    (ε : ℝ≥0) (hε : 0 < ε) (hε1 : ε < 1)
    (hsep : ∀ (u : Set α) (hu : u ∈ G) (v : Set α) (hv : v ∈ G),
      u ≠ v → (ε : ℝ) <
        dist (booleanSetLp μ u (hF u (hGF u hu)))
          (booleanSetLp μ v (hF v (hGF v hv)))) :
    G.card ≤ ⌈((2 : ℝ) / (ε : ℝ)) ^ (52 * d)⌉₊ := by
  classical
  have hGm : ∀ u ∈ G, MeasurableSet u := fun u hu => hF u (hGF u hu)
  let ν : Measure (RealizedPattern G) := μ.map (realizedPattern G)
  letI : IsProbabilityMeasure ν := by
    dsimp [ν]
    exact Measure.isProbabilityMeasure_map
      (measurable_realizedPattern G hGm).aemeasurable
  let F' : BooleanFamily (RealizedPattern G) := patternBooleanFamily G
  have hF'vc : F'.vcDim ≤ d := by
    simpa [F'] using patternBooleanFamily_vcDim_le G hGF hd
  let φ : ↑G → Lp ℝ 2 ν := fun u => booleanLp ν (patternSupport G u)
  have hφinj : Function.Injective φ := by
    intro u v huv
    by_contra huv'
    have huvSet : (u.1 : Set α) ≠ (v.1 : Set α) := by
      intro h
      exact huv' (Subtype.ext h)
    have hdist := hsep u.1 u.2 v.1 v.2 huvSet
    have hpres := dist_patternSupport (μ := μ) (G := G) (hG := hGm)
      (u := u) (v := v)
    change dist (φ u) (φ v) = _ at hpres
    have hzero : dist (booleanSetLp μ u.1 (hGm u.1 u.2))
        (booleanSetLp μ v.1 (hGm v.1 v.2)) = 0 := by
      rw [← hpres, huv, dist_self]
    rw [hzero] at hdist
    exact (not_lt_of_ge (show (0 : ℝ) ≤ ε by positivity)) hdist
  let C : Finset (Lp ℝ 2 ν) := Finset.univ.image φ
  have hCcard : C.card = G.card := by
    simpa [C] using Finset.card_image_of_injective Finset.univ hφinj
  let K : Set (Lp ℝ 2 ν) := booleanLpClass ν F'
  have hCK : (C : Set (Lp ℝ 2 ν)) ⊆ K := by
    intro x hx
    obtain ⟨u, -, rfl⟩ := Finset.mem_image.mp hx
    refine ⟨patternSupport G u, ?_, rfl⟩
    simp [F', patternBooleanFamily]
  have hCsep : Metric.IsSeparated ε (C : Set (Lp ℝ 2 ν)) := by
    intro x hx y hy hxy
    obtain ⟨u, -, rfl⟩ := Finset.mem_image.mp hx
    obtain ⟨v, -, rfl⟩ := Finset.mem_image.mp hy
    have huv : (u.1 : Set α) ≠ (v.1 : Set α) := by
      intro huv
      apply hxy
      congr
      exact Subtype.ext huv
    have hdist := hsep u.1 u.2 v.1 v.2 huv
    have hpres := dist_patternSupport (μ := μ) (G := G) (hG := hGm)
      (u := u) (v := v)
    change dist (φ u) (φ v) = _ at hpres
    have hdist' : (ε : ℝ) < dist (φ u) (φ v) := by
      rw [hpres]
      exact hdist
    simpa [edist_dist] using hdist'
  have hcardpack : (G.card : ℕ∞) ≤ Metric.packingNumber ε K := by
    calc
      (G.card : ℕ∞) = (C : Set (Lp ℝ 2 ν)).encard := by
        rw [Set.encard_coe_eq_coe_finsetCard, hCcard]
      _ ≤ Metric.packingNumber ε K :=
        Metric.IsSeparated.encard_le_packingNumber hCK hCsep
  have hhalf : 0 < ε / 2 := div_pos hε (by norm_num)
  have hhalf1 : ε / 2 < 1 := (div_lt_self hε (by norm_num)).trans hε1
  have hcover := theorem_8_3_13_vc_covering (μ := ν) F' (ε / 2) hhalf hhalf1
  have hpackcover : Metric.packingNumber ε K ≤
      Metric.coveringNumber (ε / 2) K := by
    calc
      Metric.packingNumber ε K = Metric.packingNumber (2 * (ε / 2)) K := by
        congr 2
        ring
      _ ≤ Metric.externalCoveringNumber (ε / 2) K :=
        Metric.packingNumber_two_mul_le_externalCoveringNumber (ε / 2) K
      _ ≤ Metric.coveringNumber (ε / 2) K :=
        Metric.externalCoveringNumber_le_coveringNumber (ε / 2) K
  have hεR : (0 : ℝ) < ε := by exact_mod_cast hε
  have hεR1 : (ε : ℝ) < 1 := by exact_mod_cast hε1
  have hbase1 : (1 : ℝ) ≤ 4 / (ε : ℝ) := by
    apply (le_div_iff₀ hεR).2
    linarith
  have hbase : (4 : ℝ) / (ε : ℝ) ≤
      ((2 : ℝ) / (ε : ℝ)) ^ 2 := by
    field_simp [ne_of_gt hεR]
    nlinarith
  have hreal : ((2 : ℝ) / ((ε / 2 : ℝ≥0) : ℝ)) ^ (26 * F'.vcDim) ≤
      ((2 : ℝ) / (ε : ℝ)) ^ (52 * d) := by
    calc
      ((2 : ℝ) / ((ε / 2 : ℝ≥0) : ℝ)) ^ (26 * F'.vcDim) =
          ((4 : ℝ) / (ε : ℝ)) ^ (26 * F'.vcDim) := by
        congr 1
        rw [show (((ε / 2 : ℝ≥0) : ℝ)) = (ε : ℝ) / 2 by norm_num]
        field_simp [ne_of_gt hεR]
        norm_num
      _ ≤ ((4 : ℝ) / (ε : ℝ)) ^ (26 * d) := by
        exact pow_le_pow_right₀ hbase1 (Nat.mul_le_mul_left 26 hF'vc)
      _ ≤ (((2 : ℝ) / (ε : ℝ)) ^ 2) ^ (26 * d) := by
        gcongr
      _ = ((2 : ℝ) / (ε : ℝ)) ^ (52 * d) := by
        rw [← pow_mul]
        congr 1
        omega
  have hceil : ⌈((2 : ℝ) / ((ε / 2 : ℝ≥0) : ℝ)) ^ (26 * F'.vcDim)⌉₊ ≤
      ⌈((2 : ℝ) / (ε : ℝ)) ^ (52 * d)⌉₊ := Nat.ceil_mono hreal
  have hresult : (G.card : ℕ∞) ≤
      (⌈((2 : ℝ) / (ε : ℝ)) ^ (52 * d)⌉₊ : ℕ) := by
    calc
      (G.card : ℕ∞) ≤ Metric.packingNumber ε K := hcardpack
      _ ≤ Metric.coveringNumber (ε / 2) K := hpackcover
      _ ≤ (⌈((2 : ℝ) / ((ε / 2 : ℝ≥0) : ℝ)) ^ (26 * F'.vcDim)⌉₊ : ℕ) := by
        simpa [K] using hcover
      _ ≤ (⌈((2 : ℝ) / (ε : ℝ)) ^ (52 * d)⌉₊ : ℕ) := by
        exact_mod_cast hceil
  exact_mod_cast hresult

omit [DecidableEq α] [MeasurableSingletonClass α] in
/-- For a probability measure μ and an arbitrary class of measurable Boolean
supports with VC dimension at most d, the actual Mathlib internal L² covering
number is at most ceil ((2 / ε) ^ (52 d)) whenever 0 < ε < 1. No finiteness or decidable-equality assumption is imposed on the domain or the
class. The proof bounds every finite separated subfamily after pushing μ to
its finite space of realized membership patterns, then lifts that bound through
Mathlib's packing and covering numbers.

**Book Theorem 8.3.13.** -/
theorem theorem_8_3_13_vc_covering_general_aux
    [IsProbabilityMeasure μ] (F : HDP.BooleanClass α)
    (hF : ∀ u ∈ F, MeasurableSet u) {d : ℕ} (hd : F.VCDimLE d)
    (ε : ℝ≥0) (hε : 0 < ε) (hε1 : ε < 1) :
    Metric.coveringNumber ε (booleanClassLp μ F hF) ≤
      (⌈((2 : ℝ) / (ε : ℝ)) ^ (52 * d)⌉₊ : ℕ) := by
  classical
  let K : Set (Lp ℝ 2 μ) := booleanClassLp μ F hF
  let B : ℕ := ⌈((2 : ℝ) / (ε : ℝ)) ^ (52 * d)⌉₊
  have hpacking : Metric.packingNumber ε K ≤ (B : ℕ) := by
    unfold Metric.packingNumber
    refine iSup_le fun C => ?_
    refine iSup_le fun hCK => ?_
    refine iSup_le fun hCsep => ?_
    by_contra hCB
    have hsucc : ((B + 1 : ℕ) : ℕ∞) ≤ C.encard := by
      simpa only [Nat.cast_add, Nat.cast_one] using
        Order.add_one_le_of_lt (not_le.mp hCB)
    obtain ⟨D, hDC, hDcard⟩ := Set.exists_subset_encard_eq hsucc
    have hDfinite : D.Finite := Set.finite_of_encard_eq_coe hDcard
    letI : Fintype D := hDfinite.fintype
    have hDnat : Fintype.card D = B + 1 := by
      have hcardcoe : (Fintype.card D : ℕ∞) = D.encard := Set.coe_fintypeCard D
      rw [hDcard] at hcardcoe
      exact_mod_cast hcardcoe
    have hrepr_exists (x : D) :
        ∃ u : F, booleanSetLp μ u.1 (hF u.1 u.2) = (x.1 : Lp ℝ 2 μ) := by
      have hxK : (x.1 : Lp ℝ 2 μ) ∈ K := hCK (hDC x.2)
      simpa [K, booleanClassLp] using hxK
    let repr : D → Set α := fun x => (hrepr_exists x).choose.1
    have hrepr_mem (x : D) : repr x ∈ F := (hrepr_exists x).choose.2
    have hrepr_eq (x : D) :
        booleanSetLp μ (repr x) (hF (repr x) (hrepr_mem x)) =
          (x.1 : Lp ℝ 2 μ) := (hrepr_exists x).choose_spec
    have hrepr_inj : Function.Injective repr := by
      intro x y hxy
      apply Subtype.ext
      calc
        (x.1 : Lp ℝ 2 μ) =
            booleanSetLp μ (repr x) (hF (repr x) (hrepr_mem x)) :=
          (hrepr_eq x).symm
        _ = booleanSetLp μ (repr y) (hF (repr y) (hrepr_mem y)) := by
          simp only [hxy]
        _ = (y.1 : Lp ℝ 2 μ) := hrepr_eq y
    let G : Finset (Set α) := Finset.univ.image repr
    have hGcard : G.card = B + 1 := by
      change (Finset.univ.image repr).card = B + 1
      rw [Finset.card_image_of_injective Finset.univ hrepr_inj]
      simpa using hDnat
    have hGF : ∀ u ∈ G, u ∈ F := by
      intro u hu
      obtain ⟨x, -, rfl⟩ := Finset.mem_image.mp hu
      exact hrepr_mem x
    have hGsep : ∀ (u : Set α) (hu : u ∈ G)
        (v : Set α) (hv : v ∈ G), u ≠ v →
          (ε : ℝ) < dist (booleanSetLp μ u (hF u (hGF u hu)))
            (booleanSetLp μ v (hF v (hGF v hv))) := by
      intro u hu v hv huv
      obtain ⟨x, -, rfl⟩ := Finset.mem_image.mp hu
      obtain ⟨y, -, rfl⟩ := Finset.mem_image.mp hv
      have hxy : x ≠ y := by
        intro hxy
        subst y
        exact huv rfl
      have hsepD := hCsep (hDC x.2) (hDC y.2) (fun h => hxy (Subtype.ext h))
      have hsepReal : (ε : ℝ) < dist (x.1 : Lp ℝ 2 μ) (y.1 : Lp ℝ 2 μ) := by
        simpa [edist_dist] using hsepD
      simpa [← hrepr_eq x, ← hrepr_eq y] using hsepReal
    have hGbound := finite_generalBoolean_separated_card_le
      (μ := μ) F hF hd G hGF ε hε hε1 hGsep
    rw [hGcard] at hGbound
    omega
  calc
    Metric.coveringNumber ε (booleanClassLp μ F hF) ≤
        Metric.packingNumber ε (booleanClassLp μ F hF) :=
      Metric.coveringNumber_le_packingNumber ε _
    _ ≤ (B : ℕ) := by simpa [K] using hpacking
    _ = (⌈((2 : ℝ) / (ε : ℝ)) ^ (52 * d)⌉₊ : ℕ) := rfl

/-! ## Finite internal nets for the empirical-process argument -/

/-- A concrete representative form of Theorem 8.3.13. The centers are
members of the original Boolean family (not merely points of the ambient
`L²` space), and their cardinality satisfies the same explicit VC bound. This is the interface used by the chaining proof of Theorem 8.3.15: it keeps
all choices internal to the formalization and does not ask callers to supply
a net or a chaining certificate.

**Book Theorem 8.3.13.** -/
theorem exists_booleanNet_card_le [Finite α] [IsProbabilityMeasure μ]
    (F : BooleanFamily α) (ε : ℝ≥0) (hε : 0 < ε) (hε1 : ε < 1) :
    ∃ N : Finset ↥F,
      (∀ u : ↥F, ∃ v ∈ N,
        dist (booleanLp μ u.1) (booleanLp μ v.1) ≤ (ε : ℝ)) ∧
      N.card ≤ ⌈((2 : ℝ) / (ε : ℝ)) ^ (26 * F.vcDim)⌉₊ := by
  letI := Fintype.ofFinite α
  let K : Set (Lp ℝ 2 μ) := booleanLpClass μ F
  have hKfin : K.Finite := finite_booleanLpClass (μ := μ) F
  have hcoverFinite : Metric.coveringNumber ε K ≠ ⊤ :=
    (HDP.finite_covering_packing_of_finite hKfin ε).1
  let M : HDP.FiniteNet ε K := HDP.minimalFiniteNet ε K hcoverFinite
  let C := ↥M.toFinset
  letI : Fintype C := Finset.fintypeCoeSort M.toFinset
  have hrepr_exists (x : C) :
      ∃ u ∈ F, booleanLp μ u = (x.1 : Lp ℝ 2 μ) := by
    have hxM : (x.1 : Lp ℝ 2 μ) ∈ M.points := by
      apply (HDP.FiniteNet.mem_toFinset M x.1).mp
      exact x.2
    have hxK : (x.1 : Lp ℝ 2 μ) ∈ K := M.subset hxM
    simpa [K, booleanLpClass] using hxK
  let repr : C → ↥F := fun x =>
    ⟨(hrepr_exists x).choose, (hrepr_exists x).choose_spec.1⟩
  have hrepr_eq (x : C) :
      booleanLp μ (repr x).1 = (x.1 : Lp ℝ 2 μ) :=
    (hrepr_exists x).choose_spec.2
  let N : Finset ↥F := Finset.univ.image repr
  refine ⟨N, ?_, ?_⟩
  · intro u
    have huK : booleanLp μ u.1 ∈ K := by
      exact ⟨u.1, u.2, rfl⟩
    obtain ⟨x, hxM, hxdist⟩ := M.isCover huK
    have hxFin : x ∈ M.toFinset := by simpa using hxM
    let xc : C := ⟨x, hxFin⟩
    refine ⟨repr xc, ?_, ?_⟩
    · exact Finset.mem_image.mpr ⟨xc, Finset.mem_univ _, rfl⟩
    · have hdistReal : dist (booleanLp μ u.1) (x : Lp ℝ 2 μ) ≤ (ε : ℝ) := by
        simpa [edist_dist] using hxdist
      simpa [hrepr_eq xc] using hdistReal
  · have hcardN : N.card ≤ Fintype.card C := by
      dsimp [N]
      exact (Finset.card_image_le.trans_eq Finset.card_univ)
    have hcardC : (Fintype.card C : ℕ∞) = Metric.coveringNumber ε K := by
      rw [show Fintype.card C = M.toFinset.card by
        simp [C], HDP.FiniteNet.coe_card_toFinset]
      exact Metric.encard_minimalCover hcoverFinite
    have hcover := theorem_8_3_13_vc_covering (μ := μ) F ε hε hε1
    have hcardCENat : (Fintype.card C : ℕ∞) ≤
        (⌈((2 : ℝ) / (ε : ℝ)) ^ (26 * F.vcDim)⌉₊ : ℕ) :=
      hcardC.trans_le (by simpa [K] using hcover)
    have hcardCnat : Fintype.card C ≤
        ⌈((2 : ℝ) / (ε : ℝ)) ^ (26 * F.vcDim)⌉₊ := by
      exact_mod_cast hcardCENat
    exact hcardN.trans hcardCnat

end

/-- An arbitrary measurable Boolean class with VC dimension `d` has polynomial `L2` covering numbers. For a probability measure `μ` and an arbitrary class of measurable Boolean
supports with VC dimension at most `d`, the actual Mathlib internal `L²`
covering number is at most `⌈(2 / ε) ^ (52 * d)⌉₊` for `0 < ε < 1`. The public signature needs only the probability-measure structure: its
finite-measure structure is supplied canonically by Mathlib.

**Book Theorem 8.3.13.** -/
theorem theorem_8_3_13_vc_covering_general
    {α : Type*} {mα : MeasurableSpace α} {μ : Measure α}
    [IsProbabilityMeasure μ] (F : HDP.BooleanClass α)
    (hF : ∀ u ∈ F, MeasurableSet u) {d : ℕ} (hd : F.VCDimLE d)
    (ε : ℝ≥0) (hε : 0 < ε) (hε1 : ε < 1) :
    Metric.coveringNumber ε (booleanClassLp μ F hF) ≤
      (⌈((2 : ℝ) / (ε : ℝ)) ^ (52 * d)⌉₊ : ℕ) := by
  exact theorem_8_3_13_vc_covering_general_aux
    (μ := μ) F hF hd ε hε hε1

end HDP.Chapter8

end Source_07_VCCovering

/-! ## Material formerly in `08_VCLawOfLargeNumbers.lean` -/

section Source_08_VCLawOfLargeNumbers

/-!
# Book Chapter 8, §8.3: the VC law of large numbers

The quantitative source theorem concerns arbitrary classes and suppresses
measurability of their suprema.  This module first proves the finite chaining
endpoint, then transports it to measurable arbitrary Boolean classes equipped
with the standard countable-exhaustion certificate.  It also proves the exact
real-line CDF theorem and the infinite-VC obstruction in the distribution-free
uniform Glivenko--Cantelli characterization.  The preceding covering module
supplies the dyadic nets internally; no net, entropy, or chaining certificate
appears in the public finite-family probabilistic APIs.
-/

open MeasureTheory ProbabilityTheory Set Filter Topology
open scoped BigOperators ENNReal NNReal Topology

namespace HDP.Chapter8

noncomputable section

variable {α Ω Ω' : Type*} [DecidableEq α]
  {mα : MeasurableSpace α} {mΩ : MeasurableSpace Ω}
  {mΩ' : MeasurableSpace Ω'} {μ : Measure α}
  {P : Measure Ω} {Q : Measure Ω'}

/-! ## Dyadic scales used by the internal VC chaining argument -/

/-- The positive dyadic radius `2⁻⁽ᵏ⁺¹⁾`.

**Lean implementation helper.** -/
def vcDyadicRadius (k : ℕ) : ℝ≥0 :=
  ⟨((2 : ℝ) ^ (k + 1))⁻¹, by positivity⟩

/-- The `k`th VC dyadic radius is `2^(-(k+1))` as a real number.

**Lean implementation helper.** -/
@[simp, norm_cast]
theorem coe_vcDyadicRadius (k : ℕ) :
    (vcDyadicRadius k : ℝ) = ((2 : ℝ) ^ (k + 1))⁻¹ := rfl

/-- Shows that the VC dyadic radius is strictly positive.

**Lean implementation helper.** -/
theorem vcDyadicRadius_pos (k : ℕ) : 0 < vcDyadicRadius k := by
  change 0 < ((2 : ℝ) ^ (k + 1))⁻¹
  positivity

/-- Every VC dyadic radius is strictly less than `1`.

**Lean implementation helper.** -/
theorem vcDyadicRadius_lt_one (k : ℕ) : vcDyadicRadius k < 1 := by
  change ((2 : ℝ) ^ (k + 1))⁻¹ < 1
  rw [inv_lt_one₀ (by positivity)]
  exact one_lt_pow₀ (by norm_num) (by omega)

/-- VC dyadic radii decrease with the scale index.

**Lean implementation helper.** -/
theorem vcDyadicRadius_succ_le (k : ℕ) :
    (vcDyadicRadius (k + 1) : ℝ) ≤ vcDyadicRadius k := by
  rw [coe_vcDyadicRadius, coe_vcDyadicRadius]
  apply inv_anti₀ (by positivity)
  exact pow_le_pow_right₀ (by norm_num : (1 : ℝ) ≤ 2) (by omega)

/-- The ceiling in the VC covering estimate at dyadic radius `k` simplifies to `2^((k+2)·26d)`.

**Lean implementation helper.** -/
private theorem dyadic_vc_ceiling_eq (d k : ℕ) :
    ⌈((2 : ℝ) / (vcDyadicRadius k : ℝ)) ^ (26 * d)⌉₊ =
      2 ^ ((k + 2) * (26 * d)) := by
  have hbase : (2 : ℝ) / (vcDyadicRadius k : ℝ) = 2 ^ (k + 2) := by
    calc
      (2 : ℝ) / (vcDyadicRadius k : ℝ) = 2 * 2 ^ (k + 1) := by
        rw [coe_vcDyadicRadius, div_inv_eq_mul]
      _ = 2 ^ (k + 2) := by
        conv_rhs => rw [show k + 2 = (k + 1) + 1 by omega, pow_succ]
        ring
  rw [hbase, ← pow_mul]
  rw [show (2 : ℝ) ^ ((k + 2) * (26 * d)) =
      ((2 ^ ((k + 2) * (26 * d)) : ℕ) : ℝ) by norm_cast,
    Nat.ceil_natCast]

/-- A chosen minimal-size dyadic net supplied by Theorem 8.3.13. Its
existence, cover property, and cardinal estimate are proved in
`07_VCCovering`; callers do not provide any chaining data.

**Book Theorem 8.3.13.** -/
noncomputable def vcDyadicNet [Fintype α] [MeasurableSingletonClass α]
    [IsProbabilityMeasure μ] (F : BooleanFamily α) (k : ℕ) : Finset ↥F :=
  (exists_booleanNet_card_le (μ := μ) F (vcDyadicRadius k)
    (vcDyadicRadius_pos k) (vcDyadicRadius_lt_one k)).choose

/-- Every Boolean function lies within the `k`th dyadic radius of some point in the corresponding VC net.

**Lean implementation helper.** -/
theorem vcDyadicNet_cover [Fintype α] [MeasurableSingletonClass α]
    [IsProbabilityMeasure μ] (F : BooleanFamily α) (k : ℕ) (u : ↥F) :
    ∃ v ∈ vcDyadicNet (μ := μ) F k,
      dist (booleanLp μ u.1) (booleanLp μ v.1) ≤
        (vcDyadicRadius k : ℝ) :=
  (exists_booleanNet_card_le (μ := μ) F (vcDyadicRadius k)
    (vcDyadicRadius_pos k) (vcDyadicRadius_lt_one k)).choose_spec.1 u

/-- The `k`th VC net has at most `2^((k+2)·26·VC(F))` elements.

**Lean implementation helper.** -/
theorem card_vcDyadicNet_le [Fintype α] [MeasurableSingletonClass α]
    [IsProbabilityMeasure μ] (F : BooleanFamily α) (k : ℕ) :
    (vcDyadicNet (μ := μ) F k).card ≤
      2 ^ ((k + 2) * (26 * F.vcDim)) := by
  have h := (exists_booleanNet_card_le (μ := μ) F (vcDyadicRadius k)
    (vcDyadicRadius_pos k) (vcDyadicRadius_lt_one k)).choose_spec.2
  change (vcDyadicNet (μ := μ) F k).card ≤
    ⌈((2 : ℝ) / (vcDyadicRadius k : ℝ)) ^ (26 * F.vcDim)⌉₊ at h
  rw [dyadic_vc_ceiling_eq] at h
  exact h

/-- The chosen nearest dyadic-net representative of a Boolean support.

**Lean implementation helper.** -/
noncomputable def vcDyadicProjection [Fintype α]
    [MeasurableSingletonClass α] [IsProbabilityMeasure μ]
    (F : BooleanFamily α) (k : ℕ) (u : ↥F) : ↥F :=
  (vcDyadicNet_cover (μ := μ) F k u).choose

/-- The selected VC projection belongs to the corresponding dyadic net.

**Lean implementation helper.** -/
theorem vcDyadicProjection_mem [Fintype α]
    [MeasurableSingletonClass α] [IsProbabilityMeasure μ]
    (F : BooleanFamily α) (k : ℕ) (u : ↥F) :
    vcDyadicProjection (μ := μ) F k u ∈ vcDyadicNet (μ := μ) F k :=
  (vcDyadicNet_cover (μ := μ) F k u).choose_spec.1

/-- The selected VC projection lies within the corresponding dyadic radius in `L²`.

**Lean implementation helper.** -/
theorem vcDyadicProjection_dist_le [Fintype α]
    [MeasurableSingletonClass α] [IsProbabilityMeasure μ]
    (F : BooleanFamily α) (k : ℕ) (u : ↥F) :
    dist (booleanLp μ u.1)
      (booleanLp μ (vcDyadicProjection (μ := μ) F k u).1) ≤
        (vcDyadicRadius k : ℝ) :=
  (vcDyadicNet_cover (μ := μ) F k u).choose_spec.2

/-! ## Boolean empirical deviations -/

/-- The real-valued indicator associated with a finite Boolean support.

**Lean implementation helper.** -/
def booleanIndicator (u : Finset α) (x : α) : ℝ :=
  if x ∈ u then 1 else 0

/-- The Boolean indicator equals `1` at points inside the finite set.

**Lean implementation helper.** -/
@[simp]
theorem booleanIndicator_of_mem {u : Finset α} {x : α} (hx : x ∈ u) :
    booleanIndicator u x = 1 := by
  simp [booleanIndicator, hx]

/-- The Boolean indicator equals `0` at points outside the finite set.

**Lean implementation helper.** -/
@[simp]
theorem booleanIndicator_of_not_mem {u : Finset α} {x : α} (hx : x ∉ u) :
    booleanIndicator u x = 0 := by
  simp [booleanIndicator, hx]

/-- The absolute value of a Boolean indicator is at most `1`.

**Lean implementation helper.** -/
theorem abs_booleanIndicator_le_one (u : Finset α) (x : α) :
    |booleanIndicator u x| ≤ 1 := by
  simp only [booleanIndicator]
  split_ifs <;> norm_num

/-- Identifies the Boolean indicator function with the zero-one membership function.

**Lean implementation helper.** -/
@[simp]
theorem booleanIndicator_eq_booleanValue (u : Finset α) :
    booleanIndicator u = booleanValue u := by
  funext x
  by_cases hx : x ∈ u <;> simp [booleanIndicator, booleanValue, hx]

/-- `L²` proximity for the empirical measure is exactly a Euclidean bound on
the coefficient vector used by the conditional Rademacher process.

**Lean implementation helper.** -/
theorem sum_sq_booleanIndicator_sub_le_of_empiricalLp_dist_le
    [MeasurableSingletonClass α] {n : ℕ} (hn : 0 < n) (sample : Fin n → α)
    (u v : Finset α) {r : ℝ} (hr : 0 ≤ r)
    (hdist : booleanL2Dist (empiricalMeasure (mα := mα) sample) u v ≤ r) :
    ∑ i, (booleanIndicator u (sample i) -
      booleanIndicator v (sample i)) ^ 2 ≤ (n : ℝ) * r ^ 2 := by
  let ν : Measure α := empiricalMeasure (mα := mα) sample
  letI : IsProbabilityMeasure ν :=
    ⟨by simpa [ν] using empiricalMeasure_apply_univ hn sample⟩
  have hfunm : StronglyMeasurable (fun x : α =>
      (booleanValue u x - booleanValue v x) ^ 2) :=
    (((measurable_booleanValue u).sub (measurable_booleanValue v)).pow_const 2).stronglyMeasurable
  have hsq : booleanL2Dist ν u v ^ 2 =
      (n : ℝ)⁻¹ * ∑ i,
        (booleanIndicator u (sample i) -
          booleanIndicator v (sample i)) ^ 2 := by
    calc
      booleanL2Dist ν u v ^ 2 = booleanL2Sq ν u v :=
        booleanL2Dist_sq u v
      _ = ∫ x, (booleanValue u x - booleanValue v x) ^ 2 ∂ν :=
        (integral_boolean_difference_sq (μ := ν) u v).symm
      _ = empiricalAverage sample
          (fun x => (booleanValue u x - booleanValue v x) ^ 2) := by
        exact integral_empiricalMeasure hn sample hfunm
      _ = (n : ℝ)⁻¹ * ∑ i,
          (booleanIndicator u (sample i) -
            booleanIndicator v (sample i)) ^ 2 := by
        simp only [empiricalAverage, booleanIndicator_eq_booleanValue]
  have hdist0 : 0 ≤ booleanL2Dist ν u v := Real.sqrt_nonneg _
  have hsquare : booleanL2Dist ν u v ^ 2 ≤ r ^ 2 := by
    nlinarith
  rw [hsq] at hsquare
  have hmul := mul_le_mul_of_nonneg_left hsquare (show (0 : ℝ) ≤ n by positivity)
  have hn0 : (n : ℝ) ≠ 0 := by exact_mod_cast hn.ne'
  calc
    ∑ i, (booleanIndicator u (sample i) -
        booleanIndicator v (sample i)) ^ 2 =
        (n : ℝ) * ((n : ℝ)⁻¹ * ∑ i,
          (booleanIndicator u (sample i) -
            booleanIndicator v (sample i)) ^ 2) := by
      field_simp
    _ ≤ (n : ℝ) * r ^ 2 := hmul

/-- The canonical dyadic projection for an empirical measure, with the
probability instance constructed internally from `n > 0`.

**Lean implementation helper.** -/
noncomputable def empiricalVCDyadicNet
    [Fintype α] [MeasurableSingletonClass α]
    {n : ℕ} (hn : 0 < n) (sample : Fin n → α)
    (F : BooleanFamily α) (k : ℕ) : Finset ↥F := by
  letI : IsProbabilityMeasure (empiricalMeasure (mα := mα) sample) :=
    ⟨empiricalMeasure_apply_univ hn sample⟩
  exact vcDyadicNet (μ := empiricalMeasure (mα := mα) sample) F k

/-- Chooses a nearest point in the empirical VC net at a dyadic radius.

**Lean implementation helper.** -/
noncomputable def empiricalVCDyadicProjection
    [Fintype α] [MeasurableSingletonClass α]
    {n : ℕ} (hn : 0 < n) (sample : Fin n → α)
    (F : BooleanFamily α) (k : ℕ) (u : ↥F) : ↥F := by
  letI : IsProbabilityMeasure (empiricalMeasure (mα := mα) sample) :=
    ⟨empiricalMeasure_apply_univ hn sample⟩
  exact vcDyadicProjection
    (μ := empiricalMeasure (mα := mα) sample) F k u

/-- The selected empirical VC projection belongs to the corresponding empirical dyadic net.

**Lean implementation helper.** -/
theorem empiricalVCDyadicProjection_mem
    [Fintype α] [MeasurableSingletonClass α]
    {n : ℕ} (hn : 0 < n) (sample : Fin n → α)
    (F : BooleanFamily α) (k : ℕ) (u : ↥F) :
    empiricalVCDyadicProjection hn sample F k u ∈
      empiricalVCDyadicNet hn sample F k := by
  letI : IsProbabilityMeasure
      (empiricalMeasure (mα := mα) sample) :=
    ⟨empiricalMeasure_apply_univ hn sample⟩
  simpa [empiricalVCDyadicProjection, empiricalVCDyadicNet] using
    vcDyadicProjection_mem
      (μ := empiricalMeasure (mα := mα) sample) F k u

/-- The `k`th empirical VC net has at most `2^((k+2)·26·VC(F))` elements.

**Lean implementation helper.** -/
theorem card_empiricalVCDyadicNet_le
    [Fintype α] [MeasurableSingletonClass α]
    {n : ℕ} (hn : 0 < n) (sample : Fin n → α)
    (F : BooleanFamily α) (k : ℕ) :
    (empiricalVCDyadicNet hn sample F k).card ≤
      2 ^ ((k + 2) * (26 * F.vcDim)) := by
  letI : IsProbabilityMeasure
      (empiricalMeasure (mα := mα) sample) :=
    ⟨empiricalMeasure_apply_univ hn sample⟩
  simpa [empiricalVCDyadicNet] using card_vcDyadicNet_le
    (μ := empiricalMeasure (mα := mα) sample) F k

/-- At the terminal dyadic scale `2⁻⁽ⁿ⁺¹⁾`, an empirical `L²` net point has
exactly the same Boolean trace on an `n`-point sample. This removes the
otherwise problematic final link to the full class in the finite chain.

**Lean implementation helper.** -/
theorem booleanIndicator_vcDyadicProjection_last
    [Fintype α] [MeasurableSingletonClass α]
    {n : ℕ} (hn : 0 < n) (sample : Fin n → α) (F : BooleanFamily α)
    (u : ↥F) (i : Fin n) :
    booleanIndicator
        (empiricalVCDyadicProjection hn sample F n u).1
        (sample i) = booleanIndicator u.1 (sample i) := by
  let ν : Measure α := empiricalMeasure (mα := mα) sample
  letI : IsProbabilityMeasure ν :=
    ⟨by simpa [ν] using empiricalMeasure_apply_univ hn sample⟩
  let v : ↥F := empiricalVCDyadicProjection hn sample F n u
  have hLp : dist (booleanLp ν u.1) (booleanLp ν v.1) ≤
      (vcDyadicRadius n : ℝ) := by
    simpa [v, empiricalVCDyadicProjection, ν] using
      vcDyadicProjection_dist_le (μ := ν) F n u
  have hL2 : booleanL2Dist ν u.1 v.1 ≤ (vcDyadicRadius n : ℝ) := by
    rw [← (equation_8_31 (μ := ν) u.1 v.1).1]
    exact hLp
  have hsum := sum_sq_booleanIndicator_sub_le_of_empiricalLp_dist_le
    hn sample u.1 v.1 (show 0 ≤ (vcDyadicRadius n : ℝ) by positivity) hL2
  have hsmall : (n : ℝ) * (vcDyadicRadius n : ℝ) ^ 2 < 1 := by
    have hnNat : n < 2 ^ (2 * (n + 1)) := by
      exact n.lt_two_pow_self |>.trans_le
        (Nat.pow_le_pow_right (by omega) (by omega : n ≤ 2 * (n + 1)))
    have hnReal : (n : ℝ) < ((2 : ℝ) ^ (n + 1)) ^ 2 := by
      exact_mod_cast (show n < (2 ^ (n + 1)) ^ 2 by
        simpa [← pow_mul, mul_comm] using hnNat)
    rw [coe_vcDyadicRadius, inv_pow, ← div_eq_mul_inv]
    exact (div_lt_one (by positivity)).2 hnReal
  have hsumlt : ∑ j, (booleanIndicator u.1 (sample j) -
      booleanIndicator v.1 (sample j)) ^ 2 < 1 := hsum.trans_lt hsmall
  by_contra hne
  change booleanIndicator v.1 (sample i) ≠
    booleanIndicator u.1 (sample i) at hne
  have hterm : (booleanIndicator u.1 (sample i) -
      booleanIndicator v.1 (sample i)) ^ 2 = 1 := by
    by_cases hu : sample i ∈ u.1
    · by_cases hv : sample i ∈ v.1
      · exact (hne (by simp [booleanIndicator, hu, hv])).elim
      · simp [booleanIndicator, hu, hv]
    · by_cases hv : sample i ∈ v.1
      · simp [booleanIndicator, hu, hv]
      · exact (hne (by simp [booleanIndicator, hu, hv])).elim
  have hone : (1 : ℝ) ≤ ∑ j, (booleanIndicator u.1 (sample j) -
      booleanIndicator v.1 (sample j)) ^ 2 := by
    rw [← hterm]
    exact Finset.single_le_sum
      (f := fun j => (booleanIndicator u.1 (sample j) -
        booleanIndicator v.1 (sample j)) ^ 2)
      (fun j _ => sq_nonneg _) (Finset.mem_univ i)
  linarith

/-! ## The internally constructed finite VC chain -/

/-- A fixed anchor of a nonempty Boolean family.

**Lean implementation helper.** -/
noncomputable def vcChainAnchor (F : BooleanFamily α) (hF : F.Nonempty) : ↥F :=
  ⟨hF.choose, hF.choose_spec⟩

/-- Level zero is the fixed anchor; level `k+1` is the chosen empirical
dyadic-net projection at radius `2⁻⁽ᵏ⁺¹⁾`.

**Lean implementation helper.** -/
noncomputable def vcChainProjection [Fintype α]
    [MeasurableSingletonClass α] {n : ℕ} (hn : 0 < n)
    (sample : Fin n → α) (F : BooleanFamily α) (hF : F.Nonempty)
    (level : ℕ) (u : ↥F) : ↥F :=
  if level = 0 then vcChainAnchor F hF
  else empiricalVCDyadicProjection hn sample F (level - 1) u

/-- The level-zero VC chain projection is the chosen chain anchor.

**Lean implementation helper.** -/
@[simp]
theorem vcChainProjection_zero [Fintype α]
    [MeasurableSingletonClass α] {n : ℕ} (hn : 0 < n)
    (sample : Fin n → α) (F : BooleanFamily α) (hF : F.Nonempty)
    (u : ↥F) :
    vcChainProjection hn sample F hF 0 u = vcChainAnchor F hF := by
  simp [vcChainProjection]

/-- At a successor level, the VC chain projection is the empirical dyadic-net projection from the preceding scale.

**Lean implementation helper.** -/
@[simp]
theorem vcChainProjection_succ [Fintype α]
    [MeasurableSingletonClass α] {n : ℕ} (hn : 0 < n)
    (sample : Fin n → α) (F : BooleanFamily α) (hF : F.Nonempty)
    (k : ℕ) (u : ↥F) :
    vcChainProjection hn sample F hF (k + 1) u =
      empiricalVCDyadicProjection hn sample F k u := by
  simp [vcChainProjection]

/-- The coefficient vector of one adjacent chain increment.

**Lean implementation helper.** -/
def vcChainCoefficient [Fintype α] [MeasurableSingletonClass α]
    {n : ℕ} (hn : 0 < n) (sample : Fin n → α)
    (F : BooleanFamily α) (hF : F.Nonempty) (k : ℕ) (u : ↥F) :
    Fin n → ℝ := fun i =>
  booleanIndicator (vcChainProjection hn sample F hF (k + 1) u).1 (sample i) -
    booleanIndicator (vcChainProjection hn sample F hF k u).1 (sample i)

/-- Distinct coefficient vectors appearing at scale `k`; taking the image
removes duplicate increments before the finite maximal inequality is applied.

**Lean implementation helper.** -/
def vcScaleCoefficientFamily [Fintype α] [MeasurableSingletonClass α]
    {n : ℕ} (hn : 0 < n) (sample : Fin n → α)
    (F : BooleanFamily α) (hF : F.Nonempty) (k : ℕ) :
    Finset (Fin n → ℝ) :=
  Finset.univ.image (vcChainCoefficient hn sample F hF k)

/-- Shows that the coefficient family at one VC scale is nonempty.

**Lean implementation helper.** -/
theorem vcScaleCoefficientFamily_nonempty [Fintype α]
    [MeasurableSingletonClass α] {n : ℕ} (hn : 0 < n)
    (sample : Fin n → α) (F : BooleanFamily α) (hF : F.Nonempty) (k : ℕ) :
    (vcScaleCoefficientFamily hn sample F hF k).Nonempty := by
  let u : ↥F := vcChainAnchor F hF
  exact ⟨vcChainCoefficient hn sample F hF k u,
    Finset.mem_image.mpr ⟨u, Finset.mem_univ _, rfl⟩⟩

/-- A convenient deterministic radius for one chain increment.

**Lean implementation helper.** -/
def vcChainScaleRadius (k : ℕ) : ℝ :=
  if k = 0 then 1 else 2 * (vcDyadicRadius (k - 1) : ℝ)

/-- Shows that the empirical radius of one VC chaining scale is strictly positive.

**Lean implementation helper.** -/
theorem vcChainScaleRadius_pos (k : ℕ) : 0 < vcChainScaleRadius k := by
  by_cases hk : k = 0
  · simp [vcChainScaleRadius, hk]
  · simp [vcChainScaleRadius, hk]

/-- Every distinct coefficient vector at scale `k ≤ n` has the Euclidean
radius dictated by the two adjacent empirical nets.

**Lean implementation helper.** -/
theorem vcScaleCoefficient_energy_le [Fintype α]
    [MeasurableSingletonClass α] {n : ℕ} (hn : 0 < n)
    (sample : Fin n → α) (F : BooleanFamily α) (hF : F.Nonempty)
    {k : ℕ} (hk : k ≤ n) {a : Fin n → ℝ}
    (ha : a ∈ vcScaleCoefficientFamily hn sample F hF k) :
    ∑ i, (a i) ^ 2 ≤ (n : ℝ) * (vcChainScaleRadius k) ^ 2 := by
  obtain ⟨u, _hu, rfl⟩ := Finset.mem_image.mp ha
  rcases k with _ | j
  · simp only [vcChainScaleRadius, if_pos, one_pow, mul_one]
    calc
      ∑ i, (vcChainCoefficient hn sample F hF 0 u i) ^ 2 ≤
          ∑ _i : Fin n, (1 : ℝ) := by
        apply Finset.sum_le_sum
        intro i _
        simp only [vcChainCoefficient, vcChainProjection_succ,
          vcChainProjection_zero]
        by_cases hp : sample i ∈
            (empiricalVCDyadicProjection hn sample F 0 u).1 <;>
          by_cases hq : sample i ∈ (vcChainAnchor F hF).1 <;>
          simp [booleanIndicator, hp, hq]
      _ = (n : ℝ) := by simp
  · let ν : Measure α := empiricalMeasure (mα := mα) sample
    letI : IsProbabilityMeasure ν :=
      ⟨by simpa [ν] using empiricalMeasure_apply_univ hn sample⟩
    let p : ↥F := empiricalVCDyadicProjection hn sample F (j + 1) u
    let q : ↥F := empiricalVCDyadicProjection hn sample F j u
    have hup : dist (booleanLp ν u.1) (booleanLp ν p.1) ≤
        (vcDyadicRadius (j + 1) : ℝ) := by
      simpa [p, empiricalVCDyadicProjection, ν] using
        vcDyadicProjection_dist_le (μ := ν) F (j + 1) u
    have huq : dist (booleanLp ν u.1) (booleanLp ν q.1) ≤
        (vcDyadicRadius j : ℝ) := by
      simpa [q, empiricalVCDyadicProjection, ν] using
        vcDyadicProjection_dist_le (μ := ν) F j u
    have hpq : dist (booleanLp ν p.1) (booleanLp ν q.1) ≤
        2 * (vcDyadicRadius j : ℝ) := by
      calc
        dist (booleanLp ν p.1) (booleanLp ν q.1) ≤
            dist (booleanLp ν p.1) (booleanLp ν u.1) +
              dist (booleanLp ν u.1) (booleanLp ν q.1) := dist_triangle _ _ _
        _ ≤ (vcDyadicRadius (j + 1) : ℝ) +
              (vcDyadicRadius j : ℝ) := by
          gcongr
          simpa [dist_comm] using hup
        _ ≤ 2 * (vcDyadicRadius j : ℝ) := by
          linarith [vcDyadicRadius_succ_le j]
    have hpqL2 : booleanL2Dist ν p.1 q.1 ≤
        2 * (vcDyadicRadius j : ℝ) := by
      rw [← (equation_8_31 (μ := ν) p.1 q.1).1]
      exact hpq
    have henergy := sum_sq_booleanIndicator_sub_le_of_empiricalLp_dist_le
      hn sample p.1 q.1
        (show 0 ≤ 2 * (vcDyadicRadius j : ℝ) by positivity) hpqL2
    simpa [vcChainCoefficient, vcChainProjection_succ, p, q,
      vcChainScaleRadius] using henergy

/-- The finite family of adjacent representative pairs at one scale.

**Lean implementation helper.** -/
def vcScalePairFamily [Fintype α] [MeasurableSingletonClass α]
    {n : ℕ} (hn : 0 < n) (sample : Fin n → α)
    (F : BooleanFamily α) (hF : F.Nonempty) (k : ℕ) :
    Finset (↥F × ↥F) :=
  Finset.univ.image fun u =>
    (vcChainProjection hn sample F hF (k + 1) u,
      vcChainProjection hn sample F hF k u)

/-- The coefficient family at VC scale `k` has at most `2^(104(VC(F)+1)(k+2))` elements.

**Lean implementation helper.** -/
theorem card_vcScaleCoefficientFamily_le [Fintype α]
    [MeasurableSingletonClass α] {n : ℕ} (hn : 0 < n)
    (sample : Fin n → α) (F : BooleanFamily α) (hF : F.Nonempty)
    (k : ℕ) :
    (vcScaleCoefficientFamily hn sample F hF k).card ≤
      2 ^ (104 * (F.vcDim + 1) * (k + 2)) := by
  let pairCoeff : (↥F × ↥F) → (Fin n → ℝ) := fun p i =>
    booleanIndicator p.1.1 (sample i) - booleanIndicator p.2.1 (sample i)
  have hfamily : vcScaleCoefficientFamily hn sample F hF k =
      (vcScalePairFamily hn sample F hF k).image pairCoeff := by
    rw [vcScaleCoefficientFamily, vcScalePairFamily, Finset.image_image]
    rfl
  have hcoeffPair : (vcScaleCoefficientFamily hn sample F hF k).card ≤
      (vcScalePairFamily hn sample F hF k).card := by
    rw [hfamily]
    exact Finset.card_image_le
  let N₁ : Finset ↥F := empiricalVCDyadicNet hn sample F k
  let N₀ : Finset ↥F := empiricalVCDyadicNet hn sample F (k - 1)
  let A : Finset ↥F := insert (vcChainAnchor F hF) N₀
  have hpairsSubset : vcScalePairFamily hn sample F hF k ⊆ N₁.product A := by
    intro p hp
    obtain ⟨u, _hu, rfl⟩ := Finset.mem_image.mp hp
    apply Finset.mem_product.mpr
    constructor
    · simpa [N₁] using empiricalVCDyadicProjection_mem hn sample F k u
    · rcases k with _ | j
      · simp [vcChainProjection_zero, A]
      · have hjmem := empiricalVCDyadicProjection_mem hn sample F j u
        simpa [vcChainProjection_succ, A, N₀] using
          (Finset.mem_insert_of_mem hjmem)
  have hpairsCard : (vcScalePairFamily hn sample F hF k).card ≤
      N₁.card * A.card := by
    exact (Finset.card_le_card hpairsSubset).trans_eq
      (Finset.card_product N₁ A)
  let E₀ : ℕ := 26 * (F.vcDim + 1) * (k + 2)
  have hN₁ : N₁.card ≤ 2 ^ E₀ := by
    have h := card_empiricalVCDyadicNet_le hn sample F k
    refine h.trans (Nat.pow_le_pow_right (by omega) ?_)
    dsimp [E₀]
    nlinarith
  have hN₀ : N₀.card ≤ 2 ^ E₀ := by
    have h := card_empiricalVCDyadicNet_le hn sample F (k - 1)
    refine h.trans (Nat.pow_le_pow_right (by omega) ?_)
    dsimp [E₀]
    have hkpred : k - 1 + 2 ≤ k + 2 := by omega
    nlinarith
  have hA : A.card ≤ 2 ^ (E₀ + 1) := by
    have hcardInsert : A.card ≤ N₀.card + 1 := by
      dsimp [A]
      exact Finset.card_insert_le _ _
    calc
      A.card ≤ N₀.card + 1 := hcardInsert
      _ ≤ 2 ^ E₀ + 1 := Nat.add_le_add_right hN₀ 1
      _ ≤ 2 ^ E₀ + 2 ^ E₀ := by
        gcongr
        exact Nat.one_le_two_pow
      _ = 2 ^ (E₀ + 1) := by rw [pow_succ]; omega
  have hprod : N₁.card * A.card ≤ 2 ^ (E₀ + (E₀ + 1)) := by
    calc
      N₁.card * A.card ≤ 2 ^ E₀ * 2 ^ (E₀ + 1) :=
        Nat.mul_le_mul hN₁ hA
      _ = 2 ^ (E₀ + (E₀ + 1)) := (pow_add 2 E₀ (E₀ + 1)).symm
  have hExp : E₀ + (E₀ + 1) ≤
      104 * (F.vcDim + 1) * (k + 2) := by
    let x : ℕ := (F.vcDim + 1) * (k + 2)
    have hx : 1 ≤ x := by
      dsimp [x]
      have : 0 < (F.vcDim + 1) * (k + 2) :=
        Nat.mul_pos (by omega) (by omega)
      omega
    have hE₀x : E₀ = 26 * x := by simp [E₀, x, mul_assoc, mul_left_comm]
    rw [hE₀x]
    have htarget : 104 * (F.vcDim + 1) * (k + 2) = 104 * x := by
      simp [x, mul_assoc]
    rw [htarget]
    omega
  exact hcoeffPair.trans (hpairsCard.trans
    (hprod.trans (Nat.pow_le_pow_right (by omega) hExp)))

/-- If a finite family has cardinality at most `2^E`, then `√log(|A|+2) ≤ √((E+1)log 2)`.

**Lean implementation helper.** -/
private theorem sqrt_log_card_add_two_le_of_card_le_pow
    (A : Finset (Fin n → ℝ)) {E : ℕ} (hE : 1 ≤ E)
    (hcard : A.card ≤ 2 ^ E) :
    Real.sqrt (Real.log ((A.card : ℝ) + 2)) ≤
      Real.sqrt (((E + 1 : ℕ) : ℝ) * Real.log 2) := by
  have htwo : 2 ≤ 2 ^ E := by
    exact (show 2 ^ 1 ≤ 2 ^ E from Nat.pow_le_pow_right (by omega) hE)
  have hcardPow : A.card + 2 ≤ 2 ^ (E + 1) := by
    calc
      A.card + 2 ≤ 2 ^ E + 2 := Nat.add_le_add_right hcard 2
      _ ≤ 2 ^ E + 2 ^ E := Nat.add_le_add_left htwo (2 ^ E)
      _ = 2 ^ (E + 1) := by rw [pow_succ]; omega
  have hcast : (A.card : ℝ) + 2 ≤ (2 : ℝ) ^ (E + 1) := by
    exact_mod_cast hcardPow
  have hlog := Real.log_le_log (by positivity : 0 < (A.card : ℝ) + 2) hcast
  rw [Real.log_pow] at hlog
  exact Real.sqrt_le_sqrt hlog

set_option maxHeartbeats 2000000 in
-- The cast-heavy explicit cardinality normalization needs a larger deterministic budget.
/-- The logarithmic scale cardinality is bounded by a linear dyadic weight;
the generous constant `16` keeps all ceiling and zero-dimension cases safe.

**Lean implementation helper.** -/
theorem sqrt_log_vcScaleCoefficientFamily_le [Fintype α]
    [MeasurableSingletonClass α] {n : ℕ} (hn : 0 < n)
    (sample : Fin n → α) (F : BooleanFamily α) (hF : F.Nonempty)
    (k : ℕ) :
    Real.sqrt (Real.log
      (((vcScaleCoefficientFamily hn sample F hF k).card : ℝ) + 2)) ≤
      16 * Real.sqrt (F.vcDim + 1) * (k + 2) := by
  let E : ℕ := 104 * (F.vcDim + 1) * (k + 2)
  have hE : 1 ≤ E := by
    dsimp [E]
    have : 0 < 104 * (F.vcDim + 1) * (k + 2) := by positivity
    omega
  have hcard : (vcScaleCoefficientFamily hn sample F hF k).card ≤ 2 ^ E := by
    simpa [E] using card_vcScaleCoefficientFamily_le hn sample F hF k
  refine (sqrt_log_card_add_two_le_of_card_le_pow _ hE hcard).trans ?_
  rw [Real.sqrt_le_iff]
  constructor
  · exact mul_nonneg
      (mul_nonneg (by norm_num) (Real.sqrt_nonneg _))
      (by exact_mod_cast (Nat.zero_le (k + 2)))
  · have hlog2 : Real.log 2 ≤ 1 := by
      have h := Real.log_le_sub_one_of_pos (x := (2 : ℝ)) (by norm_num)
      norm_num at h ⊢
      exact h
    have hxNat : 1 ≤ (F.vcDim + 1) * (k + 2) := by
      exact Nat.one_le_iff_ne_zero.mpr (Nat.mul_ne_zero (by omega) (by omega))
    let q : ℕ := (F.vcDim + 1) * (k + 2)
    have hq : 1 ≤ q := by simpa [q] using hxNat
    have hEinNat : E + 1 ≤ 105 * q := by
      have hEform : E = 104 * q := by
        simp [E, q]
        ring
      rw [hEform]
      calc
        104 * q + 1 ≤ 104 * q + q := Nat.add_le_add_left hq _
        _ = 105 * q := by ring
    have hEin : ((E + 1 : ℕ) : ℝ) ≤
        105 * ((F.vcDim + 1 : ℕ) : ℝ) * (k + 2) := by
      have hcast : (((E + 1 : ℕ) : ℕ) : ℝ) ≤ ((105 * q : ℕ) : ℝ) := by
        exact_mod_cast hEinNat
      calc
        ((E + 1 : ℕ) : ℝ) ≤ (105 * q : ℕ) := hcast
        _ = 105 * ((F.vcDim + 1 : ℕ) : ℝ) * (k + 2) := by
          dsimp [q]
          push_cast
          ring
    have hDnonneg : 0 ≤ (F.vcDim : ℝ) + 1 :=
      add_nonneg (Nat.cast_nonneg _) (by norm_num)
    have hsqrtD : Real.sqrt ((F.vcDim : ℝ) + 1) ^ 2 =
        (F.vcDim : ℝ) + 1 := Real.sq_sqrt hDnonneg
    have hk0 : (0 : ℝ) ≤ k := Nat.cast_nonneg _
    have hk2 : (1 : ℝ) ≤ (k : ℝ) + 2 := by linarith
    rw [mul_pow, mul_pow, hsqrtD]
    have hnonneg : 0 ≤ ((E + 1 : ℕ) : ℝ) := Nat.cast_nonneg _
    have hD : 0 ≤ ((F.vcDim + 1 : ℕ) : ℝ) := Nat.cast_nonneg _
    have hK : 0 ≤ (k : ℝ) + 2 := by linarith
    have hKsq : (k : ℝ) + 2 ≤ ((k : ℝ) + 2) ^ 2 := by
      rw [pow_two]
      calc
        (k : ℝ) + 2 = 1 * ((k : ℝ) + 2) := by ring
        _ ≤ ((k : ℝ) + 2) * ((k : ℝ) + 2) :=
          mul_le_mul_of_nonneg_right hk2 hK
    calc
      ((E + 1 : ℕ) : ℝ) * Real.log 2 ≤ ((E + 1 : ℕ) : ℝ) * 1 :=
        mul_le_mul_of_nonneg_left hlog2 hnonneg
      _ = ((E + 1 : ℕ) : ℝ) := by ring
      _ ≤ 105 * ((F.vcDim + 1 : ℕ) : ℝ) * (k + 2) := hEin
      _ ≤ 256 * ((F.vcDim + 1 : ℕ) : ℝ) * (k + 2) := by
        calc
          105 * ((F.vcDim + 1 : ℕ) : ℝ) * (k + 2) =
              105 * (((F.vcDim + 1 : ℕ) : ℝ) * (k + 2)) := by ring
          _ ≤ 256 * (((F.vcDim + 1 : ℕ) : ℝ) * (k + 2)) :=
            mul_le_mul_of_nonneg_right (by norm_num) (mul_nonneg hD hK)
          _ = 256 * ((F.vcDim + 1 : ℕ) : ℝ) * (k + 2) := by ring
      _ ≤ 256 * ((F.vcDim + 1 : ℕ) : ℝ) * (k + 2) ^ 2 :=
        mul_le_mul_of_nonneg_left hKsq (mul_nonneg (by norm_num) hD)
      _ = 16 ^ 2 * ((F.vcDim : ℝ) + 1) * ((k : ℝ) + 2) ^ 2 := by
        push_cast
        ring

/-- The explicit constant accumulated by the finite Rademacher maximum and
the dyadic VC entropy estimate.

**Lean implementation helper.** -/
def vcChainingConstant : ℝ :=
  32 * Real.sqrt (30 / Real.log 2)

/-- Shows that the vc chaining constant is strictly positive.

**Lean implementation helper.** -/
theorem vcChainingConstant_pos : 0 < vcChainingConstant := by
  unfold vcChainingConstant
  have : 0 < Real.log 2 := Real.log_pos (by norm_num)
  positivity

/-- A finite family of coefficient vectors with Euclidean radius at most `R`
has expected canonical Rademacher maximum at most
`2 * sqrt (30 / log 2) * sqrt (log (A.card + 2)) * R`. This Chapter 8 helper packages the Chapter 2 finite-maximum estimate and the
canonical sign coordinates from Chapter 6. Keeping it here preserves the
book's dependency layering: Prelude never imports a numbered chapter.

**Lean implementation helper.** -/
theorem rademacher_finite_max_le {n : ℕ}
    (A : Finset (Fin n → ℝ)) (hA : A.Nonempty) {R : ℝ} (hR : 0 < R)
    (hcoeff : ∀ a ∈ A, ∑ i, (a i) ^ 2 ≤ R ^ 2) :
    (∫ ε, A.sup' hA (fun a =>
      |∑ i, a i * HDP.Chapter6.matrixSignCoordinate i ε|)
      ∂HDP.Chapter6.matrixSignMeasure n) ≤
      (2 * Real.sqrt (30 / Real.log 2)) *
        Real.sqrt (Real.log ((A.card : ℝ) + 2)) * R := by
  classical
  let b : Fin (A.card + 2) → Fin n → ℝ := fun j =>
    if hj : j.val < A.card then
      (A.equivFin.symm ⟨j.val, hj⟩ : A).1
    else 0
  let S : Fin (A.card + 2) →
      HDP.Chapter6.MatrixSignSample n → ℝ := fun j ε =>
    ∑ i, b j i * HDP.Chapter6.matrixSignCoordinate i ε
  let X : Fin (A.card + 2) →
      HDP.Chapter6.MatrixSignSample n → ℝ := fun j ε => |S j ε|
  let ν := HDP.Chapter6.matrixSignMeasure n
  have hlog2 : (0 : ℝ) < Real.log 2 := Real.log_pos (by norm_num)
  have hb (j : Fin (A.card + 2)) : ∑ i, (b j i) ^ 2 ≤ R ^ 2 := by
    by_cases hj : j.val < A.card
    · simpa [b, hj] using
        hcoeff (A.equivFin.symm ⟨j.val, hj⟩ : A).1
          (A.equivFin.symm ⟨j.val, hj⟩ : A).2
    · simp [b, hj, sq_nonneg R]
  have hsignSub (i : Fin n) :
      HDP.SubGaussian (HDP.Chapter6.matrixSignCoordinate i) ν := by
    have hi := HDP.Chapter6.matrixSignCoordinate_isRademacherHDP i
    exact (HDP.psi2Norm_le_of_bounded (μ := ν) (M := (1 : ℝ)) one_pos (by
      filter_upwards [hi.ae_mem] with ε hε
      rcases hε with hε | hε <;> rw [hε] <;> norm_num)).1
  have hSm (j : Fin (A.card + 2)) : Measurable (S j) := by
    exact Finset.measurable_sum _ fun i _ =>
      (HDP.Chapter6.matrixSignCoordinate_measurable i).const_mul (b j i)
  have hSsub (j : Fin (A.card + 2)) : HDP.SubGaussian (S j) ν := by
    let Y : Fin n → HDP.Chapter6.MatrixSignSample n → ℝ := fun i ε =>
      b j i * HDP.Chapter6.matrixSignCoordinate i ε
    have hYm : ∀ i, AEMeasurable (Y i) ν := fun i =>
      ((HDP.Chapter6.matrixSignCoordinate_measurable i).const_mul (b j i)).aemeasurable
    have hYsub : ∀ i, HDP.SubGaussian (Y i) ν := fun i =>
      (hsignSub i).const_mul (b j i)
    have hYmean : ∀ i, ∫ ε, Y i ε ∂ν = 0 := by
      intro i
      rw [show Y i = fun ε =>
        b j i * HDP.Chapter6.matrixSignCoordinate i ε from rfl,
        integral_const_mul,
        (HDP.Chapter6.matrixSignCoordinate_isRademacherHDP i).integral_eq_zero,
        mul_zero]
    have hYindep : iIndepFun Y ν :=
      HDP.Chapter6.matrixSignCoordinate_independent.comp
        (fun i x => b j i * x) (fun i => measurable_const_mul (b j i))
    have hsum := HDP.psi2Norm_sum_sq_le hYm hYsub hYmean hYindep
    simpa [S, Y] using hsum.1
  have hSpsi (j : Fin (A.card + 2)) :
      HDP.psi2Norm (S j) ν ≤ Real.sqrt (30 / Real.log 2) * R := by
    let Y : Fin n → HDP.Chapter6.MatrixSignSample n → ℝ := fun i ε =>
      b j i * HDP.Chapter6.matrixSignCoordinate i ε
    have hYm : ∀ i, AEMeasurable (Y i) ν := fun i =>
      ((HDP.Chapter6.matrixSignCoordinate_measurable i).const_mul (b j i)).aemeasurable
    have hYsub : ∀ i, HDP.SubGaussian (Y i) ν := fun i =>
      (hsignSub i).const_mul (b j i)
    have hYmean : ∀ i, ∫ ε, Y i ε ∂ν = 0 := by
      intro i
      rw [show Y i = fun ε =>
        b j i * HDP.Chapter6.matrixSignCoordinate i ε from rfl,
        integral_const_mul,
        (HDP.Chapter6.matrixSignCoordinate_isRademacherHDP i).integral_eq_zero,
        mul_zero]
    have hYindep : iIndepFun Y ν :=
      HDP.Chapter6.matrixSignCoordinate_independent.comp
        (fun i x => b j i * x) (fun i => measurable_const_mul (b j i))
    have hsum := (HDP.psi2Norm_sum_sq_le hYm hYsub hYmean hYindep).2
    have hpsiY (i : Fin n) :
        (HDP.psi2Norm (Y i) ν) ^ 2 = (b j i) ^ 2 / Real.log 2 := by
      rw [show Y i = fun ε =>
        b j i * HDP.Chapter6.matrixSignCoordinate i ε from rfl,
        HDP.psi2Norm_const_mul,
        HDP.psi2Norm_rademacher
          (HDP.Chapter6.matrixSignCoordinate_isRademacherHDP i),
        mul_pow, div_pow, one_pow, Real.sq_sqrt hlog2.le, sq_abs]
      ring
    have hpsiSum :
        ∑ i, (HDP.psi2Norm (Y i) ν) ^ 2 =
          (∑ i, (b j i) ^ 2) / Real.log 2 := by
      rw [Finset.sum_div]
      exact Finset.sum_congr rfl fun i _ => hpsiY i
    rw [hpsiSum] at hsum
    have hsq :
        (HDP.psi2Norm (S j) ν) ^ 2 ≤
          30 * ((∑ i, (b j i) ^ 2) / Real.log 2) := by
      simpa [S, Y] using hsum
    calc
      HDP.psi2Norm (S j) ν =
          Real.sqrt ((HDP.psi2Norm (S j) ν) ^ 2) :=
        (Real.sqrt_sq (HDP.psi2Norm_nonneg _ _)).symm
      _ ≤ Real.sqrt (30 * ((∑ i, (b j i) ^ 2) / Real.log 2)) :=
        Real.sqrt_le_sqrt hsq
      _ ≤ Real.sqrt (30 * (R ^ 2 / Real.log 2)) := by
        gcongr
        exact hb j
      _ = Real.sqrt (30 / Real.log 2) * R := by
        rw [show 30 * (R ^ 2 / Real.log 2) =
          (30 / Real.log 2) * R ^ 2 by ring,
          Real.sqrt_mul (by positivity : 0 ≤ 30 / Real.log 2),
          Real.sqrt_sq hR.le]
  have hXm (j : Fin (A.card + 2)) : Measurable (X j) := by
    simpa [X] using (hSm j).abs
  have hXsub (j : Fin (A.card + 2)) : HDP.SubGaussian (X j) ν := by
    rcases hSsub j with ⟨K, hK, hSK⟩
    refine ⟨K, hK, ?_⟩
    simpa [X, HDP.psi2MGF, sq_abs] using hSK
  have hXpsi (j : Fin (A.card + 2)) :
      HDP.psi2Norm (X j) ν ≤ Real.sqrt (30 / Real.log 2) * R := by
    have habs : HDP.psi2Norm (X j) ν = HDP.psi2Norm (S j) ν := by
      simp only [X, HDP.psi2Norm, HDP.psi2MGF, sq_abs]
    rw [habs]
    exact hSpsi j
  have hKpos : 0 < Real.sqrt (30 / Real.log 2) * R := by positivity
  have hmax := HDP.expectation_max_le hXm hXsub hKpos hXpsi
  have hsup (ε : HDP.Chapter6.MatrixSignSample n) :
      A.sup' hA (fun a =>
          |∑ i, a i * HDP.Chapter6.matrixSignCoordinate i ε|) =
        Finset.univ.sup' Finset.univ_nonempty (fun j => X j ε) := by
    apply le_antisymm
    · apply Finset.sup'_le
      intro a ha
      let k : Fin A.card := A.equivFin ⟨a, ha⟩
      let j : Fin (A.card + 2) := ⟨k.val, by omega⟩
      have hj : j.val < A.card := k.isLt
      have hba : b j = a := by
        simp only [b, dif_pos hj]
        exact congrArg Subtype.val (A.equivFin.symm_apply_apply ⟨a, ha⟩)
      calc
        |∑ i, a i * HDP.Chapter6.matrixSignCoordinate i ε| = X j ε := by
          simp only [X, S, hba]
        _ ≤ Finset.univ.sup' Finset.univ_nonempty (fun q => X q ε) :=
          Finset.le_sup' (fun q => X q ε) (Finset.mem_univ j)
    · apply Finset.sup'_le
      intro j _hj
      by_cases hj : j.val < A.card
      · let a : A := A.equivFin.symm ⟨j.val, hj⟩
        have hbj : b j = a.1 := by simp [b, hj, a]
        simpa [X, S, hbj] using
          (Finset.le_sup' (fun c =>
            |∑ i, c i * HDP.Chapter6.matrixSignCoordinate i ε|) a.2)
      · have hXzero : X j ε = 0 := by simp [X, S, b, hj]
        rw [hXzero]
        obtain ⟨a, ha⟩ := hA
        exact (abs_nonneg (∑ i,
          a i * HDP.Chapter6.matrixSignCoordinate i ε)).trans
            (Finset.le_sup' (fun c =>
              |∑ i, c i * HDP.Chapter6.matrixSignCoordinate i ε|) ha)
  rw [integral_congr_ae (Filter.Eventually.of_forall hsup)]
  calc
    (∫ ε, Finset.univ.sup' Finset.univ_nonempty (fun j => X j ε) ∂ν)
        ≤ 2 * Real.sqrt (Real.log ((A.card : ℝ) + 2)) *
            (Real.sqrt (30 / Real.log 2) * R) := hmax
    _ = (2 * Real.sqrt (30 / Real.log 2)) *
          Real.sqrt (Real.log ((A.card : ℝ) + 2)) * R := by ring

/-- Expected maximum of the distinct Rademacher increments at one dyadic
scale. Both the coefficient energy and the scale cardinality are discharged
internally from the empirical VC nets.

**Lean implementation helper.** -/
theorem expected_vcScale_rademacherMax_le [Fintype α]
    [MeasurableSingletonClass α] {n : ℕ} (hn : 0 < n)
    (sample : Fin n → α) (F : BooleanFamily α) (hF : F.Nonempty)
    {k : ℕ} (hk : k ≤ n) :
    (∫ ε, (vcScaleCoefficientFamily hn sample F hF k).sup'
        (vcScaleCoefficientFamily_nonempty hn sample F hF k)
        (fun a => |∑ i, a i * HDP.Chapter6.matrixSignCoordinate i ε|)
      ∂HDP.Chapter6.matrixSignMeasure n) ≤
      vcChainingConstant * Real.sqrt (F.vcDim + 1) * (k + 2) *
        Real.sqrt n * vcChainScaleRadius k := by
  let A : Finset (Fin n → ℝ) := vcScaleCoefficientFamily hn sample F hF k
  let R : ℝ := Real.sqrt n * vcChainScaleRadius k
  have hR : 0 < R := by
    dsimp [R]
    exact mul_pos (Real.sqrt_pos.2 (by exact_mod_cast hn))
      (vcChainScaleRadius_pos k)
  have hcoeff : ∀ a ∈ A, ∑ i, (a i) ^ 2 ≤ R ^ 2 := by
    intro a ha
    have henergy := vcScaleCoefficient_energy_le hn sample F hF hk ha
    calc
      ∑ i, (a i) ^ 2 ≤ (n : ℝ) * vcChainScaleRadius k ^ 2 := henergy
      _ = R ^ 2 := by
        dsimp [R]
        rw [mul_pow, Real.sq_sqrt (by positivity : (0 : ℝ) ≤ n)]
  have hmax := rademacher_finite_max_le A
    (vcScaleCoefficientFamily_nonempty hn sample F hF k) hR hcoeff
  have hent := sqrt_log_vcScaleCoefficientFamily_le hn sample F hF k
  calc
    (∫ ε, A.sup' (vcScaleCoefficientFamily_nonempty hn sample F hF k)
        (fun a => |∑ i, a i * HDP.Chapter6.matrixSignCoordinate i ε|)
      ∂HDP.Chapter6.matrixSignMeasure n) ≤
        (2 * Real.sqrt (30 / Real.log 2)) *
          Real.sqrt (Real.log ((A.card : ℝ) + 2)) * R := hmax
    _ ≤ (2 * Real.sqrt (30 / Real.log 2)) *
          (16 * Real.sqrt (F.vcDim + 1) * (k + 2)) * R := by
      gcongr
    _ = vcChainingConstant * Real.sqrt (F.vcDim + 1) * (k + 2) *
          Real.sqrt n * vcChainScaleRadius k := by
      simp only [vcChainingConstant, R]
      ring

/-- Defines the scale-dependent coefficient used in the VC chaining estimate.

**Lean implementation helper.** -/
private def vcWeightedScale (j : ℕ) : ℝ :=
  (j + 3 : ℕ) * vcChainScaleRadius (j + 1)

/-- Successive weighted VC scales contract by a factor of at most `3/4`.

**Lean implementation helper.** -/
private theorem vcWeightedScale_ratio (j : ℕ) :
    vcWeightedScale (j + 1) ≤ (3 / 4 : ℝ) * vcWeightedScale j := by
  have hj : vcChainScaleRadius (j + 1) =
      2 / ((2 : ℝ) ^ (j + 1)) := by
    simp [vcChainScaleRadius, coe_vcDyadicRadius, div_eq_mul_inv]
  have hjs : vcChainScaleRadius (j + 2) =
      2 / ((2 : ℝ) ^ (j + 2)) := by
    simp [vcChainScaleRadius, coe_vcDyadicRadius, div_eq_mul_inv]
  rw [vcWeightedScale, vcWeightedScale, hj, hjs]
  push_cast
  have hpow : (2 : ℝ) ^ (j + 2) = 2 ^ (j + 1) * 2 := by
    conv_lhs => rw [show j + 2 = (j + 1) + 1 by omega, pow_succ]
  rw [hpow]
  have hp : 0 < (2 : ℝ) ^ (j + 1) := by positivity
  field_simp
  nlinarith

/-- The `j`th weighted VC scale is at most `3(3/4)^j`.

**Lean implementation helper.** -/
private theorem vcWeightedScale_geometric (j : ℕ) :
    vcWeightedScale j ≤ 3 * (3 / 4 : ℝ) ^ j := by
  induction j with
  | zero =>
      norm_num [vcWeightedScale, vcChainScaleRadius, coe_vcDyadicRadius]
  | succ j ih =>
      calc
        vcWeightedScale (j + 1) ≤ (3 / 4 : ℝ) * vcWeightedScale j :=
          vcWeightedScale_ratio j
        _ ≤ (3 / 4 : ℝ) * (3 * (3 / 4 : ℝ) ^ j) := by
          gcongr
        _ = 3 * (3 / 4 : ℝ) ^ (j + 1) := by
          rw [pow_succ]
          ring

/-- The dyadic weights of the finite chain have a uniform summable bound.

**Lean implementation helper.** -/
theorem sum_vcChainScaleRadius_le (n : ℕ) :
    ∑ k ∈ Finset.range (n + 1),
      (k + 2 : ℕ) * vcChainScaleRadius k ≤ 14 := by
  rw [Finset.sum_range_succ']
  have hterm0 : ((0 + 2 : ℕ) : ℝ) * vcChainScaleRadius 0 = 2 := by
    norm_num [vcChainScaleRadius]
  rw [hterm0]
  rw [add_comm]
  have hsum : (∑ j ∈ Finset.range n, vcWeightedScale j) ≤
      ∑ j ∈ Finset.range n, 3 * (3 / 4 : ℝ) ^ j := by
    exact Finset.sum_le_sum fun j _ => vcWeightedScale_geometric j
  have hgeomId := geom_sum_mul_neg (3 / 4 : ℝ) n
  have hgeomNonneg : 0 ≤ ∑ j ∈ Finset.range n, (3 / 4 : ℝ) ^ j := by
    positivity
  have hpowNonneg : 0 ≤ (3 / 4 : ℝ) ^ n := by positivity
  have hgeom : (∑ j ∈ Finset.range n, (3 / 4 : ℝ) ^ j) ≤ 4 := by
    norm_num at hgeomId
    nlinarith
  calc
    2 + ∑ x ∈ Finset.range n,
          ((x + 1 + 2 : ℕ) : ℝ) * vcChainScaleRadius (x + 1) =
        2 + ∑ j ∈ Finset.range n, vcWeightedScale j := by
      apply congrArg (fun z : ℝ => 2 + z)
      apply Finset.sum_congr rfl
      intro j _
      dsimp [vcWeightedScale]
    _ ≤ 2 + ∑ j ∈ Finset.range n, 3 * (3 / 4 : ℝ) ^ j :=
      add_le_add (le_refl 2) hsum
    _ = 2 + 3 * ∑ j ∈ Finset.range n, (3 / 4 : ℝ) ^ j := by
      rw [Finset.mul_sum]
    _ ≤ 14 := by nlinarith

/-- The empirical-process coordinate of one Boolean support.

**Lean implementation helper.** -/
def booleanDeviation {n : ℕ} (μ : Measure α)
    (sample : Fin n → α) (u : Finset α) : ℝ :=
  empiricalProcessValue μ sample (booleanIndicator u)

/-- Simultaneous Boolean empirical deviations over a finite class.

**Lean implementation helper.** -/
def booleanDeviationVector {n : ℕ} (F : BooleanFamily α)
    (μ : Measure α) (sample : Fin n → α) : ↥F → ℝ :=
  fun u => booleanDeviation μ sample u.1

/-- The finite uniform empirical deviation. The norm is the maximum absolute
coordinate on the finite subtype `↥F`, including the empty class.

**Lean implementation helper.** -/
def booleanUniformDeviation {n : ℕ} (F : BooleanFamily α)
    (μ : Measure α) (sample : Fin n → α) : ℝ :=
  ‖booleanDeviationVector F μ sample‖

/-- Shows that the uniform empirical deviation of a finite Boolean family is nonnegative.

**Lean implementation helper.** -/
theorem booleanUniformDeviation_nonneg {n : ℕ} (F : BooleanFamily α)
    (sample : Fin n → α) :
    0 ≤ booleanUniformDeviation F μ sample := norm_nonneg _

/-- Every class member is bounded by the finite uniform deviation.

**Lean implementation helper.** -/
theorem abs_booleanDeviation_le_uniform {n : ℕ} (F : BooleanFamily α)
    (sample : Fin n → α) {u : Finset α} (hu : u ∈ F) :
    |booleanDeviation μ sample u| ≤ booleanUniformDeviation F μ sample := by
  simpa [booleanUniformDeviation, booleanDeviationVector, Real.norm_eq_abs] using
    (norm_le_pi_norm (booleanDeviationVector F μ sample) ⟨u, hu⟩)

/-- A coordinatewise deviation bound is a uniform deviation bound.

**Lean implementation helper.** -/
theorem booleanUniformDeviation_le {n : ℕ} (F : BooleanFamily α)
    (sample : Fin n → α) {δ : ℝ} (hδ : 0 ≤ δ)
    (h : ∀ u ∈ F, |booleanDeviation μ sample u| ≤ δ) :
    booleanUniformDeviation F μ sample ≤ δ := by
  rw [booleanUniformDeviation, pi_norm_le_iff_of_nonneg hδ]
  intro u
  simpa [booleanDeviationVector, Real.norm_eq_abs] using h u.1 u.2

/-- Shows that the uniform empirical deviation of a finite Boolean family is measurable.

**Lean implementation helper.** -/
theorem measurable_booleanUniformDeviation {n : ℕ}
    (F : BooleanFamily α) (X : Fin n → Ω → α)
    (hdev : ∀ u ∈ F, Measurable
      (fun ω => booleanDeviation μ (fun i => X i ω) u)) :
    Measurable (fun ω => booleanUniformDeviation F μ (fun i => X i ω)) := by
  apply Measurable.norm
  apply measurable_pi_lambda
  intro u
  exact hdev u.1 u.2

/-- A pointwise tail
bound `q` for each member of a finite Boolean class yields the uniform tail
bound `|F| q`. Unlike the informal arbitrary supremum, all bad events are
explicitly measurable. Sauer--Shelah/VC covering bounds may subsequently
replace `F.card` by a dimension-dependent trace bound.

**Book Theorem 8.3.15.** -/
theorem theorem_8_3_15_finite_uniform_tail
    {n : ℕ} [IsProbabilityMeasure P]
    (F : BooleanFamily α) (X : Fin n → Ω → α)
    {δ q : ℝ} (hδ : 0 ≤ δ)
    (hdev : ∀ u ∈ F, Measurable
      (fun ω => booleanDeviation μ (fun i => X i ω) u))
    (hpoint : ∀ u ∈ F,
      P.real {ω | δ < |booleanDeviation μ (fun i => X i ω) u|} ≤ q) :
    P.real {ω | δ < booleanUniformDeviation F μ (fun i => X i ω)} ≤
      F.card * q := by
  let E : Finset α → Set Ω := fun u =>
    {ω | δ < |booleanDeviation μ (fun i => X i ω) u|}
  have hE : ∀ u ∈ F, MeasurableSet (E u) := by
    intro u hu
    exact measurableSet_lt measurable_const (hdev u hu).abs
  have hsubset :
      {ω | δ < booleanUniformDeviation F μ (fun i => X i ω)} ⊆
        ⋃ u ∈ F, E u := by
    intro ω hω
    by_contra hmem
    simp only [mem_iUnion, not_exists] at hmem
    have hall : ∀ u ∈ F,
        |booleanDeviation μ (fun i => X i ω) u| ≤ δ := by
      intro u hu
      exact le_of_not_gt (hmem u hu)
    exact (not_le_of_gt hω) (booleanUniformDeviation_le F _ hδ hall)
  calc
    P.real {ω | δ < booleanUniformDeviation F μ (fun i => X i ω)} ≤
        P.real (⋃ u ∈ F, E u) :=
      measureReal_mono hsubset (measure_ne_top P _)
    _ ≤ ∑ u ∈ F, P.real (E u) :=
      HDP.Chapter1.union_bound F E hE
    _ ≤ ∑ _u ∈ F, q := by
      exact Finset.sum_le_sum fun u hu => hpoint u hu
    _ = F.card * q := by simp

/-- Cardinality-compressed form of the finite VC tail endpoint.

**Lean implementation helper.** -/
theorem theorem_8_3_15_finite_vc_law_of_large_numbers
    {n M : ℕ} [IsProbabilityMeasure P]
    (F : BooleanFamily α) (X : Fin n → Ω → α)
    {δ q : ℝ} (hδ : 0 ≤ δ) (hq : 0 ≤ q)
    (hcard : F.card ≤ M)
    (hdev : ∀ u ∈ F, Measurable
      (fun ω => booleanDeviation μ (fun i => X i ω) u))
    (hpoint : ∀ u ∈ F,
      P.real {ω | δ < |booleanDeviation μ (fun i => X i ω) u|} ≤ q) :
    P.real {ω | δ < booleanUniformDeviation F μ (fun i => X i ω)} ≤
      M * q := by
  refine (theorem_8_3_15_finite_uniform_tail F X hδ hdev hpoint).trans ?_
  exact mul_le_mul_of_nonneg_right (by exact_mod_cast hcard) hq

/-! ## Remark 8.3.16: Rademacher complexity -/

/-- The normalized signed supremum of a finite Boolean class for fixed signs.

**Lean implementation helper.** -/
def finiteRademacherSupremum {n : ℕ} (F : BooleanFamily α)
    (sample : Fin n → α) (sign : Fin n → ℝ) : ℝ :=
  if hF : F.Nonempty then
    (n : ℝ)⁻¹ * F.sup' hF (fun u =>
      |∑ i, sign i * booleanIndicator u (sample i)|)
  else 0

/-- Rademacher complexity controls the empirical deviation and has the same VC rate. Conditional Rademacher complexity of a finite
Boolean class, with signs on an explicit probability space.

**Book Remark 8.3.16.** -/
def finiteRademacherComplexity {n : ℕ} (F : BooleanFamily α)
    (sample : Fin n → α) (ε : Fin n → Ω' → ℝ) (Q : Measure Ω') : ℝ :=
  ∫ η, finiteRademacherSupremum F sample (fun i => ε i η) ∂Q

/-- Shows that the finite Rademacher supremum is nonnegative.

**Lean implementation helper.** -/
theorem finiteRademacherSupremum_nonneg {n : ℕ}
    (F : BooleanFamily α) (sample : Fin n → α) (sign : Fin n → ℝ) :
    0 ≤ finiteRademacherSupremum F sample sign := by
  classical
  by_cases hF : F.Nonempty
  · rw [finiteRademacherSupremum, dif_pos hF]
    apply mul_nonneg (inv_nonneg.mpr (Nat.cast_nonneg n))
    obtain ⟨u, hu⟩ := hF
    exact (abs_nonneg _).trans
      (Finset.le_sup' (fun v => |∑ i, sign i * booleanIndicator v (sample i)|) hu)
  · simp [finiteRademacherSupremum, hF]

/-- Shows that the finite Rademacher complexity is nonnegative.

**Lean implementation helper.** -/
theorem finiteRademacherComplexity_nonneg {n : ℕ}
    (F : BooleanFamily α) (sample : Fin n → α)
    (ε : Fin n → Ω' → ℝ) :
    0 ≤ finiteRademacherComplexity F sample ε Q := by
  exact integral_nonneg fun η => finiteRademacherSupremum_nonneg F sample _

/-- Unnormalized signed sum indexed by one Boolean support.

**Lean implementation helper.** -/
def booleanSignedSum {n : ℕ} (sample : Fin n → α) (u : Finset α)
    (sign : Fin n → ℝ) : ℝ :=
  ∑ i, sign i * booleanIndicator u (sample i)

/-- Maximum absolute increment at one level of the internal VC chain.

**Lean implementation helper.** -/
def vcScaleSignedMax [Fintype α] [MeasurableSingletonClass α]
    {n : ℕ} (hn : 0 < n) (sample : Fin n → α)
    (F : BooleanFamily α) (hF : F.Nonempty) (k : ℕ)
    (sign : Fin n → ℝ) : ℝ :=
  (vcScaleCoefficientFamily hn sample F hF k).sup'
    (vcScaleCoefficientFamily_nonempty hn sample F hF k)
    fun a => |∑ i, a i * sign i|

/-- Pointwise telescoping of the Boolean Rademacher supremum through all
internally chosen dyadic nets. The terminal projection has the same sample
trace by `booleanIndicator_vcDyadicProjection_last`.

**Lean implementation helper.** -/
theorem booleanRademacherSup_le_chain [Fintype α]
    [MeasurableSingletonClass α] {n : ℕ} (hn : 0 < n)
    (sample : Fin n → α) (F : BooleanFamily α) (hF : F.Nonempty)
    (sign : Fin n → ℝ) :
    F.sup' hF (fun u => |booleanSignedSum sample u sign|) ≤
      |booleanSignedSum sample (vcChainAnchor F hF).1 sign| +
        ∑ k ∈ Finset.range (n + 1),
          vcScaleSignedMax hn sample F hF k sign := by
  apply Finset.sup'_le
  intro u hu
  let us : ↥F := ⟨u, hu⟩
  let Z : ℕ → ℝ := fun level =>
    booleanSignedSum sample
      (vcChainProjection hn sample F hF level us).1 sign
  have hlast : booleanSignedSum sample u sign = Z (n + 1) := by
    unfold booleanSignedSum Z us
    apply Finset.sum_congr rfl
    intro i _
    rw [vcChainProjection_succ,
      booleanIndicator_vcDyadicProjection_last hn sample F ⟨u, hu⟩ i]
  have hzero : Z 0 =
      booleanSignedSum sample (vcChainAnchor F hF).1 sign := by
    simp [Z]
  have hinc (k : ℕ) : Z (k + 1) - Z k =
      ∑ i, vcChainCoefficient hn sample F hF k us i * sign i := by
    simp only [Z, booleanSignedSum, vcChainCoefficient]
    rw [← Finset.sum_sub_distrib]
    apply Finset.sum_congr rfl
    intro i _
    ring
  have htelescope : Z (n + 1) = Z 0 +
      ∑ k ∈ Finset.range (n + 1),
        (∑ i, vcChainCoefficient hn sample F hF k us i * sign i) := by
    have htel := Finset.sum_range_sub Z (n + 1)
    simp_rw [hinc] at htel
    linarith
  rw [hlast, htelescope, hzero]
  calc
    |booleanSignedSum sample (vcChainAnchor F hF).1 sign +
        ∑ k ∈ Finset.range (n + 1),
          ∑ i, vcChainCoefficient hn sample F hF k us i * sign i| ≤
        |booleanSignedSum sample (vcChainAnchor F hF).1 sign| +
          |∑ k ∈ Finset.range (n + 1),
            ∑ i, vcChainCoefficient hn sample F hF k us i * sign i| :=
      abs_add_le _ _
    _ ≤ |booleanSignedSum sample (vcChainAnchor F hF).1 sign| +
        ∑ k ∈ Finset.range (n + 1),
          |∑ i, vcChainCoefficient hn sample F hF k us i * sign i| := by
      gcongr
      exact Finset.abs_sum_le_sum_abs _ _
    _ ≤ |booleanSignedSum sample (vcChainAnchor F hF).1 sign| +
        ∑ k ∈ Finset.range (n + 1),
          vcScaleSignedMax hn sample F hF k sign := by
      gcongr with k hk
      unfold vcScaleSignedMax
      exact Finset.le_sup'
        (fun a : Fin n → ℝ => |∑ i, a i * sign i|)
        (Finset.mem_image.mpr ⟨us, Finset.mem_univ _, rfl⟩)

/-- Shows that the largest absolute Rademacher coefficient is integrable.

**Lean implementation helper.** -/
private theorem integrable_rademacherCoefficientMax {n : ℕ}
    (A : Finset (Fin n → ℝ)) (hA : A.Nonempty) :
    Integrable (fun ε => A.sup' hA (fun a =>
      |∑ i, a i * HDP.Chapter6.matrixSignCoordinate i ε|))
      (HDP.Chapter6.matrixSignMeasure n) := by
  let ν := HDP.Chapter6.matrixSignMeasure n
  have hlinear (a : Fin n → ℝ) : Integrable (fun ε =>
      |∑ i, a i * HDP.Chapter6.matrixSignCoordinate i ε|) ν := by
    apply Integrable.abs
    apply integrable_finsetSum
    intro i _
    exact (((HDP.Chapter6.matrixSignCoordinate_isRademacherHDP i).memLp 1).integrable
      le_rfl).const_mul (a i)
  have hraw : Integrable
      (A.sup' hA fun a => fun ε =>
        |∑ i, a i * HDP.Chapter6.matrixSignCoordinate i ε|) ν :=
    Finset.sup'_induction hA
      (fun a ε => |∑ i, a i * HDP.Chapter6.matrixSignCoordinate i ε|)
      (p := fun f : HDP.Chapter6.MatrixSignSample n → ℝ => Integrable f ν)
      (fun _ hf _ hg => hf.sup hg) (fun a _ => hlinear a)
  have heq : (A.sup' hA fun a => fun ε =>
      |∑ i, a i * HDP.Chapter6.matrixSignCoordinate i ε|) =
      (fun ε => A.sup' hA (fun a =>
        |∑ i, a i * HDP.Chapter6.matrixSignCoordinate i ε|)) := by
    funext ε
    simp only [Finset.sup'_apply]
  rwa [heq] at hraw

/-- Shows that the raw Boolean Rademacher supremum is integrable.

**Lean implementation helper.** -/
private theorem integrable_booleanRademacherSupRaw
    {n : ℕ} (sample : Fin n → α) (F : BooleanFamily α) (hF : F.Nonempty) :
    Integrable (fun ε => F.sup' hF (fun u =>
      |booleanSignedSum sample u
        (fun i => HDP.Chapter6.matrixSignCoordinate i ε)|))
      (HDP.Chapter6.matrixSignMeasure n) := by
  let ν := HDP.Chapter6.matrixSignMeasure n
  have hlinear (u : Finset α) : Integrable (fun ε =>
      |booleanSignedSum sample u
        (fun i => HDP.Chapter6.matrixSignCoordinate i ε)|) ν := by
    apply Integrable.abs
    unfold booleanSignedSum
    apply integrable_finsetSum
    intro i _
    simpa [mul_comm] using
      (((HDP.Chapter6.matrixSignCoordinate_isRademacherHDP i).memLp 1).integrable
        le_rfl).const_mul (booleanIndicator u (sample i))
  have hraw : Integrable
      (F.sup' hF fun u => fun ε =>
        |booleanSignedSum sample u
          (fun i => HDP.Chapter6.matrixSignCoordinate i ε)|) ν :=
    Finset.sup'_induction hF
      (fun u ε => |booleanSignedSum sample u
        (fun i => HDP.Chapter6.matrixSignCoordinate i ε)|)
      (p := fun f : HDP.Chapter6.MatrixSignSample n → ℝ => Integrable f ν)
      (fun _ hf _ hg => hf.sup hg) (fun u _ => hlinear u)
  have heq : (F.sup' hF fun u => fun ε =>
      |booleanSignedSum sample u
        (fun i => HDP.Chapter6.matrixSignCoordinate i ε)|) =
      (fun ε => F.sup' hF (fun u =>
        |booleanSignedSum sample u
          (fun i => HDP.Chapter6.matrixSignCoordinate i ε)|)) := by
    funext ε
    simp only [Finset.sup'_apply]
  rwa [heq] at hraw

/-- The expected absolute signed sum at the VC chain anchor is at most the chaining constant times `√(VC(F)+1) √n`.

**Lean implementation helper.** -/
private theorem expected_vcChainAnchor_le
    [MeasurableSingletonClass α] {n : ℕ} (hn : 0 < n)
    (sample : Fin n → α) (F : BooleanFamily α) (hF : F.Nonempty) :
    (∫ ε, |booleanSignedSum sample (vcChainAnchor F hF).1
        (fun i => HDP.Chapter6.matrixSignCoordinate i ε)|
      ∂HDP.Chapter6.matrixSignMeasure n) ≤
      vcChainingConstant * Real.sqrt (F.vcDim + 1) * Real.sqrt n := by
  let a : Fin n → ℝ := fun i =>
    booleanIndicator (vcChainAnchor F hF).1 (sample i)
  let A : Finset (Fin n → ℝ) := {a}
  let R : ℝ := Real.sqrt n
  have hR : 0 < R := Real.sqrt_pos.2 (by exact_mod_cast hn)
  have hcoeff : ∀ b ∈ A, ∑ i, (b i) ^ 2 ≤ R ^ 2 := by
    intro b hb
    have hba : b = a := by simpa [A] using hb
    subst b
    calc
      ∑ i, (a i) ^ 2 ≤ ∑ _i : Fin n, (1 : ℝ) := by
        apply Finset.sum_le_sum
        intro i _
        by_cases hi : sample i ∈ (vcChainAnchor F hF).1 <;>
          simp [a, booleanIndicator, hi]
      _ = (n : ℝ) := by simp
      _ = R ^ 2 := by simp [R, Real.sq_sqrt (by positivity : (0 : ℝ) ≤ n)]
  have hmax := rademacher_finite_max_le A (by simp [A]) hR hcoeff
  have hlog3 : Real.sqrt (Real.log 3) ≤ 16 * Real.sqrt (F.vcDim + 1) := by
    rw [Real.sqrt_le_iff]
    constructor
    · positivity
    · have hlog : Real.log 3 ≤ 2 := by
        have h := Real.log_le_sub_one_of_pos (x := (3 : ℝ)) (by norm_num)
        norm_num at h ⊢
        exact h
      have hsqrt : Real.sqrt ((F.vcDim : ℝ) + 1) ^ 2 =
          (F.vcDim : ℝ) + 1 := Real.sq_sqrt (by positivity)
      rw [mul_pow, hsqrt]
      nlinarith
  calc
    (∫ ε, |booleanSignedSum sample (vcChainAnchor F hF).1
        (fun i => HDP.Chapter6.matrixSignCoordinate i ε)|
      ∂HDP.Chapter6.matrixSignMeasure n) =
        ∫ ε, A.sup' (by simp [A]) (fun b =>
          |∑ i, b i * HDP.Chapter6.matrixSignCoordinate i ε|)
        ∂HDP.Chapter6.matrixSignMeasure n := by
      apply integral_congr_ae
      filter_upwards [] with ε
      simp [A, a, booleanSignedSum, mul_comm]
    _ ≤ (2 * Real.sqrt (30 / Real.log 2)) *
          Real.sqrt (Real.log ((A.card : ℝ) + 2)) * R := hmax
    _ = (2 * Real.sqrt (30 / Real.log 2)) * Real.sqrt (Real.log 3) * R := by
      have hAcard : A.card = 1 := by simp [A]
      rw [hAcard]
      norm_num
    _ ≤ (2 * Real.sqrt (30 / Real.log 2)) *
          (16 * Real.sqrt (F.vcDim + 1)) * R := by
      gcongr
    _ = vcChainingConstant * Real.sqrt (F.vcDim + 1) * Real.sqrt n := by
      dsimp [vcChainingConstant, R]
      ring

/-- Expected unnormalized conditional Rademacher supremum. This is the
finite-chain conclusion before dividing by the sample size.

**Lean implementation helper.** -/
theorem expected_booleanRademacherSupRaw_le [Finite α]
    [MeasurableSingletonClass α] {n : ℕ} (hn : 0 < n)
    (sample : Fin n → α) (F : BooleanFamily α) (hF : F.Nonempty) :
    (∫ ε, F.sup' hF (fun u =>
        |booleanSignedSum sample u
          (fun i => HDP.Chapter6.matrixSignCoordinate i ε)|)
      ∂HDP.Chapter6.matrixSignMeasure n) ≤
      15 * vcChainingConstant * Real.sqrt (F.vcDim + 1) * Real.sqrt n := by
  letI := Fintype.ofFinite α
  let ν := HDP.Chapter6.matrixSignMeasure n
  let base : HDP.Chapter6.MatrixSignSample n → ℝ := fun ε =>
    |booleanSignedSum sample (vcChainAnchor F hF).1
      (fun i => HDP.Chapter6.matrixSignCoordinate i ε)|
  let scale : ℕ → HDP.Chapter6.MatrixSignSample n → ℝ := fun k ε =>
    vcScaleSignedMax hn sample F hF k
      (fun i => HDP.Chapter6.matrixSignCoordinate i ε)
  have hleftInt := integrable_booleanRademacherSupRaw sample F hF
  have hbaseInt : Integrable base ν := by
    apply Integrable.abs
    unfold booleanSignedSum
    apply integrable_finsetSum
    intro i _
    simpa [mul_comm] using
      (((HDP.Chapter6.matrixSignCoordinate_isRademacherHDP i).memLp 1).integrable
        le_rfl).const_mul (booleanIndicator (vcChainAnchor F hF).1 (sample i))
  have hscaleInt : ∀ k, Integrable (scale k) ν := by
    intro k
    simpa [scale, vcScaleSignedMax] using
      integrable_rademacherCoefficientMax
        (vcScaleCoefficientFamily hn sample F hF k)
        (vcScaleCoefficientFamily_nonempty hn sample F hF k)
  have hsumInt : Integrable
      (fun ε => ∑ k ∈ Finset.range (n + 1), scale k ε) ν :=
    integrable_finsetSum _ fun k _ => hscaleInt k
  have hrhsInt : Integrable (fun ε => base ε +
      ∑ k ∈ Finset.range (n + 1), scale k ε) ν := hbaseInt.add hsumInt
  have hmono :
      (∫ ε, F.sup' hF (fun u =>
          |booleanSignedSum sample u
            (fun i => HDP.Chapter6.matrixSignCoordinate i ε)|) ∂ν) ≤
        ∫ ε, (base ε + ∑ k ∈ Finset.range (n + 1), scale k ε) ∂ν := by
    apply integral_mono hleftInt hrhsInt
    intro ε
    exact booleanRademacherSup_le_chain hn sample F hF
      (fun i => HDP.Chapter6.matrixSignCoordinate i ε)
  have hscaleBound : ∑ k ∈ Finset.range (n + 1),
      (∫ ε, scale k ε ∂ν) ≤
      ∑ k ∈ Finset.range (n + 1),
        vcChainingConstant * Real.sqrt (F.vcDim + 1) * (k + 2) *
          Real.sqrt n * vcChainScaleRadius k := by
    apply Finset.sum_le_sum
    intro k hk
    have hkn : k ≤ n := by
      have hk' : k < n + 1 := Finset.mem_range.mp hk
      omega
    simpa [scale, vcScaleSignedMax, ν] using
      expected_vcScale_rademacherMax_le hn sample F hF hkn
  let C : ℝ := vcChainingConstant * Real.sqrt (F.vcDim + 1) * Real.sqrt n
  have hC : 0 ≤ C := by
    dsimp [C]
    exact mul_nonneg
      (mul_nonneg vcChainingConstant_pos.le (Real.sqrt_nonneg _))
      (Real.sqrt_nonneg _)
  calc
    (∫ ε, F.sup' hF (fun u =>
        |booleanSignedSum sample u
          (fun i => HDP.Chapter6.matrixSignCoordinate i ε)|) ∂ν) ≤
        ∫ ε, (base ε + ∑ k ∈ Finset.range (n + 1), scale k ε) ∂ν := hmono
    _ = (∫ ε, base ε ∂ν) +
        ∑ k ∈ Finset.range (n + 1), ∫ ε, scale k ε ∂ν := by
      rw [integral_add hbaseInt hsumInt,
        integral_finsetSum (Finset.range (n + 1)) (fun k _ => hscaleInt k)]
    _ ≤ C + ∑ k ∈ Finset.range (n + 1),
        vcChainingConstant * Real.sqrt (F.vcDim + 1) * (k + 2) *
          Real.sqrt n * vcChainScaleRadius k := by
      apply add_le_add
      · simpa [base, C, ν] using expected_vcChainAnchor_le hn sample F hF
      · exact hscaleBound
    _ = C + C * (∑ k ∈ Finset.range (n + 1),
        (k + 2 : ℕ) * vcChainScaleRadius k) := by
      dsimp [C]
      rw [Finset.mul_sum]
      congr 1
      apply Finset.sum_congr rfl
      intro k _
      push_cast
      ring
    _ ≤ C + C * 14 := by
      gcongr
      exact sum_vcChainScaleRadius_le n
    _ = 15 * vcChainingConstant * Real.sqrt (F.vcDim + 1) * Real.sqrt n := by
      dsimp [C]
      ring

/-- Explicit universal constant for the finite VC law of large numbers.

**Lean implementation helper.** -/
def vcLawConstant : ℝ := 30 * vcChainingConstant

/-- Shows that the vc law constant is strictly positive.

**Lean implementation helper.** -/
theorem vcLawConstant_pos : 0 < vcLawConstant := by
  unfold vcLawConstant
  exact mul_pos (by norm_num) vcChainingConstant_pos

/-- Rademacher complexity controls the empirical deviation and has the same VC rate. The conditional
Rademacher complexity of a nonempty Boolean class is bounded by
`C √(d/n)`, using the canonical independent signs. The hypotheses `d ≥ 1`
and `n > 0` make the source's normalization and zero-dimension edge case
explicit.

**Book Remark 8.3.16.** -/
theorem finiteRademacherComplexity_vc_le [Finite α]
    [MeasurableSingletonClass α] {n : ℕ} (hn : 0 < n)
    (sample : Fin n → α) (F : BooleanFamily α) (hF : F.Nonempty)
    (hd : 1 ≤ F.vcDim) :
    finiteRademacherComplexity F sample
      (fun i => HDP.Chapter6.matrixSignCoordinate i)
      (HDP.Chapter6.matrixSignMeasure n) ≤
      vcLawConstant * Real.sqrt ((F.vcDim : ℝ) / n) := by
  let ν := HDP.Chapter6.matrixSignMeasure n
  let raw : HDP.Chapter6.MatrixSignSample n → ℝ := fun ε =>
    F.sup' hF (fun u => |booleanSignedSum sample u
      (fun i => HDP.Chapter6.matrixSignCoordinate i ε)|)
  have hrawInt : Integrable raw ν := by
    simpa [raw] using integrable_booleanRademacherSupRaw sample F hF
  have hraw := expected_booleanRademacherSupRaw_le hn sample F hF
  have hfiniteEq : finiteRademacherComplexity F sample
      (fun i => HDP.Chapter6.matrixSignCoordinate i) ν =
      (n : ℝ)⁻¹ * ∫ ε, raw ε ∂ν := by
    rw [finiteRademacherComplexity]
    have heq : (fun ε => finiteRademacherSupremum F sample
        (fun i => HDP.Chapter6.matrixSignCoordinate i ε)) =
        (fun ε => (n : ℝ)⁻¹ * raw ε) := by
      funext ε
      simp only [finiteRademacherSupremum, dif_pos hF, raw, booleanSignedSum]
    rw [heq, integral_const_mul]
  have hsqrtD : Real.sqrt ((F.vcDim : ℝ) + 1) ≤
      2 * Real.sqrt (F.vcDim : ℝ) := by
    rw [Real.sqrt_le_iff]
    constructor
    · positivity
    · rw [mul_pow, Real.sq_sqrt (by positivity : (0 : ℝ) ≤ F.vcDim)]
      have hdR : (1 : ℝ) ≤ F.vcDim := by exact_mod_cast hd
      nlinarith
  have hscaled : (n : ℝ)⁻¹ * (∫ ε, raw ε ∂ν) ≤
      (n : ℝ)⁻¹ *
        (30 * vcChainingConstant * Real.sqrt (F.vcDim : ℝ) * Real.sqrt n) := by
    apply mul_le_mul_of_nonneg_left _ (by positivity)
    calc
      (∫ ε, raw ε ∂ν) ≤
          15 * vcChainingConstant * Real.sqrt (F.vcDim + 1) * Real.sqrt n := by
        simpa [raw, ν] using hraw
      _ ≤ 15 * vcChainingConstant *
          (2 * Real.sqrt (F.vcDim : ℝ)) * Real.sqrt n := by
        apply mul_le_mul_of_nonneg_right _ (Real.sqrt_nonneg _)
        exact mul_le_mul_of_nonneg_left hsqrtD
          (mul_nonneg (by norm_num) vcChainingConstant_pos.le)
      _ = 30 * vcChainingConstant * Real.sqrt (F.vcDim : ℝ) * Real.sqrt n := by
        ring
  rw [hfiniteEq]
  refine hscaled.trans_eq ?_
  unfold vcLawConstant
  have hnR : (0 : ℝ) < n := by exact_mod_cast hn
  have hsqrtn : 0 < Real.sqrt (n : ℝ) := Real.sqrt_pos.2 hnR
  rw [Real.sqrt_div (by positivity : (0 : ℝ) ≤ F.vcDim)]
  have hsqrtnSq : Real.sqrt (n : ℝ) ^ 2 = (n : ℝ) :=
    Real.sq_sqrt hnR.le
  have hcancel : (n : ℝ)⁻¹ * Real.sqrt (n : ℝ) =
      (Real.sqrt (n : ℝ))⁻¹ := by
    field_simp
    exact hsqrtnSq
  rw [show (n : ℝ)⁻¹ *
      (30 * vcChainingConstant * Real.sqrt (F.vcDim : ℝ) * Real.sqrt n) =
      30 * vcChainingConstant * Real.sqrt (F.vcDim : ℝ) *
        ((n : ℝ)⁻¹ * Real.sqrt n) by ring,
    hcancel]
  ring

/-- Let `X₁, …, Xₙ` be independent random variables with common law `μ`. For a
nonempty finite Boolean class of VC dimension at least one, the expected
uniform empirical deviation is at most `2 C √(d/n)`, where
`C = vcLawConstant` is explicit. The only probabilistic assumptions are the
i.i.d. sample hypotheses; all nets and the Rademacher chain are constructed
internally.

**Book Theorem 8.3.15.** -/
theorem theorem_8_3_15_finite_vc_expected [Finite α]
    [MeasurableSingletonClass α] [IsProbabilityMeasure μ]
    [IsProbabilityMeasure P] {n : ℕ} (hn : 0 < n)
    (F : BooleanFamily α) (hF : F.Nonempty) (hd : 1 ≤ F.vcDim)
    (X : Fin n → Ω → α) (hXm : ∀ i, Measurable (X i))
    (hLaw : ∀ i, HasLaw (X i) μ P) (hInd : iIndepFun X P) :
    (∫ ω, booleanUniformDeviation F μ (fun i => X i ω) ∂P) ≤
      2 * vcLawConstant * Real.sqrt ((F.vcDim : ℝ) / n) := by
  classical
  let ν := HDP.Chapter6.matrixSignMeasure n
  let V : Fin n → Ω → (↥F → ℝ) := fun i ω u =>
    booleanIndicator u.1 (X i ω)
  have hVm (i : Fin n) : Measurable (V i) := by
    apply measurable_pi_lambda
    intro u
    simpa [V, booleanIndicator_eq_booleanValue, Function.comp_def] using
      (measurable_booleanValue u.1).comp (hXm i)
  have hVint (i : Fin n) : Integrable (V i) P := by
    apply Integrable.of_eval
    intro u
    refine Integrable.of_bound
      ((measurable_pi_apply u).comp (hVm i)).aestronglyMeasurable 1 ?_
    filter_upwards [] with ω
    change |booleanIndicator u.1 (X i ω)| ≤ 1
    exact abs_booleanIndicator_le_one u.1 (X i ω)
  have hVind : iIndepFun V P := by
    have hg (i : Fin n) : Measurable
        (fun x : α => fun u : ↥F => booleanIndicator u.1 x) := by
      apply measurable_pi_lambda
      intro u
      simpa [booleanIndicator_eq_booleanValue] using
        measurable_booleanValue u.1
    simpa [V, Function.comp_def] using
      hInd.comp (fun _ x => fun u : ↥F => booleanIndicator u.1 x) hg
  have hIntCoord (i : Fin n) (u : ↥F) :
      (∫ ω, V i ω ∂P) u = ∫ ω, booleanIndicator u.1 (X i ω) ∂P := by
    rw [MeasureTheory.eval_integral (fun v => (hVint i).eval v) u]
  have hLawInt (i : Fin n) (u : ↥F) :
      (∫ ω, booleanIndicator u.1 (X i ω) ∂P) =
        ∫ x, booleanIndicator u.1 x ∂μ := by
    have h := (hLaw i).integral_comp
      (f := booleanIndicator u.1)
      (by simpa [booleanIndicator_eq_booleanValue] using
        (measurable_booleanValue u.1).aestronglyMeasurable)
    simpa [Function.comp_def] using h
  have hcenter (ω : Ω) :
      (∑ i, (V i ω - ∫ u, V i u ∂P)) =
        (n : ℝ) • booleanDeviationVector F μ (fun i => X i ω) := by
    funext u
    simp only [Finset.sum_apply, Pi.sub_apply, Pi.smul_apply, smul_eq_mul]
    simp_rw [hIntCoord, hLawInt]
    simp only [V, booleanDeviationVector, booleanDeviation,
      empiricalProcessValue, empiricalAverage]
    rw [Finset.sum_sub_distrib]
    simp only [Finset.sum_const, Finset.card_univ, Fintype.card_fin,
      nsmul_eq_mul]
    have hn0 : (n : ℝ) ≠ 0 := by exact_mod_cast hn.ne'
    field_simp
  have hleft (ω : Ω) :
      ‖∑ i, (V i ω - ∫ u, V i u ∂P)‖ =
        (n : ℝ) * booleanUniformDeviation F μ (fun i => X i ω) := by
    rw [hcenter, norm_smul]
    simp [booleanUniformDeviation]
  have hsumCoord (z : Ω × HDP.Chapter6.MatrixSignSample n) (u : ↥F) :
      (∑ i, HDP.Chapter6.matrixSignCoordinate i z.2 • V i z.1) u =
        booleanSignedSum (fun i => X i z.1) u.1
          (fun i => HDP.Chapter6.matrixSignCoordinate i z.2) := by
    simp only [Finset.sum_apply, Pi.smul_apply, smul_eq_mul, V,
      booleanSignedSum]
  have hright (z : Ω × HDP.Chapter6.MatrixSignSample n) :
      ‖∑ i, HDP.Chapter6.matrixSignCoordinate i z.2 • V i z.1‖ =
        F.sup' hF (fun u =>
          |booleanSignedSum (fun i => X i z.1) u
            (fun i => HDP.Chapter6.matrixSignCoordinate i z.2)|) := by
    let W : ↥F → ℝ :=
      ∑ i, HDP.Chapter6.matrixSignCoordinate i z.2 • V i z.1
    let M : ℝ := F.sup' hF (fun u =>
      |booleanSignedSum (fun i => X i z.1) u
        (fun i => HDP.Chapter6.matrixSignCoordinate i z.2)|)
    have hM : 0 ≤ M := by
      obtain ⟨u, hu⟩ := hF
      exact (abs_nonneg _).trans (Finset.le_sup' (fun v =>
        |booleanSignedSum (fun i => X i z.1) v
          (fun i => HDP.Chapter6.matrixSignCoordinate i z.2)|) hu)
    apply le_antisymm
    · apply (pi_norm_le_iff_of_nonneg hM).2
      intro u
      rw [Real.norm_eq_abs]
      change |W u| ≤ M
      rw [show W u = booleanSignedSum (fun i => X i z.1) u.1
        (fun i => HDP.Chapter6.matrixSignCoordinate i z.2) by
          exact hsumCoord z u]
      exact Finset.le_sup' (fun v =>
        |booleanSignedSum (fun i => X i z.1) v
          (fun i => HDP.Chapter6.matrixSignCoordinate i z.2)|) u.2
    · apply Finset.sup'_le
      intro u hu
      let uF : ↥F := ⟨u, hu⟩
      calc
        |booleanSignedSum (fun i => X i z.1) u
            (fun i => HDP.Chapter6.matrixSignCoordinate i z.2)| =
            ‖W uF‖ := by
          rw [Real.norm_eq_abs]
          congr 1
          exact (hsumCoord z uF).symm
        _ ≤ ‖W‖ := norm_le_pi_norm W uF
  have hsignInt (i : Fin n) : Integrable
      (HDP.Chapter6.matrixSignCoordinate i) ν :=
    ((HDP.Chapter6.matrixSignCoordinate_isRademacherHDP i).memLp 1).integrable le_rfl
  have htermProdInt (i : Fin n) : Integrable
      (fun z : Ω × HDP.Chapter6.MatrixSignSample n =>
        HDP.Chapter6.matrixSignCoordinate i z.2 • V i z.1) (P.prod ν) := by
    simpa [Function.comp_def] using
      ((hsignInt i).smul_prod (hVint i)).swap
  have hsumProdInt : Integrable
      (fun z : Ω × HDP.Chapter6.MatrixSignSample n =>
        ∑ i, HDP.Chapter6.matrixSignCoordinate i z.2 • V i z.1)
      (P.prod ν) :=
    integrable_finsetSum Finset.univ (fun i _ => htermProdInt i)
  have hprodNormInt : Integrable
      (fun z : Ω × HDP.Chapter6.MatrixSignSample n =>
        ‖∑ i, HDP.Chapter6.matrixSignCoordinate i z.2 • V i z.1‖)
      (P.prod ν) := hsumProdInt.norm
  have hinner (ω : Ω) :
      (∫ ε, ‖∑ i, HDP.Chapter6.matrixSignCoordinate i ε • V i ω‖ ∂ν) =
        (n : ℝ) * finiteRademacherComplexity F (fun i => X i ω)
          (fun i => HDP.Chapter6.matrixSignCoordinate i) ν := by
    rw [integral_congr_ae (Filter.Eventually.of_forall fun ε =>
      hright (ω, ε))]
    rw [finiteRademacherComplexity]
    simp only [finiteRademacherSupremum, dif_pos hF, booleanSignedSum]
    rw [integral_const_mul]
    have hn0 : (n : ℝ) ≠ 0 := by exact_mod_cast hn.ne'
    field_simp
  have hsymm := HDP.Chapter6.symmetrization_centered_sum_upper
    (X := V) (ε := fun i => HDP.Chapter6.matrixSignCoordinate i)
    hVm hVint hVind
    (fun i => HDP.Chapter6.matrixSignCoordinate_measurable i)
    (fun i => HDP.Chapter6.matrixSignCoordinate_isRademacherHDP i)
    HDP.Chapter6.matrixSignCoordinate_independent
  have hleftIntegral :
      (∫ ω, ‖∑ i, (V i ω - ∫ u, V i u ∂P)‖ ∂P) =
        (n : ℝ) *
          ∫ ω, booleanUniformDeviation F μ (fun i => X i ω) ∂P := by
    rw [integral_congr_ae (Filter.Eventually.of_forall hleft),
      integral_const_mul]
  have hrightIntegral :
      (∫ z : Ω × HDP.Chapter6.MatrixSignSample n,
          ‖∑ i, HDP.Chapter6.matrixSignCoordinate i z.2 • V i z.1‖
        ∂P.prod ν) =
        (n : ℝ) * ∫ ω, finiteRademacherComplexity F (fun i => X i ω)
          (fun i => HDP.Chapter6.matrixSignCoordinate i) ν ∂P := by
    rw [integral_prod _ hprodNormInt]
    rw [integral_congr_ae (Filter.Eventually.of_forall hinner),
      integral_const_mul]
  let B : ℝ := vcLawConstant * Real.sqrt ((F.vcDim : ℝ) / n)
  have hradPoint (ω : Ω) :
      finiteRademacherComplexity F (fun i => X i ω)
          (fun i => HDP.Chapter6.matrixSignCoordinate i) ν ≤ B := by
    simpa [B, ν] using
      finiteRademacherComplexity_vc_le hn (fun i => X i ω) F hF hd
  have hscaledRadInt : Integrable (fun ω =>
      (n : ℝ) * finiteRademacherComplexity F (fun i => X i ω)
        (fun i => HDP.Chapter6.matrixSignCoordinate i) ν) P := by
    have hout := hprodNormInt.integral_prod_left
    simpa only [hinner] using hout
  have hradInt : Integrable (fun ω =>
      finiteRademacherComplexity F (fun i => X i ω)
        (fun i => HDP.Chapter6.matrixSignCoordinate i) ν) P := by
    have h := hscaledRadInt.const_mul (n : ℝ)⁻¹
    have hn0 : (n : ℝ) ≠ 0 := by exact_mod_cast hn.ne'
    simpa [hn0] using h
  have hrad :
      (∫ ω, finiteRademacherComplexity F (fun i => X i ω)
        (fun i => HDP.Chapter6.matrixSignCoordinate i) ν ∂P) ≤ B := by
    simpa using integral_mono hradInt (integrable_const B) hradPoint
  rw [hleftIntegral, hrightIntegral] at hsymm
  have hnR : (0 : ℝ) < n := by exact_mod_cast hn
  calc
    (∫ ω, booleanUniformDeviation F μ (fun i => X i ω) ∂P) ≤
        2 * (∫ ω, finiteRademacherComplexity F (fun i => X i ω)
          (fun i => HDP.Chapter6.matrixSignCoordinate i) ν ∂P) := by
      nlinarith
    _ ≤ 2 * B := by gcongr
    _ = 2 * vcLawConstant * Real.sqrt ((F.vcDim : ℝ) / n) := by
      dsimp [B]
      ring

/-- The uniform Boolean empirical deviation is integrable for a measurable
finite sample. This reusable finite-class lemma discharges the measurability
side condition in the learning-theory specialization.

**Lean implementation helper.** -/
theorem integrable_booleanUniformDeviation_of_measurable_sample
    [MeasurableSingletonClass α] [IsProbabilityMeasure μ]
    [IsFiniteMeasure P] {n : ℕ} (hn : 0 < n)
    (F : BooleanFamily α) (X : Fin n → Ω → α)
    (hXm : ∀ i, Measurable (X i)) :
    Integrable (fun ω =>
      booleanUniformDeviation F μ (fun i => X i ω)) P := by
  classical
  have hdev : ∀ u ∈ F, Measurable
      (fun ω => booleanDeviation μ (fun i => X i ω) u) := by
    intro u _hu
    unfold booleanDeviation empiricalProcessValue empiricalAverage
    apply Measurable.sub_const
    apply Measurable.const_mul
    apply Finset.measurable_sum
    intro i _
    simpa [booleanIndicator_eq_booleanValue, Function.comp_def] using
      (measurable_booleanValue u).comp (hXm i)
  have hpop (u : Finset α) :
      |∫ x, booleanIndicator u x ∂μ| ≤ 1 := by
    have h := norm_integral_le_of_norm_le_const
      (μ := μ) (f := booleanIndicator u) (C := (1 : ℝ))
      (Filter.Eventually.of_forall fun x => by
        rw [Real.norm_eq_abs]
        exact abs_booleanIndicator_le_one u x)
    simpa [Real.norm_eq_abs] using h
  have havg (u : Finset α) (ω : Ω) :
      |empiricalAverage (fun i => X i ω) (booleanIndicator u)| ≤ 1 := by
    have hterm : ∀ i : Fin n,
        0 ≤ booleanIndicator u (X i ω) ∧
          booleanIndicator u (X i ω) ≤ 1 := by
      intro i
      by_cases hi : X i ω ∈ u <;> simp [booleanIndicator, hi]
    have hsum0 : 0 ≤ ∑ i, booleanIndicator u (X i ω) :=
      Finset.sum_nonneg fun i _ => (hterm i).1
    have hsum1 : (∑ i, booleanIndicator u (X i ω)) ≤ (n : ℝ) := by
      calc
        (∑ i, booleanIndicator u (X i ω)) ≤ ∑ _i : Fin n, (1 : ℝ) :=
          Finset.sum_le_sum fun i _ => (hterm i).2
        _ = (n : ℝ) := by simp
    have hnR : (0 : ℝ) < n := by exact_mod_cast hn
    unfold empiricalAverage
    rw [abs_of_nonneg (mul_nonneg (inv_nonneg.mpr hnR.le) hsum0)]
    calc
      (n : ℝ)⁻¹ * ∑ i, booleanIndicator u (X i ω) ≤
          (n : ℝ)⁻¹ * (n : ℝ) :=
        mul_le_mul_of_nonneg_left hsum1 (inv_nonneg.mpr hnR.le)
      _ = 1 := inv_mul_cancel₀ hnR.ne'
  refine Integrable.of_bound
    (measurable_booleanUniformDeviation F X hdev).aestronglyMeasurable 2 ?_
  filter_upwards [] with ω
  rw [Real.norm_of_nonneg (booleanUniformDeviation_nonneg F _)]
  apply (pi_norm_le_iff_of_nonneg (by norm_num : (0 : ℝ) ≤ 2)).2
  intro u
  simp only [booleanDeviationVector,
    booleanDeviation, empiricalProcessValue, Real.norm_eq_abs]
  exact (abs_sub _ _).trans <| by
    linarith [havg u.1 ω, hpop u.1]

/-- **Markov tail corollary to Book Theorem 8.3.15 (finite form).** This is
the direct consequence of `theorem_8_3_15_finite_vc_expected`. It is
useful when one wants an explicit probability statement without adding a
separate concentration theorem for the already uniform statistic.

**Book Theorem 8.3.15.** -/
theorem theorem_8_3_15_finite_vc_tail [Finite α]
    [MeasurableSingletonClass α] [IsProbabilityMeasure μ]
    [IsProbabilityMeasure P] {n : ℕ} (hn : 0 < n)
    (F : BooleanFamily α) (hF : F.Nonempty) (hd : 1 ≤ F.vcDim)
    (X : Fin n → Ω → α) (hXm : ∀ i, Measurable (X i))
    (hLaw : ∀ i, HasLaw (X i) μ P) (hInd : iIndepFun X P)
    {t : ℝ} (ht : 0 < t) :
    P.real {ω | t ≤ booleanUniformDeviation F μ (fun i => X i ω)} ≤
      (2 * vcLawConstant * Real.sqrt ((F.vcDim : ℝ) / n)) / t := by
  have hZint :=
    integrable_booleanUniformDeviation_of_measurable_sample
      (μ := μ) (P := P) hn F X hXm
  have hmean := theorem_8_3_15_finite_vc_expected
    hn F hF hd X hXm hLaw hInd
  exact (HDP.Chapter1.markov_inequality
    (Filter.Eventually.of_forall fun ω => booleanUniformDeviation_nonneg F _)
    hZint ht).trans (div_le_div_of_nonneg_right hmean ht.le)

/-! ## Pointwise-to-uniform convergence -/

/-- On a finite index type, pointwise convergence to zero is uniform.

**Lean implementation helper.** -/
theorem finite_uniform_convergence_of_pointwise
    {ι : Type*} [Fintype ι] (a : ℕ → ι → ℝ)
    (h : ∀ i, Tendsto (fun k => a k i) atTop (𝓝 0)) :
    Tendsto (fun k => ‖a k‖) atTop (𝓝 0) := by
  have ha : Tendsto a atTop (𝓝 (0 : ι → ℝ)) := by
    rw [tendsto_pi_nhds]
    intro i
    simpa using h i
  change Tendsto ((fun v : ι → ℝ => ‖v‖) ∘ a) atTop (𝓝 0)
  simpa only [norm_zero] using continuous_norm.continuousAt.tendsto.comp ha

/-- Qualitative finite-class form of the VC law of large numbers: pointwise
laws for every class member become a uniform law because the class is finite.

**Lean implementation helper.** -/
theorem theorem_8_3_15_finite_uniform_convergence
    (F : BooleanFamily α)
    (sample : (k : ℕ) → Fin (k + 1) → α)
    (hpoint : ∀ u : ↥F,
      Tendsto (fun k => booleanDeviation μ (sample k) u.1) atTop (𝓝 0)) :
    Tendsto (fun k => booleanUniformDeviation F μ (sample k))
      atTop (𝓝 0) := by
  exact finite_uniform_convergence_of_pointwise
    (fun k => booleanDeviationVector F μ (sample k)) hpoint

/-! ## The finite Glivenko--Cantelli theorem -/

section FiniteCDF

variable [Fintype α] [LinearOrder α]

/-- The support of the half-infinite interval `(-∞, x]` on a finite ordered
domain.

**Lean implementation helper.** -/
def lowerSupport (x : α) : Finset α :=
  Finset.univ.filter fun y => y ≤ x

/-- The finite class of lower rays, augmented by the empty ray. Adding the
empty support corresponds to the endpoint `-∞`; it does not change the CDF
supremum and makes the exact VC dimension equal to one on every nonempty
finite ordered domain, including a singleton domain.

**Lean implementation helper.** -/
def lowerSupportFamily : BooleanFamily α :=
  insert ∅ (Finset.univ.image lowerSupport)

/-- The empty set belongs to the family of lower supports.

**Lean implementation helper.** -/
@[simp]
theorem empty_mem_lowerSupportFamily :
    (∅ : Finset α) ∈ lowerSupportFamily (α := α) := by
  simp [lowerSupportFamily]

/-- Every lower support generated by a threshold belongs to the lower-support family.

**Lean implementation helper.** -/
theorem lowerSupport_mem_lowerSupportFamily (x : α) :
    lowerSupport x ∈ lowerSupportFamily (α := α) := by
  simp [lowerSupportFamily]

/-- Lower rays cannot shatter two ordered points.

**Lean implementation helper.** -/
theorem lowerSupportFamily_vcDim_le_one :
    (lowerSupportFamily (α := α)).vcDim ≤ 1 := by
  unfold Finset.vcDim
  apply Finset.sup_le
  intro s hsMem
  have hs : (lowerSupportFamily (α := α)).Shatters s :=
    Finset.mem_shatterer.mp hsMem
  by_contra hcard
  have htwo : 1 < s.card := Nat.lt_of_not_ge hcard
  obtain ⟨a, ha, b, hb, hab⟩ := Finset.one_lt_card.mp htwo
  have hcontra (x y : α) (hx : x ∈ s) (hy : y ∈ s) (hxy : x < y) : False := by
    have hsingleton : ({y} : Finset α) ⊆ s := by simpa using hy
    obtain ⟨u, huF, hu⟩ := hs hsingleton
    have hyu : y ∈ u := by
      have : y ∈ s ∩ u := by rw [hu]; simp
      exact Finset.mem_inter.mp this |>.2
    have huLower : ∃ z, u = lowerSupport z := by
      rw [lowerSupportFamily, Finset.mem_insert] at huF
      rcases huF with rfl | huF
      · simp at hyu
      · obtain ⟨z, _hz, rfl⟩ := Finset.mem_image.mp huF
        exact ⟨z, rfl⟩
    obtain ⟨z, rfl⟩ := huLower
    have hyz : y ≤ z := by
      simpa [lowerSupport] using hyu
    have hxz : x ≤ z := hxy.le.trans hyz
    have hxLower : x ∈ lowerSupport z := by
      simp [lowerSupport, hxz]
    have hxTarget : x ∈ ({y} : Finset α) := by
      rw [← hu]
      exact Finset.mem_inter.mpr ⟨hx, hxLower⟩
    simp [hxy.ne] at hxTarget
  rcases lt_or_gt_of_ne hab with hab' | hba'
  · exact hcontra a b ha hb hab'
  · exact hcontra b a hb ha hba'

/-- The empty ray and the ray ending at `a` realize both traces on `{a}`.

**Lean implementation helper.** -/
theorem lowerSupportFamily_shatters_singleton (a : α) :
    (lowerSupportFamily (α := α)).Shatters ({a} : Finset α) := by
  intro t ht
  rcases Finset.subset_singleton_iff.mp ht with rfl | rfl
  · exact ⟨∅, empty_mem_lowerSupportFamily, by simp⟩
  · refine ⟨lowerSupport a, lowerSupport_mem_lowerSupportFamily a, ?_⟩
    ext x
    simp only [Finset.mem_inter, Finset.mem_singleton]
    constructor
    · exact fun h => h.1
    · rintro rfl
      simp [lowerSupport]

/-- The lower-ray class has exact VC dimension one on a nonempty domain.

**Lean implementation helper.** -/
theorem lowerSupportFamily_vcDim [Nonempty α] :
    (lowerSupportFamily (α := α)).vcDim = 1 := by
  apply le_antisymm lowerSupportFamily_vcDim_le_one
  let a : α := Classical.choice inferInstance
  simpa using (lowerSupportFamily_shatters_singleton a).card_le_vcDim

/-- The empirical CDF on a finite ordered domain.

**Lean implementation helper.** -/
def empiricalCDF {n : ℕ} (sample : Fin n → α) (x : α) : ℝ :=
  empiricalAverage sample (booleanIndicator (lowerSupport x))

/-- The population CDF on a finite ordered domain.

**Lean implementation helper.** -/
def populationCDF (μ : Measure α) (x : α) : ℝ :=
  ∫ y, booleanIndicator (lowerSupport x) y ∂μ

/-- The vector of CDF errors over the whole finite domain.

**Lean implementation helper.** -/
def cdfDeviationVector {n : ℕ} (μ : Measure α)
    (sample : Fin n → α) : α → ℝ :=
  fun x => empiricalCDF sample x - populationCDF μ x

/-- The empty lower ray contributes zero, so the Boolean uniform deviation
over `lowerSupportFamily` is exactly the supremum norm of the CDF errors.

**Lean implementation helper.** -/
theorem booleanUniformDeviation_lowerSupportFamily {n : ℕ}
    (μ : Measure α) (sample : Fin n → α) :
    booleanUniformDeviation (lowerSupportFamily (α := α)) μ sample =
      ‖cdfDeviationVector μ sample‖ := by
  apply le_antisymm
  · apply booleanUniformDeviation_le _ _ (norm_nonneg _)
    intro u hu
    rw [lowerSupportFamily, Finset.mem_insert] at hu
    rcases hu with rfl | hu
    · simp [booleanDeviation, empiricalProcessValue, empiricalAverage,
        booleanIndicator]
    · obtain ⟨x, _hx, rfl⟩ := Finset.mem_image.mp hu
      simpa [cdfDeviationVector, empiricalCDF, populationCDF,
        booleanDeviation, empiricalProcessValue, Real.norm_eq_abs] using
        norm_le_pi_norm (cdfDeviationVector μ sample) x
  · apply (pi_norm_le_iff_of_nonneg
      (booleanUniformDeviation_nonneg _ _)).2
    intro x
    simpa [cdfDeviationVector, empiricalCDF, populationCDF,
      booleanDeviation, empiricalProcessValue, Real.norm_eq_abs] using
      abs_booleanDeviation_le_uniform
        (lowerSupportFamily (α := α)) sample
        (lowerSupport_mem_lowerSupportFamily x)

/-- For an i.i.d. sample, the expected supremum CDF error is
`O(n⁻¹ᐟ²)` with the same explicit universal constant as Theorem 8.3.15.

**Book Theorem 8.3.17 (Glivenko--Cantelli).** -/
theorem theorem_8_3_17_glivenko_cantelli_quantitative
    [Nonempty α] [MeasurableSingletonClass α]
    [IsProbabilityMeasure μ] [IsProbabilityMeasure P]
    {n : ℕ} (hn : 0 < n) (X : Fin n → Ω → α)
    (hXm : ∀ i, Measurable (X i))
    (hLaw : ∀ i, HasLaw (X i) μ P) (hInd : iIndepFun X P) :
    (∫ ω, ‖cdfDeviationVector μ (fun i => X i ω)‖ ∂P) ≤
      2 * vcLawConstant * Real.sqrt ((1 : ℝ) / n) := by
  have h := theorem_8_3_15_finite_vc_expected hn
    (lowerSupportFamily (α := α))
    (by simp [lowerSupportFamily])
    (by rw [lowerSupportFamily_vcDim]) X hXm hLaw hInd
  simpa [booleanUniformDeviation_lowerSupportFamily,
    lowerSupportFamily_vcDim] using h

/-- Probability form of quantitative finite Glivenko--Cantelli.

**Lean implementation helper.** -/
theorem theorem_8_3_17_glivenko_cantelli_quantitative_tail
    [Nonempty α] [MeasurableSingletonClass α]
    [IsProbabilityMeasure μ] [IsProbabilityMeasure P]
    {n : ℕ} (hn : 0 < n) (X : Fin n → Ω → α)
    (hXm : ∀ i, Measurable (X i))
    (hLaw : ∀ i, HasLaw (X i) μ P) (hInd : iIndepFun X P)
    {t : ℝ} (ht : 0 < t) :
    P.real {ω | t ≤ ‖cdfDeviationVector μ (fun i => X i ω)‖} ≤
      (2 * vcLawConstant * Real.sqrt ((1 : ℝ) / n)) / t := by
  have h := theorem_8_3_15_finite_vc_tail hn
    (lowerSupportFamily (α := α))
    (by simp [lowerSupportFamily])
    (by rw [lowerSupportFamily_vcDim]) X hXm hLaw hInd ht
  simpa [booleanUniformDeviation_lowerSupportFamily,
    lowerSupportFamily_vcDim] using h

/-- Pointwise convergence of the empirical CDF is automatically uniform.

**Book Theorem 8.3.17 (Glivenko--Cantelli).** -/
theorem theorem_8_3_17_glivenko_cantelli_finite
    (sample : (k : ℕ) → Fin (k + 1) → α)
    (hpoint : ∀ x,
      Tendsto (fun k => empiricalCDF (sample k) x - populationCDF μ x)
        atTop (𝓝 0)) :
    Tendsto (fun k => ‖cdfDeviationVector μ (sample k)‖) atTop (𝓝 0) := by
  exact finite_uniform_convergence_of_pointwise
    (fun k => cdfDeviationVector μ (sample k)) hpoint

end FiniteCDF

/-! ## Example 8.3.18 and Exercises 8.13, 8.28 -/

/-- A random sample gives low discrepancy for a finite range space of small VC dimension. A uniform
empirical bound controls the discrepancy of every range in the class.

**Book Example 8.3.18.** -/
theorem example_8_3_18_discrepancy {n : ℕ}
    (F : BooleanFamily α) (sample : Fin n → α) {δ : ℝ}
    (hδ : booleanUniformDeviation F μ sample ≤ δ) :
    ∀ u ∈ F, |empiricalAverage sample (booleanIndicator u) -
      ∫ x, booleanIndicator u x ∂μ| ≤ δ := by
  intro u hu
  exact (abs_booleanDeviation_le_uniform F sample hu).trans hδ

/-! ### Exercise 8.13: the actual class of planar disks -/

/-- Squared Euclidean norm on the coordinate model `ℝ² = ℝ × ℝ`.

**Lean implementation helper.** -/
def planeSqNorm (x : ℝ × ℝ) : ℝ := x.1 ^ 2 + x.2 ^ 2

/-- Squared Euclidean distance on the coordinate model `ℝ² = ℝ × ℝ`.

**Lean implementation helper.** -/
def planeSqDist (x c : ℝ × ℝ) : ℝ :=
  (x.1 - c.1) ^ 2 + (x.2 - c.2) ^ 2

/-- A closed planar disk, parametrized by its squared radius.

**Lean implementation helper.** -/
def algebraicClosedDisk (c : ℝ × ℝ) (r2 : ℝ) : Set (ℝ × ℝ) :=
  {x | planeSqDist x c ≤ r2}

/-- The full, generally infinite Boolean class of all closed disks in `ℝ²`.
The nonnegativity of `r2` makes the squared-radius parametrization exact.

**Lean implementation helper.** -/
def planarClosedDisks : HDP.BooleanClass (ℝ × ℝ) :=
  {u | ∃ c r2, 0 ≤ r2 ∧ u = algebraicClosedDisk c r2}

/-- The three concrete points used for the sharp lower bound.

**Lean implementation helper.** -/
noncomputable def planarCircleSample : Finset (ℝ × ℝ) :=
  {((0, 0) : ℝ × ℝ), ((1, 0) : ℝ × ℝ), ((0, 1) : ℝ × ℝ)}

/-- A set with prescribed membership on the three planar sample points has exactly the prescribed trace.

**Lean implementation helper.** -/
private theorem trace_three_eq (t : Finset (ℝ × ℝ))
    (ht : t ⊆ planarCircleSample) (D : Set (ℝ × ℝ))
    (h0 : ((0, 0) : ℝ × ℝ) ∈ D ↔ ((0, 0) : ℝ × ℝ) ∈ t)
    (h1 : ((1, 0) : ℝ × ℝ) ∈ D ↔ ((1, 0) : ℝ × ℝ) ∈ t)
    (h2 : ((0, 1) : ℝ × ℝ) ∈ D ↔ ((0, 1) : ℝ × ℝ) ∈ t) :
    HDP.BooleanClass.trace planarCircleSample D = t := by
  classical
  ext x
  simp only [HDP.BooleanClass.mem_trace]
  constructor
  · rintro ⟨hxs, hxD⟩
    simp only [planarCircleSample, Finset.mem_insert,
      Finset.mem_singleton] at hxs
    rcases hxs with rfl | rfl | rfl
    · exact h0.mp hxD
    · exact h1.mp hxD
    · exact h2.mp hxD
  · intro hxt
    have hxs := ht hxt
    refine ⟨hxs, ?_⟩
    simp only [planarCircleSample, Finset.mem_insert,
      Finset.mem_singleton] at hxs
    rcases hxs with rfl | rfl | rfl
    · exact h0.mpr hxt
    · exact h1.mpr hxt
    · exact h2.mpr hxt

/-- An affine dependence makes the weighted change of squared distance
independent of the center and radius. This identity is the four-point
obstruction in the disk VC-dimension proof.

**Lean implementation helper.** -/
private theorem weighted_planeSqDist_eq
    (q : Finset (ℝ × ℝ)) (f : (ℝ × ℝ) → ℝ)
    (hrel : ∑ x ∈ q, f x • x = 0)
    (hsum : ∑ x ∈ q, f x = 0)
    (c : ℝ × ℝ) (r2 : ℝ) :
    ∑ x ∈ q, f x * (planeSqDist x c - r2) =
      ∑ x ∈ q, f x * planeSqNorm x := by
  have hfirst : ∑ x ∈ q, f x * x.1 = 0 := by
    have h := congrArg Prod.fst hrel
    rw [Prod.fst_sum] at h
    simpa only [Prod.smul_fst, smul_eq_mul, Prod.fst_zero] using h
  have hsecond : ∑ x ∈ q, f x * x.2 = 0 := by
    have h := congrArg Prod.snd hrel
    rw [Prod.snd_sum] at h
    simpa only [Prod.smul_snd, smul_eq_mul, Prod.snd_zero] using h
  calc
    ∑ x ∈ q, f x * (planeSqDist x c - r2) =
        ∑ x ∈ q, (f x * planeSqNorm x +
          (-2 * c.1) * (f x * x.1) +
          (-2 * c.2) * (f x * x.2) +
          (planeSqNorm c - r2) * f x) := by
      apply Finset.sum_congr rfl
      intro x hx
      simp only [planeSqDist, planeSqNorm]
      ring
    _ = ∑ x ∈ q, f x * planeSqNorm x := by
      simp only [Finset.sum_add_distrib, ← Finset.mul_sum]
      rw [hfirst, hsecond, hsum]
      ring

/-- No four planar points are shattered by closed disks. For four selected
points, affine dependence supplies coefficients of both signs. Asking for
the positive and negative sign patterns produces opposite strict inequalities
for the same center-independent weighted squared-distance sum.

**Lean implementation helper.** -/
theorem planarClosedDisks_vcDimLE : planarClosedDisks.VCDimLE 3 := by
  classical
  intro s hs
  by_contra hcard
  have hlarge : 4 ≤ s.card := by omega
  obtain ⟨q, hqs, hqcard⟩ := Finset.exists_subset_card_eq hlarge
  have hqshatter : planarClosedDisks.Shatters q :=
    HDP.BooleanClass.Shatters.mono_right hqs hs
  obtain ⟨f, hrel, hsum, hpos⟩ :=
    FiniteDimensional.exists_relation_sum_zero_pos_coefficient_of_finrank_succ_lt_card
      (L := ℝ) (W := ℝ × ℝ) (t := q)
      (by simp [Module.finrank_prod, hqcard])
  obtain ⟨xp, hxpq, hxppos⟩ := hpos
  have hneg : ∃ x ∈ q, f x < 0 := by
    have hnegSum : ∑ x ∈ q, -f x = 0 := by
      rw [Finset.sum_neg_distrib, hsum, neg_zero]
    obtain ⟨x, hxq, hxpos⟩ :=
      Finset.exists_pos_of_sum_zero_of_exists_nonzero (fun x => -f x) hnegSum
        ⟨xp, hxpq, by linarith⟩
    exact ⟨x, hxq, by linarith⟩
  let C : ℝ := ∑ x ∈ q, f x * planeSqNorm x
  by_cases hC : 0 ≤ C
  · let t := q.filter fun x => 0 < f x
    have htq : t ⊆ q := Finset.filter_subset _ _
    obtain ⟨u, ⟨c, r2, hr2, rfl⟩, htrace⟩ := hqshatter t htq
    have hdelta_le {x : ℝ × ℝ} (hxq : x ∈ q) (hfx : 0 < f x) :
        planeSqDist x c - r2 ≤ 0 := by
      have hxt : x ∈ t := Finset.mem_filter.mpr ⟨hxq, hfx⟩
      have hxtrace : x ∈ HDP.BooleanClass.trace q (algebraicClosedDisk c r2) := by
        rw [htrace]
        exact hxt
      exact sub_nonpos.mpr (HDP.BooleanClass.mem_trace.mp hxtrace).2
    have hdelta_pos {x : ℝ × ℝ} (hxq : x ∈ q) (hfx : ¬ 0 < f x) :
        0 < planeSqDist x c - r2 := by
      have hxnt : x ∉ t := by simp [t, hfx]
      have hxnotdisk : x ∉ algebraicClosedDisk c r2 := by
        intro hxdisk
        apply hxnt
        rw [← htrace]
        exact HDP.BooleanClass.mem_trace.mpr ⟨hxq, hxdisk⟩
      exact sub_pos.mpr (lt_of_not_ge hxnotdisk)
    have hterm_le : ∀ x ∈ q,
        f x * (planeSqDist x c - r2) ≤ 0 := by
      intro x hxq
      by_cases hfx : 0 < f x
      · exact mul_nonpos_of_nonneg_of_nonpos hfx.le (hdelta_le hxq hfx)
      · exact mul_nonpos_of_nonpos_of_nonneg (le_of_not_gt hfx)
          (hdelta_pos hxq hfx).le
    obtain ⟨xn, hxnq, hxnneg⟩ := hneg
    have hstrict : f xn * (planeSqDist xn c - r2) < 0 :=
      mul_neg_of_neg_of_pos hxnneg (hdelta_pos hxnq (not_lt_of_ge hxnneg.le))
    have hsumneg : ∑ x ∈ q, f x * (planeSqDist x c - r2) < 0 := by
      have h := Finset.sum_lt_sum (g := fun _ => (0 : ℝ)) hterm_le
        ⟨xn, hxnq, hstrict⟩
      simpa using h
    have hid := weighted_planeSqDist_eq q f hrel hsum c r2
    rw [hid] at hsumneg
    exact (not_lt_of_ge hC) hsumneg
  · have hClt : C < 0 := lt_of_not_ge hC
    let t := q.filter fun x => f x < 0
    have htq : t ⊆ q := Finset.filter_subset _ _
    obtain ⟨u, ⟨c, r2, hr2, rfl⟩, htrace⟩ := hqshatter t htq
    have hdelta_le {x : ℝ × ℝ} (hxq : x ∈ q) (hfx : f x < 0) :
        planeSqDist x c - r2 ≤ 0 := by
      have hxt : x ∈ t := Finset.mem_filter.mpr ⟨hxq, hfx⟩
      have hxtrace : x ∈ HDP.BooleanClass.trace q (algebraicClosedDisk c r2) := by
        rw [htrace]
        exact hxt
      exact sub_nonpos.mpr (HDP.BooleanClass.mem_trace.mp hxtrace).2
    have hdelta_pos {x : ℝ × ℝ} (hxq : x ∈ q) (hfx : ¬ f x < 0) :
        0 < planeSqDist x c - r2 := by
      have hxnt : x ∉ t := by simp [t, hfx]
      have hxnotdisk : x ∉ algebraicClosedDisk c r2 := by
        intro hxdisk
        apply hxnt
        rw [← htrace]
        exact HDP.BooleanClass.mem_trace.mpr ⟨hxq, hxdisk⟩
      exact sub_pos.mpr (lt_of_not_ge hxnotdisk)
    have hterm_nonneg : ∀ x ∈ q,
        0 ≤ f x * (planeSqDist x c - r2) := by
      intro x hxq
      by_cases hfx : f x < 0
      · exact mul_nonneg_of_nonpos_of_nonpos hfx.le (hdelta_le hxq hfx)
      · exact mul_nonneg (le_of_not_gt hfx) (hdelta_pos hxq hfx).le
    have hstrict : 0 < f xp * (planeSqDist xp c - r2) :=
      mul_pos hxppos (hdelta_pos hxpq (not_lt_of_ge hxppos.le))
    have hsumpos : 0 < ∑ x ∈ q, f x * (planeSqDist x c - r2) := by
      have h := Finset.sum_lt_sum (f := fun _ => (0 : ℝ)) hterm_nonneg
        ⟨xp, hxpq, hstrict⟩
      simpa using h
    have hid := weighted_planeSqDist_eq q f hrel hsum c r2
    rw [hid] at hsumpos
    exact (not_lt_of_ge hsumpos.le) hClt

/-- The sample `{(0,0),(1,0),(0,1)}` is shattered. The eight branches use,
respectively, a disk containing all points, three pair disks, three singleton
disks, and a disk disjoint from the sample.

**Lean implementation helper.** -/
theorem planarClosedDisks_shatter_three :
    planarClosedDisks.Shatters planarCircleSample := by
  classical
  intro t ht
  by_cases h0 : ((0, 0) : ℝ × ℝ) ∈ t <;>
    by_cases h1 : ((1, 0) : ℝ × ℝ) ∈ t <;>
    by_cases h2 : ((0, 1) : ℝ × ℝ) ∈ t
  · refine ⟨algebraicClosedDisk (0, 0) 1, ⟨(0, 0), 1, by norm_num, rfl⟩, ?_⟩
    apply trace_three_eq t ht
    all_goals norm_num [algebraicClosedDisk, planeSqDist, h0, h1, h2]
  · refine ⟨algebraicClosedDisk (1 / 2, 0) (1 / 4),
      ⟨(1 / 2, 0), 1 / 4, by norm_num, rfl⟩, ?_⟩
    apply trace_three_eq t ht
    all_goals norm_num [algebraicClosedDisk, planeSqDist, h0, h1, h2]
  · refine ⟨algebraicClosedDisk (0, 1 / 2) (1 / 4),
      ⟨(0, 1 / 2), 1 / 4, by norm_num, rfl⟩, ?_⟩
    apply trace_three_eq t ht
    all_goals norm_num [algebraicClosedDisk, planeSqDist, h0, h1, h2]
  · refine ⟨algebraicClosedDisk (0, 0) 0, ⟨(0, 0), 0, by norm_num, rfl⟩, ?_⟩
    apply trace_three_eq t ht
    all_goals norm_num [algebraicClosedDisk, planeSqDist, h0, h1, h2]
  · refine ⟨algebraicClosedDisk (1, 1) 1, ⟨(1, 1), 1, by norm_num, rfl⟩, ?_⟩
    apply trace_three_eq t ht
    all_goals norm_num [algebraicClosedDisk, planeSqDist, h0, h1, h2]
  · refine ⟨algebraicClosedDisk (1, 0) 0, ⟨(1, 0), 0, by norm_num, rfl⟩, ?_⟩
    apply trace_three_eq t ht
    all_goals norm_num [algebraicClosedDisk, planeSqDist, h0, h1, h2]
  · refine ⟨algebraicClosedDisk (0, 1) 0, ⟨(0, 1), 0, by norm_num, rfl⟩, ?_⟩
    apply trace_three_eq t ht
    all_goals norm_num [algebraicClosedDisk, planeSqDist, h0, h1, h2]
  · refine ⟨algebraicClosedDisk (10, 10) 0, ⟨(10, 10), 0, by norm_num, rfl⟩, ?_⟩
    apply trace_three_eq t ht
    all_goals norm_num [algebraicClosedDisk, planeSqDist, h0, h1, h2]

/-- Planar closed disks have the stated VC dimension. The class of all
closed disks in `ℝ²` has VC dimension exactly three.

**Book Exercise 8.13.** -/
theorem exercise_8_13_planar_closed_disks :
    HDP.BooleanClass.VCDimEq planarClosedDisks 3 := by
  exact ⟨planarClosedDisks_vcDimLE, planarCircleSample,
    planarClosedDisks_shatter_three, by simp [planarCircleSample]⟩

/-- Finite analogue of a uniform Glivenko--Cantelli class: every pointwise
null sequence indexed by the class converges uniformly.

**Lean implementation helper.** -/
def IsUniformGlivenkoCantelliFinite (F : BooleanFamily α) : Prop :=
  ∀ a : ℕ → ↥F → ℝ,
    (∀ u, Tendsto (fun k => a k u) atTop (𝓝 0)) →
      Tendsto (fun k => ‖a k‖) atTop (𝓝 0)

/-- With the finite-class correction made explicit.

**Book Remark 8.3.19.** -/
theorem remark_8_3_19_finite_uniform_glivenko_cantelli
    (F : BooleanFamily α) :
    IsUniformGlivenkoCantelliFinite F := by
  intro a h
  exact finite_uniform_convergence_of_pointwise a h

/-- Compatibility result for the earlier finite-family surrogate: on a finite
domain both sides of the finite VC/uniform-convergence characterization hold.
The source-faithful arbitrary-class Exercise 8.28 is proved below.

**Book Exercise 8.28.** -/
theorem exercise_8_28_finite_compatibility
    [Fintype α] (F : BooleanFamily α) :
    IsUniformGlivenkoCantelliFinite F ↔ F.vcDim ≤ Fintype.card α := by
  constructor
  · intro _
    exact vcDim_le_card F
  · intro _
    exact remark_8_3_19_finite_uniform_glivenko_cantelli F

/-! ## Source-faithful arbitrary Boolean classes and real-line CDFs -/

/-- The real-valued indicator of a set.

**Lean implementation helper.** -/
def booleanSetIndicator {α : Type*} (u : Set α) (x : α) : ℝ :=
  u.indicator (fun _ => 1) x

/-- The real-valued set indicator equals `1` at points in the set.

**Lean implementation helper.** -/
@[simp] theorem booleanSetIndicator_of_mem {α : Type*} {u : Set α} {x : α}
    (hx : x ∈ u) : booleanSetIndicator u x = 1 := by
  simp [booleanSetIndicator, hx]

/-- The real-valued set indicator equals `0` outside the set.

**Lean implementation helper.** -/
@[simp] theorem booleanSetIndicator_of_not_mem {α : Type*} {u : Set α} {x : α}
    (hx : x ∉ u) : booleanSetIndicator u x = 0 := by
  simp [booleanSetIndicator, hx]

/-- Shows that the real indicator of a set is measurable.

**Lean implementation helper.** -/
theorem measurable_booleanSetIndicator {α : Type*} {mα : MeasurableSpace α}
    {u : Set α} (hu : MeasurableSet u) : Measurable (booleanSetIndicator u) := by
  exact measurable_const.indicator hu

/-- Defines the empirical-minus-population deviation of a measurable set.

**Lean implementation helper.** -/
def booleanSetDeviation {α : Type*} {mα : MeasurableSpace α}
    (μ : Measure α) {n : ℕ} (sample : Fin n → α) (u : Set α) : ℝ :=
  empiricalAverage sample (booleanSetIndicator u) - μ.real u

/-- Defines the largest absolute set deviation over a finite Boolean family.

**Lean implementation helper.** -/
def finiteBooleanSetUniformDeviation {α : Type*} {mα : MeasurableSpace α}
    (μ : Measure α) {n : ℕ} (sample : Fin n → α)
    (G : Finset (Set α)) (hG : G.Nonempty) : ℝ :=
  G.sup' hG fun u => |booleanSetDeviation μ sample u|

/-- Defines the supremum of absolute set deviations over an arbitrary Boolean class.

**Lean implementation helper.** -/
def booleanClassUniformDeviation {α : Type*} {mα : MeasurableSpace α}
    (μ : Measure α) {n : ℕ} (sample : Fin n → α)
    (F : HDP.BooleanClass α) : ℝ :=
  sSup (Set.range fun u : F => |booleanSetDeviation μ sample u.1|)

/-- Shows that the empirical set deviation is measurable.

**Lean implementation helper.** -/
theorem measurable_booleanSetDeviation {α Ω : Type*}
    {mα : MeasurableSpace α} {mΩ : MeasurableSpace Ω}
    (μ : Measure α) {n : ℕ} (X : Fin n → Ω → α)
    (hXm : ∀ i, Measurable (X i)) {u : Set α} (hu : MeasurableSet u) :
    Measurable (fun ω => booleanSetDeviation μ (fun i => X i ω) u) := by
  unfold booleanSetDeviation empiricalAverage
  apply Measurable.sub_const
  apply Measurable.const_mul
  apply Finset.measurable_sum
  intro i _
  exact (measurable_booleanSetIndicator hu).comp (hXm i)

/-- Shows that the finite-family uniform set deviation is measurable.

**Lean implementation helper.** -/
theorem measurable_finiteBooleanSetUniformDeviation {α Ω : Type*}
    {mα : MeasurableSpace α} {mΩ : MeasurableSpace Ω}
    (μ : Measure α) {n : ℕ} (X : Fin n → Ω → α)
    (hXm : ∀ i, Measurable (X i)) (G : Finset (Set α)) (hG : G.Nonempty)
    (hGm : ∀ u ∈ G, MeasurableSet u) :
    Measurable (fun ω => finiteBooleanSetUniformDeviation μ
      (fun i => X i ω) G hG) := by
  unfold finiteBooleanSetUniformDeviation
  have h := Finset.measurable_sup' hG (fun u hu =>
    (measurable_booleanSetDeviation μ X hXm (hGm u hu)).abs)
  convert h using 1
  ext ω
  simp only [Finset.sup'_apply]

/-- For a nonempty sample and a probability measure, every empirical set deviation has absolute value at most `1`.

**Lean implementation helper.** -/
theorem booleanSetDeviation_le_one {α : Type*} {mα : MeasurableSpace α}
    {μ : Measure α} [IsProbabilityMeasure μ] {n : ℕ} (hn : 0 < n)
    (sample : Fin n → α) (u : Set α) :
    |booleanSetDeviation μ sample u| ≤ 1 := by
  have hterm (i : Fin n) :
      0 ≤ booleanSetIndicator u (sample i) ∧
        booleanSetIndicator u (sample i) ≤ 1 := by
    by_cases h : sample i ∈ u <;> simp [booleanSetIndicator, h]
  have hsum0 : 0 ≤ ∑ i, booleanSetIndicator u (sample i) :=
    Finset.sum_nonneg fun i _ => (hterm i).1
  have hsum1 : (∑ i, booleanSetIndicator u (sample i)) ≤ (n : ℝ) := by
    calc
      (∑ i, booleanSetIndicator u (sample i)) ≤ ∑ _i : Fin n, (1 : ℝ) :=
        Finset.sum_le_sum fun i _ => (hterm i).2
      _ = (n : ℝ) := by simp
  have hnR : (0 : ℝ) < n := by exact_mod_cast hn
  have havg0 : 0 ≤ empiricalAverage sample (booleanSetIndicator u) := by
    exact mul_nonneg (inv_nonneg.mpr hnR.le) hsum0
  have havg1 : empiricalAverage sample (booleanSetIndicator u) ≤ 1 := by
    unfold empiricalAverage
    calc
      (n : ℝ)⁻¹ * ∑ i, booleanSetIndicator u (sample i) ≤
          (n : ℝ)⁻¹ * (n : ℝ) :=
        mul_le_mul_of_nonneg_left hsum1 (inv_nonneg.mpr hnR.le)
      _ = 1 := inv_mul_cancel₀ hnR.ne'
  have hμ0 : 0 ≤ μ.real u := measureReal_nonneg
  have hμ1 : μ.real u ≤ 1 := by
    simpa only [probReal_univ] using measureReal_mono (μ := μ) (Set.subset_univ u)
  unfold booleanSetDeviation
  rw [abs_le]
  constructor <;> linarith

/-- The uniform empirical deviation over a nonempty finite Boolean family is at most `1`.

**Lean implementation helper.** -/
theorem finiteBooleanSetUniformDeviation_le_one {α : Type*}
    {mα : MeasurableSpace α} {μ : Measure α} [IsProbabilityMeasure μ]
    {n : ℕ} (hn : 0 < n) (sample : Fin n → α)
    (G : Finset (Set α)) (hG : G.Nonempty) :
    finiteBooleanSetUniformDeviation μ sample G hG ≤ 1 := by
  unfold finiteBooleanSetUniformDeviation
  apply Finset.sup'_le hG
  intro u _
  exact booleanSetDeviation_le_one hn sample u

/-- Shows that the finite-family uniform set deviation is nonnegative.

**Lean implementation helper.** -/
theorem finiteBooleanSetUniformDeviation_nonneg {α : Type*}
    {mα : MeasurableSpace α} (μ : Measure α) {n : ℕ}
    (sample : Fin n → α) (G : Finset (Set α)) (hG : G.Nonempty) :
    0 ≤ finiteBooleanSetUniformDeviation μ sample G hG := by
  unfold finiteBooleanSetUniformDeviation
  obtain ⟨u, hu⟩ := hG
  exact (abs_nonneg (booleanSetDeviation μ sample u)).trans
    (Finset.le_sup' (fun v => |booleanSetDeviation μ sample v|) hu)

/-- Under the realized-pattern pushforward, the measure of a pattern support equals the measure of its original set.

**Lean implementation helper.** -/
theorem map_realizedPattern_patternSupport_real {α : Type*}
    {mα : MeasurableSpace α} (μ : Measure α) (G : Finset (Set α))
    (hGm : ∀ u ∈ G, MeasurableSet u) (u : ↑G) :
    (μ.map (realizedPattern G)).real
        (patternSupport G u : Set (RealizedPattern G)) = μ.real u.1 := by
  apply congrArg ENNReal.toReal
  rw [Measure.map_apply (measurable_realizedPattern G hGm)
    (patternSupport G u).measurableSet]
  congr 1
  ext x
  simp only [Set.mem_preimage, Finset.mem_coe,
    realizedPattern_mem_patternSupport]

/-- Evaluating a pattern-support indicator on the pattern of `x` reproduces the original set indicator at `x`.

**Lean implementation helper.** -/
@[simp]
theorem booleanIndicator_patternSupport_realized {α : Type*}
    (G : Finset (Set α)) (u : ↑G) (x : α) :
    booleanIndicator (patternSupport G u) (realizedPattern G x) =
      booleanSetIndicator u.1 x := by
  by_cases hx : x ∈ (u.1 : Set α)
  · have hm : realizedPattern G x ∈ patternSupport G u :=
      (realizedPattern_mem_patternSupport G u x).2 hx
    simp [booleanIndicator, booleanSetIndicator, hx, hm]
  · have hm : realizedPattern G x ∉ patternSupport G u := by
      simpa only [realizedPattern_mem_patternSupport] using hx
    simp [booleanIndicator, booleanSetIndicator, hx, hm]

/-- Empirical deviation of a pattern support under the pushforward measure equals deviation of the corresponding original set.

**Lean implementation helper.** -/
theorem booleanDeviation_patternSupport {α : Type*}
    {mα : MeasurableSpace α} (μ : Measure α) (G : Finset (Set α))
    (hGm : ∀ u ∈ G, MeasurableSet u) {n : ℕ}
    (sample : Fin n → α) (u : ↑G) :
    booleanDeviation (μ.map (realizedPattern G))
        (fun i => realizedPattern G (sample i)) (patternSupport G u) =
      booleanSetDeviation μ sample u.1 := by
  unfold booleanDeviation empiricalProcessValue booleanSetDeviation empiricalAverage
  have hint : (∫ x, booleanIndicator (patternSupport G u) x
      ∂μ.map (realizedPattern G)) =
        (μ.map (realizedPattern G)).real (patternSupport G u) := by
    rw [booleanIndicator_eq_booleanValue]
    exact integral_indicator_one (patternSupport G u).measurableSet
  rw [hint,
    map_realizedPattern_patternSupport_real μ G hGm u]
  apply congrArg (fun z => z - μ.real (u.1 : Set α))
  apply congrArg ((n : ℝ)⁻¹ * ·)
  apply Finset.sum_congr rfl
  intro i _
  exact booleanIndicator_patternSupport_realized G u (sample i)

/-- The uniform deviation of the pattern Boolean family equals the finite-family deviation of the original sets.

**Lean implementation helper.** -/
theorem booleanUniformDeviation_patternBooleanFamily {α : Type*}
    {mα : MeasurableSpace α} (μ : Measure α) (G : Finset (Set α))
    (hG : G.Nonempty) (hGm : ∀ u ∈ G, MeasurableSet u) {n : ℕ}
    (sample : Fin n → α) :
    booleanUniformDeviation (patternBooleanFamily G)
        (μ.map (realizedPattern G)) (fun i => realizedPattern G (sample i)) =
      finiteBooleanSetUniformDeviation μ sample G hG := by
  let ν : Measure (RealizedPattern G) := μ.map (realizedPattern G)
  let F' : BooleanFamily (RealizedPattern G) := patternBooleanFamily G
  apply le_antisymm
  · apply booleanUniformDeviation_le F' _
      (show 0 ≤ finiteBooleanSetUniformDeviation μ sample G hG by
        unfold finiteBooleanSetUniformDeviation
        obtain ⟨u, hu⟩ := hG
        exact (abs_nonneg (booleanSetDeviation μ sample u)).trans
          (Finset.le_sup' (fun v => |booleanSetDeviation μ sample v|) hu))
    intro w hw
    obtain ⟨u, -, rfl⟩ := Finset.mem_image.mp hw
    rw [booleanDeviation_patternSupport μ G hGm sample u]
    unfold finiteBooleanSetUniformDeviation
    exact Finset.le_sup' (fun v => |booleanSetDeviation μ sample v|) u.2
  · unfold finiteBooleanSetUniformDeviation
    apply Finset.sup'_le hG
    intro u hu
    rw [← booleanDeviation_patternSupport μ G hGm sample ⟨u, hu⟩]
    exact abs_booleanDeviation_le_uniform F'
      (fun i => realizedPattern G (sample i)) (by
        simp [F', patternBooleanFamily])

/-- If two family members separate some point, the pattern Boolean family has VC dimension at least one.

**Lean implementation helper.** -/
theorem patternBooleanFamily_vcDim_pos_of_separates {α : Type*}
    (G : Finset (Set α)) {x : α} {u v : Set α}
    (huG : u ∈ G) (hvG : v ∈ G) (hxu : x ∈ u) (hxv : x ∉ v) :
    1 ≤ (patternBooleanFamily G).vcDim := by
  classical
  let p : RealizedPattern G := realizedPattern G x
  have hpu : p ∈ patternSupport G ⟨u, huG⟩ :=
    (realizedPattern_mem_patternSupport G ⟨u, huG⟩ x).2 hxu
  have hpv : p ∉ patternSupport G ⟨v, hvG⟩ := by
    intro hp
    exact hxv ((realizedPattern_mem_patternSupport G ⟨v, hvG⟩ x).1 hp)
  have hsh : (patternBooleanFamily G).Shatters ({p} : Finset (RealizedPattern G)) := by
    intro t ht
    rcases Finset.subset_singleton_iff.mp ht with rfl | rfl
    · refine ⟨patternSupport G ⟨v, hvG⟩, ?_, ?_⟩
      · simp [patternBooleanFamily]
      · ext z
        simp only [Finset.mem_inter, Finset.mem_singleton]
        constructor
        · rintro ⟨rfl, hp⟩
          exact (hpv hp).elim
        · simp
    · refine ⟨patternSupport G ⟨u, huG⟩, ?_, ?_⟩
      · simp [patternBooleanFamily]
      · ext z
        simp only [Finset.mem_inter, Finset.mem_singleton]
        constructor
        · exact fun h => h.1
        · rintro rfl
          exact ⟨rfl, hpu⟩
  simpa using hsh.card_le_vcDim

/-- The expected uniform deviation of a finite subfamily of VC dimension at most `d` is bounded by `2·vcLawConstant·√(d/n)`.

**Lean implementation helper.** -/
theorem finite_generalBoolean_expected_le {α Ω : Type*}
    {mα : MeasurableSpace α} {mΩ : MeasurableSpace Ω}
    {μ : Measure α} {P : Measure Ω} [IsProbabilityMeasure μ]
    [IsProbabilityMeasure P] {n : ℕ} (hn : 0 < n)
    (F : HDP.BooleanClass α) (hF : ∀ u ∈ F, MeasurableSet u)
    {d : ℕ} (hd : F.VCDimLE d) (G : Finset (Set α))
    (hG : G.Nonempty) (hGF : ∀ u ∈ G, u ∈ F)
    {x : α} {u v : Set α} (huG : u ∈ G) (hvG : v ∈ G)
    (hxu : x ∈ u) (hxv : x ∉ v)
    (X : Fin n → Ω → α) (hXm : ∀ i, Measurable (X i))
    (hLaw : ∀ i, HasLaw (X i) μ P) (hInd : iIndepFun X P) :
    (∫ ω, finiteBooleanSetUniformDeviation μ (fun i => X i ω) G hG ∂P) ≤
      2 * vcLawConstant * Real.sqrt ((d : ℝ) / n) := by
  classical
  have hGm : ∀ w ∈ G, MeasurableSet w := fun w hw => hF w (hGF w hw)
  let ν : Measure (RealizedPattern G) := μ.map (realizedPattern G)
  letI : IsProbabilityMeasure ν := by
    dsimp [ν]
    exact Measure.isProbabilityMeasure_map
      (measurable_realizedPattern G hGm).aemeasurable
  let F' : BooleanFamily (RealizedPattern G) := patternBooleanFamily G
  have hF'nonempty : F'.Nonempty := by
    obtain ⟨w, hw⟩ := hG
    refine ⟨patternSupport G ⟨w, hw⟩, ?_⟩
    simp [F', patternBooleanFamily]
  have hF'vc : F'.vcDim ≤ d := by
    simpa [F'] using patternBooleanFamily_vcDim_le G hGF hd
  have hF'pos : 1 ≤ F'.vcDim := by
    simpa [F'] using patternBooleanFamily_vcDim_pos_of_separates
      G huG hvG hxu hxv
  let Y : Fin n → Ω → RealizedPattern G := fun i ω => realizedPattern G (X i ω)
  have hYm (i : Fin n) : Measurable (Y i) :=
    (measurable_realizedPattern G hGm).comp (hXm i)
  have hYLaw (i : Fin n) : HasLaw (Y i) ν P := by
    let hmap : HasLaw (realizedPattern G) ν μ :=
      ⟨(measurable_realizedPattern G hGm).aemeasurable, rfl⟩
    simpa [Y, Function.comp_def] using hmap.comp (hLaw i)
  have hYInd : iIndepFun Y P := by
    simpa [Y, Function.comp_def] using hInd.comp
      (fun _ => realizedPattern G)
      (fun _ => measurable_realizedPattern G hGm)
  have hfinite := theorem_8_3_15_finite_vc_expected
    (μ := ν) hn F' hF'nonempty hF'pos Y hYm hYLaw hYInd
  have htransport (ω : Ω) :
      booleanUniformDeviation F' ν (fun i => Y i ω) =
        finiteBooleanSetUniformDeviation μ (fun i => X i ω) G hG := by
    simpa [F', ν, Y] using
      booleanUniformDeviation_patternBooleanFamily μ G hG hGm
        (fun i => X i ω)
  rw [integral_congr_ae (Filter.Eventually.of_forall htransport)] at hfinite
  calc
    (∫ ω, finiteBooleanSetUniformDeviation μ (fun i => X i ω) G hG ∂P) ≤
        2 * vcLawConstant * Real.sqrt ((F'.vcDim : ℝ) / n) := hfinite
    _ ≤ 2 * vcLawConstant * Real.sqrt ((d : ℝ) / n) := by
      apply mul_le_mul_of_nonneg_left _
        (mul_nonneg (by norm_num) vcLawConstant_pos.le)
      apply Real.sqrt_le_sqrt
      apply div_le_div_of_nonneg_right _ (by positivity)
      exact_mod_cast hF'vc

/-- A measurable arbitrary Boolean class is *countably exhausted for empirical
deviations* when an increasing sequence of finite subfamilies converges
pointwise to its full uniform deviation.  The two sets in the initial family
that disagree at one point make the source theorem's positive-VC edge case
explicit. -/
structure BooleanDeviationExhaustion {α : Type*} {mα : MeasurableSpace α}
    (μ : Measure α) (F : HDP.BooleanClass α) where
  family : ℕ → Finset (Set α)
  nonempty : ∀ k, (family k).Nonempty
  monotone : Monotone family
  subset : ∀ k u, u ∈ family k → u ∈ F
  separates : ∃ x u v, u ∈ family 0 ∧ v ∈ family 0 ∧ x ∈ u ∧ x ∉ v
  tendsTo : ∀ {n : ℕ} (_hn : 0 < n) (sample : Fin n → α),
    Tendsto (fun k => finiteBooleanSetUniformDeviation μ sample
      (family k) (nonempty k)) atTop
      (𝓝 (booleanClassUniformDeviation μ sample F))

/-- A Boolean class of VC dimension `d` has expected uniform empirical deviation `O(sqrt(d/n))`. The domain and Boolean class may both be infinite. The explicit exhaustion
hypothesis is the standard pointwise-measurability/separability condition
needed to make the arbitrary supremum a genuine measurable random variable.
All finite stages are transported to their realized membership-pattern space,
where the already proved VC chaining theorem applies.

**Book Theorem 8.3.15.** -/
theorem theorem_8_3_15_vc_expected {α Ω : Type*}
    {mα : MeasurableSpace α} {mΩ : MeasurableSpace Ω}
    {μ : Measure α} {P : Measure Ω} [IsProbabilityMeasure μ]
    [IsProbabilityMeasure P] {n : ℕ} (hn : 0 < n)
    (F : HDP.BooleanClass α) (hF : ∀ u ∈ F, MeasurableSet u)
    {d : ℕ} (hd : F.VCDimLE d) (E : BooleanDeviationExhaustion μ F)
    (X : Fin n → Ω → α) (hXm : ∀ i, Measurable (X i))
    (hLaw : ∀ i, HasLaw (X i) μ P) (hInd : iIndepFun X P) :
    (∫ ω, booleanClassUniformDeviation μ (fun i => X i ω) F ∂P) ≤
      2 * vcLawConstant * Real.sqrt ((d : ℝ) / n) := by
  classical
  let M : ℕ → Ω → ℝ := fun k ω =>
    finiteBooleanSetUniformDeviation μ (fun i => X i ω)
      (E.family k) (E.nonempty k)
  have hMm (k : ℕ) : Measurable (M k) := by
    exact measurable_finiteBooleanSetUniformDeviation μ X hXm
      (E.family k) (E.nonempty k)
      (fun u hu => hF u (E.subset k u hu))
  have hMnorm (k : ℕ) (ω : Ω) : ‖M k ω‖ ≤ 1 := by
    rw [Real.norm_of_nonneg
      (finiteBooleanSetUniformDeviation_nonneg μ _ _ _)]
    exact finiteBooleanSetUniformDeviation_le_one hn _ _ _
  obtain ⟨x, u, v, hu0, hv0, hxu, hxv⟩ := E.separates
  have hMmean (k : ℕ) :
      (∫ ω, M k ω ∂P) ≤
        2 * vcLawConstant * Real.sqrt ((d : ℝ) / n) := by
    have h0k : E.family 0 ⊆ E.family k := E.monotone (Nat.zero_le k)
    exact finite_generalBoolean_expected_le hn F hF hd
      (E.family k) (E.nonempty k) (fun w hw => E.subset k w hw)
      (h0k hu0) (h0k hv0) hxu hxv X hXm hLaw hInd
  have hIntTend : Tendsto (fun k => ∫ ω, M k ω ∂P) atTop
      (𝓝 (∫ ω, booleanClassUniformDeviation μ (fun i => X i ω) F ∂P)) := by
    apply tendsto_integral_filter_of_norm_le_const
    · exact Filter.Eventually.of_forall fun k => (hMm k).aestronglyMeasurable
    · exact ⟨1, Filter.Eventually.of_forall fun k =>
        Filter.Eventually.of_forall fun ω => hMnorm k ω⟩
    · exact Filter.Eventually.of_forall fun ω => by
        simpa [M] using E.tendsTo hn (fun i => X i ω)
  exact le_of_tendsto' hIntTend hMmean

/-! ## The actual lower-ray class on the real line -/

/-- The source class `x ↦ 𝟙_{(-∞,x]}` on the actual domain `ℝ`.

**Lean implementation helper.** -/
def realLowerRays : HDP.BooleanClass ℝ :=
  {u | ∃ x : ℝ, u = Set.Iic x}

/-- Shows that the class of lower rays on the real line is measurable.

**Lean implementation helper.** -/
theorem measurable_realLowerRays (u : Set ℝ) (hu : u ∈ realLowerRays) :
    MeasurableSet u := by
  obtain ⟨x, rfl⟩ := hu
  exact measurableSet_Iic

/-- Closed lower rays have VC dimension at most one.

**Lean implementation helper.** -/
theorem realLowerRays_vcDimLE : realLowerRays.VCDimLE 1 := by
  classical
  intro s hs
  by_contra hcard
  have htwo : 1 < s.card := Nat.lt_of_not_ge hcard
  obtain ⟨a, ha, b, hb, hab⟩ := Finset.one_lt_card.mp htwo
  have hcontra (x y : ℝ) (hx : x ∈ s) (hy : y ∈ s) (hxy : x < y) : False := by
    have hsingleton : ({y} : Finset ℝ) ⊆ s := by simpa using hy
    obtain ⟨u, huF, htrace⟩ := hs {y} hsingleton
    obtain ⟨c, rfl⟩ := huF
    have hyc : y ≤ c := by
      have : y ∈ HDP.BooleanClass.trace s (Set.Iic c) := by
        rw [htrace]
        simp
      exact (HDP.BooleanClass.mem_trace.mp this).2
    have hxc : x ≤ c := hxy.le.trans hyc
    have hxTrace : x ∈ HDP.BooleanClass.trace s (Set.Iic c) :=
      HDP.BooleanClass.mem_trace.mpr ⟨hx, hxc⟩
    rw [htrace] at hxTrace
    simp [hxy.ne] at hxTrace
  rcases lt_or_gt_of_ne hab with hablt | hbalt
  · exact hcontra a b ha hb hablt
  · exact hcontra b a hb ha hbalt

/-- Deviation of the lower ray `(-∞,x]` equals the empirical CDF at `x` minus the population CDF.

**Lean implementation helper.** -/
theorem booleanSetDeviation_Iic_eq_cdf_sub (μ : Measure ℝ)
    [IsProbabilityMeasure μ] {n : ℕ} (hn : 0 < n)
    (sample : Fin n → ℝ) (x : ℝ) :
    booleanSetDeviation μ sample (Set.Iic x) =
      cdf (empiricalMeasure sample) x - cdf μ x := by
  let ν : Measure ℝ := empiricalMeasure sample
  letI : IsProbabilityMeasure ν :=
    ⟨by simpa [ν] using empiricalMeasure_apply_univ hn sample⟩
  have hemp : empiricalAverage sample (booleanSetIndicator (Set.Iic x)) =
      ν.real (Set.Iic x) := by
    rw [← integral_empiricalMeasure hn sample
      (measurable_booleanSetIndicator measurableSet_Iic).stronglyMeasurable]
    unfold booleanSetIndicator
    exact integral_indicator_one measurableSet_Iic
  unfold booleanSetDeviation
  rw [hemp, ← cdf_eq_real ν x, ← cdf_eq_real μ x]

/-- Absolute lower-ray deviations converge along any rational sequence decreasing to the endpoint.

**Lean implementation helper.** -/
theorem tendsto_abs_booleanSetDeviation_Iic_of_rat (μ : Measure ℝ)
    [IsProbabilityMeasure μ] {n : ℕ} (hn : 0 < n)
    (sample : Fin n → ℝ) (x : ℝ) (q : ℕ → ℚ)
    (hqx : ∀ k, x < (q k : ℝ))
    (hq : Tendsto (fun k => (q k : ℝ)) atTop (𝓝 x)) :
    Tendsto (fun k => |booleanSetDeviation μ sample (Set.Iic (q k : ℝ))|)
      atTop (𝓝 |booleanSetDeviation μ sample (Set.Iic x)|) := by
  let ν : Measure ℝ := empiricalMeasure sample
  letI : IsProbabilityMeasure ν :=
    ⟨by simpa [ν] using empiricalMeasure_apply_univ hn sample⟩
  have hwithin : Tendsto (fun k => (q k : ℝ)) atTop (𝓝[Set.Ici x] x) :=
    tendsto_nhdsWithin_iff.mpr ⟨hq,
      Filter.Eventually.of_forall fun k => (hqx k).le⟩
  have hν : Tendsto (fun k => cdf ν (q k : ℝ)) atTop (𝓝 (cdf ν x)) :=
    (cdf ν).right_continuous x |>.tendsto.comp hwithin
  have hμ : Tendsto (fun k => cdf μ (q k : ℝ)) atTop (𝓝 (cdf μ x)) :=
    (cdf μ).right_continuous x |>.tendsto.comp hwithin
  have hsub := (hν.sub hμ).abs
  simpa [ν, booleanSetDeviation_Iic_eq_cdf_sub μ hn sample] using hsub

/-- A fixed enumeration of all rational closed lower rays.

**Lean implementation helper.** -/
def enumeratedRationalLowerRay (k : ℕ) : Set ℝ :=
  Set.Iic (((Denumerable.eqv ℚ).symm k : ℚ) : ℝ)

/-- The first `k+1` rational lower rays, with two fixed separating rays.

**Lean implementation helper.** -/
noncomputable def realLowerRayFiniteFamily (k : ℕ) : Finset (Set ℝ) :=
  {Set.Iic (-1 : ℝ), Set.Iic (0 : ℝ)} ∪
    (Finset.range (k + 1)).image enumeratedRationalLowerRay

/-- Shows that the finite family of rational lower rays is nonempty.

**Lean implementation helper.** -/
theorem realLowerRayFiniteFamily_nonempty (k : ℕ) :
    (realLowerRayFiniteFamily k).Nonempty := by
  classical
  refine ⟨Set.Iic (0 : ℝ), ?_⟩
  simp [realLowerRayFiniteFamily]

/-- Shows that the finite family of rational lower rays is monotone.

**Lean implementation helper.** -/
theorem realLowerRayFiniteFamily_mono : Monotone realLowerRayFiniteFamily := by
  classical
  intro k l hkl u hu
  rw [realLowerRayFiniteFamily, Finset.mem_union] at hu ⊢
  rcases hu with hu | hu
  · exact Or.inl hu
  · right
    obtain ⟨j, hj, rfl⟩ := Finset.mem_image.mp hu
    exact Finset.mem_image.mpr ⟨j, Finset.mem_range.mpr
      ((Finset.mem_range.mp hj).trans_le (Nat.add_le_add_right hkl 1)), rfl⟩

/-- Shows that the finite family of rational lower rays lies in the ambient source set.

**Lean implementation helper.** -/
theorem realLowerRayFiniteFamily_subset (k : ℕ) (u : Set ℝ)
    (hu : u ∈ realLowerRayFiniteFamily k) : u ∈ realLowerRays := by
  classical
  rw [realLowerRayFiniteFamily, Finset.mem_union] at hu
  rcases hu with hu | hu
  · simp only [Finset.mem_insert, Finset.mem_singleton] at hu
    rcases hu with rfl | rfl
    · exact ⟨-1, rfl⟩
    · exact ⟨0, rfl⟩
  · obtain ⟨j, -, rfl⟩ := Finset.mem_image.mp hu
    exact ⟨(Denumerable.ofNat ℚ j : ℚ), rfl⟩

/-- The initial finite family of rational lower rays contains two sets that separate a point.

**Lean implementation helper.** -/
theorem realLowerRayFiniteFamily_separates :
    ∃ x u v, u ∈ realLowerRayFiniteFamily 0 ∧
      v ∈ realLowerRayFiniteFamily 0 ∧ x ∈ u ∧ x ∉ v := by
  classical
  refine ⟨0, Set.Iic (0 : ℝ), Set.Iic (-1 : ℝ), ?_, ?_, by simp, by simp⟩
  · simp [realLowerRayFiniteFamily]
  · simp [realLowerRayFiniteFamily]

/-- Uniform deviations over the increasing finite rational lower-ray families converge to the deviation over all real lower rays.

**Lean implementation helper.** -/
theorem realLowerRayFiniteFamily_tendsTo (μ : Measure ℝ)
    [IsProbabilityMeasure μ] {n : ℕ} (hn : 0 < n)
    (sample : Fin n → ℝ) :
    Tendsto (fun k => finiteBooleanSetUniformDeviation μ sample
      (realLowerRayFiniteFamily k) (realLowerRayFiniteFamily_nonempty k))
      atTop (𝓝 (booleanClassUniformDeviation μ sample realLowerRays)) := by
  classical
  let M : ℕ → ℝ := fun k => finiteBooleanSetUniformDeviation μ sample
    (realLowerRayFiniteFamily k) (realLowerRayFiniteFamily_nonempty k)
  have hMmono : Monotone M := by
    intro k l hkl
    unfold M finiteBooleanSetUniformDeviation
    apply Finset.sup'_le (realLowerRayFiniteFamily_nonempty k)
    intro u hu
    exact Finset.le_sup' (fun v => |booleanSetDeviation μ sample v|)
      (realLowerRayFiniteFamily_mono hkl hu)
  have hMbdd : BddAbove (Set.range M) := by
    refine ⟨1, ?_⟩
    rintro z ⟨k, rfl⟩
    exact finiteBooleanSetUniformDeviation_le_one hn sample
      (realLowerRayFiniteFamily k) (realLowerRayFiniteFamily_nonempty k)
  have htend : Tendsto M atTop (𝓝 (⨆ k, M k)) :=
    tendsto_atTop_ciSup hMmono hMbdd
  have hfullBdd : BddAbove (Set.range fun u : realLowerRays =>
      |booleanSetDeviation μ sample u.1|) := by
    refine ⟨1, ?_⟩
    rintro z ⟨u, rfl⟩
    exact booleanSetDeviation_le_one hn sample u.1
  have hfullNonempty : (Set.range fun u : realLowerRays =>
      |booleanSetDeviation μ sample u.1|).Nonempty := by
    exact ⟨|booleanSetDeviation μ sample (Set.Iic 0)|,
      ⟨⟨Set.Iic 0, ⟨0, rfl⟩⟩, rfl⟩⟩
  have heq : (⨆ k, M k) =
      booleanClassUniformDeviation μ sample realLowerRays := by
    unfold booleanClassUniformDeviation
    apply le_antisymm
    · apply ciSup_le
      intro k
      unfold M finiteBooleanSetUniformDeviation
      apply Finset.sup'_le (realLowerRayFiniteFamily_nonempty k)
      intro u hu
      apply le_csSup hfullBdd
      exact ⟨⟨u, realLowerRayFiniteFamily_subset k u hu⟩, rfl⟩
    · apply csSup_le hfullNonempty
      rintro z ⟨u, rfl⟩
      rcases u with ⟨u, hu⟩
      obtain ⟨x, rfl⟩ := hu
      obtain ⟨q, _hqanti, hqx, hq⟩ := Real.exists_seq_rat_strictAnti_tendsto x
      have hlim := tendsto_abs_booleanSetDeviation_Iic_of_rat μ hn sample x q hqx hq
      apply le_of_tendsto' hlim
      intro m
      let j : ℕ := Denumerable.eqv ℚ (q m)
      have henum : enumeratedRationalLowerRay j = Set.Iic (q m : ℝ) := by
        simp [enumeratedRationalLowerRay, j]
      have hmem : Set.Iic (q m : ℝ) ∈ realLowerRayFiniteFamily j := by
        rw [← henum]
        rw [realLowerRayFiniteFamily, Finset.mem_union]
        right
        exact Finset.mem_image.mpr ⟨j, by simp, rfl⟩
      calc
        |booleanSetDeviation μ sample (Set.Iic (q m : ℝ))| ≤ M j := by
          unfold M finiteBooleanSetUniformDeviation
          exact Finset.le_sup' (fun v => |booleanSetDeviation μ sample v|) hmem
        _ ≤ ⨆ k, M k := le_ciSup hMbdd j
  simpa [M, heq] using htend

/-- The rational lower-ray exhaustion supplies the separability hypothesis of
the arbitrary-class VC law on `ℝ`.

**Lean implementation helper.** -/
def realLowerRayDeviationExhaustion (μ : Measure ℝ)
    [IsProbabilityMeasure μ] : BooleanDeviationExhaustion μ realLowerRays where
  family := realLowerRayFiniteFamily
  nonempty := realLowerRayFiniteFamily_nonempty
  monotone := realLowerRayFiniteFamily_mono
  subset := realLowerRayFiniteFamily_subset
  separates := realLowerRayFiniteFamily_separates
  tendsTo := fun hn sample => realLowerRayFiniteFamily_tendsTo μ hn sample

/-- The empirical CDF on the actual real line.

**Lean implementation helper.** -/
def realEmpiricalCDF {n : ℕ} (sample : Fin n → ℝ) (x : ℝ) : ℝ :=
  empiricalAverage sample (booleanSetIndicator (Set.Iic x))

/-- The actual uniform CDF error over every `x : ℝ`.

**Lean implementation helper.** -/
def realCDFUniformDeviation (μ : Measure ℝ) {n : ℕ}
    (sample : Fin n → ℝ) : ℝ :=
  booleanClassUniformDeviation μ sample realLowerRays

/-- Uniform CDF deviation is the supremum over `x` of the absolute empirical-minus-population CDF difference.

**Lean implementation helper.** -/
theorem realCDFUniformDeviation_eq_sSup (μ : Measure ℝ)
    [IsProbabilityMeasure μ] {n : ℕ} (sample : Fin n → ℝ) :
    realCDFUniformDeviation μ sample =
      sSup (Set.range fun x : ℝ => |realEmpiricalCDF sample x - cdf μ x|) := by
  unfold realCDFUniformDeviation booleanClassUniformDeviation
  congr 1
  ext z
  constructor
  · rintro ⟨u, rfl⟩
    rcases u with ⟨u, hu⟩
    obtain ⟨x, rfl⟩ := hu
    refine ⟨x, ?_⟩
    simp [booleanSetDeviation, realEmpiricalCDF, cdf_eq_real]
  · rintro ⟨x, rfl⟩
    refine ⟨⟨Set.Iic x, ⟨x, rfl⟩⟩, ?_⟩
    simp [booleanSetDeviation, realEmpiricalCDF, cdf_eq_real]

/-- Glivenko--Cantelli: the empirical CDF converges uniformly at rate `1/sqrt n`. For independent real random variables with common law `μ`, the expected
supremum of the empirical-CDF error over every real threshold is bounded by
an explicit universal constant times `n⁻¹ᐟ²`.

**Book Theorem 8.3.17.** -/
theorem theorem_8_3_17_glivenko_cantelli_real {Ω : Type*}
    {mΩ : MeasurableSpace Ω} {μ : Measure ℝ} {P : Measure Ω}
    [IsProbabilityMeasure μ] [IsProbabilityMeasure P]
    {n : ℕ} (hn : 0 < n) (X : Fin n → Ω → ℝ)
    (hXm : ∀ i, Measurable (X i))
    (hLaw : ∀ i, HasLaw (X i) μ P) (hInd : iIndepFun X P) :
    (∫ ω, realCDFUniformDeviation μ (fun i => X i ω) ∂P) ≤
      2 * vcLawConstant * Real.sqrt ((1 : ℝ) / n) := by
  simpa [realCDFUniformDeviation] using
    (theorem_8_3_15_vc_expected hn realLowerRays
      measurable_realLowerRays realLowerRays_vcDimLE
      (realLowerRayDeviationExhaustion μ) X hXm hLaw hInd)

/-! ## Distribution-free uniform Glivenko--Cantelli classes -/

/-- Finite VC dimension yields a uniform Glivenko--Cantelli class; infinite VC dimension obstructs uniform convergence. Distribution-free uniform Glivenko--Cantelli convergence, written in
epsilon--delta form on the canonical iid product space.

**Book Remark 8.3.19.** -/
def IsUniformGlivenkoCantelli {α : Type*} [MeasurableSpace α]
    (F : HDP.BooleanClass α) : Prop :=
  ∀ ε : ℝ, 0 < ε → ∀ δ : ℝ, 0 < δ → ∃ N : ℕ,
    ∀ n : ℕ, N ≤ n → 0 < n → ∀ (μ : Measure α) [IsProbabilityMeasure μ],
      let Q : Measure (Fin n → α) := Measure.pi fun _ : Fin n => μ
      Q.real {sample | ε < booleanClassUniformDeviation μ sample F} ≤ δ

/-- Under the uniform measure on a nonempty finite set, the probability of `u` is the fraction of sample points in its trace.

**Lean implementation helper.** -/
theorem uniformOn_real_eq_trace_ratio {α : Type*} [MeasurableSpace α]
    [MeasurableSingletonClass α] (s : Finset α) (_hs : s.Nonempty)
    (u : Set α) (_hu : MeasurableSet u) :
    (uniformOn (s : Set α)).real u =
      ((HDP.BooleanClass.trace s u).card : ℝ) / s.card := by
  have hinter : (s : Set α) ∩ u =
      (HDP.BooleanClass.trace s u : Set α) := by
    ext x
    simp only [Set.mem_inter_iff, Finset.mem_coe,
      HDP.BooleanClass.mem_trace]
  rw [measureReal_def, uniformOn, ProbabilityTheory.cond_apply s.measurableSet]
  rw [hinter, Measure.count_apply_finset, Measure.count_apply_finset]
  rw [← ENNReal.div_eq_inv_mul, ENNReal.toReal_div]
  all_goals simp

/-- Infinite VC dimension yields an `n`-sample unseen-mass obstruction on a
uniform distribution over a shattered `2n`-point set.

**Lean implementation helper.** -/
theorem infinite_vc_unseen_mass_obstruction {α : Type*}
    [MeasurableSpace α] [MeasurableSingletonClass α]
    (F : HDP.BooleanClass α)
    (hF : ∀ u ∈ F, MeasurableSet u)
    (hinf : ∀ d : ℕ, ∃ s : Finset α, F.Shatters s ∧ d < s.card)
    {n : ℕ} (hn : 0 < n) :
    ∃ s : Finset α, ∃ _hs : s.Nonempty,
      s.card = 2 * n ∧
      ∀ sample : Fin n → α, (∀ i, sample i ∈ s) →
        1 / 2 ≤ booleanClassUniformDeviation
          (uniformOn (s : Set α)) sample F := by
  classical
  obtain ⟨s0, hs0sh, hs0card⟩ := hinf (2 * n - 1)
  have h2n : 2 * n ≤ s0.card := by omega
  obtain ⟨s, hss0, hscard⟩ := Finset.exists_subset_card_eq h2n
  have hssh : F.Shatters s := HDP.BooleanClass.Shatters.mono_right hss0 hs0sh
  have hs : s.Nonempty := by
    rw [Finset.nonempty_iff_ne_empty]
    intro h
    rw [h, Finset.card_empty] at hscard
    omega
  refine ⟨s, hs, hscard, ?_⟩
  intro sample hsample
  let seen : Finset α := Finset.univ.image sample
  have hseenS : seen ⊆ s := by
    intro x hx
    obtain ⟨i, -, rfl⟩ := Finset.mem_image.mp hx
    exact hsample i
  have hseenCard : seen.card ≤ n := by
    calc
      seen.card ≤ Finset.univ.card := Finset.card_image_le
      _ = n := Fintype.card_fin n
  let unseen : Finset α := s \ seen
  have hunseenCard : n ≤ unseen.card := by
    change n ≤ (s \ seen).card
    rw [Finset.card_sdiff_of_subset hseenS, hscard]
    omega
  obtain ⟨u, huF, htrace⟩ := hssh unseen (Finset.sdiff_subset)
  have huMeas : MeasurableSet u := hF u huF
  have hemp : empiricalAverage sample (booleanSetIndicator u) = 0 := by
    unfold empiricalAverage
    have hsum : (∑ i, booleanSetIndicator u (sample i)) = 0 := by
      apply Finset.sum_eq_zero
      intro i _
      have hiSeen : sample i ∈ seen :=
        Finset.mem_image.mpr ⟨i, Finset.mem_univ i, rfl⟩
      have hiS : sample i ∈ s := hsample i
      have hiNotUnseen : sample i ∉ unseen := by
        simp [unseen, hiSeen]
      have hiNotU : sample i ∉ u := by
        intro hiu
        have : sample i ∈ HDP.BooleanClass.trace s u :=
          HDP.BooleanClass.mem_trace.mpr ⟨hiS, hiu⟩
        rw [htrace] at this
        exact hiNotUnseen this
      exact booleanSetIndicator_of_not_mem hiNotU
    rw [hsum, mul_zero]
  have hpop : 1 / 2 ≤ (uniformOn (s : Set α)).real u := by
    rw [uniformOn_real_eq_trace_ratio s hs u huMeas, htrace, hscard]
    have hnR : (0 : ℝ) < n := by exact_mod_cast hn
    have hcardR : (n : ℝ) ≤ unseen.card := by exact_mod_cast hunseenCard
    push_cast
    apply (le_div_iff₀ (by positivity : (0 : ℝ) < 2 * n)).2
    linarith
  have hdev : 1 / 2 ≤ |booleanSetDeviation (uniformOn (s : Set α)) sample u| := by
    unfold booleanSetDeviation
    rw [hemp]
    simpa only [zero_sub, abs_neg, abs_of_nonneg measureReal_nonneg] using hpop
  letI : IsProbabilityMeasure (uniformOn (s : Set α)) :=
    isProbabilityMeasure_uniformOn s.finite_toSet (by simpa using hs)
  unfold booleanClassUniformDeviation
  apply hdev.trans
  apply le_csSup
  · refine ⟨1, ?_⟩
    rintro z ⟨v, rfl⟩
    exact booleanSetDeviation_le_one hn sample v.1
  · exact ⟨⟨u, huF⟩, rfl⟩

/-- Finite VC dimension yields a uniform Glivenko--Cantelli class; infinite VC dimension obstructs uniform convergence. If a measurable Boolean class has
infinite VC dimension, it is not distribution-free uniform
Glivenko--Cantelli. For every sample size `n`, a uniform law on a shattered
`2n`-point support leaves at least half of that support unseen by every
`n`-sample, and the class can select exactly those unseen points.

**Book Remark 8.3.19.** -/
theorem exercise_8_28_infinite_vc_not_uniform_gc {α : Type*}
    [MeasurableSpace α] [MeasurableSingletonClass α]
    (F : HDP.BooleanClass α) (hF : ∀ u ∈ F, MeasurableSet u)
    (hinf : ∀ d : ℕ, ∃ s : Finset α, F.Shatters s ∧ d < s.card) :
    ¬ IsUniformGlivenkoCantelli F := by
  classical
  intro hUGC
  obtain ⟨N, hN⟩ := hUGC (1 / 4) (by norm_num) (1 / 2) (by norm_num)
  let n : ℕ := max N 1
  have hNn : N ≤ n := Nat.le_max_left _ _
  have hn : 0 < n := lt_of_lt_of_le Nat.zero_lt_one (Nat.le_max_right _ _)
  obtain ⟨s, hs, hscard, hobs⟩ :=
    infinite_vc_unseen_mass_obstruction F hF hinf hn
  let μ : Measure α := uniformOn (s : Set α)
  letI : IsProbabilityMeasure μ := by
    dsimp [μ]
    exact isProbabilityMeasure_uniformOn s.finite_toSet (by simpa using hs)
  let Q : Measure (Fin n → α) := Measure.pi fun _ : Fin n => μ
  let S : Set (Fin n → α) := Set.pi Set.univ fun _ : Fin n => (s : Set α)
  let A : Set (Fin n → α) :=
    {sample | (1 / 4 : ℝ) < booleanClassUniformDeviation μ sample F}
  have htail : Q.real A ≤ 1 / 2 := by
    simpa [Q, A] using hN n hNn hn μ
  have hμs : μ (s : Set α) = 1 := by
    dsimp [μ]
    rw [uniformOn_apply_finset, Finset.inter_self]
    exact ENNReal.div_self (by simp [hs.ne_empty]) (by simp)
  have hQS : Q S = 1 := by
    dsimp [Q, S]
    rw [Measure.pi_pi]
    simp [hμs]
  have hQSreal : Q.real S = 1 := by
    rw [measureReal_def, hQS]
    norm_num
  have hSA : S ⊆ A := by
    intro sample hsample
    have hsampleS : ∀ i, sample i ∈ s := by
      simpa [S] using hsample
    have hhalf : (1 / 2 : ℝ) ≤ booleanClassUniformDeviation μ sample F := by
      simpa [μ] using hobs sample hsampleS
    exact lt_of_lt_of_le (by norm_num) hhalf
  have hone : (1 : ℝ) ≤ Q.real A := by
    rw [← hQSreal]
    exact measureReal_mono hSA
  have : (1 : ℝ) ≤ 1 / 2 := hone.trans htail
  norm_num at this

/-- Finite VC dimension yields a uniform Glivenko--Cantelli class; infinite VC dimension obstructs uniform convergence. Every distribution-free
uniform Glivenko--Cantelli Boolean class has finite VC dimension. No
finiteness assumption is imposed on the domain or on the class.

**Book Remark 8.3.19.** -/
theorem exercise_8_28_uniform_gc_implies_finite_vc {α : Type*}
    [MeasurableSpace α] [MeasurableSingletonClass α]
    (F : HDP.BooleanClass α) (hF : ∀ u ∈ F, MeasurableSet u)
    (hUGC : IsUniformGlivenkoCantelli F) :
    ∃ d : ℕ, F.VCDimLE d := by
  classical
  by_contra hfinite
  have hinf : ∀ d : ℕ, ∃ s : Finset α,
      F.Shatters s ∧ d < s.card := by
    intro d
    by_contra hnone
    have hd : F.VCDimLE d := by
      intro s hsh
      by_contra hnle
      exact hnone ⟨s, hsh, Nat.lt_of_not_ge hnle⟩
    exact hfinite ⟨d, hd⟩
  exact exercise_8_28_infinite_vc_not_uniform_gc F hF hinf hUGC

end

end HDP.Chapter8

end Source_08_VCLawOfLargeNumbers

/-! ## Material formerly in `09_StatisticalLearning.lean` -/

section Source_09_StatisticalLearning

/-!
# Book Chapter 8, §8.4: statistical learning theory

The source writes `argmin` without an attainment assumption.  This module
first supplies a backward-compatible finite API, where nonemptiness proves
attainment, and then the source-faithful arbitrary Boolean-class API, where
population and empirical minimizers are explicit hypotheses.  Expected-risk
statements carry the measurability, separability, and integrability conditions
suppressed in the prose.
-/

open MeasureTheory ProbabilityTheory Set
open scoped BigOperators ENNReal NNReal Topology symmDiff

namespace HDP.Chapter8

noncomputable section

variable {α Ω : Type*} {mα : MeasurableSpace α}
  {mΩ : MeasurableSpace Ω} {μ : Measure α} {P : Measure Ω}

/-! ## Risk, fit, and finite minimizers -/

/-- Population squared prediction risk. Equation (8.37), squared prediction loss at one point.

**Book Equation (8.37).** -/
def squaredLoss (target hypothesis : α → ℝ) (x : α) : ℝ :=
  (hypothesis x - target x) ^ 2

/-- Population squared prediction risk. Equation (8.37), population risk.

**Book Equation (8.37).** -/
def populationRisk (μ : Measure α) (target hypothesis : α → ℝ) : ℝ :=
  ∫ x, squaredLoss target hypothesis x ∂μ

/-- ERM minimizes empirical squared loss, and population risk has a minimizer only when attainment is supplied/proved. Equation (8.39), empirical risk.

**Book Definition 8.4.3.** -/
def empiricalRisk {n : ℕ} (sample : Fin n → α)
    (target hypothesis : α → ℝ) : ℝ :=
  empiricalAverage sample (squaredLoss target hypothesis)

/-- A minimizer over a finite class. The subtype records membership, while
`IsMinOn` records optimality without requiring decidable equality on `H`.

**Lean implementation helper.** -/
def IsFiniteMinimizer {H : Type*}
    (F : Finset H) (objective : H → ℝ) (h : ↥F) : Prop :=
  IsMinOn (fun g : ↥F => objective g.1) Set.univ h

/-- Every nonempty finite real-valued optimization problem has a minimizer.

**Lean implementation helper.** -/
theorem exists_isFiniteMinimizer {H : Type*}
    (F : Finset H) (hF : F.Nonempty) (objective : H → ℝ) :
    ∃ h : ↥F, IsFiniteMinimizer F objective h := by
  obtain ⟨h, hh, hmin⟩ := F.exists_min_image objective hF
  refine ⟨⟨h, hh⟩, ?_⟩
  intro g _
  exact hmin g.1 g.2

/-- ERM minimizes empirical squared loss, and population risk has a minimizer only when attainment is supplied/proved. Definition 8.4.3, finite empirical-risk minimizer.

**Book Definition 8.4.3.** -/
def IsEmpiricalRiskMinimizer {n : ℕ} (F : Finset (α → ℝ))
    (sample : Fin n → α) (target : α → ℝ) (learned : ↥F) : Prop :=
  IsFiniteMinimizer F (empiricalRisk sample target) learned

/-- ERM minimizes empirical squared loss, and population risk has a minimizer only when attainment is supplied/proved. The corrected finite population minimizer used as the comparison
hypothesis `f*`.

**Book Definition 8.4.3.** -/
def IsPopulationRiskMinimizer (F : Finset (α → ℝ))
    (μ : Measure α) (target : α → ℝ) (best : ↥F) : Prop :=
  IsFiniteMinimizer F (populationRisk μ target) best

/-- Every nonempty finite hypothesis class has an empirical risk minimizer for any sample and target.

**Lean implementation helper.** -/
theorem exists_empiricalRiskMinimizer {n : ℕ}
    (F : Finset (α → ℝ)) (hF : F.Nonempty)
    (sample : Fin n → α) (target : α → ℝ) :
    ∃ learned : ↥F, IsEmpiricalRiskMinimizer F sample target learned :=
  exists_isFiniteMinimizer F hF (empiricalRisk sample target)

/-- Every nonempty finite hypothesis class has a population risk minimizer.

**Lean implementation helper.** -/
theorem exists_populationRiskMinimizer
    (F : Finset (α → ℝ)) (hF : F.Nonempty)
    (target : α → ℝ) :
    ∃ best : ↥F, IsPopulationRiskMinimizer F μ target best :=
  exists_isFiniteMinimizer F hF (populationRisk μ target)

/-! ## Classification -/

section Classification

variable [DecidableEq α]

/-- The support on which a Boolean hypothesis disagrees with the target.

**Lean implementation helper.** -/
def lossSupport (target hypothesis : Finset α) : Finset α :=
  target ∆ hypothesis

/-- Taking symmetric-difference loss support with the same target twice recovers the original finite hypothesis.

**Lean implementation helper.** -/
@[simp]
theorem lossSupport_involutive (target hypothesis : Finset α) :
    lossSupport target (lossSupport target hypothesis) = hypothesis := by
  simp [lossSupport]

/-- Boolean squared loss equals misclassification probability/symmetric-difference loss. Squared loss for Boolean indicators is exactly the
indicator of misclassification.

**Book Example 8.4.2.** -/
theorem example_8_4_2_classification_loss
    (target hypothesis : Finset α) (x : α) :
    squaredLoss (booleanIndicator target) (booleanIndicator hypothesis) x =
      booleanIndicator (lossSupport target hypothesis) x := by
  by_cases ht : x ∈ target <;> by_cases hh : x ∈ hypothesis <;>
    simp [squaredLoss, booleanIndicator, lossSupport, Finset.mem_symmDiff, ht, hh]

/-- In classification, empirical risk is the empirical misclassification rate. Empirical classification risk is the empirical
fraction of misclassified sample points.

**Book Example 8.4.4.** -/
theorem example_8_4_4_empirical_classification_risk {n : ℕ}
    (sample : Fin n → α) (target hypothesis : Finset α) :
    empiricalRisk sample (booleanIndicator target)
      (booleanIndicator hypothesis) =
      empiricalAverage sample (booleanIndicator (lossSupport target hypothesis)) := by
  apply congrArg (empiricalAverage sample)
  funext x
  exact example_8_4_2_classification_loss target hypothesis x

end Classification

/-! ## Uniform risk deviations and excess risk -/

/-- Empirical-minus-population risk over a finite hypothesis class.

**Lean implementation helper.** -/
def riskDeviationVector {n : ℕ} (F : Finset (α → ℝ))
    (μ : Measure α) (sample : Fin n → α) (target : α → ℝ) : ↥F → ℝ :=
  fun f => empiricalRisk sample target f.1 - populationRisk μ target f.1

/-- The finite-class uniform risk deviation.

**Lean implementation helper.** -/
def riskUniformDeviation {n : ℕ} (F : Finset (α → ℝ))
    (μ : Measure α) (sample : Fin n → α) (target : α → ℝ) : ℝ :=
  ‖riskDeviationVector F μ sample target‖

/-- The empirical-to-population risk gap of any hypothesis is bounded by the class's uniform risk deviation.

**Lean implementation helper.** -/
theorem abs_riskDeviation_le_uniform {n : ℕ}
    (F : Finset (α → ℝ)) (sample : Fin n → α) (target : α → ℝ)
    (f : ↥F) :
    |empiricalRisk sample target f.1 - populationRisk μ target f.1| ≤
      riskUniformDeviation F μ sample target := by
  simpa [riskUniformDeviation, riskDeviationVector, Real.norm_eq_abs] using
    (norm_le_pi_norm (riskDeviationVector F μ sample target) f)

/-- Equation (8.40), with the finite class and minimizer membership made
explicit. In fact the comparison hypothesis need only belong to the class.

**Book Equation (8.40).** -/
theorem excessRisk_le_two_uniformDeviation {n : ℕ}
    (F : Finset (α → ℝ)) (sample : Fin n → α) (target : α → ℝ)
    (learned comparison : ↥F)
    (hERM : IsEmpiricalRiskMinimizer F sample target learned) :
    populationRisk μ target learned.1 - populationRisk μ target comparison.1 ≤
      2 * riskUniformDeviation F μ sample target := by
  have hlearned := abs_riskDeviation_le_uniform
    (μ := μ) F sample target learned
  have hcomparisonDev := abs_riskDeviation_le_uniform
    (μ := μ) F sample target comparison
  have hmin : empiricalRisk sample target learned.1 ≤
      empiricalRisk sample target comparison.1 := hERM (Set.mem_univ comparison)
  rw [abs_le] at hlearned hcomparisonDev
  linarith

/-- The explicit population minimizer repairs the source's unattained `argmin`;
the proof is the three-line excess-risk argument.

**Book Theorem 8.4.5.** -/
theorem theorem_8_4_5_vc_generalization_bound {n : ℕ}
    (F : Finset (α → ℝ)) (sample : Fin n → α) (target : α → ℝ)
    (learned best : ↥F)
    (hERM : IsEmpiricalRiskMinimizer F sample target learned)
    (_hbest : IsPopulationRiskMinimizer F μ target best) :
    populationRisk μ target learned.1 ≤
      populationRisk μ target best.1 +
        2 * riskUniformDeviation F μ sample target := by
  have h := excessRisk_le_two_uniformDeviation
    (μ := μ) F sample target learned best hERM
  linarith

/-- Expected-risk form of Theorem 8.4.5. Measurability and integrability of
the data-dependent learned risk and uniform deviation are explicit rather than
being inferred from an arbitrary supremum.

**Book Theorem 8.4.5.** -/
theorem theorem_8_4_5_expected_generalization
    {n : ℕ} [IsProbabilityMeasure P]
    (F : Finset (α → ℝ)) (X : Fin n → Ω → α) (target : α → ℝ)
    (learned : Ω → ↥F) (best : ↥F)
    (hERM : ∀ ω,
      IsEmpiricalRiskMinimizer F (fun i => X i ω) target (learned ω))
    (hbest : IsPopulationRiskMinimizer F μ target best)
    (hLearnedInt : Integrable
      (fun ω : Ω => populationRisk μ target (learned ω).1) P)
    (hUniformInt : Integrable
      (fun ω => riskUniformDeviation F μ (fun i => X i ω) target) P) :
    (∫ ω : Ω, populationRisk μ target (learned ω).1 ∂P) ≤
      populationRisk μ target best.1 +
        2 * ∫ ω, riskUniformDeviation F μ (fun i => X i ω) target ∂P := by
  have hRhs : Integrable (fun ω : Ω =>
      populationRisk μ target best.1 +
        2 * riskUniformDeviation F μ (fun i => X i ω) target) P :=
    (integrable_const _).add (hUniformInt.const_mul 2)
  calc
    (∫ ω : Ω, populationRisk μ target (learned ω).1 ∂P) ≤
        ∫ ω, (populationRisk μ target best.1 +
          2 * riskUniformDeviation F μ (fun i => X i ω) target) ∂P := by
      apply integral_mono hLearnedInt hRhs
      intro ω
      exact theorem_8_4_5_vc_generalization_bound
        (μ := μ) F (fun i => X i ω) target (learned ω) best (hERM ω) hbest
    _ = populationRisk μ target best.1 +
        2 * ∫ ω, riskUniformDeviation F μ (fun i => X i ω) target ∂P := by
      rw [integral_add (integrable_const _) (hUniformInt.const_mul 2),
        integral_const, integral_const_mul]
      simp

/-! ## Exercise 8.29: the loss class preserves VC dimension -/

/-! ### Source-faithful arbitrary Boolean classes -/

/-- The support on which two arbitrary Boolean functions disagree.

**Lean implementation helper.** -/
def setLossSupport (target hypothesis : Set α) : Set α :=
  target ∆ hypothesis

/-- Taking measurable-set loss support with the same target twice recovers the original hypothesis set.

**Lean implementation helper.** -/
@[simp]
theorem setLossSupport_involutive (target hypothesis : Set α) :
    setLossSupport target (setLossSupport target hypothesis) = hypothesis := by
  simp [setLossSupport]

/-- The loss class obtained by toggling every support in an arbitrary Boolean
class by a fixed target support.

**Lean implementation helper.** -/
def lossBooleanClass (target : Set α) (F : HDP.BooleanClass α) :
    HDP.BooleanClass α :=
  setLossSupport target '' F

/-- Applying the target-loss transformation twice recovers the original Boolean class.

**Lean implementation helper.** -/
@[simp]
theorem lossBooleanClass_involutive (target : Set α)
    (F : HDP.BooleanClass α) :
    lossBooleanClass target (lossBooleanClass target F) = F := by
  ext u
  simp [lossBooleanClass, setLossSupport]

section ArbitraryLossClass

/-- The trace of a loss support is the symmetric difference of the target trace and hypothesis trace.

**Lean implementation helper.** -/
theorem trace_setLossSupport [DecidableEq α]
    (s : Finset α) (target hypothesis : Set α) :
    HDP.BooleanClass.trace s (setLossSupport target hypothesis) =
      HDP.BooleanClass.trace s target ∆
        HDP.BooleanClass.trace s hypothesis := by
  classical
  ext x
  simp only [HDP.BooleanClass.mem_trace, setLossSupport,
    Set.mem_symmDiff, Finset.mem_symmDiff]
  tauto

/-- Shattering by a Boolean class is preserved by the target-loss transformation.

**Lean implementation helper.** -/
private theorem lossBooleanClass_shatters_forward
    (target : Set α) (F : HDP.BooleanClass α) (s : Finset α)
    (h : F.Shatters s) :
    (lossBooleanClass target F).Shatters s := by
  classical
  intro v hv
  let v' := HDP.BooleanClass.trace s target ∆ v
  have hv' : v' ⊆ s := by
    intro x hx
    rw [Finset.mem_symmDiff] at hx
    rcases hx with hx | hx
    · exact (HDP.BooleanClass.mem_trace.mp hx.1).1
    · exact hv hx.1
  obtain ⟨u, huF, hu⟩ := h v' hv'
  refine ⟨setLossSupport target u, ⟨u, huF, rfl⟩, ?_⟩
  rw [trace_setLossSupport, hu]
  simp [v']

/-- A Boolean class and its target-loss transform shatter exactly the same finite sets.

**Lean implementation helper.** -/
theorem lossBooleanClass_shatters_iff
    (target : Set α) (F : HDP.BooleanClass α) (s : Finset α) :
    (lossBooleanClass target F).Shatters s ↔ F.Shatters s := by
  constructor
  · intro h
    have hh := lossBooleanClass_shatters_forward target
      (lossBooleanClass target F) s h
    simpa using hh
  · exact lossBooleanClass_shatters_forward target F s

/-- The Boolean
loss transform preserves every finite VC-dimension upper bound, without any
finiteness assumption on the domain or hypothesis class.

**Book Exercise 8.29.** -/
theorem exercise_8_29_loss_class_vcDimLE_iff
    (target : Set α) (F : HDP.BooleanClass α) (d : ℕ) :
    (lossBooleanClass target F).VCDimLE d ↔ F.VCDimLE d := by
  constructor
  · intro h s hs
    exact h s ((lossBooleanClass_shatters_iff target F s).mpr hs)
  · intro h s hs
    exact h s ((lossBooleanClass_shatters_iff target F s).mp hs)

/-- The classification loss class has the same VC dimension as the hypothesis class, giving the classification specialization. The
class of Boolean squared-loss functions has exactly the same VC dimension as
the original arbitrary hypothesis class.

**Book Example 8.4.6.** -/
theorem exercise_8_29_loss_class_vcDimEq_iff
    (target : Set α) (F : HDP.BooleanClass α) (d : ℕ) :
    HDP.BooleanClass.VCDimEq (lossBooleanClass target F) d ↔
      HDP.BooleanClass.VCDimEq F d := by
  constructor
  · rintro ⟨hle, s, hs, hcard⟩
    exact ⟨(exercise_8_29_loss_class_vcDimLE_iff target F d).mp hle,
      s, (lossBooleanClass_shatters_iff target F s).mp hs, hcard⟩
  · rintro ⟨hle, s, hs, hcard⟩
    exact ⟨(exercise_8_29_loss_class_vcDimLE_iff target F d).mpr hle,
      s, (lossBooleanClass_shatters_iff target F s).mpr hs, hcard⟩

end ArbitraryLossClass

/-! ## Source-faithful arbitrary-class VC generalization -/

/-- Statistical classification is learning a Boolean target from labeled iid data. Population misclassification risk for arbitrary Boolean supports.

**Book Example 8.4.1.** -/
def booleanSetPopulationRisk (μ : Measure α)
    (target hypothesis : Set α) : ℝ :=
  μ.real (setLossSupport target hypothesis)

/-- Statistical classification is learning a Boolean target from labeled iid data. Empirical misclassification risk for arbitrary Boolean supports.

**Book Example 8.4.1.** -/
def booleanSetEmpiricalRisk {n : ℕ} (sample : Fin n → α)
    (target hypothesis : Set α) : ℝ :=
  empiricalAverage sample
    (booleanSetIndicator (setLossSupport target hypothesis))

/-- An attained empirical-risk minimizer in an arbitrary Boolean class.
Membership is part of the predicate; no finiteness or choice of an `argmin`
is hidden in the definition.

**Lean implementation helper.** -/
def IsBooleanClassEmpiricalRiskMinimizer {n : ℕ}
    (F : HDP.BooleanClass α) (sample : Fin n → α)
    (target learned : Set α) : Prop :=
  learned ∈ F ∧ ∀ f ∈ F,
    booleanSetEmpiricalRisk sample target learned ≤
      booleanSetEmpiricalRisk sample target f

/-- An attained population-risk minimizer in an arbitrary Boolean class.

**Lean implementation helper.** -/
def IsBooleanClassPopulationRiskMinimizer
    (F : HDP.BooleanClass α) (μ : Measure α)
    (target best : Set α) : Prop :=
  best ∈ F ∧ ∀ f ∈ F,
    booleanSetPopulationRisk μ target best ≤
      booleanSetPopulationRisk μ target f

/-- Shows that the Boolean class of loss supports is measurable.

**Lean implementation helper.** -/
theorem measurable_lossBooleanClass
    (target : Set α) (hTarget : MeasurableSet target)
    (F : HDP.BooleanClass α) (hF : ∀ f ∈ F, MeasurableSet f) :
    ∀ u ∈ lossBooleanClass target F, MeasurableSet u := by
  intro u hu
  obtain ⟨f, hf, rfl⟩ := hu
  exact hTarget.symmDiff (hF f hf)

/-- Set deviation of a loss support equals empirical Boolean risk minus population Boolean risk.

**Lean implementation helper.** -/
@[simp]
theorem booleanSetDeviation_lossSupport
    (μ : Measure α) {n : ℕ} (sample : Fin n → α)
    (target hypothesis : Set α) :
    booleanSetDeviation μ sample (setLossSupport target hypothesis) =
      booleanSetEmpiricalRisk sample target hypothesis -
        booleanSetPopulationRisk μ target hypothesis := rfl

/-- Every risk deviation of a member is bounded by the actual `sSup` over
the arbitrary loss class. Probability normalization and `n>0` provide the
bounded-above certificate required by the safe supremum.

**Lean implementation helper.** -/
theorem abs_booleanSetRiskDeviation_le_uniform
    [IsProbabilityMeasure μ] {n : ℕ} (hn : 0 < n)
    (F : HDP.BooleanClass α) (sample : Fin n → α)
    (target hypothesis : Set α) (hHypothesis : hypothesis ∈ F) :
    |booleanSetEmpiricalRisk sample target hypothesis -
        booleanSetPopulationRisk μ target hypothesis| ≤
      booleanClassUniformDeviation μ sample (lossBooleanClass target F) := by
  unfold booleanClassUniformDeviation
  apply le_csSup
  · refine ⟨1, ?_⟩
    rintro z ⟨u, rfl⟩
    exact booleanSetDeviation_le_one hn sample u.1
  · let u : ↥(lossBooleanClass target F) :=
      ⟨setLossSupport target hypothesis, ⟨hypothesis, hHypothesis, rfl⟩⟩
    exact ⟨u, by simp [u, booleanSetDeviation_lossSupport]⟩

/-- ERM excess risk is at most twice uniform risk deviation. Equation (8.40), for the source's actual arbitrary Boolean class.

**Book Equation (8.40).** -/
theorem equation_8_40_excessRisk_arbitrary
    [IsProbabilityMeasure μ] {n : ℕ} (hn : 0 < n)
    (F : HDP.BooleanClass α) (sample : Fin n → α)
    (target learned best : Set α)
    (hERM : IsBooleanClassEmpiricalRiskMinimizer F sample target learned)
    (hBest : IsBooleanClassPopulationRiskMinimizer F μ target best) :
    booleanSetPopulationRisk μ target learned -
        booleanSetPopulationRisk μ target best ≤
      2 * booleanClassUniformDeviation μ sample
        (lossBooleanClass target F) := by
  have hLearned := abs_booleanSetRiskDeviation_le_uniform
    (μ := μ) hn F sample target learned hERM.1
  have hBestDev := abs_booleanSetRiskDeviation_le_uniform
    (μ := μ) hn F sample target best hBest.1
  have hMin := hERM.2 best hBest.1
  rw [abs_le] at hLearned hBestDev
  linarith

/-- An exhaustion makes the arbitrary-class uniform deviation measurable and
integrable. This is the analytic side condition suppressed by the source's
notation `E sup`; it follows rather than being assumed in Theorem 8.4.5.

**Book Theorem 8.4.5.** -/
theorem integrable_booleanClassUniformDeviation_of_exhaustion
    {Ω : Type*} {mΩ : MeasurableSpace Ω}
    {P : Measure Ω} [IsProbabilityMeasure μ] [IsProbabilityMeasure P]
    {n : ℕ} (hn : 0 < n) (F : HDP.BooleanClass α)
    (hF : ∀ u ∈ F, MeasurableSet u)
    (E : BooleanDeviationExhaustion μ F)
    (X : Fin n → Ω → α) (hXm : ∀ i, Measurable (X i)) :
    Integrable
      (fun ω => booleanClassUniformDeviation μ (fun i => X i ω) F) P := by
  let M : ℕ → Ω → ℝ := fun k ω =>
    finiteBooleanSetUniformDeviation μ (fun i => X i ω)
      (E.family k) (E.nonempty k)
  let Z : Ω → ℝ := fun ω =>
    booleanClassUniformDeviation μ (fun i => X i ω) F
  have hMm (k : ℕ) : Measurable (M k) := by
    exact measurable_finiteBooleanSetUniformDeviation μ X hXm
      (E.family k) (E.nonempty k)
      (fun u hu => hF u (E.subset k u hu))
  have hMZ : Filter.Tendsto M Filter.atTop (𝓝 Z) := by
    rw [tendsto_pi_nhds]
    intro ω
    simpa [M, Z] using E.tendsTo hn (fun i => X i ω)
  have hZm : Measurable Z := measurable_of_tendsto_metrizable hMm hMZ
  have hZle (ω : Ω) : Z ω ≤ 1 := by
    exact le_of_tendsto (by
      simpa [M, Z] using E.tendsTo hn (fun i => X i ω))
      (Filter.Eventually.of_forall fun k =>
        finiteBooleanSetUniformDeviation_le_one hn _ _ _)
  have hZnonneg (ω : Ω) : 0 ≤ Z ω := by
    exact ge_of_tendsto (by
      simpa [M, Z] using E.tendsTo hn (fun i => X i ω))
      (Filter.Eventually.of_forall fun k =>
        finiteBooleanSetUniformDeviation_nonneg
          μ (fun i => X i ω) (E.family k) (E.nonempty k))
  apply Integrable.of_bound hZm.aestronglyMeasurable 1
  exact Filter.Eventually.of_forall fun ω => by
    rw [Real.norm_of_nonneg (hZnonneg ω)]
    exact hZle ω

/-- VC generalization bound controls expected excess risk by `sqrt(vc/n)`. The hypothesis space and domain may be infinite. The two minimizers are
explicitly assumed to be attained, repairing the printed unqualified
`argmin`; `E` is the standard measurability/separability certificate for the
loss-class supremum.

**Book Theorem 8.4.5.** -/
theorem theorem_8_4_5_vc_generalization_bound_arbitrary
    {Ω : Type*} {mΩ : MeasurableSpace Ω}
    {P : Measure Ω} [IsProbabilityMeasure μ] [IsProbabilityMeasure P]
    {n d : ℕ} (hn : 0 < n)
    (F : HDP.BooleanClass α) (hF : ∀ f ∈ F, MeasurableSet f)
    (hd : F.VCDimLE d) (target : Set α) (hTarget : MeasurableSet target)
    (E : BooleanDeviationExhaustion μ (lossBooleanClass target F))
    (X : Fin n → Ω → α) (hXm : ∀ i, Measurable (X i))
    (hLaw : ∀ i, HasLaw (X i) μ P) (hInd : iIndepFun X P)
    (learned : Ω → Set α) (best : Set α)
    (hERM : ∀ ω, IsBooleanClassEmpiricalRiskMinimizer F
      (fun i => X i ω) target (learned ω))
    (hBest : IsBooleanClassPopulationRiskMinimizer F μ target best)
    (hLearnedInt : Integrable
      (fun ω => booleanSetPopulationRisk μ target (learned ω)) P) :
    (∫ ω, booleanSetPopulationRisk μ target (learned ω) ∂P) ≤
      booleanSetPopulationRisk μ target best +
        4 * vcLawConstant * Real.sqrt ((d : ℝ) / n) := by
  classical
  let L := lossBooleanClass target F
  have hLm : ∀ u ∈ L, MeasurableSet u := by
    simpa [L] using measurable_lossBooleanClass target hTarget F hF
  have hLvc : L.VCDimLE d := by
    simpa [L] using
      (exercise_8_29_loss_class_vcDimLE_iff target F d).mpr hd
  have hUniformInt : Integrable
      (fun ω => booleanClassUniformDeviation μ (fun i => X i ω) L) P :=
    integrable_booleanClassUniformDeviation_of_exhaustion
      hn L hLm (by simpa [L] using E) X hXm
  have hRhsInt : Integrable (fun ω =>
      booleanSetPopulationRisk μ target best +
        2 * booleanClassUniformDeviation μ (fun i => X i ω) L) P :=
    (integrable_const _).add (hUniformInt.const_mul 2)
  have hPoint (ω : Ω) :
      booleanSetPopulationRisk μ target (learned ω) ≤
        booleanSetPopulationRisk μ target best +
          2 * booleanClassUniformDeviation μ (fun i => X i ω) L := by
    have h := equation_8_40_excessRisk_arbitrary
      (μ := μ) hn F (fun i => X i ω) target (learned ω) best
      (hERM ω) hBest
    simpa [L] using (show
      booleanSetPopulationRisk μ target (learned ω) ≤
        booleanSetPopulationRisk μ target best +
          2 * booleanClassUniformDeviation μ (fun i => X i ω)
            (lossBooleanClass target F) by linarith)
  have hUniformMean := theorem_8_3_15_vc_expected
    (μ := μ) (P := P) hn L hLm hLvc (by simpa [L] using E)
    X hXm hLaw hInd
  calc
    (∫ ω, booleanSetPopulationRisk μ target (learned ω) ∂P) ≤
        ∫ ω, (booleanSetPopulationRisk μ target best +
          2 * booleanClassUniformDeviation μ (fun i => X i ω) L) ∂P :=
      integral_mono hLearnedInt hRhsInt hPoint
    _ = booleanSetPopulationRisk μ target best +
        2 * ∫ ω, booleanClassUniformDeviation μ (fun i => X i ω) L ∂P := by
      rw [integral_add (integrable_const _) (hUniformInt.const_mul 2),
        integral_const, integral_const_mul]
      simp
    _ ≤ booleanSetPopulationRisk μ target best +
        4 * vcLawConstant * Real.sqrt ((d : ℝ) / n) := by
      nlinarith

/-! ### Backward-compatible finite support API -/

section LossClass

variable [DecidableEq α]

/-- The Boolean loss class obtained by toggling every support by the fixed
target support.

**Lean implementation helper.** -/
def lossSupportFamily (target : Finset α) (F : BooleanFamily α) :
    BooleanFamily α :=
  F.image (lossSupport target)

/-- Applying the finite-family loss-support transformation twice recovers the original family.

**Lean implementation helper.** -/
@[simp]
theorem lossSupportFamily_involutive (target : Finset α)
    (F : BooleanFamily α) :
    lossSupportFamily target (lossSupportFamily target F) = F := by
  classical
  ext u
  simp [lossSupportFamily]

/-- Shattering by a finite Boolean family is preserved by the loss-support transformation.

**Lean implementation helper.** -/
private theorem lossSupportFamily_shatters_forward
    (target : Finset α) (F : BooleanFamily α) (s : Finset α)
    (h : F.Shatters s) :
    (lossSupportFamily target F).Shatters s := by
  intro v hv
  let v' := (s ∩ target) ∆ v
  have hv' : v' ⊆ s := by
    intro x hx
    rw [Finset.mem_symmDiff] at hx
    rcases hx with hx | hx
    · exact (Finset.mem_inter.mp hx.1).1
    · exact hv hx.1
  obtain ⟨u, huF, hu⟩ := h hv'
  refine ⟨lossSupport target u, ?_, ?_⟩
  · exact Finset.mem_image.mpr ⟨u, huF, rfl⟩
  · ext x
    have hux := Finset.ext_iff.mp hu x
    by_cases hxs : x ∈ s
    · simp only [Finset.mem_inter, hxs, true_and,
        lossSupport, Finset.mem_symmDiff] at hux ⊢
      change (x ∈ u ↔ x ∈ v') at hux
      simp only [v', Finset.mem_symmDiff, Finset.mem_inter, hxs, true_and] at hux
      tauto
    · have hxv : x ∉ v := fun hx => hxs (hv hx)
      simp [hxs, hxv]

/-- Toggling all labels by a fixed target preserves every shattered set.

**Lean implementation helper.** -/
theorem lossSupportFamily_shatters_iff
    (target : Finset α) (F : BooleanFamily α) (s : Finset α) :
    (lossSupportFamily target F).Shatters s ↔ F.Shatters s := by
  constructor
  · intro h
    have hh := lossSupportFamily_shatters_forward target
      (lossSupportFamily target F) s h
    simpa using hh
  · exact lossSupportFamily_shatters_forward target F s

/-- For a fixed Boolean target, the
class of squared-loss functions has exactly the same VC dimension as the
hypothesis class: on supports it is the involution `u ↦ target ∆ u`.

**Book Exercise 8.29.** -/
theorem exercise_8_29_loss_class_vcDim
    (target : Finset α) (F : BooleanFamily α) :
    (lossSupportFamily target F).vcDim = F.vcDim := by
  have hsh : (lossSupportFamily target F).shatterer = F.shatterer := by
    ext s
    simp only [Finset.mem_shatterer]
    exact lossSupportFamily_shatters_iff target F s
  simp only [Finset.vcDim, hsh]

end LossClass

/-! ## Quantitative Boolean VC generalization -/

section BooleanGeneralization

variable [DecidableEq α]

/-- Finite empirical-risk minimization specialized to Boolean supports.

**Lean implementation helper.** -/
def IsBooleanEmpiricalRiskMinimizer {n : ℕ} (F : BooleanFamily α)
    (sample : Fin n → α) (target : Finset α) (learned : ↥F) : Prop :=
  IsFiniteMinimizer F
    (fun h => empiricalRisk sample (booleanIndicator target)
      (booleanIndicator h)) learned

/-- Finite population-risk minimization specialized to Boolean supports.

**Lean implementation helper.** -/
def IsBooleanPopulationRiskMinimizer (F : BooleanFamily α)
    (μ : Measure α) (target : Finset α) (best : ↥F) : Prop :=
  IsFiniteMinimizer F
    (fun h => populationRisk μ (booleanIndicator target)
      (booleanIndicator h)) best

/-- Boolean population risk is the probability integral of the
misclassification support.

**Lean implementation helper.** -/
theorem populationRisk_booleanIndicator (target hypothesis : Finset α) :
    populationRisk μ (booleanIndicator target) (booleanIndicator hypothesis) =
      ∫ x, booleanIndicator (lossSupport target hypothesis) x ∂μ := by
  apply integral_congr_ae
  filter_upwards [] with x
  exact example_8_4_2_classification_loss target hypothesis x

/-- The deterministic excess-risk argument indexed directly by Boolean
supports. Its uniform class is the loss class `target ∆ F`, not a
caller-supplied function class.

**Lean implementation helper.** -/
theorem booleanExcessRisk_le_two_uniformDeviation {n : ℕ}
    (F : BooleanFamily α) (sample : Fin n → α) (target : Finset α)
    (learned comparison : ↥F)
    (hERM : IsBooleanEmpiricalRiskMinimizer F sample target learned) :
    populationRisk μ (booleanIndicator target) (booleanIndicator learned.1) -
        populationRisk μ (booleanIndicator target) (booleanIndicator comparison.1) ≤
      2 * booleanUniformDeviation (lossSupportFamily target F) μ sample := by
  have hlearnedMem : lossSupport target learned.1 ∈ lossSupportFamily target F :=
    Finset.mem_image.mpr ⟨learned.1, learned.2, rfl⟩
  have hcomparisonMem : lossSupport target comparison.1 ∈
      lossSupportFamily target F :=
    Finset.mem_image.mpr ⟨comparison.1, comparison.2, rfl⟩
  have hlearned := abs_booleanDeviation_le_uniform
    (μ := μ) (lossSupportFamily target F) sample hlearnedMem
  have hcomparison := abs_booleanDeviation_le_uniform
    (μ := μ) (lossSupportFamily target F) sample hcomparisonMem
  rw [booleanDeviation, empiricalProcessValue,
    ← example_8_4_4_empirical_classification_risk,
    ← populationRisk_booleanIndicator] at hlearned hcomparison
  have hmin : empiricalRisk sample (booleanIndicator target)
      (booleanIndicator learned.1) ≤
        empiricalRisk sample (booleanIndicator target)
          (booleanIndicator comparison.1) :=
    hERM (Set.mem_univ comparison)
  rw [abs_le] at hlearned hcomparison
  linarith

variable [Finite α] [MeasurableSingletonClass α]

/-- The classification loss class has the same VC dimension as the hypothesis class, giving the classification specialization. For i.i.d. data and a finite Boolean class of VC dimension `d ≥ 1`, an
empirical-risk minimizer whose learned population-risk random variable is
integrable has expected population risk at most the best-in-class risk plus
`4 C √(d/n)`. The loss-class VC equality
is proved by Exercise 8.29 and the quantitative uniform law is supplied by
Theorem 8.3.15; no entropy or chaining certificate is an input.

**Book Example 8.4.6.** -/
theorem theorem_8_4_5_boolean_vc_expected
    [IsProbabilityMeasure μ] [IsProbabilityMeasure P]
    {n : ℕ} (hn : 0 < n) (F : BooleanFamily α) (hF : F.Nonempty)
    (hd : 1 ≤ F.vcDim) (target : Finset α)
    (X : Fin n → Ω → α) (hXm : ∀ i, Measurable (X i))
    (hLaw : ∀ i, HasLaw (X i) μ P) (hInd : iIndepFun X P)
    (learned : Ω → ↥F) (best : ↥F)
    (hERM : ∀ ω, IsBooleanEmpiricalRiskMinimizer F
      (fun i => X i ω) target (learned ω))
    (_hbest : IsBooleanPopulationRiskMinimizer F μ target best)
    (hLearnedInt : Integrable (fun ω =>
      populationRisk μ (booleanIndicator target)
        (booleanIndicator (learned ω).1)) P) :
    (∫ ω, populationRisk μ (booleanIndicator target)
        (booleanIndicator (learned ω).1) ∂P) ≤
      populationRisk μ (booleanIndicator target) (booleanIndicator best.1) +
        4 * vcLawConstant * Real.sqrt ((F.vcDim : ℝ) / n) := by
  let G : BooleanFamily α := lossSupportFamily target F
  have hG : G.Nonempty := by
    obtain ⟨f, hf⟩ := hF
    exact ⟨lossSupport target f,
      Finset.mem_image.mpr ⟨f, hf, rfl⟩⟩
  have hGdim : G.vcDim = F.vcDim := by
    simpa [G] using exercise_8_29_loss_class_vcDim target F
  have hUniformInt : Integrable (fun ω =>
      booleanUniformDeviation G μ (fun i => X i ω)) P :=
    integrable_booleanUniformDeviation_of_measurable_sample hn G X hXm
  have hRhsInt : Integrable (fun ω =>
      populationRisk μ (booleanIndicator target) (booleanIndicator best.1) +
        2 * booleanUniformDeviation G μ (fun i => X i ω)) P :=
    (integrable_const _).add (hUniformInt.const_mul 2)
  have hdet (ω : Ω) :
      populationRisk μ (booleanIndicator target)
          (booleanIndicator (learned ω).1) ≤
        populationRisk μ (booleanIndicator target) (booleanIndicator best.1) +
          2 * booleanUniformDeviation G μ (fun i => X i ω) := by
    have h := booleanExcessRisk_le_two_uniformDeviation
      (μ := μ) F (fun i => X i ω) target (learned ω) best (hERM ω)
    simpa [G] using (show
      populationRisk μ (booleanIndicator target)
          (booleanIndicator (learned ω).1) ≤
        populationRisk μ (booleanIndicator target) (booleanIndicator best.1) +
          2 * booleanUniformDeviation (lossSupportFamily target F) μ
            (fun i => X i ω) by linarith)
  have hUniformMean :
      (∫ ω, booleanUniformDeviation G μ (fun i => X i ω) ∂P) ≤
        vcLawConstant * 2 * Real.sqrt ((F.vcDim : ℝ) / n) := by
    have h := theorem_8_3_15_finite_vc_expected hn G hG
      (by simpa [hGdim] using hd) X hXm hLaw hInd
    rw [hGdim] at h
    nlinarith
  calc
    (∫ ω, populationRisk μ (booleanIndicator target)
        (booleanIndicator (learned ω).1) ∂P) ≤
        ∫ ω, (populationRisk μ (booleanIndicator target)
          (booleanIndicator best.1) +
            2 * booleanUniformDeviation G μ (fun i => X i ω)) ∂P :=
      integral_mono hLearnedInt hRhsInt hdet
    _ = populationRisk μ (booleanIndicator target) (booleanIndicator best.1) +
        2 * ∫ ω, booleanUniformDeviation G μ (fun i => X i ω) ∂P := by
      rw [integral_add (integrable_const _) (hUniformInt.const_mul 2),
        integral_const, integral_const_mul]
      simp
    _ ≤ populationRisk μ (booleanIndicator target) (booleanIndicator best.1) +
        4 * vcLawConstant * Real.sqrt ((F.vcDim : ℝ) / n) := by
      nlinarith

end BooleanGeneralization

/-- Increasing model complexity reduces approximation bias but increases the VC estimation term. The generalization bound decomposes into the best-in-class risk and twice the
uniform estimation error.

**Book Remark 8.4.7.** -/
theorem remark_8_4_7_bias_variance_tradeoff {n : ℕ}
    (F : Finset (α → ℝ)) (sample : Fin n → α) (target : α → ℝ)
    (learned best : ↥F)
    (hERM : IsEmpiricalRiskMinimizer F sample target learned)
    (hbest : IsPopulationRiskMinimizer F μ target best) :
    populationRisk μ target learned.1 ≤
      populationRisk μ target best.1 +
        2 * riskUniformDeviation F μ sample target :=
  theorem_8_4_5_vc_generalization_bound F sample target learned best hERM hbest

end

end HDP.Chapter8

