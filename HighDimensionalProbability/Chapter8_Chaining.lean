/-! ## Arbitrary bounded sets under the book's finite-subfamily convention

Remark 7.2.1 defines an expected supremum over an arbitrary index set as the
supremum of the expected maxima over all nonempty finite subfamilies.  The
following API implements that convention directly.  It is deliberately
`ℝ≥0∞`-valued: boundedness/finiteness is a separate certificate, rather than
being hidden by a total real `sSup`.
-/

/-- A nonempty finite subfamily of a set. -/
structure NonemptyFiniteSubset {E : Type*} (T : Set E) where
  carrier : Finset E
  nonempty : carrier.Nonempty
  subset : (carrier : Set E) ⊆ T

omit hMM in
/-- The union of two finite subfamilies is a common upper subfamily.

**Lean implementation helper.** -/
noncomputable def NonemptyFiniteSubset.union {E : Type*} {T : Set E}
    (U V : NonemptyFiniteSubset T) : NonemptyFiniteSubset T := by
  classical
  refine ⟨U.carrier ∪ V.carrier, ?_, ?_⟩
  · exact U.nonempty.mono Finset.subset_union_left
  · intro x hx
    rcases Finset.mem_union.mp hx with hx | hx
    · exact U.subset hx
    · exact V.subset hx

