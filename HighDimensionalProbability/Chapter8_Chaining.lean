  have hSG : HDP.HasSubGaussianIncrementsWith Z μ d K := by
    refine ⟨hK, ?_⟩
    intro s t
    simpa [Z, d, finiteEuclideanProcess, dist_eq_norm] using
      hinc t.1 t.2 s.1 s.2
  have hpair := genericChainingSupremumOfIncrements Z hZm hZint d
    (fun s t => dist_nonneg) (fun s t => dist_comm _ _)
    (fun r s t => dist_triangle _ _ _) (fun t => dist_self _) hSG
  have hgamma := gamma2_euclidean_finset_le_gaussianWidth A (by simp [A])
  have hwidth := gaussianWidth_insert_zero_le_gaussianComplexity T hT
  have hcoef : 0 ≤ 2 * genericChainingConstant * K :=
