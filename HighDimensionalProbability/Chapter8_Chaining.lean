/-- Chevet bilinear process has increments controlled by opposite radii. Equation (8.52), first step: the bilinear process has subgaussian
increments controlled by the two product-metric terms. The constant `√30`
is the explicit constant supplied by promoted Exercise 3.34.

**Book Equation (8.52).** -/
theorem equation_8_52_row_increment {m n : ℕ}
    [IsProbabilityMeasure μ]
    (A : Fin m → Ω → EuclideanSpace ℝ (Fin n))
    (hAm : ∀ i x, AEMeasurable (fun ω => inner ℝ (A i ω) x) μ)
    (hsub : ∀ i, HDP.SubGaussianVector (A i) μ)
    (hmean : ∀ i x, ∫ ω, inner ℝ (A i ω) x ∂μ = 0)
    (hindep : iIndepFun A μ)
    (hbounded : ∀ i, BddAbove {r : ℝ |
      ∃ x : EuclideanSpace ℝ (Fin n), ‖x‖ = 1 ∧
        r = HDP.psi2Norm (fun ω => inner ℝ (A i ω) x) μ})
    {K : ℝ} (hK : 0 ≤ K)
    (hpsi : ∀ i, HDP.psi2NormVector (A i) μ ≤ K)
    (u w : EuclideanSpace ℝ (Fin n))
    (v z : EuclideanSpace ℝ (Fin m)) :
    HDP.SubGaussian
        (fun ω => rowBilinearProcess A u v ω -
          rowBilinearProcess A w z ω) μ ∧
      HDP.psi2Norm
          (fun ω => rowBilinearProcess A u v ω -
            rowBilinearProcess A w z ω) μ ≤
        Real.sqrt 30 * K *
          (‖u - w‖ * ‖v‖ + ‖w‖ * ‖v - z‖) := by
  let Y : Ω → ℝ := rowBilinearProcess A (u - w) v
  let Z : Ω → ℝ := rowBilinearProcess A w (v - z)
  have hY := HDP.Chapter3.exercise_3_34 A hAm hsub hmean hindep
    hbounded hK hpsi v (u - w)
  have hZ := HDP.Chapter3.exercise_3_34 A hAm hsub hmean hindep
    hbounded hK hpsi (v - z) w
  have hYm : AEMeasurable Y μ :=
    aemeasurable_rowBilinearProcess A hAm (u - w) v
  have hZm : AEMeasurable Z μ :=
    aemeasurable_rowBilinearProcess A hAm w (v - z)
  have hYZsub : HDP.SubGaussian (fun ω => Y ω + Z ω) μ :=
    hY.1.add hYm hZm hZ.1
  have hYZpsi : HDP.psi2Norm (fun ω => Y ω + Z ω) μ ≤
      HDP.psi2Norm Y μ + HDP.psi2Norm Z μ :=
    HDP.psi2Norm_add_le hYm hZm hY.1 hZ.1
  have hbound : HDP.psi2Norm (fun ω => Y ω + Z ω) μ ≤
      Real.sqrt 30 * K *
        (‖u - w‖ * ‖v‖ + ‖w‖ * ‖v - z‖) := by
    calc
      HDP.psi2Norm (fun ω => Y ω + Z ω) μ ≤
          HDP.psi2Norm Y μ + HDP.psi2Norm Z μ := hYZpsi
      _ ≤ (Real.sqrt 30 * ‖v‖ * ‖u - w‖ * K) +
          (Real.sqrt 30 * ‖v - z‖ * ‖w‖ * K) :=
        add_le_add hY.2 hZ.2
      _ = Real.sqrt 30 * K *
          (‖u - w‖ * ‖v‖ + ‖w‖ * ‖v - z‖) := by ring
  have hfun : (fun ω => rowBilinearProcess A u v ω -
      rowBilinearProcess A w z ω) = fun ω => Y ω + Z ω := by
    funext ω
    exact rowBilinearProcess_sub A u w v z ω
  rw [hfun]
  exact ⟨hYZsub, hbound⟩

