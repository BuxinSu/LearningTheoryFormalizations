/-- Frobenius inner products of vectorized rank-one matrices factor.

**Lean implementation helper.** -/
theorem inner_rankOneGaussianPoint {m n : ℕ}
    (u w : EuclideanSpace ℝ (Fin n))
    (v z : EuclideanSpace ℝ (Fin m)) :
    inner ℝ (rankOneGaussianPoint u v) (rankOneGaussianPoint w z) =
      inner ℝ u w * inner ℝ v z := by
  simp only [rankOneGaussianPoint, PiLp.inner_apply, Real.inner_apply]
  rw [Fintype.sum_prod_type]
  calc
    (∑ i, ∑ j,
        (WithLp.ofLp v) i * (WithLp.ofLp u) j *
          ((WithLp.ofLp z) i * (WithLp.ofLp w) j)) =
        ∑ i, ∑ j,
          ((WithLp.ofLp u) j * (WithLp.ofLp w) j) *
            ((WithLp.ofLp v) i * (WithLp.ofLp z) i) := by
      apply Finset.sum_congr rfl
      intro i _
      apply Finset.sum_congr rfl
      intro j _
      ring
    _ = ∑ i,
        (∑ j, (WithLp.ofLp u) j * (WithLp.ofLp w) j) *
          ((WithLp.ofLp v) i * (WithLp.ofLp z) i) := by
      apply Finset.sum_congr rfl
      intro i _
      rw [Finset.sum_mul]
    _ = (∑ j, (WithLp.ofLp u) j * (WithLp.ofLp w) j) *
        ∑ i, (WithLp.ofLp v) i * (WithLp.ofLp z) i := by
      rw [Finset.mul_sum]

