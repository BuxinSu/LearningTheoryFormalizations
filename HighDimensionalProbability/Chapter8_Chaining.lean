/-- This is the public arbitrary-set endpoint dictated
by Remark 7.2.1; the earlier finite theorem is its proof engine.

**Book Theorem 8.6.1.** -/
theorem theorem_8_6_1_subgaussian_chevet_arbitrary_envelope {m n : ℕ}
    [IsProbabilityMeasure μ]
    (A : Fin m → Ω → EuclideanSpace ℝ (Fin n))
    (hM : ∀ i x, Measurable (fun ω => inner ℝ (A i ω) x))
    (hsub : ∀ i, HDP.SubGaussianVector (A i) μ)
    (hmean : ∀ i x, ∫ ω, inner ℝ (A i ω) x ∂μ = 0)
    (hindep : iIndepFun A μ)
    (hbounded : ∀ i, BddAbove {r : ℝ |
      ∃ x : EuclideanSpace ℝ (Fin n), ‖x‖ = 1 ∧
        r = HDP.psi2Norm (fun ω => inner ℝ (A i ω) x) μ})
    {K : ℝ} (hK : 0 ≤ K)
    (hpsi : ∀ i, HDP.psi2NormVector (A i) μ ≤ K)
    (T : Set (EuclideanSpace ℝ (Fin n)))
    (S : Set (EuclideanSpace ℝ (Fin m))) :
    subGaussianChevetExpectationEnvelope μ A T S ≤
      ENNReal.ofReal (chevetConstant * K) *
        gaussianChevetControlEnvelope T S := by
  apply iSup_le
  intro U
  apply iSup_le
  intro V
  letI : Nonempty ↥U.carrier := U.nonempty.to_subtype
  letI : Nonempty ↥V.carrier := V.nonempty.to_subtype
  have h := theorem_8_6_1_subgaussian_chevet A hM hsub hmean hindep
    hbounded hK hpsi U.carrier V.carrier U.nonempty V.nonempty
  have hcK : 0 ≤ chevetConstant * K :=
    mul_nonneg chevetConstant_pos.le hK
  calc
    finiteSubGaussianChevetExpectationNN μ A U V ≤ ENNReal.ofReal
        (chevetConstant * K *
          (HDP.Chapter7.gaussianWidth U.carrier *
              HDP.Chapter7.finiteRadius V.carrier +
            HDP.Chapter7.gaussianWidth V.carrier *
              HDP.Chapter7.finiteRadius U.carrier)) :=
      ENNReal.ofReal_le_ofReal h
    _ = ENNReal.ofReal (chevetConstant * K) *
        finiteGaussianChevetControlNN U V := by
      rw [ENNReal.ofReal_mul hcK,
        finiteGaussianChevetControlNN_eq_ofReal]
    _ ≤ ENNReal.ofReal (chevetConstant * K) *
        gaussianChevetControlEnvelope T S :=
      mul_le_mul_right
        (le_iSup_of_le U (le_iSup (fun V : NonemptyFiniteSubset S =>
          finiteGaussianChevetControlNN U V) V)) _

