    {I : Type*} {m n : ℕ}
    (u : I → EuclideanSpace ℝ (Fin n))
    (v : I → EuclideanSpace ℝ (Fin m))
    (rT rS : ℝ)
    (hu : ∀ i, ‖u i‖ = rT) (hv : ∀ i, ‖v i‖ = rS)
