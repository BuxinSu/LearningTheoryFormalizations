/-! ## From dimension reduction to traces -/

/-- If a deterministic sample gives positive empirical distance to every
distinct pair in `G`, restriction to the set of sampled points is injective.
Sauer--Shelah then bounds the class by the binomial growth expression at the
original (possibly repeated) sample size.

**Lean implementation helper.** -/
theorem card_le_binomial_of_empirically_separated {n d : ℕ}
    (sample : Fin n → α) (G : BooleanFamily α) (hd : G.vcDim ≤ d)
    (hpositive : ∀ u ∈ G, ∀ v ∈ G, u ≠ v →
      0 < empiricalBooleanL2Dist sample u v) :
    G.card ≤ ∑ k ∈ Finset.range (d + 1), n.choose k := by
  let s : Finset α := Finset.univ.image sample
  have hsamp (i : Fin n) : sample i ∈ s := by
    simp [s]
  have hinj : Set.InjOn (fun u : Finset α => s ∩ u) (G : Set (Finset α)) := by
    intro u hu v hv huv
    by_contra huvne
    have hpos := hpositive u hu v hv huvne
    have hpoint (i : Fin n) : booleanValue u (sample i) = booleanValue v (sample i) := by
      have hm := Finset.ext_iff.mp huv (sample i)
      have hs := hsamp i
      simp only [Finset.mem_inter, hs, true_and] at hm
      by_cases hmem : sample i ∈ u
      · have : sample i ∈ v := hm.mp hmem
        simp [booleanValue, hmem, this]
      · have : sample i ∉ v := fun hv => hmem (hm.mpr hv)
        simp [booleanValue, hmem, this]
    have hsq : empiricalBooleanL2Sq sample u v = 0 := by
      simp [empiricalBooleanL2Sq, empiricalAverage, hpoint]
    have hdist : empiricalBooleanL2Dist sample u v = 0 := by
      simp [empiricalBooleanL2Dist, hsq]
    linarith
  have htrace : (rawTraceFamily G s).card = G.card := by
    rw [rawTraceFamily, Finset.card_image_iff]
    exact hinj
  have hscard : s.card ≤ n := by
    simpa [s] using Finset.card_image_le (f := sample) (s := Finset.univ)
  calc
    G.card = (rawTraceFamily G s).card := htrace.symm
    _ ≤ ∑ k ∈ Finset.range (d + 1), s.card.choose k :=
      card_rawTraceFamily_le_binomial G s d hd
    _ ≤ ∑ k ∈ Finset.range (d + 1), n.choose k := by
      exact Finset.sum_le_sum fun k _ => Nat.choose_le_choose k hscard

