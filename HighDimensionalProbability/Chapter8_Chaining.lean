      ‖u‖ ^ 2 * ‖v‖ ^ 2 + ‖w‖ ^ 2 * ‖z‖ ^ 2 -
        2 * inner ℝ u w * inner ℝ v z := by
  have hself (a : EuclideanSpace ℝ (Fin n))
      (b : EuclideanSpace ℝ (Fin m)) :
      ‖rankOneGaussianPoint a b‖ ^ 2 = ‖a‖ ^ 2 * ‖b‖ ^ 2 := by
    rw [← real_inner_self_eq_norm_sq,
      inner_rankOneGaussianPoint,
      real_inner_self_eq_norm_sq, real_inner_self_eq_norm_sq]
  rw [norm_sub_sq_real, hself, hself, inner_rankOneGaussianPoint]
  ring

omit hMM in
/-- Rank-one increment comparison on spheres of arbitrary radii. The unit
sphere inequality used in the classical proof is the special case
`rT = rS = 1`.

**Lean implementation helper.** -/
theorem rankOneGaussianPoint_sub_norm_sq_le_of_norm_eq
    {m n : ℕ}
    (u w : EuclideanSpace ℝ (Fin n))
    (v z : EuclideanSpace ℝ (Fin m))
    (rT rS : ℝ)
    (hu : ‖u‖ = rT) (hw : ‖w‖ = rT)
    (hv : ‖v‖ = rS) (hz : ‖z‖ = rS) :
    ‖rankOneGaussianPoint u v - rankOneGaussianPoint w z‖ ^ 2 ≤
      rS ^ 2 * ‖u - w‖ ^ 2 + rT ^ 2 * ‖v - z‖ ^ 2 := by
  have hinnerUW : inner ℝ u w ≤ rT ^ 2 := by
    calc
      inner ℝ u w ≤ ‖u‖ * ‖w‖ := real_inner_le_norm u w
      _ = rT ^ 2 := by rw [hu, hw]; ring
  have hinnerVZ : inner ℝ v z ≤ rS ^ 2 := by
    calc
      inner ℝ v z ≤ ‖v‖ * ‖z‖ := real_inner_le_norm v z
      _ = rS ^ 2 := by rw [hv, hz]; ring
  have hprod :
      0 ≤ (rT ^ 2 - inner ℝ u w) *
        (rS ^ 2 - inner ℝ v z) :=
    mul_nonneg (sub_nonneg.mpr hinnerUW) (sub_nonneg.mpr hinnerVZ)
  rw [rankOneGaussianPoint_sub_norm_sq,
    norm_sub_sq_real, norm_sub_sq_real, hu, hw, hv, hz]
  nlinarith

