The large numerical factor keeps the real-logarithm bookkeeping elementary
and yields the universal exponent `26` below.

**Lean implementation helper.** -/
def vcCoverSampleSize (m d : ℕ) (ε : ℝ) : ℕ :=
  ⌈1024 * ε⁻¹ ^ 4 * (d : ℝ) *
    (m : ℝ) ^ (1 / (2 * (d : ℝ)))⌉₊

/-- Shows that the sample size used in the VC covering argument is strictly positive.

**Lean implementation helper.** -/
private theorem vcCoverSampleSize_pos {m d : ℕ} {ε : ℝ}
    (hm : 1 ≤ m) (hd : 1 ≤ d) (hε : 0 < ε) :
    0 < vcCoverSampleSize m d ε := by
  have hmR : (0 : ℝ) < m := by exact_mod_cast (Nat.zero_lt_of_lt hm)
  have hA : 0 < 1024 * ε⁻¹ ^ 4 * (d : ℝ) *
      (m : ℝ) ^ (1 / (2 * (d : ℝ))) := by positivity
  exact (Nat.one_le_ceil_iff.mpr hA).trans_lt' Nat.zero_lt_one

/-- The chosen VC sample size makes the dimension-reduction failure estimate at most `1/100`.

**Lean implementation helper.** -/
private theorem vcCoverSampleSize_failure_bound {m d : ℕ} {ε : ℝ}
    (hm : 2 ≤ m) (hd : 1 ≤ d) (hε : 0 < ε) (hε1 : ε < 1) :
    (m : ℝ) ^ 2 *
      Real.exp (-(vcCoverSampleSize m d ε : ℝ) * ε ^ 4 / 8) ≤ 1 / 100 := by
  let r : ℝ := (m : ℝ) ^ (1 / (2 * (d : ℝ)))
  let A : ℝ := 1024 * ε⁻¹ ^ 4 * (d : ℝ) * r
  have hmR : (0 : ℝ) < m := by exact_mod_cast (lt_of_lt_of_le Nat.zero_lt_two hm)
  have hdR : (0 : ℝ) < d := by exact_mod_cast (Nat.zero_lt_of_lt hd)
  have hinv : 1 ≤ ε⁻¹ := by
    exact (one_le_inv₀ hε).2 hε1.le
  have hr1 : 1 ≤ r := by
    dsimp [r]
    exact Real.one_le_rpow (by exact_mod_cast (show 1 ≤ m by omega)) (by positivity)
  have hdR1 : (1 : ℝ) ≤ d := by exact_mod_cast hd
  have hdr1 : 1 ≤ (d : ℝ) * r := by
    calc
      (1 : ℝ) = 1 * 1 := by ring
      _ ≤ (d : ℝ) * r := mul_le_mul hdR1 hr1 (by norm_num) hdR.le
  have hlogm0 : 0 ≤ Real.log (m : ℝ) :=
    Real.log_nonneg (by exact_mod_cast (show 1 ≤ m by omega))
  have hlogm : Real.log (m : ℝ) ≤ 2 * (d : ℝ) * r := by
    have hexp := Real.add_one_le_exp (Real.log (m : ℝ) *
      (1 / (2 * (d : ℝ))))
    have hrdef : r = Real.exp (Real.log (m : ℝ) *
        (1 / (2 * (d : ℝ)))) := by
      dsimp [r]
      rw [Real.rpow_def_of_pos hmR]
    rw [← hrdef] at hexp
    have hfrac : Real.log (m : ℝ) / (2 * (d : ℝ)) ≤ r := by
      have hraw : Real.log (m : ℝ) * (1 / (2 * (d : ℝ))) ≤ r := by
        linarith
      simpa [div_eq_mul_inv] using hraw
    have hden : 0 < 2 * (d : ℝ) := by positivity
    simpa [mul_comm, mul_left_comm, mul_assoc] using
      (div_le_iff₀ hden).mp hfrac
  have hlog100 : Real.log (100 : ℝ) ≤ 100 :=
    Real.log_le_self (by norm_num)
  have hlogprod : Real.log ((100 : ℝ) * (m : ℝ) ^ 2) ≤
      128 * (d : ℝ) * r := by
    rw [Real.log_mul (by norm_num : (100 : ℝ) ≠ 0) (ne_of_gt (sq_pos_of_pos hmR)),
      Real.log_pow]
    calc
      Real.log 100 + (2 : ℝ) * Real.log (m : ℝ) ≤
          100 + 2 * (2 * (d : ℝ) * r) :=
        add_le_add hlog100 (mul_le_mul_of_nonneg_left hlogm (by norm_num))
      _ ≤ 128 * (d : ℝ) * r := by nlinarith [hdr1]
  have hA0 : 0 ≤ A := by positivity
  have hnA : A ≤ (vcCoverSampleSize m d ε : ℝ) := by
    exact Nat.le_ceil A
  have hT : 128 * (d : ℝ) * r ≤
