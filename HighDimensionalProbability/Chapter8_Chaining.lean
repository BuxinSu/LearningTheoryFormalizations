/-- Every coordinate of the product-Gaussian comparison process has a finite
second moment.

**Lean implementation helper.** -/
theorem sumCanonicalGaussianProcess_isL2
    {I E F : Type*}
    [NormedAddCommGroup E] [InnerProductSpace ℝ E]
    [FiniteDimensional ℝ E] [MeasurableSpace E] [BorelSpace E]
    [NormedAddCommGroup F] [InnerProductSpace ℝ F]
    [FiniteDimensional ℝ F] [MeasurableSpace F] [BorelSpace F]
    (u : I → E) (v : I → F) :
    HDP.IsL2Process (sumCanonicalGaussianProcess u v)
      ((stdGaussian E).prod (stdGaussian F)) := by
  intro i
  exact ((sumCanonicalGaussianProcess_isGaussian u v).hasGaussianLaw_eval i).memLp_two

