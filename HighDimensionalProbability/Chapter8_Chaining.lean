/-- A fixed left vector turns the Gaussian matrix process into the canonical
Gaussian process on the right-hand set, scaled by the vector norm.

**Lean implementation helper.** -/
theorem expectedFiniteSupremum_rankOne_fixed_left {m n : ℕ}
    (u : EuclideanSpace ℝ (Fin n))
    (S : Finset (EuclideanSpace ℝ (Fin m)))
    [Nonempty ↥S] (hS : S.Nonempty) :
    HDP.Chapter7.expectedFiniteSupremum
        (stdGaussian (EuclideanSpace ℝ (Fin m × Fin n)))
        (rankOneCanonicalGaussianProcess
          (fun _ : ↥S => u) (fun v : ↥S => v.1)) =
      ‖u‖ * HDP.Chapter7.gaussianWidth S := by
  let X := rankOneCanonicalGaussianProcess
    (fun _ : ↥S => u) (fun v : ↥S => v.1)
  let Y := HDP.Chapter7.canonicalGaussianProcess
    (fun v : ↥S => ‖u‖ • v.1)
  have hXG : IsGaussianProcess X
      (stdGaussian (EuclideanSpace ℝ (Fin m × Fin n))) := by
    simpa [X, rankOneCanonicalGaussianProcess] using
      HDP.Chapter7.canonicalGaussianProcess_isGaussian
        (fun v : ↥S => rankOneGaussianPoint u v.1)
  have hYG : IsGaussianProcess Y
      (stdGaussian (EuclideanSpace ℝ (Fin m))) := by
    simpa [Y] using HDP.Chapter7.canonicalGaussianProcess_isGaussian
      (fun v : ↥S => ‖u‖ • v.1)
  have hX0 : HDP.IsCenteredProcess X
      (stdGaussian (EuclideanSpace ℝ (Fin m × Fin n))) := by
    simpa [X, rankOneCanonicalGaussianProcess] using
      HDP.Chapter7.canonicalGaussianProcess_centered
        (fun v : ↥S => rankOneGaussianPoint u v.1)
  have hY0 : HDP.IsCenteredProcess Y
      (stdGaussian (EuclideanSpace ℝ (Fin m))) := by
    simpa [Y] using HDP.Chapter7.canonicalGaussianProcess_centered
      (fun v : ↥S => ‖u‖ • v.1)
  have hinc : ∀ v z : ↥S,
      HDP.Chapter7.processIncrementSecondMoment
          (stdGaussian (EuclideanSpace ℝ (Fin m × Fin n))) X v z =
        HDP.Chapter7.processIncrementSecondMoment
          (stdGaussian (EuclideanSpace ℝ (Fin m))) Y v z := by
    intro v z
    rw [show X = rankOneCanonicalGaussianProcess
        (fun _ : ↥S => u) (fun q : ↥S => q.1) from rfl,
      rankOneCanonicalGaussianProcess_incrementSecondMoment]
    rw [show Y = HDP.Chapter7.canonicalGaussianProcess
        (fun q : ↥S => ‖u‖ • q.1) from rfl,
      HDP.Chapter7.processIncrementSecondMoment_canonicalGaussianProcess]
    rw [rankOneGaussianPoint_sub_norm_sq,
      real_inner_self_eq_norm_sq, norm_sub_sq_real]
    simp only [norm_smul, Real.norm_eq_abs, inner_smul_left,
      inner_smul_right, starRingEnd_apply, star_trivial, mul_pow, sq_abs]
    ring
  have hXY := HDP.Chapter7.sudakovFernique
    (stdGaussian (EuclideanSpace ℝ (Fin m × Fin n)))
    (stdGaussian (EuclideanSpace ℝ (Fin m))) X Y hXG hYG hX0 hY0
    (fun v z => (hinc v z).le)
  have hYX := HDP.Chapter7.sudakovFernique
    (stdGaussian (EuclideanSpace ℝ (Fin m)))
    (stdGaussian (EuclideanSpace ℝ (Fin m × Fin n))) Y X hYG hXG hY0 hX0
    (fun v z => (hinc v z).ge)
  have hEq : HDP.Chapter7.expectedFiniteSupremum
      (stdGaussian (EuclideanSpace ℝ (Fin m × Fin n))) X =
      HDP.Chapter7.expectedFiniteSupremum
        (stdGaussian (EuclideanSpace ℝ (Fin m))) Y :=
    le_antisymm hXY hYX
  have hpoint : finiteProcessSup Y = fun g =>
      ‖u‖ * HDP.Chapter7.finiteGaussianSupport S g := by
    funext g
    rw [HDP.Chapter7.finiteGaussianSupport_eq_sup' S hS]
    apply le_antisymm
    · unfold finiteProcessSup
      apply Finset.sup'_le
      intro v hv
      change inner ℝ (‖u‖ • v.1) g ≤
        ‖u‖ * S.sup' hS (fun y => inner ℝ g y)
      rw [inner_smul_left]
      simp only [starRingEnd_apply, star_trivial]
      rw [real_inner_comm g v.1]
      exact mul_le_mul_of_nonneg_left
        (Finset.le_sup' (fun y => inner ℝ g y) v.2) (norm_nonneg u)
    · obtain ⟨v, hv, hmax⟩ :=
        Finset.exists_mem_eq_sup' hS (fun y => inner ℝ g y)
      let q : ↥S := ⟨v, hv⟩
      calc
        ‖u‖ * S.sup' hS (fun y => inner ℝ g y) =
            Y q g := by
          simp only [Y, HDP.Chapter7.canonicalGaussianProcess,
            q, inner_smul_left, starRingEnd_apply, star_trivial]
          rw [real_inner_comm g v, hmax]
        _ ≤ finiteProcessSup Y g := by
          unfold finiteProcessSup
          exact Finset.le_sup' (fun q : ↥S => Y q g) (Finset.mem_univ q)
  rw [hEq]
  unfold HDP.Chapter7.expectedFiniteSupremum
  change (∫ g, finiteProcessSup Y g
      ∂stdGaussian (EuclideanSpace ℝ (Fin m))) = _
  rw [hpoint, integral_const_mul]
  rfl

