/-- A bounded Euclidean set has covering entropy at most `√(2 n · diam(T) / x)`.

**Lean implementation helper.** -/
lemma euclideanSetCoverEntropy_le_sqrt_div
    {n : ℕ} [NeZero n]
    {T : Set (EuclideanSpace ℝ (Fin n))}
    (hTne : T.Nonempty) (hTb : Bornology.IsBounded T)
    (_hD : 0 < Metric.diam T) {x : ℝ} (hx : 0 < x) :
    euclideanSetCoverEntropy T x ≤
      Real.sqrt (2 * (n : ℝ) * Metric.diam T / x) := by
  let D : ℝ≥0 := ⟨Metric.diam T, Metric.diam_nonneg⟩
  let ε : ℝ≥0 := x.toNNReal
  have hTne' := hTne
  obtain ⟨c, hcT⟩ := hTne
  have hsub : T ⊆ Metric.closedBall c (D : ℝ) := by
    intro y hy
    rw [Metric.mem_closedBall]
    exact Metric.dist_le_diam_of_mem hTb hy hcT
  have hε : 0 < ε := by simpa [ε] using hx
  have hcov := coveringNumber_subset_closedBall_upper (n := n)
    (ε := ε) (R := D) hε hsub
  have hfin : Metric.coveringNumber ε T ≠ ⊤ :=
    bounded_coveringNumber_ne_top hTb hε.ne'
  let b : ℝ≥0 := 2 * D / ε + 1
  have hbtop : ((b : ℝ≥0∞) ^ n) ≠ ⊤ := by simp
  have hcovReal := ENNReal.toReal_mono hbtop hcov
  have hcovNat : ((Metric.coveringNumber ε T).toNat : ℝ) ≤ (b : ℝ) ^ n := by
    have hcoe : (((Metric.coveringNumber ε T).toNat : ℕ) : ℝ≥0∞) =
        (Metric.coveringNumber ε T : ℝ≥0∞) := by
      exact_mod_cast ENat.coe_toNat hfin
    rw [← hcoe] at hcovReal
    simpa only [ENNReal.toReal_natCast, ENNReal.toReal_pow,
      ENNReal.coe_toReal, Nat.cast_ofNat] using hcovReal
  have hcardPos : (0 : ℝ) < (Metric.coveringNumber ε T).toNat := by
    exact_mod_cast ENat.toNat_pos
      (Metric.coveringNumber_pos_iff.mpr hTne').ne' hfin
  have hbpos : (0 : ℝ) < (b : ℝ) := by positivity
  have hpowpos : (0 : ℝ) < (b : ℝ) ^ n := pow_pos hbpos n
  have hlogCov : Real.log ((Metric.coveringNumber ε T).toNat : ℝ) ≤
      Real.log ((b : ℝ) ^ n) := Real.log_le_log hcardPos hcovNat
  have hlogb : Real.log (b : ℝ) ≤ (b : ℝ) - 1 :=
    Real.log_le_sub_one_of_pos hbpos
  have hn0 : (0 : ℝ) ≤ n := by positivity
  have hlogFinal : Real.log ((Metric.coveringNumber ε T).toNat : ℝ) ≤
      2 * (n : ℝ) * Metric.diam T / x := by
    calc
      Real.log ((Metric.coveringNumber ε T).toNat : ℝ) ≤
          Real.log ((b : ℝ) ^ n) := hlogCov
      _ = (n : ℝ) * Real.log (b : ℝ) := by rw [Real.log_pow]
      _ ≤ (n : ℝ) * ((b : ℝ) - 1) :=
        mul_le_mul_of_nonneg_left hlogb hn0
      _ = 2 * (n : ℝ) * Metric.diam T / x := by
        change (n : ℝ) *
            (2 * (D : ℝ) / (ε : ℝ) + 1 - 1) =
          2 * (n : ℝ) * Metric.diam T / x
        have hDcoe : (D : ℝ) = Metric.diam T := rfl
        have hεcoe : (ε : ℝ) = x := by
          exact Real.coe_toNNReal x hx.le
        rw [hDcoe, hεcoe]
        field_simp
        ring
  unfold euclideanSetCoverEntropy
  have heps : x.toNNReal = ε := rfl
  rw [heps]
  exact Real.sqrt_le_sqrt hlogFinal

/-- A non-singleton bounded set has covering entropy at radius `diam(T)/8` at least `√log 2`.

**Lean implementation helper.** -/
lemma euclideanSetCoverEntropy_diam_div_eight_lower
    {n : ℕ} {T : Set (EuclideanSpace ℝ (Fin n))}
    (_hTne : T.Nonempty) (hTb : Bornology.IsBounded T)
    (hD : 0 < Metric.diam T) :
    Real.sqrt (Real.log 2) ≤
      euclideanSetCoverEntropy T (Metric.diam T / 8) := by
  let D := Metric.diam T
  have hp : ∃ x ∈ T, ∃ y ∈ T, D / 2 < dist x y := by
    by_contra h
    push Not at h
    have hle := Metric.diam_le_of_forall_dist_le
      (s := T) (div_nonneg Metric.diam_nonneg (by norm_num)) h
    nlinarith
  obtain ⟨x, hx, y, hy, hxy⟩ := hp
  let r : ℝ≥0 := ⟨D / 8, by positivity⟩
  let C : Set (EuclideanSpace ℝ (Fin n)) := {x, y}
  have hCsub : C ⊆ T := by
    intro z hz
    simp only [C, Set.mem_insert_iff, Set.mem_singleton_iff] at hz
    rcases hz with rfl | rfl <;> assumption
  have hCsep : Metric.IsSeparated (↑(2 * r) : ℝ≥0∞) C := by
    intro a ha b hb hab
    simp only [C, Set.mem_insert_iff, Set.mem_singleton_iff] at ha hb
    have habdist : D / 2 < dist a b := by
      rcases ha with rfl | rfl <;> rcases hb with rfl | rfl
      · exact (hab rfl).elim
      · exact hxy
      · simpa [dist_comm] using hxy
      · exact (hab rfl).elim
    change (↑(2 * r) : ℝ≥0∞) < edist a b
    rw [edist_nndist, ENNReal.coe_lt_coe]
    change 2 * (D / 8) < dist a b
    linarith
  have hxyne : x ≠ y := by
    intro heq
    rw [heq, dist_self] at hxy
    nlinarith [hD]
  have hlower : (2 : ℕ∞) ≤ Metric.coveringNumber r T := by
    calc
      (2 : ℕ∞) = C.encard := by
        rw [show C = ({x, y} : Set _) by rfl, Set.encard_pair hxyne]
      _ ≤ Metric.packingNumber (2 * r) T :=
        hCsep.encard_le_packingNumber hCsub
      _ ≤ Metric.externalCoveringNumber r T :=
        Metric.packingNumber_two_mul_le_externalCoveringNumber r T
      _ ≤ Metric.coveringNumber r T :=
        Metric.externalCoveringNumber_le_coveringNumber r T
  have hrpos : 0 < r := by
    change (0 : ℝ) < D / 8
    dsimp [D]
    exact div_pos hD (by norm_num)
  have hfin := bounded_coveringNumber_ne_top hTb hrpos.ne'
  have hnat : 2 ≤ (Metric.coveringNumber r T).toNat := by
    exact_mod_cast ENat.toNat_le_toNat hlower hfin
  unfold euclideanSetCoverEntropy
  have hto : (D / 8).toNNReal = r := by
    apply NNReal.eq
    rw [Real.coe_toNNReal (D / 8) (by positivity)]
    rfl
  rw [hto]
  apply Real.sqrt_le_sqrt
  exact Real.log_le_log (by norm_num) (by exact_mod_cast hnat)

/-- One sixteenth of the diameter is bounded by the Euclidean Sudakov functional.

**Lean implementation helper.** -/
lemma diam_div_sixteen_le_sudakovFunctionalENN
    {n : ℕ} {T : Set (EuclideanSpace ℝ (Fin n))}
    (hTne : T.Nonempty) (hTb : Bornology.IsBounded T)
    (hD : 0 < Metric.diam T) :
    ENNReal.ofReal (Metric.diam T / 16) ≤
      euclideanSetSudakovFunctionalENN T := by
  let r : ℝ≥0 := ⟨Metric.diam T / 8, by positivity⟩
  have hent := euclideanSetCoverEntropy_diam_div_eight_lower hTne hTb hD
  have hsqrt : (1 / 2 : ℝ) ≤ Real.sqrt (Real.log 2) := by
    have hlog : (1 / 4 : ℝ) ≤ Real.log 2 :=
      (by norm_num : (1 / 4 : ℝ) < 0.6931471803).le.trans
        Real.log_two_gt_d9.le
    have hs0 := Real.sqrt_nonneg (Real.log 2)
    have hsq := Real.sq_sqrt (Real.log_nonneg (by norm_num : (1 : ℝ) ≤ 2))
    nlinarith
  have hhalf : (1 / 2 : ℝ) ≤
      euclideanSetCoverEntropy T (Metric.diam T / 8) := hsqrt.trans hent
  have hrpos : 0 < (r : ℝ) := by
    change 0 < Metric.diam T / 8
    positivity
  calc
    ENNReal.ofReal (Metric.diam T / 16) =
        (r : ℝ≥0∞) * ENNReal.ofReal (1 / 2 : ℝ) := by
      rw [← ENNReal.ofReal_coe_nnreal,
        ← ENNReal.ofReal_mul (by positivity : (0 : ℝ) ≤ (r : ℝ))]
      congr 1
      change Metric.diam T / 16 =
        (Metric.diam T / 8) * (1 / 2 : ℝ)
      ring_nf
    _ ≤ (r : ℝ≥0∞) *
        ENNReal.ofReal
          (euclideanSetCoverEntropy T (Metric.diam T / 8)) := by
      gcongr
    _ = (r : ℝ≥0∞) * euclideanSetCoverEntropyENN T (r : ℝ) := by
      rw [euclideanSetCoverEntropyENN, if_neg (not_le.mpr hrpos)]
      congr 2
    _ ≤ euclideanSetSudakovFunctionalENN T := by
      unfold euclideanSetSudakovFunctionalENN
      exact le_iSup (fun ε : ℝ≥0 => (ε : ℝ≥0∞) *
        euclideanSetCoverEntropyENN T (ε : ℝ)) r

/-- For positive `A` and `x`, `√(A/x) = √A · x⁻¹ᐟ²`.

**Lean implementation helper.** -/
lemma sqrt_div_eq_sqrt_mul_rpow_neg_half {A x : ℝ}
    (hA : 0 ≤ A) (hx : 0 < x) :
    Real.sqrt (A / x) = Real.sqrt A * x ^ (-(1 / 2 : ℝ)) := by
  rw [Real.sqrt_div hA]
  simp only [Real.sqrt_eq_rpow, div_eq_mul_inv]
  rw [← Real.rpow_neg (le_of_lt hx)]

/-- The low-scale integral of `√(2nD/x)` up to `D/n²` is at most `4D`.

**Lean implementation helper.** -/
lemma integral_sqrt_two_mul_dim_mul_diam_div_le_four_diam
    {n : ℕ} (hn : 2 ≤ n) {D : ℝ} (hD : 0 < D) :
    (∫ x in (0 : ℝ)..D / (n : ℝ) ^ 2,
      Real.sqrt (2 * (n : ℝ) * D / x)) ≤ 4 * D := by
  let A : ℝ := 2 * (n : ℝ) * D
  let a : ℝ := D / (n : ℝ) ^ 2
  have hA : 0 ≤ A := by dsimp [A]; positivity
  have ha : 0 < a := by dsimp [a]; positivity
  have hpowint : IntervalIntegrable
      (fun x : ℝ => x ^ (-(1 / 2 : ℝ))) volume 0 a :=
    intervalIntegral.intervalIntegrable_rpow' (by norm_num)
  have hfun : ∀ᵐ x ∂volume.restrict (Set.Ioc (0 : ℝ) a),
      Real.sqrt (A / x) = Real.sqrt A * x ^ (-(1 / 2 : ℝ)) := by
    filter_upwards [self_mem_ae_restrict measurableSet_Ioc] with x hx
    exact sqrt_div_eq_sqrt_mul_rpow_neg_half hA hx.1
  have hintEq : (∫ x in (0 : ℝ)..a, Real.sqrt (A / x)) =
      Real.sqrt A * ∫ x in (0 : ℝ)..a, x ^ (-(1 / 2 : ℝ)) := by
    rw [intervalIntegral.integral_of_le ha.le]
    rw [integral_congr_ae hfun]
    rw [integral_const_mul]
    rw [← intervalIntegral.integral_of_le ha.le]
  have hrpow : (∫ x in (0 : ℝ)..a, x ^ (-(1 / 2 : ℝ))) =
      2 * Real.sqrt a := by
    rw [integral_rpow (Or.inl (by norm_num : (-1 : ℝ) < -(1 / 2 : ℝ)))]
    rw [Real.zero_rpow (by norm_num : (-(1 / 2 : ℝ) + 1) ≠ 0)]
    rw [show (-(1 / 2 : ℝ) + 1) = 1 / 2 by ring]
    rw [← Real.sqrt_eq_rpow]
    ring
  change (∫ x in (0 : ℝ)..a, Real.sqrt (A / x)) ≤ 4 * D
  rw [hintEq, hrpow]
  have hsA0 := Real.sqrt_nonneg A
  have hsa0 := Real.sqrt_nonneg a
  have hnreal : (2 : ℝ) ≤ n := by exact_mod_cast hn
  have hnpos : (0 : ℝ) < n := by linarith
  have hAa_eq : A * a = 2 * D ^ 2 / (n : ℝ) := by
    dsimp [A, a]
    field_simp
  have hAa : A * a ≤ D ^ 2 := by
    rw [hAa_eq]
    apply (div_le_iff₀ hnpos).2
    have hnonneg := mul_nonneg (sq_nonneg D) (sub_nonneg.mpr hnreal)
    nlinarith
  have hsqrt_mul : Real.sqrt A * Real.sqrt a ≤ D := by
    rw [← Real.sqrt_mul hA]
    calc
      Real.sqrt (A * a) ≤ Real.sqrt (D ^ 2) := Real.sqrt_le_sqrt hAa
      _ = D := by rw [Real.sqrt_sq_eq_abs, abs_of_pos hD]
  nlinarith

/-- For positive `A` and `a`, the function `x ↦ √(A/x)` is integrable on `(0,a]`.

**Lean implementation helper.** -/
lemma integrableOn_sqrt_div
    {A a : ℝ} (hA : 0 ≤ A) (ha : 0 < a) :
    IntegrableOn (fun x : ℝ => Real.sqrt (A / x)) (Set.Ioc 0 a) := by
  have hpowint : IntervalIntegrable
      (fun x : ℝ => x ^ (-(1 / 2 : ℝ))) volume 0 a :=
    intervalIntegral.intervalIntegrable_rpow' (by norm_num)
  have hpOn : IntegrableOn
      (fun x : ℝ => Real.sqrt A * x ^ (-(1 / 2 : ℝ)))
      (Set.Ioc 0 a) :=
    (intervalIntegrable_iff_integrableOn_Ioc_of_le ha.le).1
      (hpowint.const_mul (Real.sqrt A))
  apply hpOn.congr
  filter_upwards [self_mem_ae_restrict measurableSet_Ioc] with x hx
  exact (sqrt_div_eq_sqrt_mul_rpow_neg_half hA hx.1).symm

/-- The low-scale part of the Euclidean entropy integral is at most four times the diameter.

**Lean implementation helper.** -/
lemma low_entropy_lintegral_le_four_diam
    {n : ℕ} [NeZero n] (hn : 2 ≤ n)
    {T : Set (EuclideanSpace ℝ (Fin n))}
    (hTne : T.Nonempty) (hTb : Bornology.IsBounded T)
    (hD : 0 < Metric.diam T) :
    (∫⁻ x in Set.Ioc (0 : ℝ) (Metric.diam T / (n : ℝ) ^ 2),
      euclideanSetCoverEntropyENN T x) ≤
        ENNReal.ofReal (4 * Metric.diam T) := by
  let D : ℝ := Metric.diam T
  let a : ℝ := D / (n : ℝ) ^ 2
  let A : ℝ := 2 * (n : ℝ) * D
  have hA : 0 ≤ A := by dsimp [A, D]; positivity
  have ha : 0 < a := by dsimp [a, D]; positivity
  have hgInt : IntegrableOn (fun x : ℝ => Real.sqrt (A / x))
      (Set.Ioc 0 a) := integrableOn_sqrt_div hA ha
  calc
    (∫⁻ x in Set.Ioc (0 : ℝ) a, euclideanSetCoverEntropyENN T x) ≤
        ∫⁻ x in Set.Ioc (0 : ℝ) a,
          ENNReal.ofReal (Real.sqrt (A / x)) := by
      apply lintegral_mono_ae
      filter_upwards [self_mem_ae_restrict measurableSet_Ioc] with x hx
      rw [euclideanSetCoverEntropyENN, if_neg (not_le.mpr hx.1)]
      apply ENNReal.ofReal_le_ofReal
      simpa [A, D] using
        (euclideanSetCoverEntropy_le_sqrt_div hTne hTb hD hx.1)
    _ = ENNReal.ofReal
        (∫ x in Set.Ioc (0 : ℝ) a, Real.sqrt (A / x)) := by
      symm
      exact MeasureTheory.ofReal_integral_eq_lintegral_ofReal hgInt
        (Eventually.of_forall (fun _ => Real.sqrt_nonneg _))
    _ = ENNReal.ofReal
        (∫ x in (0 : ℝ)..a, Real.sqrt (A / x)) := by
      rw [intervalIntegral.integral_of_le ha.le]
    _ ≤ ENNReal.ofReal (4 * D) := by
      apply ENNReal.ofReal_le_ofReal
      simpa [A, a, D] using
        (integral_sqrt_two_mul_dim_mul_diam_div_le_four_diam hn hD)

/-- At every positive scale `x`, covering entropy is at most the Sudakov functional divided by `x`.

**Lean implementation helper.** -/
lemma euclideanSetCoverEntropyENN_le_sudakov_div
    {n : ℕ} {T : Set (EuclideanSpace ℝ (Fin n))}
    {x : ℝ} (hx : 0 < x) :
    euclideanSetCoverEntropyENN T x ≤
      euclideanSetSudakovFunctionalENN T / ENNReal.ofReal x := by
  let r : ℝ≥0 := x.toNNReal
  have hr : (r : ℝ≥0∞) = ENNReal.ofReal x := by
    simpa [r] using ENNReal.ofNNReal_toNNReal x
  have hterm : (r : ℝ≥0∞) * euclideanSetCoverEntropyENN T (r : ℝ) ≤
      euclideanSetSudakovFunctionalENN T := by
    unfold euclideanSetSudakovFunctionalENN
    exact le_iSup (fun ε : ℝ≥0 => (ε : ℝ≥0∞) *
      euclideanSetCoverEntropyENN T (ε : ℝ)) r
  have hrx : (r : ℝ) = x := by simp [r, hx.le]
  rw [hrx, hr] at hterm
  apply (ENNReal.le_div_iff_mul_le
    (Or.inl (ENNReal.ofReal_ne_zero_iff.mpr hx))
    (Or.inl ENNReal.ofReal_ne_top)).2
  simpa [mul_comm] using hterm

/-- The high-scale entropy integral is at most `2 log n` times the Sudakov functional.

**Lean implementation helper.** -/
lemma high_entropy_lintegral_le_two_log_mul_sudakov
    {n : ℕ} (hn : 2 ≤ n)
    {T : Set (EuclideanSpace ℝ (Fin n))}
    (hD : 0 < Metric.diam T) :
    (∫⁻ x in Set.Ioc (Metric.diam T / (n : ℝ) ^ 2) (Metric.diam T),
      euclideanSetCoverEntropyENN T x) ≤
        ENNReal.ofReal (2 * Real.log n) *
          euclideanSetSudakovFunctionalENN T := by
  let D : ℝ := Metric.diam T
  let a : ℝ := D / (n : ℝ) ^ 2
  have hnreal : (2 : ℝ) ≤ n := by exact_mod_cast hn
  have hnpos : (0 : ℝ) < n := by linarith
  have ha : 0 < a := by dsimp [a, D]; positivity
  have haD : a ≤ D := by
    dsimp [a]
    exact div_le_self (le_of_lt hD)
      (by nlinarith [sq_nonneg ((n : ℝ) - 1)])
  have hinvInt : IntegrableOn (fun x : ℝ => 1 / x) (Set.Ioc a D) := by
    exact (intervalIntegrable_iff_integrableOn_Ioc_of_le haD).1
      (by simpa only [id_eq, one_div] using
        (intervalIntegral.intervalIntegrable_inv
        (fun x hx => by
          rw [uIcc_of_le haD] at hx
          exact (ha.trans_le hx.1).ne')
        continuousOn_id))
  calc
    (∫⁻ x in Set.Ioc a D, euclideanSetCoverEntropyENN T x) ≤
        ∫⁻ x in Set.Ioc a D,
          euclideanSetSudakovFunctionalENN T / ENNReal.ofReal x := by
      apply lintegral_mono_ae
      filter_upwards [self_mem_ae_restrict measurableSet_Ioc] with x hx
      exact euclideanSetCoverEntropyENN_le_sudakov_div (ha.trans hx.1)
    _ = euclideanSetSudakovFunctionalENN T *
        ∫⁻ x in Set.Ioc a D, ENNReal.ofReal (1 / x) := by
      rw [MeasureTheory.lintegral_congr_ae]
      · rw [MeasureTheory.lintegral_const_mul]
        exact (measurable_const.div measurable_id).ennreal_ofReal
      · filter_upwards [self_mem_ae_restrict measurableSet_Ioc] with x hx
        have hxpos : 0 < x := ha.trans hx.1
        rw [div_eq_mul_inv, one_div, ENNReal.ofReal_inv_of_pos hxpos]
    _ = euclideanSetSudakovFunctionalENN T *
        ENNReal.ofReal (∫ x in Set.Ioc a D, 1 / x) := by
      rw [MeasureTheory.ofReal_integral_eq_lintegral_ofReal hinvInt]
      filter_upwards [self_mem_ae_restrict measurableSet_Ioc] with x hx
      exact one_div_nonneg.mpr (ha.trans hx.1).le
    _ = euclideanSetSudakovFunctionalENN T *
        ENNReal.ofReal (Real.log (D / a)) := by
      rw [← intervalIntegral.integral_of_le haD,
        integral_one_div_of_pos ha hD]
    _ = ENNReal.ofReal (2 * Real.log n) *
        euclideanSetSudakovFunctionalENN T := by
      have hratio : D / a = (n : ℝ) ^ 2 := by
        dsimp [a]
        have hDne : D ≠ 0 := by simpa [D] using hD.ne'
        field_simp [hDne]
      rw [hratio, Real.log_pow]
      ring_nf

/-- Combining the low- and high-scale estimates bounds the Dudley functional by `100 log n` times the Sudakov functional.

**Lean implementation helper.** -/
lemma combine_entropy_scale_bounds
    {n : ℕ} (hn : 2 ≤ n)
    {T : Set (EuclideanSpace ℝ (Fin n))}
    (hD : 0 < Metric.diam T)
    (hlow :
      (∫⁻ x in Set.Ioc (0 : ℝ) (Metric.diam T / (n : ℝ) ^ 2),
        euclideanSetCoverEntropyENN T x) ≤
          ENNReal.ofReal (4 * Metric.diam T))
    (hhigh :
      (∫⁻ x in Set.Ioc (Metric.diam T / (n : ℝ) ^ 2) (Metric.diam T),
        euclideanSetCoverEntropyENN T x) ≤
          ENNReal.ofReal (2 * Real.log n) *
            euclideanSetSudakovFunctionalENN T)
    (hdiam : ENNReal.ofReal (Metric.diam T / 16) ≤
      euclideanSetSudakovFunctionalENN T) :
    euclideanSetDudleyFunctionalENN T ≤
      ENNReal.ofReal (100 * Real.log n) *
        euclideanSetSudakovFunctionalENN T := by
  let D : ℝ := Metric.diam T
  let a : ℝ := D / (n : ℝ) ^ 2
  let s := euclideanSetSudakovFunctionalENN T
  have hnreal : (2 : ℝ) ≤ n := by exact_mod_cast hn
  have hnpos : (0 : ℝ) < n := by linarith
  have ha : 0 < a := by dsimp [a, D]; positivity
  have haD : a ≤ D := by
    dsimp [a]
    apply div_le_self (le_of_lt hD)
    nlinarith [sq_nonneg ((n : ℝ) - 1)]
  have hsplit : euclideanSetDudleyFunctionalENN T =
      (∫⁻ x in Set.Ioc (0 : ℝ) a, euclideanSetCoverEntropyENN T x) +
      ∫⁻ x in Set.Ioc a D, euclideanSetCoverEntropyENN T x := by
    unfold euclideanSetDudleyFunctionalENN
    rw [← Set.Ioc_union_Ioc_eq_Ioc ha.le haD,
      MeasureTheory.lintegral_union measurableSet_Ioc
        (Set.Ioc_disjoint_Ioc_of_le le_rfl)]
  have hlow' :
      (∫⁻ x in Set.Ioc (0 : ℝ) a, euclideanSetCoverEntropyENN T x) ≤
        (64 : ℝ≥0∞) * s := by
    calc
      (∫⁻ x in Set.Ioc (0 : ℝ) a, euclideanSetCoverEntropyENN T x) ≤
          ENNReal.ofReal (4 * D) := by simpa [a, D] using hlow
      _ = (64 : ℝ≥0∞) * ENNReal.ofReal (D / 16) := by
        rw [← ENNReal.ofReal_ofNat 64,
          ← ENNReal.ofReal_mul (by positivity : (0 : ℝ) ≤ 64)]
        congr 1
        ring
      _ ≤ (64 : ℝ≥0∞) * s := by gcongr
  have hlog2 : Real.log 2 ≤ Real.log n := by
    exact Real.strictMonoOn_log.monotoneOn
      (Set.mem_Ioi.mpr (by norm_num)) (Set.mem_Ioi.mpr hnpos) hnreal
  have hlogn : 0 ≤ Real.log n :=
    Real.log_nonneg (by linarith)
  have hnum : (64 : ℝ) + 2 * Real.log n ≤ 100 * Real.log n := by
    have hloglower : (69 / 100 : ℝ) < Real.log 2 :=
      (by norm_num : (69 / 100 : ℝ) < 0.6931471803).trans
        Real.log_two_gt_d9
    nlinarith
  rw [hsplit]
  calc
    (∫⁻ x in Set.Ioc (0 : ℝ) a, euclideanSetCoverEntropyENN T x) +
        ∫⁻ x in Set.Ioc a D, euclideanSetCoverEntropyENN T x ≤
      (64 : ℝ≥0∞) * s + ENNReal.ofReal (2 * Real.log n) * s :=
        add_le_add hlow' (by simpa [a, D, s] using hhigh)
    _ = ENNReal.ofReal ((64 : ℝ) + 2 * Real.log n) * s := by
      rw [← add_mul]
      congr 1
      rw [ENNReal.ofReal_add (by norm_num : (0 : ℝ) ≤ 64)
        (mul_nonneg (by norm_num) hlogn), ENNReal.ofReal_ofNat]
    _ ≤ ENNReal.ofReal (100 * Real.log n) * s := by
      gcongr

/-- Exercise 8.5, explicit-constant reverse estimate for the actual metric
entropy integral and Sudakov functional. The endpoint is stated for `n ≥ 2`,
the nondegenerate range in which the printed logarithmic factor is meaningful.

**Book Exercise 8.5.** -/
theorem exercise_8_5_dudleyFunctionalENN_le_log_mul_sudakov
    {n : ℕ} (hn : 2 ≤ n)
    {T : Set (EuclideanSpace ℝ (Fin n))}
    (hTne : T.Nonempty) (hTb : Bornology.IsBounded T) :
    euclideanSetDudleyFunctionalENN T ≤
      ENNReal.ofReal (100 * Real.log n) *
        euclideanSetSudakovFunctionalENN T := by
  letI : NeZero n := ⟨by omega⟩
  by_cases hD0 : Metric.diam T = 0
  · simp [euclideanSetDudleyFunctionalENN, hD0]
  · have hD : 0 < Metric.diam T :=
      lt_of_le_of_ne Metric.diam_nonneg (Ne.symm hD0)
    exact combine_entropy_scale_bounds hn hD
      (low_entropy_lintegral_le_four_diam hn hTne hTb hD)
      (high_entropy_lintegral_le_two_log_mul_sudakov hn hD)
      (diam_div_sixteen_le_sudakovFunctionalENN hTne hTb hD)

/-- Dudley can overestimate width, but by at most a logarithmic factor; a weighted-basis family exhibits divergence of the entropy integral with bounded width. Source-facing absolute-constant comparison for the
actual covering-number entropy functionals.

**Book Remark 8.1.10.** -/
theorem exercise_8_5_actualEntropyFunctionals :
    ∃ C : ℝ, 0 < C ∧
      ∀ n : ℕ, 2 ≤ n →
      ∀ T : Set (EuclideanSpace ℝ (Fin n)),
        T.Nonempty → Bornology.IsBounded T →
        euclideanSetSudakovFunctionalENN T ≤
            euclideanSetDudleyFunctionalENN T ∧
          euclideanSetDudleyFunctionalENN T ≤
            ENNReal.ofReal (C * Real.log n) *
              euclideanSetSudakovFunctionalENN T := by
  refine ⟨100, by norm_num, ?_⟩
  intro n hn T hTne hTb
  exact ⟨euclideanSetSudakovFunctionalENN_le_dudley hTb,
    exercise_8_5_dudleyFunctionalENN_le_log_mul_sudakov hn hTne hTb⟩

/-- Explicit-constant safe real reverse estimate. The
conversion from `ℝ≥0∞` is made only after boundedness proves that both
functionals are finite.

**Book Exercise 8.5.** -/
theorem exercise_8_5_dudleyFunctional_le_log_mul_sudakov
    {n : ℕ} (hn : 2 ≤ n)
    {T : Set (EuclideanSpace ℝ (Fin n))}
    (hTne : T.Nonempty) (hTb : Bornology.IsBounded T) :
    euclideanSetDudleyFunctional T ≤
      100 * Real.log n * euclideanSetSudakovFunctional T := by
  have hsne := euclideanSetSudakovFunctionalENN_ne_top hTne hTb
  have hbound :=
    exercise_8_5_dudleyFunctionalENN_le_log_mul_sudakov hn hTne hTb
  have hcoef : 0 ≤ 100 * Real.log n := by
    have hnreal : (1 : ℝ) ≤ n := by exact_mod_cast (show 1 ≤ n by omega)
    exact mul_nonneg (by norm_num) (Real.log_nonneg hnreal)
  have hrhs : ENNReal.ofReal (100 * Real.log n) *
      euclideanSetSudakovFunctionalENN T ≠ ⊤ :=
    ENNReal.mul_ne_top ENNReal.ofReal_ne_top hsne
  have hreal := ENNReal.toReal_mono hrhs hbound
  rw [ENNReal.toReal_mul, ENNReal.toReal_ofReal hcoef] at hreal
  exact hreal

/-- Source-facing ordinary-real comparison. This is
the displayed `s(T) ≤ d(T) ≤ C log(n) s(T)` statement, with the corrected
nondegenerate range `n ≥ 2`.

**Book Exercise 8.5.** -/
theorem exercise_8_5_actualEntropyFunctionals_real :
    ∃ C : ℝ, 0 < C ∧
      ∀ n : ℕ, 2 ≤ n →
      ∀ T : Set (EuclideanSpace ℝ (Fin n)),
        T.Nonempty → Bornology.IsBounded T →
        euclideanSetSudakovFunctional T ≤
            euclideanSetDudleyFunctional T ∧
          euclideanSetDudleyFunctional T ≤
            C * Real.log n * euclideanSetSudakovFunctional T := by
  refine ⟨100, by norm_num, ?_⟩
  intro n hn T hTne hTb
  have hdne := euclideanSetDudleyFunctionalENN_ne_top hTne hTb
  have hleft := ENNReal.toReal_mono hdne
    (euclideanSetSudakovFunctionalENN_le_dudley hTb)
  exact ⟨hleft,
    exercise_8_5_dudleyFunctional_le_log_mul_sudakov hn hTne hTb⟩

end

end HDP.Chapter8

end Source_02_DudleyInequality

/-! ## Material formerly in `03_EmpiricalProcessesFoundations.lean` -/

section Source_03_EmpiricalProcessesFoundations

/-!
# Book Chapter 8, §8.2: empirical-process foundations

The source writes empirical averages for an arbitrary sample size and silently
divides by that size.  The definitions below are total (`0⁻¹ = 0`), while every
probabilistic statement that uses normalization assumes `0 < n` explicitly.
This foundation layer begins with finite classes, so its suprema and
function-space norms are automatically measurable.  The subsequent empirical-
process block constructs countable finite nets and passes to the genuine
uncountable Lipschitz class with measurability proved.
-/

open Filter MeasureTheory ProbabilityTheory Set
open scoped BigOperators ENNReal NNReal

namespace HDP.Chapter8

noncomputable section

variable {α Ω Ω' : Type*} {mα : MeasurableSpace α}
  {mΩ : MeasurableSpace Ω} {mΩ' : MeasurableSpace Ω'}
  {μ : Measure α} {P : Measure Ω} {Q : Measure Ω'}

/-! ## Monte Carlo averages and empirical measures -/

/-- Monte Carlo integral is approximated by the normalized sample average. Equation (8.19), the normalized average of a finite deterministic sample.
For the empty sample this is zero, by the field convention `0⁻¹ = 0`.

**Book Equation (8.19).** -/
def empiricalAverage {n : ℕ} (sample : Fin n → α) (f : α → ℝ) : ℝ :=
  (n : ℝ)⁻¹ * ∑ i, f (sample i)

/-- The normalized empirical average over an empty sample is zero.

**Lean implementation helper.** -/
@[simp]
theorem empiricalAverage_zero (sample : Fin 0 → α) (f : α → ℝ) :
    empiricalAverage sample f = 0 := by
  simp [empiricalAverage]

/-- The empirical process is the centered normalized sample average indexed by a function class. Equation (8.23), the empirical-process coordinate indexed by `f`.

**Book Definition 8.2.5.** -/
def empiricalProcessValue {n : ℕ} (μ : Measure α)
    (sample : Fin n → α) (f : α → ℝ) : ℝ :=
  empiricalAverage sample f - ∫ x, f x ∂μ

/-- Empirical measure is the normalized sum of sample Dirac masses. Equation (8.26), the normalized empirical measure.

**Book Equation (8.26).** -/
def empiricalMeasure {n : ℕ} (sample : Fin n → α) : Measure α :=
  (n : ℝ≥0∞)⁻¹ • ∑ i, Measure.dirac (sample i)

/-- A nonempty empirical measure is a probability measure.

**Lean implementation helper.** -/
theorem empiricalMeasure_apply_univ {n : ℕ} (hn : 0 < n)
    (sample : Fin n → α) :
    empiricalMeasure (mα := mα) sample Set.univ = 1 := by
  have h0 : (n : ℝ≥0∞) ≠ 0 := by exact_mod_cast hn.ne'
  have htop : (n : ℝ≥0∞) ≠ ∞ := by simp
  simpa [empiricalMeasure, Measure.smul_apply] using
    (ENNReal.inv_mul_cancel h0 htop)

/-- Integration against the empirical measure is the empirical average.
Strong measurability is the exact hypothesis needed for integration against
Dirac measures without imposing measurable singletons on the sample space.

**Lean implementation helper.** -/
theorem integral_empiricalMeasure {n : ℕ} (_hn : 0 < n)
    (sample : Fin n → α) {f : α → ℝ} (hf : StronglyMeasurable f) :
    (∫ x, f x ∂empiricalMeasure (mα := mα) sample) =
      empiricalAverage sample f := by
  rw [empiricalMeasure, integral_smul_measure]
  rw [integral_finsetSum_measure]
  · simp_rw [integral_dirac' f _ hf]
    simp [empiricalAverage]
  · intro i hi
    exact integrable_dirac' hf (by simp)

/-- The empirical process is the difference between integration against the
empirical and population measures.

**Lean implementation helper.** -/
theorem empiricalProcessValue_eq_integral_sub {n : ℕ} (hn : 0 < n)
    (sample : Fin n → α) {f : α → ℝ} (hf : StronglyMeasurable f) :
    empiricalProcessValue μ sample f =
      (∫ x, f x ∂empiricalMeasure (mα := mα) sample) - ∫ x, f x ∂μ := by
  rw [integral_empiricalMeasure hn sample hf]
  rfl

/-- Monte Carlo integral is approximated by the normalized sample average. The random Monte Carlo average associated with a sample family.

**Book Equation (8.19).** -/
def monteCarloAverage {n : ℕ} (X : Fin n → Ω → α)
    (f : α → ℝ) (ω : Ω) : ℝ :=
  empiricalAverage (fun i => X i ω) f

/-- Shows that the Monte Carlo sample average is integrable.

**Lean implementation helper.** -/
theorem integrable_monteCarloAverage {n : ℕ} (X : Fin n → Ω → α)
    (f : α → ℝ) (hX : ∀ i, Integrable (fun ω => f (X i ω)) P) :
    Integrable (monteCarloAverage X f) P := by
  unfold monteCarloAverage empiricalAverage
  exact (integrable_finsetSum Finset.univ fun i _ => hX i).const_mul _

/-- A nonempty Monte Carlo average is unbiased whenever all sample coordinates
have the population integral. Independence is not needed for this
first-moment statement. This is a helper for the Monte Carlo discussion; the
actual almost-sure statement in equation (8.18) is
`equation_8_18_monteCarlo_strong_law` below.

**Book Equation (8.18).** -/
theorem monteCarlo_unbiased {n : ℕ} (hn : 0 < n)
    (X : Fin n → Ω → α) (f : α → ℝ)
    (hX : ∀ i, Integrable (fun ω => f (X i ω)) P)
    (hlaw : ∀ i, ∫ ω, f (X i ω) ∂P = ∫ x, f x ∂μ) :
    ∫ ω, monteCarloAverage X f ω ∂P = ∫ x, f x ∂μ := by
  rw [show monteCarloAverage X f =
      fun ω => (n : ℝ)⁻¹ * ∑ i, f (X i ω) by rfl]
  rw [integral_const_mul]
  rw [integral_finsetSum Finset.univ (fun i _ => hX i)]
  simp_rw [hlaw]
  simp [hn.ne']

/-- The empirical-process coordinate has mean zero under the hypotheses of
`monteCarlo_unbiased`.

**Lean implementation helper.** -/
theorem integral_empiricalProcessValue_eq_zero {n : ℕ}
    [IsProbabilityMeasure P] (hn : 0 < n)
    (X : Fin n → Ω → α) (f : α → ℝ)
    (hX : ∀ i, Integrable (fun ω => f (X i ω)) P)
    (_hf : Integrable f μ)
    (hlaw : ∀ i, ∫ ω, f (X i ω) ∂P = ∫ x, f x ∂μ) :
    ∫ ω, empiricalProcessValue μ (fun i => X i ω) f ∂P = 0 := by
  have hmc := integrable_monteCarloAverage X f hX
  rw [show (fun ω => empiricalProcessValue μ (fun i => X i ω) f) =
      fun ω => monteCarloAverage X f ω - ∫ x, f x ∂μ by rfl]
  rw [integral_sub hmc (integrable_const _), integral_const,
    monteCarlo_unbiased hn X f hX hlaw]
  simp

/-- Monte Carlo sample averages converge almost surely.

**Book Equation (8.18).** -/
theorem equation_8_18_monteCarlo_strong_law
    [IsProbabilityMeasure P] [IsProbabilityMeasure Q]
    (X : Ω' → α) (sample : ℕ → Ω → α) (f : α → ℝ)
    (hf : Measurable f) (hint : Integrable (f ∘ X) Q)
    (hindep : iIndepFun sample P)
    (hlaw : ∀ i, IdentDistrib (sample i) X P Q) :
    ∀ᵐ ω ∂P,
      Tendsto
        (fun n : ℕ => empiricalAverage (fun i : Fin n => sample i ω) f)
        atTop (nhds (∫ x, f (X x) ∂Q)) := by
  let Y : ℕ → Ω → ℝ := fun i => f ∘ sample i
  have hYint : Integrable (Y 0) P := by
    exact ((hlaw 0).comp hf).integrable_iff.mpr hint
  have hYindep : iIndepFun Y P := by
    simpa [Y] using hindep.comp (fun _ => f) (fun _ => hf)
  have hYident : ∀ i, IdentDistrib (Y i) (Y 0) P P := by
    intro i
    exact ((hlaw i).comp hf).trans ((hlaw 0).comp hf).symm
  have hYmean : (∫ ω, Y 0 ω ∂P) = ∫ x, f (X x) ∂Q := by
    exact ((hlaw 0).comp hf).integral_eq
  have hstrong := HDP.Chapter1.strong_law_of_large_numbers
    (X := Y) hYint hYindep hYident hYmean
  filter_upwards [hstrong] with ω hω
  have havg :
      (fun n : ℕ => empiricalAverage (fun i : Fin n => sample i ω) f) =
        fun n : ℕ => (∑ i ∈ Finset.range n, Y i ω) / n := by
    funext n
    rw [empiricalAverage]
    have hsum := Fin.sum_univ_eq_sum_range
      (fun i : ℕ => f (sample i ω)) n
    rw [hsum]
    simp only [Y, Function.comp_apply, div_eq_inv_mul]
  rw [havg]
  exact hω

/-! ## Remarks 8.2.1--8.2.2: scalar Monte Carlo error -/

/-- The `L¹` fluctuation about the mean is at most the standard deviation.
This is the Cauchy--Schwarz step used in Remark 8.2.1.

**Book Remark 8.2.1.** -/
theorem expected_abs_sub_mean_le_sqrt_variance [IsProbabilityMeasure P]
    {Z : Ω → ℝ} (hZ : MemLp Z 2 P) :
    (∫ ω, |Z ω - ∫ u, Z u ∂P| ∂P) ≤ Real.sqrt (Var[Z; P]) := by
  let W : Ω → ℝ := fun ω => Z ω - ∫ u, Z u ∂P
  have hW : MemLp W 2 P := hZ.sub (memLp_const _)
  have hWabs : MemLp (fun ω => |W ω|) (ENNReal.ofReal (2 : ℝ)) P := by
    simpa [W, Real.norm_eq_abs] using hW.norm
  have hOne : MemLp (fun _ : Ω => (1 : ℝ)) (ENNReal.ofReal (2 : ℝ)) P := by
    simpa using (memLp_const (p := ENNReal.ofReal (2 : ℝ)) (1 : ℝ))
  have h := MeasureTheory.integral_mul_le_Lp_mul_Lq_of_nonneg
    (μ := P) Real.HolderConjugate.two_two
    (f := fun ω => |W ω|) (g := fun _ => (1 : ℝ))
    (Filter.Eventually.of_forall fun _ => abs_nonneg _)
    (Filter.Eventually.of_forall fun _ => by norm_num)
    hWabs hOne
  simp only [Real.rpow_two] at h
  rw [variance_eq_integral hZ.aemeasurable]
  simpa [W, Real.sqrt_eq_rpow] using h

/-- Monte Carlo sample-mean expected absolute error is at most standard deviation divided by `sqrt n`. For pairwise independent
square-integrable observations with common mean `m` and variance `σ²`, the
expected absolute error of their sample mean is at most `sqrt (σ² / n)`.
The constant is exactly one.

**Book Remark 8.2.1.** -/
theorem theorem_8_2_1_monteCarlo_expected_error [IsProbabilityMeasure P]
    {n : ℕ} (hn : 0 < n) {Y : Fin n → Ω → ℝ} {m σsq : ℝ}
    (hY : ∀ i, MemLp (Y i) 2 P)
    (hmean : ∀ i, ∫ ω, Y i ω ∂P = m)
    (hvar : ∀ i, Var[Y i; P] = σsq)
    (hindep : Set.Pairwise Set.univ fun i j => IndepFun (Y i) (Y j) P) :
    (∫ ω, |(∑ i, Y i ω) / (n : ℝ) - m| ∂P) ≤
      Real.sqrt (σsq / n) := by
  let Z : Ω → ℝ := fun ω => (∑ i, Y i ω) / (n : ℝ)
  have hZ : MemLp Z 2 P := by
    have hsum : MemLp (fun ω => ∑ i, Y i ω) 2 P := by
      exact memLp_finsetSum Finset.univ fun i _ => hY i
    simpa [Z, div_eq_inv_mul] using hsum.const_mul ((n : ℝ)⁻¹)
  have hZmean : ∫ ω, Z ω ∂P = m := by
    rw [show Z = fun ω => (n : ℝ)⁻¹ * ∑ i, Y i ω by
      funext ω; simp [Z, div_eq_inv_mul]]
    rw [integral_const_mul, integral_finsetSum Finset.univ
      (fun i _ => (hY i).integrable one_le_two)]
    simp_rw [hmean]
    simp [hn.ne']
  calc
    (∫ ω, |(∑ i, Y i ω) / (n : ℝ) - m| ∂P) =
        ∫ ω, |Z ω - ∫ u, Z u ∂P| ∂P := by rw [hZmean]
    _ ≤ Real.sqrt (Var[Z; P]) := expected_abs_sub_mean_le_sqrt_variance hZ
    _ = Real.sqrt (σsq / n) := by
      congr 1
      simpa [Z] using HDP.Chapter1.variance_sample_mean hn σsq hY hvar hindep

/-- The Monte Carlo rate is dimension-free. The preceding estimate
depends only on the scalar variance and sample size. The observation space
`α` is arbitrary; in particular, no ambient dimension occurs in the bound.

**Book Remark 8.2.2.** -/
theorem remark_8_2_2_dimension_free_monteCarlo [IsProbabilityMeasure P]
    {n : ℕ} (hn : 0 < n) (X : Fin n → Ω → α) (f : α → ℝ)
    {m σsq : ℝ} (hX : ∀ i, MemLp (fun ω => f (X i ω)) 2 P)
    (hmean : ∀ i, ∫ ω, f (X i ω) ∂P = m)
    (hvar : ∀ i, Var[fun ω => f (X i ω); P] = σsq)
    (hindep : Set.Pairwise Set.univ fun i j =>
      IndepFun (fun ω => f (X i ω)) (fun ω => f (X j ω)) P) :
    (∫ ω, |monteCarloAverage X f ω - m| ∂P) ≤
      Real.sqrt (σsq / n) := by
  simpa [monteCarloAverage, empiricalAverage, div_eq_inv_mul] using
    theorem_8_2_1_monteCarlo_expected_error hn hX hmean hvar hindep

/-! ## Finite empirical processes -/

/-- The empirical process is the centered normalized sample average indexed by a function class. The empirical process simultaneously indexed by a finite function class.
The subtype `↥F` is a finite index type, so its supremum/norm is measurable
whenever the individual coordinates are measurable.

**Book Definition 8.2.5.** -/
def finiteEmpiricalProcess {n : ℕ} (F : Finset (α → ℝ))
    (μ : Measure α) (sample : Fin n → α) : ↥F → ℝ :=
  fun f => empiricalProcessValue μ sample f.1

/-- Evaluation of all functions in a finite class at one point.

**Lean implementation helper.** -/
def finiteClassEvaluation (F : Finset (α → ℝ)) (x : α) : ↥F → ℝ :=
  fun f => f.1 x

/-- The empirical process vector is the normalized sum of centered evaluation
vectors.

**Lean implementation helper.** -/
theorem finiteEmpiricalProcess_eq_centered_sum {n : ℕ} (hn : 0 < n)
    (F : Finset (α → ℝ)) (sample : Fin n → α) :
    finiteEmpiricalProcess F μ sample =
      (n : ℝ)⁻¹ • ∑ i,
        (finiteClassEvaluation F (sample i) -
          fun f => ∫ x, f.1 x ∂μ) := by
  funext f
  simp only [finiteEmpiricalProcess, empiricalProcessValue,
    empiricalAverage, finiteClassEvaluation, Pi.smul_apply, Pi.sub_apply,
    Finset.sum_apply, smul_eq_mul]
  rw [Finset.sum_sub_distrib]
  simp only [Finset.sum_const, Finset.card_univ, Fintype.card_fin,
    nsmul_eq_mul]
  have hn0 : (n : ℝ) ≠ 0 := by exact_mod_cast hn.ne'
  field_simp [hn0]

/-! ## Theorem 8.2.3: a finite, measurable Lipschitz uniform LLN -/

/-- A telescoping sum stopped at `x`. This elementary identity is the
summation-by-parts core of the one-dimensional Lipschitz estimate.

**Lean implementation helper.** -/
lemma sum_range_increment_indicator (g : ℕ → ℝ) :
    ∀ m x : ℕ, x ≤ m →
      (∑ k ∈ Finset.range m,
        (g (k + 1) - g k) * if k < x then 1 else 0) = g x - g 0 := by
  intro m
  induction m with
  | zero =>
      intro x hx
      have hx0 : x = 0 := Nat.eq_zero_of_le_zero hx
      subst x
      simp
  | succ m ih =>
      intro x hx
      rw [Finset.sum_range_succ]
      by_cases hxm : x ≤ m
      · rw [if_neg (Nat.not_lt_of_ge hxm), mul_zero, add_zero]
        exact ih x hxm
      · have hxeq : x = m + 1 := by omega
        subst x
        have hhead :
            (∑ k ∈ Finset.range m,
              (g (k + 1) - g k) * if k < m + 1 then 1 else 0) =
              ∑ k ∈ Finset.range m, (g (k + 1) - g k) := by
          apply Finset.sum_congr rfl
          intro k hk
          rw [if_pos (Nat.lt_trans (Finset.mem_range.mp hk) (Nat.lt_succ_self m)),
            mul_one]
        rw [if_pos (Nat.lt_succ_self m), mul_one, hhead,
          Finset.sum_range_sub]
        ring

/-- The upper-tail indicator associated with the edge `k → k+1` of a finite
ordered grid.

**Lean implementation helper.** -/
def chainUpperIndicator {m : ℕ} (k : Fin m) (x : Fin (m + 1)) : ℝ :=
  if k.val < x.val then 1 else 0

/-- The increment of a function across one edge of a finite ordered grid.

**Lean implementation helper.** -/
def chainIncrement {m : ℕ} (f : Fin (m + 1) → ℝ) (k : Fin m) : ℝ :=
  f k.succ - f k.castSucc

/-- Every function on a finite chain is its value at zero plus the sum of its
increments against upper-tail indicators.

**Lean implementation helper.** -/
lemma chain_telescope {m : ℕ} (f : Fin (m + 1) → ℝ) (x : Fin (m + 1)) :
    (∑ k, chainIncrement f k * chainUpperIndicator k x) = f x - f 0 := by
  let g : ℕ → ℝ := fun j => if hj : j < m + 1 then f ⟨j, hj⟩ else 0
  have h := sum_range_increment_indicator g m x.val (Nat.le_of_lt_succ x.isLt)
  calc
    (∑ k, chainIncrement f k * chainUpperIndicator k x) =
        ∑ k : Fin m,
          (g (k.val + 1) - g k.val) * if k.val < x.val then 1 else 0 := by
      apply Finset.sum_congr rfl
      intro k _
      by_cases hkx : k.val < x.val
      · simp only [chainIncrement, chainUpperIndicator, if_pos hkx, mul_one]
        have hgSucc : g (k.val + 1) = f k.succ := by
          simp only [g, dif_pos (Nat.succ_lt_succ k.isLt)]
          exact congrArg f (Fin.ext rfl)
        have hgCast : g k.val = f k.castSucc := by
          simp only [g, dif_pos (Nat.lt_trans k.isLt (Nat.lt_succ_self m))]
          exact congrArg f (Fin.ext rfl)
        rw [hgSucc, hgCast]
      · simp [chainUpperIndicator, hkx]
    _ = ∑ k ∈ Finset.range m,
          (g (k + 1) - g k) * if k < x.val then 1 else 0 :=
      Fin.sum_univ_eq_sum_range
        (fun k => (g (k + 1) - g k) * if k < x.val then 1 else 0) m
    _ = g x.val - g 0 := h
    _ = f x - f 0 := by
      have hgx : g x.val = f x := by
        simp only [g, dif_pos x.isLt]
      have hg0 : g 0 = f 0 := by
        simp only [g, dif_pos (Nat.zero_lt_succ m)]
        exact congrArg f (Fin.ext rfl)
      rw [hgx, hg0]

/-- Shows that the upper-tail indicator used in the chaining integral is integrable.

**Lean implementation helper.** -/
lemma chainUpperIndicator_integrable {m : ℕ}
    {ν : Measure (Fin (m + 1))} [IsFiniteMeasure ν]
    (k : Fin m) : Integrable (chainUpperIndicator k) ν := by
  refine Integrable.of_bound (measurable_of_finite _).aestronglyMeasurable 1 ?_
  exact Filter.Eventually.of_forall fun x => by
    simp only [Real.norm_eq_abs, chainUpperIndicator]
    split_ifs <;> norm_num

/-- A constant function has zero centered empirical-process value.

**Lean implementation helper.** -/
lemma empiricalProcessValue_const {β : Type*} {mβ : MeasurableSpace β}
    {ν : Measure β} [IsProbabilityMeasure ν] {n : ℕ} (hn : 0 < n)
    (sample : Fin n → β) (c : ℝ) :
    empiricalProcessValue ν sample (fun _ => c) = 0 := by
  simp [empiricalProcessValue, empiricalAverage, hn.ne']

/-- The empirical-process value of a finite weighted sum is the corresponding weighted sum of empirical-process values.

**Lean implementation helper.** -/
lemma empiricalProcessValue_weighted_sum {β : Type*} {mβ : MeasurableSpace β}
    {ν : Measure β} {n q : ℕ} (sample : Fin n → β)
    (c : Fin q → ℝ) (g : Fin q → β → ℝ)
    (hg : ∀ k, Integrable (g k) ν) :
    empiricalProcessValue ν sample (fun x => ∑ k, c k * g k x) =
      ∑ k, c k * empiricalProcessValue ν sample (g k) := by
  unfold empiricalProcessValue empiricalAverage
  rw [integral_finsetSum Finset.univ (fun k _ => (hg k).const_mul (c k))]
  simp_rw [integral_const_mul]
  rw [Finset.sum_comm]
  simp_rw [← Finset.mul_sum]
  rw [Finset.mul_sum]
  simp_rw [mul_sub]
  rw [Finset.sum_sub_distrib]
  congr 1
  apply Finset.sum_congr rfl
  intro k _
  ring

/-- The empirical-process value is additive on integrable functions.

**Lean implementation helper.** -/
lemma empiricalProcessValue_add {β : Type*} {mβ : MeasurableSpace β}
    {ν : Measure β} {n : ℕ} (sample : Fin n → β)
    {f g : β → ℝ} (hf : Integrable f ν) (hg : Integrable g ν) :
    empiricalProcessValue ν sample (fun x => f x + g x) =
      empiricalProcessValue ν sample f + empiricalProcessValue ν sample g := by
  unfold empiricalProcessValue empiricalAverage
  rw [Finset.sum_add_distrib, integral_add hf hg]
  ring

/-- The empirical process of a function on a finite chain is the weighted sum
of the empirical processes of the chain's upper-tail indicators.

**Lean implementation helper.** -/
lemma empiricalProcessValue_chain_decomposition {m n : ℕ}
    {ν : Measure (Fin (m + 1))} [IsProbabilityMeasure ν] (hn : 0 < n)
    (sample : Fin n → Fin (m + 1)) (f : Fin (m + 1) → ℝ) :
    empiricalProcessValue ν sample f =
      ∑ k, chainIncrement f k *
        empiricalProcessValue ν sample (chainUpperIndicator k) := by
  have hf : f = fun x => f 0 + ∑ k, chainIncrement f k * chainUpperIndicator k x := by
    funext x
    linarith [chain_telescope f x]
  let G : Fin (m + 1) → ℝ := fun x =>
    ∑ k, chainIncrement f k * chainUpperIndicator k x
  have hGint : Integrable G ν :=
    integrable_finsetSum Finset.univ fun k _ =>
      (chainUpperIndicator_integrable k).const_mul (chainIncrement f k)
  calc
    empiricalProcessValue ν sample f =
        empiricalProcessValue ν sample (fun x => f 0 + G x) := by
      simpa only [G] using
        congrArg (fun g => empiricalProcessValue ν sample g) hf
    _ = empiricalProcessValue ν sample (fun _ => f 0) +
        empiricalProcessValue ν sample G :=
      empiricalProcessValue_add sample (integrable_const _) hGint
    _ = empiricalProcessValue ν sample G := by
      rw [empiricalProcessValue_const hn sample (f 0), zero_add]
    _ = ∑ k, chainIncrement f k *
        empiricalProcessValue ν sample (chainUpperIndicator k) := by
      exact empiricalProcessValue_weighted_sum sample
        (fun k => chainIncrement f k) chainUpperIndicator
        (fun k => chainUpperIndicator_integrable k)

/-- Each upper-tail empirical-process coordinate has expected absolute value
at most `1 / sqrt n`. Its Bernoulli variance is computed inside the proof;
no deviation or entropy bound is assumed.

**Lean implementation helper.** -/
lemma expected_abs_chain_indicator_process_le {m n : ℕ}
    {ν : Measure (Fin (m + 1))} [IsProbabilityMeasure P]
    [IsProbabilityMeasure ν] (hn : 0 < n)
    (X : Fin n → Ω → Fin (m + 1))
    (hLaw : ∀ i, IdentDistrib (X i) (id : Fin (m + 1) → Fin (m + 1)) P ν)
    (hindep : Set.Pairwise Set.univ fun i j => IndepFun (X i) (X j) P)
    (k : Fin m) :
    (∫ ω, |empiricalProcessValue ν (fun i => X i ω)
        (chainUpperIndicator k)| ∂P) ≤ 1 / Real.sqrt n := by
  let h : Fin (m + 1) → ℝ := chainUpperIndicator k
  let Y : Fin n → Ω → ℝ := fun i ω => h (X i ω)
  let q : ℝ := ∫ x, h x ∂ν
  have hhMeas : Measurable h := measurable_of_finite _
  have hhMem : MemLp h 2 ν := by
    refine MemLp.of_bound hhMeas.aestronglyMeasurable 1 ?_
    exact Filter.Eventually.of_forall fun x => by
      simp only [h, Real.norm_eq_abs, chainUpperIndicator]
      split_ifs <;> norm_num
  have hYLaw (i : Fin n) : IdentDistrib (Y i) h P ν := by
    simpa [Y, h, Function.comp_def] using (hLaw i).comp hhMeas
  have hYMem : ∀ i, MemLp (Y i) 2 P := fun i =>
    (hYLaw i).memLp_iff.mpr hhMem
  have hYmean : ∀ i, ∫ ω, Y i ω ∂P = q := fun i => by
    simpa [q] using (hYLaw i).integral_eq
  have hsq : (fun x => h x ^ 2) = h := by
    funext x
    simp only [h, chainUpperIndicator]
    split_ifs <;> norm_num
  have hhvar : Var[h; ν] = q - q ^ 2 := by
    rw [variance_eq_sub hhMem]
    change (∫ x, h x ^ 2 ∂ν) - (∫ x, h x ∂ν) ^ 2 = q - q ^ 2
    rw [hsq]
  have hYvar : ∀ i, Var[Y i; P] = q - q ^ 2 := fun i => by
    rw [(hYLaw i).variance_eq, hhvar]
  have hYindep : Set.Pairwise Set.univ fun i j => IndepFun (Y i) (Y j) P := by
    intro i _hi j _hj hij
    simpa [Y, Function.comp_def] using
      (hindep (Set.mem_univ i) (Set.mem_univ j) hij).comp hhMeas hhMeas
  have hmc := theorem_8_2_1_monteCarlo_expected_error
    hn hYMem hYmean hYvar hYindep
  have hvarle : q - q ^ 2 ≤ 1 := by
    nlinarith [sq_nonneg (q - (1 / 2 : ℝ))]
  calc
    (∫ ω, |empiricalProcessValue ν (fun i => X i ω)
        (chainUpperIndicator k)| ∂P) =
        ∫ ω, |(∑ i, Y i ω) / (n : ℝ) - q| ∂P := by
      apply integral_congr_ae
      exact Filter.Eventually.of_forall fun ω => by
        simp only [empiricalProcessValue, empiricalAverage, Y, h, q]
        congr 2
        rw [div_eq_inv_mul]
    _ ≤ Real.sqrt ((q - q ^ 2) / n) := hmc
    _ ≤ Real.sqrt (1 / n) := by
      gcongr
    _ = 1 / Real.sqrt n := by
      rw [Real.sqrt_div (by norm_num : (0 : ℝ) ≤ 1), Real.sqrt_one]

/-- The sum of successive chain increments telescopes to the terminal value minus the initial value.

**Lean implementation helper.** -/
lemma sum_chainIncrement {m : ℕ} (z : Fin (m + 1) → ℝ) :
    (∑ k, chainIncrement z k) = z (Fin.last m) - z 0 := by
  have h := chain_telescope z (Fin.last m)
  simpa [chainUpperIndicator] using h

/-- The finite, hence measurable, empirical process obtained by evaluating a
finite class of real functions on an ordered grid.

**Lean implementation helper.** -/
def finiteGridEmpiricalProcess {m n : ℕ} (F : Finset (ℝ → ℝ))
    (grid : Fin (m + 1) → ℝ) (ν : Measure (Fin (m + 1)))
    (sample : Fin n → Fin (m + 1)) : ↥F → ℝ :=
  fun f => empiricalProcessValue ν sample (fun j => f.1 (grid j))

/-- Shows that the norm finite grid empirical process is integrable.

**Lean implementation helper.** -/
lemma integrable_norm_finiteGridEmpiricalProcess {m n : ℕ}
    {ν : Measure (Fin (m + 1))} [IsProbabilityMeasure P] [IsFiniteMeasure ν]
    (F : Finset (ℝ → ℝ)) (grid : Fin (m + 1) → ℝ)
    (X : Fin n → Ω → Fin (m + 1)) (hXm : ∀ i, Measurable (X i)) :
    Integrable (fun ω =>
      ‖finiteGridEmpiricalProcess F grid ν (fun i => X i ω)‖) P := by
  have hcoordMeas (f : ↥F) : Measurable (fun ω =>
      finiteGridEmpiricalProcess F grid ν (fun i => X i ω) f) := by
    unfold finiteGridEmpiricalProcess empiricalProcessValue empiricalAverage
    apply Measurable.sub_const
    apply Measurable.const_mul
    apply Finset.measurable_sum
    intro i _
    exact (measurable_of_finite (fun j => f.1 (grid j))).comp (hXm i)
  have hcoordInt (f : ↥F) : Integrable (fun ω =>
      finiteGridEmpiricalProcess F grid ν (fun i => X i ω) f) P := by
    let g : Fin (m + 1) → ℝ := fun j => f.1 (grid j)
    have hgi : ∀ i, Integrable (fun ω => g (X i ω)) P := fun i => by
      refine Integrable.of_bound
        ((measurable_of_finite g).comp (hXm i)).aestronglyMeasurable ‖g‖ ?_
      exact Filter.Eventually.of_forall fun ω => norm_le_pi_norm g (X i ω)
    have havg := integrable_monteCarloAverage X g hgi
    have hproc := havg.sub (integrable_const (∫ x, g x ∂ν))
    change Integrable (fun ω =>
      monteCarloAverage X g ω - ∫ x, g x ∂ν) P
    have heq : (fun ω => monteCarloAverage X g ω - ∫ x, g x ∂ν) =
        monteCarloAverage X g - fun _ => ∫ x, g x ∂ν := by
      funext ω
      rfl
    rw [heq]
    exact hproc
  have hvecMeas : Measurable (fun ω =>
      finiteGridEmpiricalProcess F grid ν (fun i => X i ω)) := by
    apply measurable_pi_lambda
    exact hcoordMeas
  have hsumInt : Integrable (fun ω => ∑ f : ↥F,
      |finiteGridEmpiricalProcess F grid ν (fun i => X i ω) f|) P :=
    integrable_finsetSum Finset.univ fun f _ => (hcoordInt f).abs
  apply Integrable.mono' hsumInt hvecMeas.norm.aestronglyMeasurable
  exact Filter.Eventually.of_forall fun ω => by
    rw [Real.norm_of_nonneg (norm_nonneg _)]
    apply (pi_norm_le_iff_of_nonneg
      (Finset.sum_nonneg fun f _ => abs_nonneg _)).2
    intro f
    simpa [Real.norm_eq_abs] using Finset.single_le_sum
      (fun g (_hg : g ∈ Finset.univ) => abs_nonneg
        (finiteGridEmpiricalProcess F grid ν (fun i => X i ω) g))
      (Finset.mem_univ f)

/-- Let `grid` be any ordered finite subset of `[0,1]`, let `ν` be any probability
law on that grid, and let `X₁, …, Xₙ` be pairwise independent samples with law
`ν`. For every finite class `F` of globally `L`-Lipschitz real functions, `E ‖(f ↦ n⁻¹∑ᵢ f(grid(Xᵢ)) - Eν f(grid))_{f∈F}‖∞ ≤ L / √n`. Thus the universal constant is explicitly `1`. Finiteness of `F` makes the
supremum measurable. Crucially, the assumptions contain only iid sampling and
Lipschitz regularity; no entropy integral or desired supremum bound is assumed.

**Book Theorem 8.2.3.** -/
theorem theorem_8_2_3_lipschitz_uniform_lln_finite_grid {m n : ℕ}
    {ν : Measure (Fin (m + 1))} [IsProbabilityMeasure P]
    [IsProbabilityMeasure ν] (hn : 0 < n)
    (grid : Fin (m + 1) → ℝ) (hgrid : Monotone grid)
    (hgrid0 : 0 ≤ grid 0) (hgrid1 : grid (Fin.last m) ≤ 1)
    (F : Finset (ℝ → ℝ)) (L : ℝ≥0)
    (hLip : ∀ f ∈ F, LipschitzWith L f)
    (X : Fin n → Ω → Fin (m + 1)) (hXm : ∀ i, Measurable (X i))
    (hLaw : ∀ i, IdentDistrib (X i) (id : Fin (m + 1) → Fin (m + 1)) P ν)
    (hindep : Set.Pairwise Set.univ fun i j => IndepFun (X i) (X j) P) :
    (∫ ω, ‖finiteGridEmpiricalProcess F grid ν (fun i => X i ω)‖ ∂P) ≤
      (L : ℝ) / Real.sqrt n := by
  let E : Fin m → Ω → ℝ := fun k ω =>
    empiricalProcessValue ν (fun i => X i ω) (chainUpperIndicator k)
  let gap : Fin m → ℝ := fun k => grid k.succ - grid k.castSucc
  let D : Ω → ℝ := fun ω => ∑ k, gap k * |E k ω|
  have hgap (k : Fin m) : 0 ≤ gap k := by
    exact sub_nonneg.mpr (hgrid (Fin.castSucc_le_succ k))
  have hsumGap : ∑ k, gap k = grid (Fin.last m) - grid 0 := by
    simpa [gap, chainIncrement] using sum_chainIncrement grid
  have hsumGapLe : ∑ k, gap k ≤ 1 := by
    rw [hsumGap]
    linarith
  have hEmeas (k : Fin m) : Measurable (E k) := by
    unfold E empiricalProcessValue empiricalAverage
    apply Measurable.sub_const
    apply Measurable.const_mul
    apply Finset.measurable_sum
    intro i _
    exact (measurable_of_finite (chainUpperIndicator k)).comp (hXm i)
  have hEint (k : Fin m) : Integrable (E k) P := by
    let h : Fin (m + 1) → ℝ := chainUpperIndicator k
    have hhMeas : Measurable h := measurable_of_finite _
    have hhInt : Integrable h ν := chainUpperIndicator_integrable k
    have hYi : ∀ i, Integrable (fun ω => h (X i ω)) P := fun i => by
      have hid : IdentDistrib (fun ω => h (X i ω)) h P ν := by
        simpa [Function.comp_def] using (hLaw i).comp hhMeas
      exact hid.integrable_iff.mpr hhInt
    have havg := integrable_monteCarloAverage X h hYi
    have hproc := havg.sub (integrable_const (∫ x, h x ∂ν))
    change Integrable (fun ω => monteCarloAverage X h ω - ∫ x, h x ∂ν) P
    have heq : (fun ω => monteCarloAverage X h ω - ∫ x, h x ∂ν) =
        monteCarloAverage X h - fun _ => ∫ x, h x ∂ν := by
      funext ω
      rfl
    rw [heq]
    exact hproc
  have hDint : Integrable D P := by
    exact integrable_finsetSum Finset.univ fun k _ =>
      (hEint k).abs.const_mul (gap k)
  have hDnonneg (ω : Ω) : 0 ≤ D ω := by
    exact Finset.sum_nonneg fun k _ => mul_nonneg (hgap k) (abs_nonneg _)
  have hprocMeas : Measurable (fun ω =>
      finiteGridEmpiricalProcess F grid ν (fun i => X i ω)) := by
    apply measurable_pi_lambda
    intro f
    unfold finiteGridEmpiricalProcess empiricalProcessValue empiricalAverage
    apply Measurable.sub_const
    apply Measurable.const_mul
    apply Finset.measurable_sum
    intro i _
    exact (measurable_of_finite (fun j => f.1 (grid j))).comp (hXm i)
  have hpoint (ω : Ω) :
      ‖finiteGridEmpiricalProcess F grid ν (fun i => X i ω)‖ ≤
        (L : ℝ) * D ω := by
    apply (pi_norm_le_iff_of_nonneg (mul_nonneg L.coe_nonneg (hDnonneg ω))).2
    intro f
    let g : Fin (m + 1) → ℝ := fun j => f.1 (grid j)
    have hdecomp := empiricalProcessValue_chain_decomposition (ν := ν) hn
      (fun i => X i ω) g
    have hinc (k : Fin m) : |chainIncrement g k| ≤ (L : ℝ) * gap k := by
      have hdist := (hLip f.1 f.2).dist_le_mul (grid k.succ) (grid k.castSucc)
      simpa [g, gap, chainIncrement, Real.dist_eq,
        abs_of_nonneg (hgap k)] using hdist
    change |empiricalProcessValue ν (fun i => X i ω) g| ≤ (L : ℝ) * D ω
    calc
      |empiricalProcessValue ν (fun i => X i ω) g| =
          |∑ k, chainIncrement g k * E k ω| := by rw [hdecomp]
      _ ≤ ∑ k, |chainIncrement g k * E k ω| :=
        Finset.abs_sum_le_sum_abs _ _
      _ = ∑ k, |chainIncrement g k| * |E k ω| := by
        apply Finset.sum_congr rfl
        intro k _
        rw [abs_mul]
      _ ≤ ∑ k, ((L : ℝ) * gap k) * |E k ω| := by
        apply Finset.sum_le_sum
        intro k _
        exact mul_le_mul_of_nonneg_right (hinc k) (abs_nonneg _)
      _ = (L : ℝ) * D ω := by
        rw [Finset.mul_sum]
        apply Finset.sum_congr rfl
        intro k _
        ring
  have hprocInt : Integrable (fun ω =>
      ‖finiteGridEmpiricalProcess F grid ν (fun i => X i ω)‖) P := by
    apply Integrable.mono' (hDint.const_mul (L : ℝ))
    · exact hprocMeas.norm.aestronglyMeasurable
    · exact Filter.Eventually.of_forall fun ω => by
        rw [Real.norm_of_nonneg (norm_nonneg _)]
        exact hpoint ω
  have hLDint : Integrable (fun ω => (L : ℝ) * D ω) P :=
    hDint.const_mul (L : ℝ)
  calc
    (∫ ω, ‖finiteGridEmpiricalProcess F grid ν (fun i => X i ω)‖ ∂P)
        ≤ ∫ ω, (L : ℝ) * D ω ∂P :=
      integral_mono hprocInt hLDint hpoint
    _ = (L : ℝ) * ∫ ω, D ω ∂P := by rw [integral_const_mul]
    _ = (L : ℝ) * ∑ k, gap k * ∫ ω, |E k ω| ∂P := by
      rw [integral_finsetSum Finset.univ (fun k _ =>
        (hEint k).abs.const_mul (gap k))]
      simp_rw [integral_const_mul]
    _ ≤ (L : ℝ) * ∑ k, gap k * (1 / Real.sqrt n) := by
      apply mul_le_mul_of_nonneg_left _ L.coe_nonneg
      apply Finset.sum_le_sum
      intro k _
      exact mul_le_mul_of_nonneg_left
        (expected_abs_chain_indicator_process_le hn X hLaw hindep k) (hgap k)
    _ = (L : ℝ) * ((∑ k, gap k) * (1 / Real.sqrt n)) := by
      rw [Finset.sum_mul]
    _ ≤ (L : ℝ) * (1 * (1 / Real.sqrt n)) := by
      apply mul_le_mul_of_nonneg_left _ L.coe_nonneg
      exact mul_le_mul_of_nonneg_right hsumGapLe (by positivity)
    _ = (L : ℝ) / Real.sqrt n := by ring

/-- A nonnegative integrable random variable with expectation at most `B > 0` is smaller than `2B` at some outcome.

**Lean implementation helper.** -/
private lemma exists_lt_two_mul_of_integral_le [IsProbabilityMeasure P]
    {Z : Ω → ℝ} (hZint : Integrable Z P) (hZ0 : ∀ ω, 0 ≤ Z ω)
    {B : ℝ} (hB : 0 < B) (hmean : ∫ ω, Z ω ∂P ≤ B) :
    ∃ ω, Z ω < 2 * B := by
  by_contra hex
  push Not at hex
  have hset : {ω | 2 * B ≤ Z ω} = Set.univ := Set.eq_univ_of_forall hex
  have hmarkov := mul_meas_ge_le_integral_of_nonneg (μ := P)
    (Filter.Eventually.of_forall hZ0) hZint (2 * B)
  rw [hset] at hmarkov
  have huniv : P.real Set.univ = 1 := by simp
  rw [huniv, mul_one] at hmarkov
  linarith

/-- One sample realizes the uniform Lipschitz error bound simultaneously for every function. Under the concrete
hypotheses of Theorem 8.2.3 and `L > 0`, Markov's inequality produces a sample
on which every member of the finite Lipschitz class has error less than
`2L / sqrt n` simultaneously.

**Book Remark 8.2.4.** -/
theorem remark_8_2_4_exists_good_lipschitz_sample_finite_grid {m n : ℕ}
    {ν : Measure (Fin (m + 1))} [IsProbabilityMeasure P]
    [IsProbabilityMeasure ν] (hn : 0 < n)
    (grid : Fin (m + 1) → ℝ) (hgrid : Monotone grid)
    (hgrid0 : 0 ≤ grid 0) (hgrid1 : grid (Fin.last m) ≤ 1)
    (F : Finset (ℝ → ℝ)) (L : ℝ≥0) (hL : 0 < L)
    (hLip : ∀ f ∈ F, LipschitzWith L f)
    (X : Fin n → Ω → Fin (m + 1)) (hXm : ∀ i, Measurable (X i))
    (hLaw : ∀ i, IdentDistrib (X i) (id : Fin (m + 1) → Fin (m + 1)) P ν)
    (hindep : Set.Pairwise Set.univ fun i j => IndepFun (X i) (X j) P) :
    ∃ ω, ‖finiteGridEmpiricalProcess F grid ν (fun i => X i ω)‖ <
      2 * ((L : ℝ) / Real.sqrt n) := by
  let Z : Ω → ℝ := fun ω =>
    ‖finiteGridEmpiricalProcess F grid ν (fun i => X i ω)‖
  have hZint : Integrable Z P :=
    integrable_norm_finiteGridEmpiricalProcess F grid X hXm
  have hZ0 : ∀ ω, 0 ≤ Z ω := fun _ => norm_nonneg _
  have hmean : ∫ ω, Z ω ∂P ≤ (L : ℝ) / Real.sqrt n :=
    theorem_8_2_3_lipschitz_uniform_lln_finite_grid hn grid hgrid hgrid0 hgrid1
      F L hLip X hXm hLaw hindep
  have hB : 0 < (L : ℝ) / Real.sqrt n := by
    have hnR : (0 : ℝ) < n := by exact_mod_cast hn
    positivity
  exact exists_lt_two_mul_of_integral_le hZint hZ0 hB hmean

/-! ## Exercise 8.9: the Lipschitz-net approximation step -/

/-- Construct a small covering net for the Lipschitz class. If two `K`-Lipschitz functions
are `δ`-close on an `ε`-net, they are `2Kε + δ`-close everywhere on the
covered set. This is the deterministic approximation step in the source's
covering-number construction; finiteness/cardinality belongs to the separate
combinatorial encoding of the net values.

**Book Exercise 8.9.** -/
theorem exercise_8_9_lipschitz_net_approximation
    {E : Type*} [PseudoMetricSpace α] [PseudoMetricSpace E]
    {K : ℝ≥0} {ε δ : ℝ} {S N : Set α} {f g : α → E}
    (hcover : ∀ x ∈ S, ∃ y ∈ N, dist x y ≤ ε)
    (hf : LipschitzWith K f) (hg : LipschitzWith K g)
    (hnet : ∀ y ∈ N, dist (f y) (g y) ≤ δ) :
    ∀ x ∈ S, dist (f x) (g x) ≤ 2 * (K : ℝ) * ε + δ := by
  intro x hx
  obtain ⟨y, hyN, hxy⟩ := hcover x hx
  calc
    dist (f x) (g x) ≤
        dist (f x) (f y) + dist (f y) (g y) + dist (g y) (g x) := by
      calc
        dist (f x) (g x) ≤ dist (f x) (f y) + dist (f y) (g x) :=
          dist_triangle _ _ _
        _ ≤ dist (f x) (f y) +
            (dist (f y) (g y) + dist (g y) (g x)) := by
          gcongr
          exact dist_triangle _ _ _
        _ = dist (f x) (f y) + dist (f y) (g y) +
            dist (g y) (g x) := by ring
    _ ≤ (K : ℝ) * ε + δ + (K : ℝ) * ε := by
      gcongr
      · exact (hf.dist_le_mul x y).trans
          (mul_le_mul_of_nonneg_left hxy K.coe_nonneg)
      · exact hnet y hyN
      · have hyx : dist y x ≤ ε := by simpa [dist_comm] using hxy
        exact (hg.dist_le_mul y x).trans
          (mul_le_mul_of_nonneg_left hyx K.coe_nonneg)
    _ = 2 * (K : ℝ) * ε + δ := by ring

/-! ## Exercise 8.11: empirical symmetrization -/

/-- The signed maximum of the coordinates of a nonempty finite vector.
This auxiliary functional is useful for one-sided symmetrization; Exercise
8.11 itself uses the absolute coordinate supremum, represented below by the
Pi norm.

**Book Exercise 8.11.** -/
noncomputable def finiteCoordinateSup {ι : Type*} [Fintype ι]
    [Nonempty ι] (x : ι → ℝ) : ℝ :=
  Finset.univ.sup' Finset.univ_nonempty x

/-- Every coordinate of a finite vector is bounded above by its maximum coordinate.

**Lean implementation helper.** -/
lemma finiteCoordinateSup_apply_le {ι : Type*} [Fintype ι] [Nonempty ι]
    (x : ι → ℝ) (i : ι) : x i ≤ finiteCoordinateSup x := by
  exact Finset.le_sup' x (Finset.mem_univ i)

/-- The maximum coordinate is subadditive under pointwise addition.

**Lean implementation helper.** -/
lemma finiteCoordinateSup_add_le {ι : Type*} [Fintype ι] [Nonempty ι]
    (x y : ι → ℝ) :
    finiteCoordinateSup (x + y) ≤ finiteCoordinateSup x + finiteCoordinateSup y := by
  unfold finiteCoordinateSup
  apply Finset.sup'_le Finset.univ_nonempty
  intro i _
  exact add_le_add (finiteCoordinateSup_apply_le x i)
    (finiteCoordinateSup_apply_le y i)

/-- Bounds the absolute value of the maximum coordinate functional by the norm.

**Lean implementation helper.** -/
lemma abs_finiteCoordinateSup_le_norm {ι : Type*} [Fintype ι] [Nonempty ι]
    (x : ι → ℝ) : |finiteCoordinateSup x| ≤ ‖x‖ := by
  apply (abs_le).2
  constructor
  · let i : ι := Classical.choice (inferInstance : Nonempty ι)
    exact (neg_le_of_abs_le (by
      simpa [Real.norm_eq_abs] using norm_le_pi_norm x i)).trans
      (finiteCoordinateSup_apply_le x i)
  · unfold finiteCoordinateSup
    apply Finset.sup'_le Finset.univ_nonempty
    intro i _
    exact (le_abs_self (x i)).trans (by
      simpa [Real.norm_eq_abs] using norm_le_pi_norm x i)

/-- Shows that the maximum coordinate functional is continuous.

**Lean implementation helper.** -/
lemma continuous_finiteCoordinateSup {ι : Type*} [Fintype ι] [Nonempty ι] :
    Continuous (finiteCoordinateSup : (ι → ℝ) → ℝ) := by
  unfold finiteCoordinateSup
  exact Continuous.finset_sup'_apply Finset.univ_nonempty
    (fun i _ => continuous_apply i)

/-- Shows that the maximum coordinate functional is convex on the stated domain.

**Lean implementation helper.** -/
lemma convexOn_finiteCoordinateSup {ι : Type*} [Fintype ι] [Nonempty ι] :
    ConvexOn ℝ Set.univ (finiteCoordinateSup : (ι → ℝ) → ℝ) := by
  refine ⟨convex_univ, ?_⟩
  intro x _ y _ a b ha hb _
  unfold finiteCoordinateSup
  apply Finset.sup'_le Finset.univ_nonempty
  intro i _
  simp only [Pi.add_apply, Pi.smul_apply, smul_eq_mul]
  exact add_le_add
    (mul_le_mul_of_nonneg_left
      (Finset.le_sup' x (Finset.mem_univ i)) ha)
    (mul_le_mul_of_nonneg_left
      (Finset.le_sup' y (Finset.mem_univ i)) hb)

/-- Shows that the finite coordinate sup comp is integrable.

**Lean implementation helper.** -/
lemma integrable_finiteCoordinateSup_comp {ι Ω₀ : Type*} [Fintype ι]
    [Nonempty ι] [MeasurableSpace Ω₀] {R : Measure Ω₀}
    {Y : Ω₀ → (ι → ℝ)} (hY : Integrable Y R) :
    Integrable (fun ω => finiteCoordinateSup (Y ω)) R := by
  apply Integrable.mono' hY.norm
    (continuous_finiteCoordinateSup.comp_aestronglyMeasurable
      hY.aestronglyMeasurable)
  filter_upwards [] with ω
  simpa [Real.norm_eq_abs] using abs_finiteCoordinateSup_le_norm (Y ω)

/-- Negating an independent Rademacher family preserves its joint distribution.

**Lean implementation helper.** -/
lemma identDistrib_neg_rademacher_family {ι Ω₀ : Type*} [Finite ι]
    [MeasurableSpace Ω₀] {R : Measure Ω₀} [IsProbabilityMeasure R]
    {ε : ι → Ω₀ → ℝ} (hε : ∀ i, HDP.IsRademacher (ε i) R)
    (hεind : iIndepFun ε R) :
    IdentDistrib (fun ω i => -ε i ω) (fun ω i => ε i ω) R R := by
  have hnegInd : iIndepFun (fun i ω => -ε i ω) R := by
    simpa [Function.comp_def] using hεind.comp
      (fun _ => fun x : ℝ => -x)
      (fun _ => (measurable_neg : Measurable fun x : ℝ => -x))
  exact IdentDistrib.pi (fun i => (hε i).isSymmetricRV.symm) hnegInd hεind

/-- Maximum of a real functional over a nonempty finite function class.

**Lean implementation helper.** -/
noncomputable def finiteFunctionClassSup (F : Finset (α → ℝ))
    (hF : F.Nonempty) (Z : (α → ℝ) → ℝ) : ℝ :=
  F.sup' hF Z

/-- Supremum of a real functional over a possibly uncountable function class.

**Lean implementation helper.** -/
noncomputable def functionClassSup (F : Set (α → ℝ))
    (Z : (α → ℝ) → ℝ) : ℝ :=
  sSup (Set.range fun f : ↥F => Z f.1)

/-- The maximum over coordinates indexed by a nonempty finite function class equals the corresponding finite-class supremum.

**Lean implementation helper.** -/
lemma finiteCoordinateSup_subtype_eq_functionClassSup
    (F : Finset (α → ℝ)) (hF : F.Nonempty) [Nonempty ↥F]
    (Z : (α → ℝ) → ℝ) :
    finiteCoordinateSup (fun f : ↥F => Z f.1) =
      finiteFunctionClassSup F hF Z := by
  apply le_antisymm
  · unfold finiteCoordinateSup finiteFunctionClassSup
    apply Finset.sup'_le Finset.univ_nonempty
    intro f _
    exact Finset.le_sup' Z f.2
  · unfold finiteCoordinateSup finiteFunctionClassSup
    apply Finset.sup'_le hF
    intro f hf
    exact Finset.le_sup' (fun g : ↥F => Z g.1)
      (Finset.mem_univ ⟨f, hf⟩)

/-- Shows that the supremum over a finite function class is measurable.

**Lean implementation helper.** -/
lemma measurable_finiteFunctionClassSup {Ω₀ : Type*}
    [MeasurableSpace Ω₀] (F : Finset (α → ℝ)) (hF : F.Nonempty)
    (Z : (α → ℝ) → Ω₀ → ℝ)
    (hZ : ∀ f ∈ F, Measurable (Z f)) :
    Measurable (fun ω => finiteFunctionClassSup F hF (fun f => Z f ω)) := by
  classical
  letI : Nonempty ↥F :=
    ⟨⟨Classical.choose hF, Classical.choose_spec hF⟩⟩
  have hvec : Measurable (fun ω => fun f : ↥F => Z f.1 ω) := by
    apply measurable_pi_lambda
    intro f
    exact hZ f.1 f.2
  have hmax : Measurable
      (fun ω => finiteCoordinateSup (fun f : ↥F => Z f.1 ω)) :=
    continuous_finiteCoordinateSup.measurable.comp hvec
  convert hmax using 1
  funext ω
  exact (finiteCoordinateSup_subtype_eq_functionClassSup F hF
    (fun f => Z f ω)).symm

/-- A class is Boolean when all its functions take only the values zero and
one. Real-valued indicators are used so that the empirical sums have the
literal form printed in Exercise 8.11.

**Book Exercise 8.11.** -/
def IsBooleanFunctionClass (F : Set (α → ℝ)) : Prop :=
  ∀ f ∈ F, ∀ x, f x = 0 ∨ f x = 1

/-- Normalized centered maximum over a finite function class.

**Lean implementation helper.** -/
noncomputable def finiteEmpiricalCenteredSup {n : ℕ}
    (F : Finset (α → ℝ)) (hF : F.Nonempty) (μ : Measure α)
    (sample : Fin n → α) : ℝ :=
  (n : ℝ)⁻¹ * finiteFunctionClassSup F hF
    (fun f => ∑ i, (f (sample i) - ∫ x, f x ∂μ))

/-- Normalized Rademacher maximum over a finite function class.

**Lean implementation helper.** -/
noncomputable def finiteEmpiricalRademacherSup {n : ℕ}
    (F : Finset (α → ℝ)) (hF : F.Nonempty)
    (sample : Fin n → α) (sign : Fin n → ℝ) : ℝ :=
  (n : ℝ)⁻¹ * finiteFunctionClassSup F hF
    (fun f => ∑ i, sign i * f (sample i))

/-- Normalized centered supremum over an arbitrary function class.

**Lean implementation helper.** -/
noncomputable def empiricalCenteredSup {n : ℕ} (F : Set (α → ℝ))
    (μ : Measure α) (sample : Fin n → α) : ℝ :=
  (n : ℝ)⁻¹ * functionClassSup F
    (fun f => ∑ i, (f (sample i) - ∫ x, f x ∂μ))

/-- Normalized Rademacher supremum over an arbitrary function class.

**Lean implementation helper.** -/
noncomputable def empiricalRademacherSup {n : ℕ} (F : Set (α → ℝ))
    (sample : Fin n → α) (sign : Fin n → ℝ) : ℝ :=
  (n : ℝ)⁻¹ * functionClassSup F
    (fun f => ∑ i, sign i * f (sample i))

/-- Normalized absolute centered supremum over a finite function class.
The Pi norm is exactly the maximum of the absolute coordinate values.

**Lean implementation helper.** -/
noncomputable def finiteEmpiricalCenteredAbsSup {n : ℕ}
    (F : Finset (α → ℝ)) (μ : Measure α)
    (sample : Fin n → α) : ℝ :=
  (n : ℝ)⁻¹ * ‖fun f : ↥F =>
    ∑ i, (f.1 (sample i) - ∫ x, f.1 x ∂μ)‖

/-- Normalized absolute Rademacher supremum over a finite function class.

**Lean implementation helper.** -/
noncomputable def finiteEmpiricalRademacherAbsSup {n : ℕ}
    (F : Finset (α → ℝ)) (sample : Fin n → α)
    (sign : Fin n → ℝ) : ℝ :=
  (n : ℝ)⁻¹ * ‖fun f : ↥F => ∑ i, sign i * f.1 (sample i)‖

/-- Absolute supremum of a functional over a possibly uncountable function
class. Finiteness and measurability of this extended-looking `sSup` wrapper
are supplied at the source endpoint by Boolean boundedness and the explicit
finite-exhaustion certificate.

**Lean implementation helper.** -/
noncomputable def functionClassAbsSup (F : Set (α → ℝ))
    (Z : (α → ℝ) → ℝ) : ℝ :=
  sSup (Set.range fun f : ↥F => |Z f.1|)

/-- Normalized absolute centered supremum over an arbitrary function class.

**Lean implementation helper.** -/
noncomputable def empiricalCenteredAbsSup {n : ℕ} (F : Set (α → ℝ))
    (μ : Measure α) (sample : Fin n → α) : ℝ :=
  (n : ℝ)⁻¹ * functionClassAbsSup F
    (fun f => ∑ i, (f (sample i) - ∫ x, f x ∂μ))

/-- Normalized absolute Rademacher supremum over an arbitrary function class.

**Lean implementation helper.** -/
noncomputable def empiricalRademacherAbsSup {n : ℕ}
    (F : Set (α → ℝ)) (sample : Fin n → α)
    (sign : Fin n → ℝ) : ℝ :=
  (n : ℝ)⁻¹ * functionClassAbsSup F
    (fun f => ∑ i, sign i * f (sample i))

/-- Pointwise separability data for Exercise 8.11.  The finite families need
not enumerate an uncountable class: they only have to be increasing,
contained in it, and attain both *absolute* empirical suprema in the limit
for every finite deterministic sample and every deterministic sign vector. -/
structure EmpiricalSymmetrizationExhaustion (μ : Measure α)
    (F : Set (α → ℝ)) where
  family : ℕ → Finset (α → ℝ)
  nonempty : ∀ k, (family k).Nonempty
  monotone : Monotone family
  subset : ∀ k f, f ∈ family k → f ∈ F
  centered_tendsto : ∀ {n : ℕ} (sample : Fin n → α),
    Tendsto (fun k => finiteEmpiricalCenteredAbsSup
      (family k) μ sample) atTop
      (nhds (empiricalCenteredAbsSup F μ sample))
  rademacher_tendsto : ∀ {n : ℕ} (sample : Fin n → α)
      (sign : Fin n → ℝ),
    Tendsto (fun k => finiteEmpiricalRademacherAbsSup
      (family k) sample sign) atTop
      (nhds (empiricalRademacherAbsSup F sample sign))

/-- Pointwise finite exhaustion for the auxiliary one-sided inequality.  This
is kept separate so that the source-facing Exercise 8.11 certificate above
states convergence of the absolute suprema actually printed in the book. -/
structure EmpiricalSymmetrizationSignedExhaustion (μ : Measure α)
    (F : Set (α → ℝ)) where
  family : ℕ → Finset (α → ℝ)
  nonempty : ∀ k, (family k).Nonempty
  monotone : Monotone family
  subset : ∀ k f, f ∈ family k → f ∈ F
  centered_tendsto : ∀ {n : ℕ} (sample : Fin n → α),
    Tendsto (fun k => finiteEmpiricalCenteredSup
      (family k) (nonempty k) μ sample) atTop
      (nhds (empiricalCenteredSup F μ sample))
  rademacher_tendsto : ∀ {n : ℕ} (sample : Fin n → α)
      (sign : Fin n → ℝ),
    Tendsto (fun k => finiteEmpiricalRademacherSup
      (family k) (nonempty k) sample sign) atTop
      (nhds (empiricalRademacherSup F sample sign))

/-- Every value of a Boolean function has absolute value at most `1`.

**Lean implementation helper.** -/
private lemma abs_boolean_function_value_le_one
    {F : Set (α → ℝ)} (hF : IsBooleanFunctionClass F)
    {f : α → ℝ} (hf : f ∈ F) (x : α) : |f x| ≤ 1 := by
  rcases hF f hf x with hx | hx <;> simp [hx]

/-- The centered empirical supremum over a nonempty finite Boolean class has absolute value at most `2`.

**Lean implementation helper.** -/
private lemma abs_finiteEmpiricalCenteredSup_le_two
    [IsProbabilityMeasure μ] {n : ℕ} (hn : 0 < n)
    {F : Set (α → ℝ)} (hBool : IsBooleanFunctionClass F)
    (G : Finset (α → ℝ)) (hG : G.Nonempty)
    (hGF : ∀ f ∈ G, f ∈ F) (sample : Fin n → α) :
    |finiteEmpiricalCenteredSup G hG μ sample| ≤ 2 := by
  have hnR : (0 : ℝ) < n := by exact_mod_cast hn
  have hpop (f : α → ℝ) (hf : f ∈ G) : |∫ x, f x ∂μ| ≤ 1 := by
    have h := norm_integral_le_of_norm_le_const (μ := μ) (f := f)
      (C := (1 : ℝ)) (Filter.Eventually.of_forall fun x => by
        rw [Real.norm_eq_abs]
        exact abs_boolean_function_value_le_one hBool (hGF f hf) x)
    simpa [Real.norm_eq_abs] using h
  have hcoord (f : α → ℝ) (hf : f ∈ G) :
      |∑ i, (f (sample i) - ∫ x, f x ∂μ)| ≤ 2 * (n : ℝ) := by
    calc
      |∑ i, (f (sample i) - ∫ x, f x ∂μ)| ≤
          ∑ i, |f (sample i) - ∫ x, f x ∂μ| :=
        Finset.abs_sum_le_sum_abs _ _
      _ ≤ ∑ _i : Fin n, (2 : ℝ) := by
        apply Finset.sum_le_sum
        intro i _
        calc
          |f (sample i) - ∫ x, f x ∂μ| ≤
              |f (sample i)| + |∫ x, f x ∂μ| := abs_sub _ _
          _ ≤ 1 + 1 := add_le_add
            (abs_boolean_function_value_le_one hBool (hGF f hf) _)
            (hpop f hf)
          _ = 2 := by norm_num
      _ = 2 * (n : ℝ) := by simp; ring
  have hsup : |finiteFunctionClassSup G hG
      (fun f => ∑ i, (f (sample i) - ∫ x, f x ∂μ))| ≤ 2 * (n : ℝ) := by
    apply (abs_le).2
    constructor
    · obtain ⟨f, hf⟩ := hG
      unfold finiteFunctionClassSup
      exact (neg_le_of_abs_le (hcoord f hf)).trans
        (Finset.le_sup' (fun f => ∑ i,
          (f (sample i) - ∫ x, f x ∂μ)) hf)
    · unfold finiteFunctionClassSup
      apply Finset.sup'_le hG
      intro f hf
      exact (le_abs_self _).trans (hcoord f hf)
  unfold finiteEmpiricalCenteredSup
  rw [abs_mul, abs_of_nonneg (inv_nonneg.mpr hnR.le)]
  calc
    (n : ℝ)⁻¹ * |finiteFunctionClassSup G hG
        (fun f => ∑ i, (f (sample i) - ∫ x, f x ∂μ))| ≤
        (n : ℝ)⁻¹ * (2 * (n : ℝ)) :=
      mul_le_mul_of_nonneg_left hsup (inv_nonneg.mpr hnR.le)
    _ = 2 := by field_simp

/-- With coefficients of absolute value at most `1`, the finite Boolean Rademacher supremum has absolute value at most `1`.

**Lean implementation helper.** -/
private lemma abs_finiteEmpiricalRademacherSup_le_one
    {n : ℕ} (hn : 0 < n) {F : Set (α → ℝ)}
    (hBool : IsBooleanFunctionClass F)
    (G : Finset (α → ℝ)) (hG : G.Nonempty)
    (hGF : ∀ f ∈ G, f ∈ F) (sample : Fin n → α)
    (sign : Fin n → ℝ) (hsign : ∀ i, |sign i| ≤ 1) :
    |finiteEmpiricalRademacherSup G hG sample sign| ≤ 1 := by
  have hnR : (0 : ℝ) < n := by exact_mod_cast hn
  have hcoord (f : α → ℝ) (hf : f ∈ G) :
      |∑ i, sign i * f (sample i)| ≤ (n : ℝ) := by
    calc
      |∑ i, sign i * f (sample i)| ≤
          ∑ i, |sign i * f (sample i)| :=
        Finset.abs_sum_le_sum_abs _ _
      _ ≤ ∑ _i : Fin n, (1 : ℝ) := by
        apply Finset.sum_le_sum
        intro i _
        rw [abs_mul]
        calc
          |sign i| * |f (sample i)| ≤ 1 * |f (sample i)| :=
            mul_le_mul_of_nonneg_right (hsign i) (abs_nonneg _)
          _ ≤ 1 * 1 := mul_le_mul_of_nonneg_left
            (abs_boolean_function_value_le_one hBool (hGF f hf) _) (by norm_num)
          _ = 1 := by norm_num
      _ = (n : ℝ) := by simp
  have hsup : |finiteFunctionClassSup G hG
      (fun f => ∑ i, sign i * f (sample i))| ≤ (n : ℝ) := by
    apply (abs_le).2
    constructor
    · obtain ⟨f, hf⟩ := hG
      unfold finiteFunctionClassSup
      exact (neg_le_of_abs_le (hcoord f hf)).trans
        (Finset.le_sup' (fun f => ∑ i, sign i * f (sample i)) hf)
    · unfold finiteFunctionClassSup
      apply Finset.sup'_le hG
      intro f hf
      exact (le_abs_self _).trans (hcoord f hf)
  unfold finiteEmpiricalRademacherSup
  rw [abs_mul, abs_of_nonneg (inv_nonneg.mpr hnR.le)]
  calc
    (n : ℝ)⁻¹ * |finiteFunctionClassSup G hG
        (fun f => ∑ i, sign i * f (sample i))| ≤
        (n : ℝ)⁻¹ * (n : ℝ) :=
      mul_le_mul_of_nonneg_left hsup (inv_nonneg.mpr hnR.le)
    _ = 1 := by field_simp

/-- Shows that the absolute centered empirical supremum is nonnegative.

**Lean implementation helper.** -/
private lemma finiteEmpiricalCenteredAbsSup_nonneg {n : ℕ}
    (F : Finset (α → ℝ)) (μ : Measure α) (sample : Fin n → α) :
    0 ≤ finiteEmpiricalCenteredAbsSup F μ sample := by
  unfold finiteEmpiricalCenteredAbsSup
  positivity

/-- Shows that the absolute empirical Rademacher supremum is nonnegative.

**Lean implementation helper.** -/
private lemma finiteEmpiricalRademacherAbsSup_nonneg {n : ℕ}
    (F : Finset (α → ℝ)) (sample : Fin n → α)
    (sign : Fin n → ℝ) :
    0 ≤ finiteEmpiricalRademacherAbsSup F sample sign := by
  unfold finiteEmpiricalRademacherAbsSup
  positivity

/-- The absolute centered empirical supremum over a finite Boolean class is at most `2`.

**Lean implementation helper.** -/
private lemma finiteEmpiricalCenteredAbsSup_le_two
    [IsProbabilityMeasure μ] {n : ℕ} (hn : 0 < n)
    {F : Set (α → ℝ)} (hBool : IsBooleanFunctionClass F)
    (G : Finset (α → ℝ)) (hGF : ∀ f ∈ G, f ∈ F)
    (sample : Fin n → α) :
    finiteEmpiricalCenteredAbsSup G μ sample ≤ 2 := by
  have hnR : (0 : ℝ) < n := by exact_mod_cast hn
  have hpop (f : α → ℝ) (hf : f ∈ G) : |∫ x, f x ∂μ| ≤ 1 := by
    have h := norm_integral_le_of_norm_le_const (μ := μ) (f := f)
      (C := (1 : ℝ)) (Filter.Eventually.of_forall fun x => by
        rw [Real.norm_eq_abs]
        exact abs_boolean_function_value_le_one hBool (hGF f hf) x)
    simpa [Real.norm_eq_abs] using h
  have hcoord (f : ↥G) :
      ‖∑ i, (f.1 (sample i) - ∫ x, f.1 x ∂μ)‖ ≤
        2 * (n : ℝ) := by
    rw [Real.norm_eq_abs]
    calc
      |∑ i, (f.1 (sample i) - ∫ x, f.1 x ∂μ)| ≤
          ∑ i, |f.1 (sample i) - ∫ x, f.1 x ∂μ| :=
        Finset.abs_sum_le_sum_abs _ _
      _ ≤ ∑ _i : Fin n, (2 : ℝ) := by
        apply Finset.sum_le_sum
        intro i _
        calc
          |f.1 (sample i) - ∫ x, f.1 x ∂μ| ≤
              |f.1 (sample i)| + |∫ x, f.1 x ∂μ| := abs_sub _ _
          _ ≤ 1 + 1 := add_le_add
            (abs_boolean_function_value_le_one hBool (hGF f.1 f.2) _)
            (hpop f.1 f.2)
          _ = 2 := by norm_num
      _ = 2 * (n : ℝ) := by simp; ring
  have hnorm : ‖fun f : ↥G =>
      ∑ i, (f.1 (sample i) - ∫ x, f.1 x ∂μ)‖ ≤ 2 * (n : ℝ) :=
    (pi_norm_le_iff_of_nonneg (by positivity)).2 hcoord
  unfold finiteEmpiricalCenteredAbsSup
  calc
    (n : ℝ)⁻¹ * ‖fun f : ↥G =>
        ∑ i, (f.1 (sample i) - ∫ x, f.1 x ∂μ)‖ ≤
        (n : ℝ)⁻¹ * (2 * (n : ℝ)) :=
      mul_le_mul_of_nonneg_left hnorm (inv_nonneg.mpr hnR.le)
    _ = 2 := by field_simp

/-- With coefficients of absolute value at most `1`, the absolute finite Boolean Rademacher supremum is at most `1`.

**Lean implementation helper.** -/
private lemma finiteEmpiricalRademacherAbsSup_le_one
    {n : ℕ} (hn : 0 < n) {F : Set (α → ℝ)}
    (hBool : IsBooleanFunctionClass F)
    (G : Finset (α → ℝ)) (hGF : ∀ f ∈ G, f ∈ F)
    (sample : Fin n → α) (sign : Fin n → ℝ)
    (hsign : ∀ i, |sign i| ≤ 1) :
    finiteEmpiricalRademacherAbsSup G sample sign ≤ 1 := by
  have hnR : (0 : ℝ) < n := by exact_mod_cast hn
  have hcoord (f : ↥G) :
      ‖∑ i, sign i * f.1 (sample i)‖ ≤ (n : ℝ) := by
    rw [Real.norm_eq_abs]
    calc
      |∑ i, sign i * f.1 (sample i)| ≤
          ∑ i, |sign i * f.1 (sample i)| :=
        Finset.abs_sum_le_sum_abs _ _
      _ ≤ ∑ _i : Fin n, (1 : ℝ) := by
        apply Finset.sum_le_sum
        intro i _
        rw [abs_mul]
        calc
          |sign i| * |f.1 (sample i)| ≤ 1 * |f.1 (sample i)| :=
            mul_le_mul_of_nonneg_right (hsign i) (abs_nonneg _)
          _ ≤ 1 * 1 := mul_le_mul_of_nonneg_left
            (abs_boolean_function_value_le_one hBool (hGF f.1 f.2) _)
            (by norm_num)
          _ = 1 := by norm_num
      _ = (n : ℝ) := by simp
  have hnorm : ‖fun f : ↥G =>
      ∑ i, sign i * f.1 (sample i)‖ ≤ (n : ℝ) :=
    (pi_norm_le_iff_of_nonneg hnR.le).2 hcoord
  unfold finiteEmpiricalRademacherAbsSup
  calc
    (n : ℝ)⁻¹ * ‖fun f : ↥G =>
        ∑ i, sign i * f.1 (sample i)‖ ≤
        (n : ℝ)⁻¹ * (n : ℝ) :=
      mul_le_mul_of_nonneg_left hnorm (inv_nonneg.mpr hnR.le)
    _ = 1 := by field_simp

/-- Auxiliary finite one-sided empirical symmetrization. Exercise 8.11 uses
absolute suprema; its source-facing arbitrary-class theorem below instead
passes the Pi-norm inequality to the limit.

**Book Exercise 8.11.** -/
theorem finite_empirical_symmetrization_signed_sup
    {n : ℕ} (F : Finset (α → ℝ)) (_hF : F.Nonempty) [Nonempty ↥F]
    (X : Fin n → Ω → α) (ε : Fin n → Ω' → ℝ)
    [IsProbabilityMeasure P] [IsProbabilityMeasure Q]
    (hEvalM : ∀ i, Measurable
      (fun ω => finiteClassEvaluation F (X i ω)))
    (hEvalInt : ∀ i, Integrable
      (fun ω => finiteClassEvaluation F (X i ω)) P)
    (hEvalInd : iIndepFun
      (fun i ω => finiteClassEvaluation F (X i ω)) P)
    (hεm : ∀ i, Measurable (ε i))
    (hε : ∀ i, HDP.IsRademacher (ε i) Q)
    (hεind : iIndepFun ε Q) :
    (∫ ω, finiteCoordinateSup (∑ i,
        (finiteClassEvaluation F (X i ω) -
          ∫ u, finiteClassEvaluation F (X i u) ∂P)) ∂P) ≤
      2 * ∫ z : Ω × Ω', finiteCoordinateSup (∑ i,
        ε i z.2 • finiteClassEvaluation F (X i z.1)) ∂P.prod Q := by
  classical
  let V : Fin n → Ω → (↥F → ℝ) :=
    fun i ω => finiteClassEvaluation F (X i ω)
  let C : (↥F → ℝ) → ℝ := finiteCoordinateSup
  let Y : Ω → (↥F → ℝ) :=
    fun ω => ∑ i, (V i ω - ∫ u, V i u ∂P)
  let S : Ω × Ω' → (↥F → ℝ) :=
    fun z => ∑ i, ε i z.2 • V i z.1
  let Sneg : Ω × Ω' → (↥F → ℝ) := fun z => -S z
  let SD : (Ω × Ω) × Ω' → (↥F → ℝ) :=
    fun z => ∑ i, ε i z.2 • (V i z.1.1 - V i z.1.2)
  have hVm (i : Fin n) : Measurable (V i) := by
    simpa [V] using hEvalM i
  have hVint (i : Fin n) : Integrable (V i) P := by
    simpa [V] using hEvalInt i
  have hVind : iIndepFun V P := by
    simpa [V] using hEvalInd
  have hYint : Integrable Y P := by
    apply integrable_finsetSum Finset.univ
    intro i _
    exact (hVint i).sub (integrable_const _)
  have hYmean : ∫ ω, Y ω ∂P = 0 := by
    calc
      (∫ ω, Y ω ∂P) =
          ∫ ω, ∑ i, (V i ω - ∫ u, V i u ∂P) ∂P := by rfl
      _ = ∑ i, ∫ ω, (V i ω - ∫ u, V i u ∂P) ∂P :=
        integral_finsetSum Finset.univ (fun i _ =>
          (hVint i).sub (integrable_const _))
      _ = 0 := by
        apply Finset.sum_eq_zero
        intro i _
        rw [integral_sub (hVint i) (integrable_const _), integral_const]
        simp
  have hnegYmean : ∫ ω, -Y ω ∂P = 0 := by
    rw [integral_neg]
    simp [hYmean]
  have hCYint : Integrable (fun ω => C (Y ω)) P := by
    simpa [C] using integrable_finiteCoordinateSup_comp hYint
  have hYdiffInt : Integrable
      (fun z : Ω × Ω => Y z.1 + -Y z.2) (P.prod P) :=
    (hYint.comp_fst P).add (hYint.neg.comp_snd P)
  have hCYdiffInt : Integrable
      (fun z : Ω × Ω => C (Y z.1 + -Y z.2)) (P.prod P) := by
    simpa [C] using integrable_finiteCoordinateSup_comp hYdiffInt
  have hghost := HDP.Chapter6.integral_convex_le_integral_add_independent_centered
    (Y := Y) (Z := fun ω => -Y ω) (F := C)
    (by simpa [C] using
      (convexOn_finiteCoordinateSup :
        ConvexOn ℝ Set.univ (finiteCoordinateSup : (↥F → ℝ) → ℝ)))
    (by simpa [C] using
      (continuous_finiteCoordinateSup :
        Continuous (finiteCoordinateSup : (↥F → ℝ) → ℝ)))
    hYint.neg hnegYmean hCYint hCYdiffInt
  have hcenter_le_ghost :
      (∫ ω, C (Y ω) ∂P) ≤
        ∫ z : Ω × Ω, C (∑ i, (V i z.1 - V i z.2)) ∂P.prod P := by
    calc
      (∫ ω, C (Y ω) ∂P) ≤
          ∫ z : Ω × Ω, C (Y z.1 + -Y z.2) ∂P.prod P := hghost
      _ = ∫ z : Ω × Ω, C (∑ i, (V i z.1 - V i z.2)) ∂P.prod P := by
        apply integral_congr_ae
        filter_upwards [] with z
        congr 1
        funext f
        simp only [Y, Pi.add_apply, Pi.neg_apply, Finset.sum_apply,
          Pi.sub_apply]
        simp only [sub_eq_add_neg, Finset.sum_add_distrib,
          Finset.sum_neg_distrib]
        abel
  have hSDint : Integrable SD ((P.prod P).prod Q) := by
    let D : Fin n → (Ω × Ω) → (↥F → ℝ) :=
      fun i z => V i z.1 - V i z.2
    have hDint : ∀ i, Integrable (D i) (P.prod P) := fun i =>
      (hVint i).comp_fst P |>.sub ((hVint i).comp_snd P)
    apply integrable_finsetSum Finset.univ
    intro i _
    have hi : Integrable
        (fun z : Ω' × (Ω × Ω) => ε i z.1 • D i z.2) (Q.prod (P.prod P)) :=
      ((((hε i).memLp 1).integrable le_rfl).smul_prod (hDint i))
    simpa [SD, D, Function.comp_def] using hi.swap
  have hCSDint : Integrable (fun z => C (SD z)) ((P.prod P).prod Q) := by
    simpa [C] using integrable_finiteCoordinateSup_comp hSDint
  have hSint : Integrable S (P.prod Q) := by
    apply integrable_finsetSum Finset.univ
    intro i _
    have hi : Integrable
        (fun z : Ω' × Ω => ε i z.1 • V i z.2) (Q.prod P) :=
      ((((hε i).memLp 1).integrable le_rfl).smul_prod (hVint i))
    simpa [S, Function.comp_def] using hi.swap
  have hSnegInt : Integrable Sneg (P.prod Q) := by
    simpa [Sneg] using hSint.neg
  have hCSint : Integrable (fun z => C (S z)) (P.prod Q) := by
    simpa [C] using integrable_finiteCoordinateSup_comp hSint
  have hCSnegInt : Integrable (fun z => C (Sneg z)) (P.prod Q) := by
    simpa [C] using integrable_finiteCoordinateSup_comp hSnegInt
  have hsignLaw := HDP.Chapter6.identDistrib_signed_independentCopy_sub
    hVm hεm hVind hεind hε
  let Φ : (Fin n → (↥F → ℝ)) → ℝ := fun W => C (∑ i, W i)
  have hΦm : Measurable Φ := by
    apply Continuous.measurable
    apply (show Continuous C by
      simpa [C] using
        (continuous_finiteCoordinateSup :
          Continuous (finiteCoordinateSup : (↥F → ℝ) → ℝ))).comp
    fun_prop
  have hghost_eq_signed :
      (∫ z : Ω × Ω, C (∑ i, (V i z.1 - V i z.2)) ∂P.prod P) =
        ∫ z : (Ω × Ω) × Ω', C (SD z) ∂(P.prod P).prod Q := by
    have h := (hsignLaw.comp hΦm).integral_eq
    simpa [Φ, SD, V, C, Function.comp_def] using h.symm
  have hslice (η : Ω') :
      (∫ z : Ω × Ω, C (SD (z, η)) ∂P.prod P) ≤
        (∫ ω, C (S (ω, η)) ∂P) +
          ∫ ω, C (Sneg (ω, η)) ∂P := by
    have hAint : Integrable (fun ω => S (ω, η)) P := by
      apply integrable_finsetSum Finset.univ
      intro i _
      exact (hVint i).smul (ε i η)
    have hAnegInt : Integrable (fun ω => Sneg (ω, η)) P := by
      simpa [Sneg] using hAint.neg
    have hCAint : Integrable (fun ω => C (S (ω, η))) P := by
      simpa [C] using integrable_finiteCoordinateSup_comp hAint
    have hCAnegInt : Integrable (fun ω => C (Sneg (ω, η))) P := by
      simpa [C] using integrable_finiteCoordinateSup_comp hAnegInt
    have hpairMajor : Integrable
        (fun z : Ω × Ω => C (S (z.1, η)) + C (Sneg (z.2, η)))
        (P.prod P) :=
      (hCAint.comp_fst P).add (hCAnegInt.comp_snd P)
    have hpairLeft : Integrable
        (fun z : Ω × Ω => C (SD (z, η))) (P.prod P) := by
      have hDη : Integrable (fun z : Ω × Ω => SD (z, η)) (P.prod P) := by
        apply integrable_finsetSum Finset.univ
        intro i _
        exact ((hVint i).comp_fst P |>.sub
          ((hVint i).comp_snd P)).smul (ε i η)
      simpa [C] using integrable_finiteCoordinateSup_comp hDη
    calc
      (∫ z : Ω × Ω, C (SD (z, η)) ∂P.prod P) ≤
          ∫ z : Ω × Ω,
            (C (S (z.1, η)) + C (Sneg (z.2, η))) ∂P.prod P := by
        apply integral_mono hpairLeft hpairMajor
        intro z
        have heq : SD (z, η) = S (z.1, η) + Sneg (z.2, η) := by
          funext f
          simp only [SD, S, Sneg, Finset.sum_apply, Pi.smul_apply,
            Pi.sub_apply, Pi.add_apply, Pi.neg_apply, smul_eq_mul]
          simp_rw [mul_sub]
          rw [Finset.sum_sub_distrib]
          rw [sub_eq_add_neg]
        change C (SD (z, η)) ≤ C (S (z.1, η)) + C (Sneg (z.2, η))
        rw [heq]
        exact finiteCoordinateSup_add_le _ _
      _ = (∫ ω, C (S (ω, η)) ∂P) +
          ∫ ω, C (Sneg (ω, η)) ∂P := by
        rw [integral_add (hCAint.comp_fst P) (hCAnegInt.comp_snd P),
          integral_prod _ (hCAint.comp_fst P),
          integral_prod _ (hCAnegInt.comp_snd P)]
        simp
  have houter :
      (∫ η, ∫ z : Ω × Ω, C (SD (z, η)) ∂P.prod P ∂Q) ≤
        ∫ η, ((∫ ω, C (S (ω, η)) ∂P) +
          ∫ ω, C (Sneg (ω, η)) ∂P) ∂Q := by
    apply integral_mono
    · exact hCSDint.integral_prod_right
    · exact hCSint.integral_prod_right.add hCSnegInt.integral_prod_right
    · exact hslice
  have hneg_eq :
      (∫ z : Ω × Ω', C (Sneg z) ∂P.prod Q) =
        ∫ z : Ω × Ω', C (S z) ∂P.prod Q := by
    rw [integral_prod _ hCSnegInt, integral_prod _ hCSint]
    apply integral_congr_ae
    filter_upwards [] with ω
    let Ψ : (Fin n → ℝ) → ℝ := fun e =>
      C (∑ i, e i • V i ω)
    have hΨm : Measurable Ψ := by
      apply Continuous.measurable
      apply (show Continuous C by
        simpa [C] using
          (continuous_finiteCoordinateSup :
            Continuous (finiteCoordinateSup : (↥F → ℝ) → ℝ))).comp
      fun_prop
    have h := ((identDistrib_neg_rademacher_family hε hεind).comp hΨm).integral_eq
    simpa [Ψ, S, Sneg, Function.comp_def, ← Finset.sum_neg_distrib] using h
  have hsignedD_le_two :
      (∫ z : (Ω × Ω) × Ω', C (SD z) ∂(P.prod P).prod Q) ≤
        2 * ∫ z : Ω × Ω', C (S z) ∂P.prod Q := by
    calc
      (∫ z : (Ω × Ω) × Ω', C (SD z) ∂(P.prod P).prod Q) =
          ∫ η, ∫ z : Ω × Ω, C (SD (z, η)) ∂P.prod P ∂Q :=
        integral_prod_symm _ hCSDint
      _ ≤ ∫ η, ((∫ ω, C (S (ω, η)) ∂P) +
          ∫ ω, C (Sneg (ω, η)) ∂P) ∂Q := houter
      _ = (∫ z : Ω × Ω', C (S z) ∂P.prod Q) +
          ∫ z : Ω × Ω', C (Sneg z) ∂P.prod Q := by
        rw [integral_add hCSint.integral_prod_right
          hCSnegInt.integral_prod_right,
          integral_prod_symm _ hCSint, integral_prod_symm _ hCSnegInt]
      _ = 2 * ∫ z : Ω × Ω', C (S z) ∂P.prod Q := by
        rw [hneg_eq]
        ring
  exact hcenter_le_ghost.trans <| hghost_eq_signed.le.trans hsignedD_le_two

/-- Auxiliary arbitrary-class one-sided symmetrization inequality. This
variant is useful independently, but Exercise 8.11 itself has absolute values
on both suprema; the source-facing theorem follows below.

**Book Exercise 8.11.** -/
theorem empirical_symmetrization_arbitraryClass_oneSided
    {n : ℕ} (hn : 0 < n) (μ : Measure α) [IsProbabilityMeasure μ]
    (F : Set (α → ℝ)) (hBool : IsBooleanFunctionClass F)
    (hFm : ∀ f ∈ F, Measurable f)
    (E : EmpiricalSymmetrizationSignedExhaustion μ F)
    (X : Fin n → Ω → α) (ε : Fin n → Ω' → ℝ)
    [IsProbabilityMeasure P] [IsProbabilityMeasure Q]
    (hXm : ∀ i, Measurable (X i))
    (hLaw : ∀ i, HasLaw (X i) μ P)
    (hXind : iIndepFun X P)
    (hεm : ∀ i, Measurable (ε i))
    (hε : ∀ i, HDP.IsRademacher (ε i) Q)
    (hεind : iIndepFun ε Q) :
    (∫ ω, empiricalCenteredSup F μ (fun i => X i ω) ∂P) ≤
      2 * ∫ z : Ω × Ω', empiricalRademacherSup F
        (fun i => X i z.1) (fun i => ε i z.2) ∂P.prod Q := by
  classical
  let L : ℕ → Ω → ℝ := fun k ω =>
    finiteEmpiricalCenteredSup (E.family k) (E.nonempty k) μ
      (fun i => X i ω)
  let R : ℕ → (Ω × Ω') → ℝ := fun k z =>
    finiteEmpiricalRademacherSup (E.family k) (E.nonempty k)
      (fun i => X i z.1) (fun i => ε i z.2)
  have hLm (k : ℕ) : Measurable (L k) := by
    unfold L finiteEmpiricalCenteredSup
    apply Measurable.const_mul
    apply measurable_finiteFunctionClassSup
    intro f hf
    apply Finset.measurable_sum
    intro i _
    exact ((hFm f (E.subset k f hf)).comp (hXm i)).sub_const _
  have hRm (k : ℕ) : Measurable (R k) := by
    unfold R finiteEmpiricalRademacherSup
    apply Measurable.const_mul
    apply measurable_finiteFunctionClassSup
    intro f hf
    apply Finset.measurable_sum
    intro i _
    exact ((hεm i).comp measurable_snd).mul
      (((hFm f (E.subset k f hf)).comp (hXm i)).comp measurable_fst)
  have hsignAE : ∀ᵐ η ∂Q, ∀ i, |ε i η| ≤ 1 := by
    apply ae_all_iff.mpr
    intro i
    filter_upwards [(hε i).ae_mem] with η hη
    rcases hη with hη | hη <;> simp [hη]
  have hsignProd : ∀ᵐ z ∂P.prod Q, ∀ i, |ε i z.2| ≤ 1 := by
    have hm : MeasurableSet {z : Ω × Ω' | ∀ i, |ε i z.2| ≤ 1} := by
      simp only [Set.setOf_forall]
      exact MeasurableSet.iInter fun i =>
        measurableSet_le (((hεm i).comp measurable_snd).abs) measurable_const
    apply (Measure.ae_prod_iff_ae_ae hm).2
    exact Filter.Eventually.of_forall fun _ => hsignAE
  have hLbound (k : ℕ) (ω : Ω) : ‖L k ω‖ ≤ 2 := by
    rw [Real.norm_eq_abs]
    exact abs_finiteEmpiricalCenteredSup_le_two hn hBool
      (E.family k) (E.nonempty k) (E.subset k) (fun i => X i ω)
  have hRbound (k : ℕ) : ∀ᵐ z ∂P.prod Q, ‖R k z‖ ≤ 1 := by
    filter_upwards [hsignProd] with z hz
    rw [Real.norm_eq_abs]
    exact abs_finiteEmpiricalRademacherSup_le_one hn hBool
      (E.family k) (E.nonempty k) (E.subset k)
      (fun i => X i z.1) (fun i => ε i z.2) hz
  have hstage (k : ℕ) :
      (∫ ω, L k ω ∂P) ≤ 2 * ∫ z, R k z ∂P.prod Q := by
    let G := E.family k
    letI : Nonempty ↥G :=
      ⟨⟨Classical.choose (E.nonempty k), Classical.choose_spec (E.nonempty k)⟩⟩
    let V : Fin n → Ω → (↥G → ℝ) :=
      fun i ω => finiteClassEvaluation G (X i ω)
    have hVm (i : Fin n) : Measurable (V i) := by
      apply measurable_pi_lambda
      intro f
      exact (hFm f.1 (E.subset k f.1 f.2)).comp (hXm i)
    have hVint (i : Fin n) : Integrable (V i) P := by
      apply Integrable.of_eval
      intro f
      refine Integrable.of_bound
        ((measurable_pi_apply f).comp (hVm i)).aestronglyMeasurable 1 ?_
      filter_upwards [] with ω
      change |f.1 (X i ω)| ≤ 1
      exact abs_boolean_function_value_le_one hBool
        (E.subset k f.1 f.2) (X i ω)
    have hVind : iIndepFun V P := by
      have hg (i : Fin n) : Measurable
          (fun x : α => finiteClassEvaluation G x) := by
        apply measurable_pi_lambda
        intro f
        exact hFm f.1 (E.subset k f.1 f.2)
      simpa [V, Function.comp_def] using
        hXind.comp (fun _ x => finiteClassEvaluation G x) hg
    have hmean (i : Fin n) :
        (∫ u, finiteClassEvaluation G (X i u) ∂P) =
          fun f : ↥G => ∫ x, f.1 x ∂μ := by
      funext f
      rw [MeasureTheory.eval_integral (fun v => (hVint i).eval v) f]
      have h := (hLaw i).integral_comp (f := f.1)
        ((hFm f.1 (E.subset k f.1 f.2)).aestronglyMeasurable)
      change (∫ x, f.1 (X i x) ∂P) = ∫ x, f.1 x ∂μ
      simpa [Function.comp_def] using h
    have hfin := finite_empirical_symmetrization_signed_sup
      G (E.nonempty k) X ε hVm hVint hVind hεm hε hεind
    simp_rw [hmean] at hfin
    have hraw :
        (∫ ω, finiteFunctionClassSup G (E.nonempty k)
          (fun f => ∑ i, (f (X i ω) - ∫ x, f x ∂μ)) ∂P) ≤
        2 * ∫ z : Ω × Ω', finiteFunctionClassSup G (E.nonempty k)
          (fun f => ∑ i, ε i z.2 * f (X i z.1)) ∂P.prod Q := by
      calc
        (∫ ω, finiteFunctionClassSup G (E.nonempty k)
            (fun f => ∑ i, (f (X i ω) - ∫ x, f x ∂μ)) ∂P) =
            ∫ ω, finiteCoordinateSup (∑ i,
              (finiteClassEvaluation G (X i ω) -
                fun f : ↥G => ∫ x, f.1 x ∂μ)) ∂P := by
          apply integral_congr_ae
          filter_upwards [] with ω
          have hvec : (∑ i,
              (finiteClassEvaluation G (X i ω) -
                fun f : ↥G => ∫ x, f.1 x ∂μ)) =
              fun f : ↥G => ∑ i,
                (f.1 (X i ω) - ∫ x, f.1 x ∂μ) := by
            funext f
            simp [finiteClassEvaluation]
          rw [hvec]
          exact (finiteCoordinateSup_subtype_eq_functionClassSup G
            (E.nonempty k)
            (fun f => ∑ i, (f (X i ω) - ∫ x, f x ∂μ))).symm
        _ ≤ 2 * ∫ z : Ω × Ω', finiteCoordinateSup (∑ i,
            ε i z.2 • finiteClassEvaluation G (X i z.1)) ∂P.prod Q := hfin
        _ = 2 * ∫ z : Ω × Ω', finiteFunctionClassSup G (E.nonempty k)
            (fun f => ∑ i, ε i z.2 * f (X i z.1)) ∂P.prod Q := by
          congr 1
          apply integral_congr_ae
          filter_upwards [] with z
          have hvec : (∑ i,
              ε i z.2 • finiteClassEvaluation G (X i z.1)) =
              fun f : ↥G => ∑ i, ε i z.2 * f.1 (X i z.1) := by
            funext f
            simp [finiteClassEvaluation]
          rw [hvec]
          exact finiteCoordinateSup_subtype_eq_functionClassSup G
            (E.nonempty k)
            (fun f => ∑ i, ε i z.2 * f (X i z.1))
    have hnInv : 0 ≤ (n : ℝ)⁻¹ := inv_nonneg.mpr (by positivity)
    have hscaled := mul_le_mul_of_nonneg_left hraw hnInv
    calc
      (∫ ω, L k ω ∂P) = (n : ℝ)⁻¹ *
          ∫ ω, finiteFunctionClassSup G (E.nonempty k)
            (fun f => ∑ i, (f (X i ω) - ∫ x, f x ∂μ)) ∂P := by
        rw [← integral_const_mul]
        rfl
      _ ≤ (n : ℝ)⁻¹ * (2 * ∫ z : Ω × Ω',
          finiteFunctionClassSup G (E.nonempty k)
            (fun f => ∑ i, ε i z.2 * f (X i z.1)) ∂P.prod Q) := hscaled
      _ = 2 * ((n : ℝ)⁻¹ * ∫ z : Ω × Ω',
          finiteFunctionClassSup G (E.nonempty k)
            (fun f => ∑ i, ε i z.2 * f (X i z.1)) ∂P.prod Q) := by ring
      _ = 2 * ∫ z, R k z ∂P.prod Q := by
        congr 1
        rw [← integral_const_mul]
        rfl
  have hLint : Tendsto (fun k => ∫ ω, L k ω ∂P) atTop
      (nhds (∫ ω, empiricalCenteredSup F μ (fun i => X i ω) ∂P)) := by
    apply tendsto_integral_filter_of_norm_le_const
    · exact Filter.Eventually.of_forall fun k => (hLm k).aestronglyMeasurable
    · exact ⟨2, Filter.Eventually.of_forall fun k =>
        Filter.Eventually.of_forall fun ω => hLbound k ω⟩
    · exact Filter.Eventually.of_forall fun ω => by
        simpa [L] using E.centered_tendsto (fun i => X i ω)
  have hRint : Tendsto (fun k => ∫ z, R k z ∂P.prod Q) atTop
      (nhds (∫ z : Ω × Ω', empiricalRademacherSup F
        (fun i => X i z.1) (fun i => ε i z.2) ∂P.prod Q)) := by
    apply tendsto_integral_filter_of_norm_le_const
    · exact Filter.Eventually.of_forall fun k => (hRm k).aestronglyMeasurable
    · exact ⟨1, Filter.Eventually.of_forall hRbound⟩
    · exact Filter.Eventually.of_forall fun z => by
        simpa [R] using E.rademacher_tendsto
          (fun i => X i z.1) (fun i => ε i z.2)
  exact le_of_tendsto_of_tendsto' hLint (tendsto_const_nhds.mul hRint) hstage

/-- Empirical symmetrization over an arbitrary Boolean class.

**Book Exercise 8.11.** -/
theorem exercise_8_11_empirical_symmetrization_arbitraryClass
    {n : ℕ} (hn : 0 < n) (μ : Measure α) [IsProbabilityMeasure μ]
    (F : Set (α → ℝ)) (hBool : IsBooleanFunctionClass F)
    (hFm : ∀ f ∈ F, Measurable f)
    (E : EmpiricalSymmetrizationExhaustion μ F)
    (X : Fin n → Ω → α) (ε : Fin n → Ω' → ℝ)
    [IsProbabilityMeasure P] [IsProbabilityMeasure Q]
    (hXm : ∀ i, Measurable (X i))
    (hLaw : ∀ i, HasLaw (X i) μ P)
    (hXind : iIndepFun X P)
    (hεm : ∀ i, Measurable (ε i))
    (hε : ∀ i, HDP.IsRademacher (ε i) Q)
    (hεind : iIndepFun ε Q) :
    (∫ ω, empiricalCenteredAbsSup F μ (fun i => X i ω) ∂P) ≤
      2 * ∫ z : Ω × Ω', empiricalRademacherAbsSup F
        (fun i => X i z.1) (fun i => ε i z.2) ∂P.prod Q := by
  classical
  let L : ℕ → Ω → ℝ := fun k ω =>
    finiteEmpiricalCenteredAbsSup (E.family k) μ (fun i => X i ω)
  let R : ℕ → (Ω × Ω') → ℝ := fun k z =>
    finiteEmpiricalRademacherAbsSup (E.family k)
      (fun i => X i z.1) (fun i => ε i z.2)
  have hLm (k : ℕ) : Measurable (L k) := by
    unfold L finiteEmpiricalCenteredAbsSup
    apply Measurable.const_mul
    apply Measurable.norm
    apply measurable_pi_lambda
    intro f
    apply Finset.measurable_sum
    intro i _
    exact ((hFm f.1 (E.subset k f.1 f.2)).comp (hXm i)).sub_const _
  have hRm (k : ℕ) : Measurable (R k) := by
    unfold R finiteEmpiricalRademacherAbsSup
    apply Measurable.const_mul
    apply Measurable.norm
    apply measurable_pi_lambda
    intro f
    apply Finset.measurable_sum
    intro i _
    exact ((hεm i).comp measurable_snd).mul
      (((hFm f.1 (E.subset k f.1 f.2)).comp (hXm i)).comp measurable_fst)
  have hsignAE : ∀ᵐ η ∂Q, ∀ i, |ε i η| ≤ 1 := by
    apply ae_all_iff.mpr
    intro i
    filter_upwards [(hε i).ae_mem] with η hη
    rcases hη with hη | hη <;> simp [hη]
  have hsignProd : ∀ᵐ z ∂P.prod Q, ∀ i, |ε i z.2| ≤ 1 := by
    have hm : MeasurableSet {z : Ω × Ω' | ∀ i, |ε i z.2| ≤ 1} := by
      simp only [Set.setOf_forall]
      exact MeasurableSet.iInter fun i =>
        measurableSet_le (((hεm i).comp measurable_snd).abs) measurable_const
    apply (Measure.ae_prod_iff_ae_ae hm).2
    exact Filter.Eventually.of_forall fun _ => hsignAE
  have hLbound (k : ℕ) (ω : Ω) : ‖L k ω‖ ≤ 2 := by
    rw [Real.norm_eq_abs,
      abs_of_nonneg (finiteEmpiricalCenteredAbsSup_nonneg
        (E.family k) μ (fun i => X i ω))]
    exact finiteEmpiricalCenteredAbsSup_le_two hn hBool
      (E.family k) (E.subset k) (fun i => X i ω)
  have hRbound (k : ℕ) : ∀ᵐ z ∂P.prod Q, ‖R k z‖ ≤ 1 := by
    filter_upwards [hsignProd] with z hz
    rw [Real.norm_eq_abs,
      abs_of_nonneg (finiteEmpiricalRademacherAbsSup_nonneg
        (E.family k) (fun i => X i z.1) (fun i => ε i z.2))]
    exact finiteEmpiricalRademacherAbsSup_le_one hn hBool
      (E.family k) (E.subset k) (fun i => X i z.1)
      (fun i => ε i z.2) hz
  have hstage (k : ℕ) :
      (∫ ω, L k ω ∂P) ≤ 2 * ∫ z, R k z ∂P.prod Q := by
    let G := E.family k
    let V : Fin n → Ω → (↥G → ℝ) :=
      fun i ω => finiteClassEvaluation G (X i ω)
    have hVm (i : Fin n) : Measurable (V i) := by
      apply measurable_pi_lambda
      intro f
      exact (hFm f.1 (E.subset k f.1 f.2)).comp (hXm i)
    have hVint (i : Fin n) : Integrable (V i) P := by
      apply Integrable.of_eval
      intro f
      refine Integrable.of_bound
        ((measurable_pi_apply f).comp (hVm i)).aestronglyMeasurable 1 ?_
      filter_upwards [] with ω
      change |f.1 (X i ω)| ≤ 1
      exact abs_boolean_function_value_le_one hBool
        (E.subset k f.1 f.2) (X i ω)
    have hVind : iIndepFun V P := by
      have hg (i : Fin n) : Measurable
          (fun x : α => finiteClassEvaluation G x) := by
        apply measurable_pi_lambda
        intro f
        exact hFm f.1 (E.subset k f.1 f.2)
      simpa [V, Function.comp_def] using
        hXind.comp (fun _ x => finiteClassEvaluation G x) hg
    have hmean (i : Fin n) :
        (∫ u, finiteClassEvaluation G (X i u) ∂P) =
          fun f : ↥G => ∫ x, f.1 x ∂μ := by
      funext f
      rw [MeasureTheory.eval_integral (fun v => (hVint i).eval v) f]
      have h := (hLaw i).integral_comp (f := f.1)
        ((hFm f.1 (E.subset k f.1 f.2)).aestronglyMeasurable)
      change (∫ x, f.1 (X i x) ∂P) = ∫ x, f.1 x ∂μ
      simpa [Function.comp_def] using h
    have hfin := HDP.Chapter6.symmetrization_centered_sum_upper
      hVm hVint hVind hεm hε hεind
    have hfin' :
        (∫ ω, ‖∑ i, (finiteClassEvaluation G (X i ω) -
          ∫ u, finiteClassEvaluation G (X i u) ∂P)‖ ∂P) ≤
        2 * ∫ z : Ω × Ω', ‖∑ i,
          ε i z.2 • finiteClassEvaluation G (X i z.1)‖ ∂P.prod Q := by
      simpa [V] using hfin
    have hraw :
        (∫ ω, ‖fun f : ↥G =>
          ∑ i, (f.1 (X i ω) - ∫ x, f.1 x ∂μ)‖ ∂P) ≤
        2 * ∫ z : Ω × Ω', ‖fun f : ↥G =>
          ∑ i, ε i z.2 * f.1 (X i z.1)‖ ∂P.prod Q := by
      calc
        (∫ ω, ‖fun f : ↥G =>
            ∑ i, (f.1 (X i ω) - ∫ x, f.1 x ∂μ)‖ ∂P) =
            ∫ ω, ‖∑ i, (finiteClassEvaluation G (X i ω) -
              ∫ u, finiteClassEvaluation G (X i u) ∂P)‖ ∂P := by
          apply integral_congr_ae
          filter_upwards [] with ω
          congr 1
          funext f
          simp [finiteClassEvaluation, hmean]
        _ ≤ 2 * ∫ z : Ω × Ω', ‖∑ i,
            ε i z.2 • finiteClassEvaluation G (X i z.1)‖ ∂P.prod Q := hfin'
        _ = 2 * ∫ z : Ω × Ω', ‖fun f : ↥G =>
            ∑ i, ε i z.2 * f.1 (X i z.1)‖ ∂P.prod Q := by
          congr 1
          apply integral_congr_ae
          filter_upwards [] with z
          congr 1
          funext f
          simp [finiteClassEvaluation]
    have hnInv : 0 ≤ (n : ℝ)⁻¹ := inv_nonneg.mpr (by positivity)
    have hscaled := mul_le_mul_of_nonneg_left hraw hnInv
    calc
      (∫ ω, L k ω ∂P) = (n : ℝ)⁻¹ *
          ∫ ω, ‖fun f : ↥G =>
            ∑ i, (f.1 (X i ω) - ∫ x, f.1 x ∂μ)‖ ∂P := by
        rw [← integral_const_mul]
        rfl
      _ ≤ (n : ℝ)⁻¹ * (2 * ∫ z : Ω × Ω',
          ‖fun f : ↥G => ∑ i,
            ε i z.2 * f.1 (X i z.1)‖ ∂P.prod Q) := hscaled
      _ = 2 * ((n : ℝ)⁻¹ * ∫ z : Ω × Ω',
          ‖fun f : ↥G => ∑ i,
            ε i z.2 * f.1 (X i z.1)‖ ∂P.prod Q) := by ring
      _ = 2 * ∫ z, R k z ∂P.prod Q := by
        congr 1
        rw [← integral_const_mul]
        rfl
  have hLint : Tendsto (fun k => ∫ ω, L k ω ∂P) atTop
      (nhds (∫ ω, empiricalCenteredAbsSup F μ
        (fun i => X i ω) ∂P)) := by
    apply tendsto_integral_filter_of_norm_le_const
    · exact Filter.Eventually.of_forall fun k => (hLm k).aestronglyMeasurable
    · exact ⟨2, Filter.Eventually.of_forall fun k =>
        Filter.Eventually.of_forall fun ω => hLbound k ω⟩
    · exact Filter.Eventually.of_forall fun ω => by
        simpa [L] using E.centered_tendsto (fun i => X i ω)
  have hRint : Tendsto (fun k => ∫ z, R k z ∂P.prod Q) atTop
      (nhds (∫ z : Ω × Ω', empiricalRademacherAbsSup F
        (fun i => X i z.1) (fun i => ε i z.2) ∂P.prod Q)) := by
    apply tendsto_integral_filter_of_norm_le_const
    · exact Filter.Eventually.of_forall fun k => (hRm k).aestronglyMeasurable
    · exact ⟨1, Filter.Eventually.of_forall hRbound⟩
    · exact Filter.Eventually.of_forall fun z => by
        simpa [R] using E.rademacher_tendsto
          (fun i => X i z.1) (fun i => ε i z.2)
  exact le_of_tendsto_of_tendsto' hLint (tendsto_const_nhds.mul hRint) hstage

/-- Finite-class empirical
symmetrization. The random vectors are the simultaneous evaluations of the
class. The signs live on a separate probability space, so independence from
the data is structural. The explicit measurability/integrability hypotheses
repair the source's silent arbitrary-supremum assumptions.

**Book Exercise 8.11.** -/
theorem exercise_8_11_empirical_symmetrization
    {n : ℕ} (F : Finset (α → ℝ))
    (X : Fin n → Ω → α) (ε : Fin n → Ω' → ℝ)
    [IsProbabilityMeasure P] [IsProbabilityMeasure Q]
    (hEvalM : ∀ i, Measurable
      (fun ω => finiteClassEvaluation F (X i ω)))
    (hEvalInt : ∀ i, Integrable
      (fun ω => finiteClassEvaluation F (X i ω)) P)
    (hEvalInd : iIndepFun
      (fun i ω => finiteClassEvaluation F (X i ω)) P)
    (hεm : ∀ i, Measurable (ε i))
    (hε : ∀ i, HDP.IsRademacher (ε i) Q)
    (hεind : iIndepFun ε Q) :
    (∫ ω, ‖∑ i,
        (finiteClassEvaluation F (X i ω) -
          ∫ u, finiteClassEvaluation F (X i u) ∂P)‖ ∂P) ≤
      2 * ∫ z : Ω × Ω', ‖∑ i,
        ε i z.2 • finiteClassEvaluation F (X i z.1)‖ ∂P.prod Q := by
  exact HDP.Chapter6.symmetrization_centered_sum_upper
    hEvalM hEvalInt hEvalInd hεm hε hεind

end

end HDP.Chapter8

