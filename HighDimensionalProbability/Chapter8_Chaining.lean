/-- Exact canonical `L²` increment of the product-Gaussian process.

**Lean implementation helper.** -/
theorem sumCanonicalGaussianProcess_increment
    {I E F : Type*}
    [NormedAddCommGroup E] [InnerProductSpace ℝ E]
    [FiniteDimensional ℝ E] [MeasurableSpace E] [BorelSpace E]
    [NormedAddCommGroup F] [InnerProductSpace ℝ F]
    [FiniteDimensional ℝ F] [MeasurableSpace F] [BorelSpace F]
    (u : I → E) (v : I → F) (i j : I) :
    HDP.processIncrement (sumCanonicalGaussianProcess u v)
        ((stdGaussian E).prod (stdGaussian F)) i j =
      Real.sqrt (‖u i - u j‖ ^ 2 + ‖v i - v j‖ ^ 2) := by
  let Y := sumCanonicalGaussianProcess u v
  let ν := (stdGaussian E).prod (stdGaussian F)
  have hL2 : HDP.IsL2Process Y ν :=
    sumCanonicalGaussianProcess_isL2 u v
  let D : E × F → ℝ := fun p => Y i p - Y j p
  have hD : MemLp D 2 ν := (hL2 i).sub (hL2 j)
  have hsq : HDP.processIncrement Y ν i j ^ 2 =
      HDP.Chapter7.processIncrementSecondMoment ν Y i j := by
    change HDP.Chapter1.lpNormRV D 2 ν ^ 2 =
      ∫ p, D p ^ 2 ∂ν
    rw [HDP.Chapter1.sq_lpNormRV_two_eq_l2InnerRV hD]
    unfold HDP.Chapter1.l2InnerRV
    apply integral_congr_ae
    filter_upwards [] with p
    simp [pow_two]
  rw [sumCanonicalGaussianProcess_incrementSecondMoment u v i j] at hsq
  have hnonneg : 0 ≤ HDP.processIncrement Y ν i j :=
    HDP.processIncrement_nonneg (hL2 i) (hL2 j)
  have hrhs : 0 ≤ ‖u i - u j‖ ^ 2 + ‖v i - v j‖ ^ 2 :=
    add_nonneg (sq_nonneg _) (sq_nonneg _)
  have hsqrt := Real.sq_sqrt hrhs
  nlinarith [Real.sqrt_nonneg
    (‖u i - u j‖ ^ 2 + ‖v i - v j‖ ^ 2)]

/-- Talagrand comparison against the explicit product-Gaussian process. This
is the public comparison endpoint used by the proof of Chevet's inequality.

**Lean implementation helper.** -/
theorem talagrandComparison_sumCanonical
    {I Ω E F : Type} [Fintype I] [Nonempty I]
    [MeasurableSpace Ω]
    [NormedAddCommGroup E] [InnerProductSpace ℝ E]
    [FiniteDimensional ℝ E] [MeasurableSpace E] [BorelSpace E]
    [NormedAddCommGroup F] [InnerProductSpace ℝ F]
    [FiniteDimensional ℝ F] [MeasurableSpace F] [BorelSpace F]
    (μ : Measure Ω) [IsProbabilityMeasure μ]
    (X : HDP.RandomProcess I Ω)
    (hXm : ∀ i, Measurable (X i))
    (hXint : ∀ i, Integrable (X i) μ)
    (hXcenter : HDP.IsCenteredProcess X μ)
    (u : I → E) (v : I → F)
    {K : ℝ} (hK : 0 ≤ K)
    (hinc : ∀ s t,
      HDP.SubGaussian (fun ω => X t ω - X s ω) μ ∧
        HDP.psi2Norm (fun ω => X t ω - X s ω) μ ≤
          K * Real.sqrt
            (‖u t - u s‖ ^ 2 + ‖v t - v s‖ ^ 2)) :
    HDP.Chapter7.expectedFiniteSupremum μ X ≤
      talagrandComparisonConstant * K *
        HDP.Chapter7.expectedFiniteSupremum
          ((stdGaussian E).prod (stdGaussian F))
          (sumCanonicalGaussianProcess u v) := by
  apply talagrandComparison μ ((stdGaussian E).prod (stdGaussian F))
    X (sumCanonicalGaussianProcess u v) hXm hXint hXcenter
    (sumCanonicalGaussianProcess_isGaussian u v)
    (sumCanonicalGaussianProcess_centered u v)
    (sumCanonicalGaussianProcess_isL2 u v) hK
  intro s t
  simpa [sumCanonicalGaussianProcess_increment u v t s] using hinc s t

