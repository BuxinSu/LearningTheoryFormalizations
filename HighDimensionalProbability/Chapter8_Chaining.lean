/-- The Euclidean vectorization of the rank-one matrix `v uᵀ`.

**Lean implementation helper.** -/
def rankOneGaussianPoint {m n : ℕ}
    (u : EuclideanSpace ℝ (Fin n))
    (v : EuclideanSpace ℝ (Fin m)) :
    EuclideanSpace ℝ (Fin m × Fin n) :=
  WithLp.toLp 2 (fun p =>
    (WithLp.ofLp v) p.1 * (WithLp.ofLp u) p.2)

