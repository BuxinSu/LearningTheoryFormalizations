/-! ## Material formerly in `03_EmpiricalProcesses.lean` -/

section Source_03_EmpiricalProcesses

open Filter MeasureTheory ProbabilityTheory Set
open scoped BigOperators ENNReal NNReal BoundedContinuousFunction Pointwise

namespace HDP.Chapter8

noncomputable section

/-- The source interval `[0,1]`, as a compact metric space. -/
abbrev UnitInterval := Set.Icc (0 : ℝ) 1

variable {Ω : Type*} {mΩ : MeasurableSpace Ω}
  {ν : Measure UnitInterval} {P : Measure Ω}

/-- Normalized `[0,1]`-valued one-Lipschitz class. The class from Exercise 8.9, embedded in the sup-norm space of bounded
continuous real functions.

**Book Equation (8.24).** -/
def unitIntervalLipschitzClass : Set (UnitInterval →ᵇ ℝ) :=
  {f | LipschitzWith 1 f ∧ ∀ x, f x ∈ Set.Icc (0 : ℝ) 1}

/-- Shows that the unit-interval Lipschitz class is nonempty.

**Lean implementation helper.** -/
lemma unitIntervalLipschitzClass_nonempty :
    (unitIntervalLipschitzClass : Set (UnitInterval →ᵇ ℝ)).Nonempty := by
  let z : UnitInterval →ᵇ ℝ := BoundedContinuousFunction.const UnitInterval 0
  refine ⟨z, ?_⟩
  constructor
  · change LipschitzWith 1 (fun _ : UnitInterval => (0 : ℝ))
    exact (LipschitzWith.const (α := UnitInterval) (0 : ℝ)).weaken
      (show (0 : ℝ≥0) ≤ 1 by simp)
  · intro x
    simp [z]

/-- The uniform grid `j/m`, including both endpoints.

**Lean implementation helper.** -/
def unitGridPoint (m : ℕ) (hm : 0 < m) (j : Fin (m + 1)) : UnitInterval :=
  ⟨(j : ℝ) / m, by
    constructor
    · positivity
    · apply (div_le_one (show (0 : ℝ) < m by exact_mod_cast hm)).2
      exact_mod_cast Nat.le_of_lt_succ j.isLt⟩

/-- The `j`th point of the uniform `m`-grid has real coordinate `j/m`.

**Lean implementation helper.** -/
@[simp] lemma unitGridPoint_val (m : ℕ) (hm : 0 < m) (j : Fin (m + 1)) :
    (unitGridPoint m hm j : ℝ) = (j : ℝ) / m := rfl

/-- Consecutive points of the uniform `m`-grid are exactly `1/m` apart.

**Lean implementation helper.** -/
lemma dist_unitGridPoint_succ (m : ℕ) (hm : 0 < m) (j : Fin m) :
    dist (unitGridPoint m hm j.castSucc) (unitGridPoint m hm j.succ) =
      1 / (m : ℝ) := by
  rw [Subtype.dist_eq, Real.dist_eq]
  simp only [unitGridPoint_val, Fin.val_castSucc, Fin.val_succ]
  have hmR : (0 : ℝ) < m := by exact_mod_cast hm
  rw [abs_of_nonpos]
  · field_simp
    push_cast
    ring
  · apply sub_nonpos.mpr
    apply (div_le_div_iff_of_pos_right hmR).2
    push_cast
    linarith

/-- Quantization of a grid value at resolution `1/m`.

**Lean implementation helper.** -/
def lipschitzGridQuantizedValue (m : ℕ) (hm : 0 < m)
    (f : ↥unitIntervalLipschitzClass) (j : Fin (m + 1)) : ℕ :=
  Nat.floor ((m : ℝ) * f.1 (unitGridPoint m hm j))

/-- Every quantized value of a unit-interval Lipschitz function is at most the grid size `m`.

**Lean implementation helper.** -/
lemma lipschitzGridQuantizedValue_le (m : ℕ) (hm : 0 < m)
    (f : ↥unitIntervalLipschitzClass) (j : Fin (m + 1)) :
    lipschitzGridQuantizedValue m hm f j ≤ m := by
  apply Nat.floor_le_of_le
  have hf := (f.2.2 (unitGridPoint m hm j)).2
  nlinarith

/-- A quantized grid value can increase by at most one between adjacent grid points.

**Lean implementation helper.** -/
lemma lipschitzGridQuantizedValue_adjacent_le (m : ℕ) (hm : 0 < m)
    (f : ↥unitIntervalLipschitzClass) (j : Fin m) :
    lipschitzGridQuantizedValue m hm f j.succ ≤
      lipschitzGridQuantizedValue m hm f j.castSucc + 1 := by
  let a := (m : ℝ) * f.1 (unitGridPoint m hm j.succ)
  let b := (m : ℝ) * f.1 (unitGridPoint m hm j.castSucc)
  have hmR : (0 : ℝ) < m := by exact_mod_cast hm
  have hb0 : 0 ≤ b := mul_nonneg hmR.le (f.2.2 _).1
  have hLip := f.2.1.dist_le_mul
    (unitGridPoint m hm j.succ) (unitGridPoint m hm j.castSucc)
  norm_num at hLip
  rw [show dist (unitGridPoint m hm j.succ)
      (unitGridPoint m hm j.castSucc) =
      dist (unitGridPoint m hm j.castSucc)
        (unitGridPoint m hm j.succ) by rw [dist_comm],
    dist_unitGridPoint_succ m hm j] at hLip
  have habs : |f.1 (unitGridPoint m hm j.succ) -
      f.1 (unitGridPoint m hm j.castSucc)| ≤ 1 / (m : ℝ) := by
    simpa [Real.dist_eq, abs_sub_comm] using hLip
  have hab : a ≤ b + 1 := by
    dsimp [a, b]
    have hdiff := (le_abs_self
      (f.1 (unitGridPoint m hm j.succ) -
        f.1 (unitGridPoint m hm j.castSucc))).trans habs
    have hinv : (m : ℝ) * (1 / (m : ℝ)) = 1 := by field_simp
    nlinarith
  unfold lipschitzGridQuantizedValue
  calc
    Nat.floor a ≤ Nat.floor (b + 1) := Nat.floor_le_floor hab
    _ = Nat.floor b + 1 := Nat.floor_add_one hb0

/-- A quantized grid value can decrease by at most one between adjacent grid points.

**Lean implementation helper.** -/
lemma lipschitzGridQuantizedValue_reverse_adjacent_le (m : ℕ) (hm : 0 < m)
    (f : ↥unitIntervalLipschitzClass) (j : Fin m) :
    lipschitzGridQuantizedValue m hm f j.castSucc ≤
      lipschitzGridQuantizedValue m hm f j.succ + 1 := by
  let a := (m : ℝ) * f.1 (unitGridPoint m hm j.castSucc)
  let b := (m : ℝ) * f.1 (unitGridPoint m hm j.succ)
  have hmR : (0 : ℝ) < m := by exact_mod_cast hm
  have hb0 : 0 ≤ b := mul_nonneg hmR.le (f.2.2 _).1
  have hLip := f.2.1.dist_le_mul
    (unitGridPoint m hm j.castSucc) (unitGridPoint m hm j.succ)
  have habs : |f.1 (unitGridPoint m hm j.castSucc) -
      f.1 (unitGridPoint m hm j.succ)| ≤ 1 / (m : ℝ) := by
    simpa [Real.dist_eq, dist_unitGridPoint_succ m hm j] using hLip
  have hab : a ≤ b + 1 := by
    dsimp [a, b]
    have hdiff := (le_abs_self
      (f.1 (unitGridPoint m hm j.castSucc) -
        f.1 (unitGridPoint m hm j.succ))).trans habs
    have hinv : (m : ℝ) * (1 / (m : ℝ)) = 1 := by field_simp
    nlinarith
  unfold lipschitzGridQuantizedValue
  calc
    Nat.floor a ≤ Nat.floor (b + 1) := Nat.floor_le_floor hab
    _ = Nat.floor b + 1 := Nat.floor_add_one hb0

/-- The compressed code of a Lipschitz path: one initial quantized value and
one of three possible increments at every subsequent grid point. -/
abbrev LipschitzGridCode (m : ℕ) := Fin (m + 1) × (Fin m → Fin 3)

/-- Encodes a unit-Lipschitz function by quantized values and adjacent quantized increments on a uniform grid.

**Lean implementation helper.** -/
def lipschitzGridCode (m : ℕ) (hm : 0 < m)
    (f : ↥unitIntervalLipschitzClass) : LipschitzGridCode m :=
  (⟨lipschitzGridQuantizedValue m hm f 0,
      Nat.lt_succ_of_le (lipschitzGridQuantizedValue_le m hm f 0)⟩,
    fun j =>
      ⟨(lipschitzGridQuantizedValue m hm f j.succ + 1) -
          lipschitzGridQuantizedValue m hm f j.castSucc, by
        have h := lipschitzGridQuantizedValue_adjacent_le m hm f j
        omega⟩)

/-- The signed step stored in a Lipschitz grid code recovers the next quantized grid value.

**Lean implementation helper.** -/
lemma lipschitzGridCode_step_recover (m : ℕ) (hm : 0 < m)
    (f : ↥unitIntervalLipschitzClass) (j : Fin m) :
    (lipschitzGridCode m hm f).2 j +
        lipschitzGridQuantizedValue m hm f j.castSucc =
      lipschitzGridQuantizedValue m hm f j.succ + 1 := by
  change ((lipschitzGridQuantizedValue m hm f j.succ + 1) -
      lipschitzGridQuantizedValue m hm f j.castSucc) +
        lipschitzGridQuantizedValue m hm f j.castSucc = _
  exact Nat.sub_add_cancel
    (lipschitzGridQuantizedValue_reverse_adjacent_le m hm f j)

/-- Equal Lipschitz grid codes have equal quantized values at every grid point.

**Lean implementation helper.** -/
lemma lipschitzGridCode_eq_imp_quantizedValue_eq (m : ℕ) (hm : 0 < m)
    {f g : ↥unitIntervalLipschitzClass}
    (hcode : lipschitzGridCode m hm f = lipschitzGridCode m hm g)
    (j : Fin (m + 1)) :
    lipschitzGridQuantizedValue m hm f j =
      lipschitzGridQuantizedValue m hm g j := by
  have hzero : lipschitzGridQuantizedValue m hm f 0 =
      lipschitzGridQuantizedValue m hm g 0 := by
    exact congrArg (fun c : LipschitzGridCode m => c.1.val) hcode
  have hstep : ∀ k : Fin m,
      (lipschitzGridCode m hm f).2 k =
        (lipschitzGridCode m hm g).2 k := by
    intro k
    exact congrFun (congrArg Prod.snd hcode) k
  have hind : ∀ q : ℕ, ∀ hq : q < m + 1,
      lipschitzGridQuantizedValue m hm f ⟨q, hq⟩ =
        lipschitzGridQuantizedValue m hm g ⟨q, hq⟩ := by
    intro q
    induction q with
    | zero =>
        intro hq
        simpa using hzero
    | succ q ih =>
        intro hq
        have hqm : q < m := by omega
        let k : Fin m := ⟨q, hqm⟩
        have hprev : lipschitzGridQuantizedValue m hm f k.castSucc =
            lipschitzGridQuantizedValue m hm g k.castSucc := by
          simpa [k] using ih (by omega : q < m + 1)
        have hfrec := lipschitzGridCode_step_recover m hm f k
        have hgrec := lipschitzGridCode_step_recover m hm g k
        have hsk := hstep k
        have hnext : lipschitzGridQuantizedValue m hm f k.succ =
            lipschitzGridQuantizedValue m hm g k.succ := by omega
        simpa [k] using hnext
  exact hind j.val j.isLt

/-- Every point of the unit interval lies within `1/m` of some point of the uniform `m`-grid.

**Lean implementation helper.** -/
lemma unitGridCover (m : ℕ) (hm : 0 < m) :
    ∀ x : UnitInterval, ∃ j : Fin (m + 1),
      dist x (unitGridPoint m hm j) ≤ 1 / (m : ℝ) := by
  intro x
  let q : ℕ := Nat.floor ((m : ℝ) * (x : ℝ))
  have hmR : (0 : ℝ) < m := by exact_mod_cast hm
  have hx0 : 0 ≤ (x : ℝ) := x.2.1
  have hqle : q ≤ m := by
    dsimp [q]
    apply Nat.floor_le_of_le
    nlinarith [x.2.2]
  let j : Fin (m + 1) := ⟨q, Nat.lt_succ_of_le hqle⟩
  refine ⟨j, ?_⟩
  rw [Subtype.dist_eq, Real.dist_eq]
  have hq_lower : (q : ℝ) ≤ (m : ℝ) * (x : ℝ) := by
    exact Nat.floor_le (mul_nonneg hmR.le hx0)
  have hq_upper : (m : ℝ) * (x : ℝ) < (q : ℝ) + 1 := by
    exact Nat.lt_floor_add_one _
  have hgridle : (q : ℝ) / m ≤ (x : ℝ) := by
    apply (div_le_iff₀ hmR).2
    nlinarith
  change |(x : ℝ) - (q : ℝ) / m| ≤ 1 / (m : ℝ)
  rw [abs_of_nonneg (sub_nonneg.mpr hgridle)]
  change (x : ℝ) - (q : ℝ) / m ≤ 1 / (m : ℝ)
  apply (sub_le_iff_le_add).2
  rw [show 1 / (m : ℝ) + (q : ℝ) / m = ((q : ℝ) + 1) / m by ring]
  apply (le_div_iff₀ hmR).2
  nlinarith

/-- Functions with the same grid code differ by at most `1/m` at each grid point.

**Lean implementation helper.** -/
lemma dist_le_inv_of_lipschitzGridCode_eq (m : ℕ) (hm : 0 < m)
    {f g : ↥unitIntervalLipschitzClass}
    (hcode : lipschitzGridCode m hm f = lipschitzGridCode m hm g)
    (j : Fin (m + 1)) :
    dist (f.1 (unitGridPoint m hm j)) (g.1 (unitGridPoint m hm j)) ≤
      1 / (m : ℝ) := by
  rw [Real.dist_eq]
  let a := (m : ℝ) * f.1 (unitGridPoint m hm j)
  let b := (m : ℝ) * g.1 (unitGridPoint m hm j)
  let q := lipschitzGridQuantizedValue m hm f j
  have hmR : (0 : ℝ) < m := by exact_mod_cast hm
  have ha0 : 0 ≤ a := mul_nonneg hmR.le (f.2.2 _).1
  have hb0 : 0 ≤ b := mul_nonneg hmR.le (g.2.2 _).1
  have hqeq := lipschitzGridCode_eq_imp_quantizedValue_eq m hm hcode j
  have hqa : (q : ℝ) ≤ a := by
    exact Nat.floor_le ha0
  have haq : a < (q : ℝ) + 1 := Nat.lt_floor_add_one _
  have hqb : (q : ℝ) ≤ b := by
    rw [show q = lipschitzGridQuantizedValue m hm g j from hqeq]
    exact Nat.floor_le hb0
  have hbq : b < (q : ℝ) + 1 := by
    rw [show q = lipschitzGridQuantizedValue m hm g j from hqeq]
    exact Nat.lt_floor_add_one _
  have hab : |a - b| ≤ 1 := (abs_le).2 ⟨by linarith, by linarith⟩
  have hscale : |a - b| = (m : ℝ) *
      |f.1 (unitGridPoint m hm j) - g.1 (unitGridPoint m hm j)| := by
    dsimp [a, b]
    calc
      |(m : ℝ) * f.1 (unitGridPoint m hm j) -
          (m : ℝ) * g.1 (unitGridPoint m hm j)| =
          |(m : ℝ) * (f.1 (unitGridPoint m hm j) -
            g.1 (unitGridPoint m hm j))| := by
        congr 1
        ring
      _ = |(m : ℝ)| *
          |f.1 (unitGridPoint m hm j) - g.1 (unitGridPoint m hm j)| :=
        abs_mul _ _
      _ = (m : ℝ) *
          |f.1 (unitGridPoint m hm j) - g.1 (unitGridPoint m hm j)| := by
        rw [abs_of_pos hmR]
  rw [hscale] at hab
  apply (le_div_iff₀ hmR).2
  nlinarith

/-- Two unit-Lipschitz functions with the same grid code are uniformly within `3/m` of one another.

**Lean implementation helper.** -/
lemma dist_le_three_div_of_lipschitzGridCode_eq (m : ℕ) (hm : 0 < m)
    {f g : ↥unitIntervalLipschitzClass}
    (hcode : lipschitzGridCode m hm f = lipschitzGridCode m hm g) :
    dist f.1 g.1 ≤ 3 / (m : ℝ) := by
  apply (BoundedContinuousFunction.dist_le (by positivity)).2
  intro x
  have hpoint := exercise_8_9_lipschitz_net_approximation
    (K := (1 : ℝ≥0)) (ε := 1 / (m : ℝ)) (δ := 1 / (m : ℝ))
    (S := Set.univ) (N := Set.range (unitGridPoint m hm))
    (f := f.1) (g := g.1)
    (fun y _ => by
      obtain ⟨j, hj⟩ := unitGridCover m hm y
      exact ⟨unitGridPoint m hm j, ⟨j, rfl⟩, hj⟩)
    f.2.1 g.2.1
    (fun y hy => by
      obtain ⟨j, rfl⟩ := hy
      exact dist_le_inv_of_lipschitzGridCode_eq m hm hcode j)
    x (Set.mem_univ x)
  calc
    dist (f.1 x) (g.1 x) ≤
        2 * ((1 : ℝ≥0) : ℝ) * (1 / (m : ℝ)) + 1 / (m : ℝ) := hpoint
    _ = 3 / (m : ℝ) := by norm_num; ring

/-- Chooses a unit-Lipschitz function realizing a valid grid code.

**Lean implementation helper.** -/
noncomputable def lipschitzGridRepresentative (m : ℕ) (hm : 0 < m)
    (c : LipschitzGridCode m) : ↥unitIntervalLipschitzClass := by
  classical
  exact
    if h : ∃ f : ↥unitIntervalLipschitzClass, lipschitzGridCode m hm f = c then
      Classical.choose h
    else
      ⟨Classical.choose unitIntervalLipschitzClass_nonempty,
        Classical.choose_spec unitIntervalLipschitzClass_nonempty⟩

/-- The chosen representative of a realizable grid code has exactly that code.

**Lean implementation helper.** -/
lemma lipschitzGridRepresentative_code (m : ℕ) (hm : 0 < m)
    (f : ↥unitIntervalLipschitzClass) :
    lipschitzGridCode m hm
        (lipschitzGridRepresentative m hm (lipschitzGridCode m hm f)) =
      lipschitzGridCode m hm f := by
  classical
  unfold lipschitzGridRepresentative
  rw [dif_pos (show ∃ g : ↥unitIntervalLipschitzClass,
      lipschitzGridCode m hm g = lipschitzGridCode m hm f from ⟨f, rfl⟩)]
  exact Classical.choose_spec (show ∃ g : ↥unitIntervalLipschitzClass,
      lipschitzGridCode m hm g = lipschitzGridCode m hm f from ⟨f, rfl⟩)

/-- Forms the finite set of chosen representatives of all realizable Lipschitz grid codes.

**Lean implementation helper.** -/
noncomputable def lipschitzGridNet (m : ℕ) (hm : 0 < m) :
    Finset (UnitInterval →ᵇ ℝ) := by
  classical
  exact (Finset.univ : Finset (LipschitzGridCode m)).image fun c =>
      (lipschitzGridRepresentative m hm c).1

/-- Shows that the finite Lipschitz grid net lies in the ambient source set.

**Lean implementation helper.** -/
lemma lipschitzGridNet_subset (m : ℕ) (hm : 0 < m) :
    (lipschitzGridNet m hm : Set (UnitInterval →ᵇ ℝ)) ⊆
      unitIntervalLipschitzClass := by
  classical
  intro f hf
  rcases Finset.mem_image.mp hf with ⟨c, hc, rfl⟩
  exact (lipschitzGridRepresentative m hm c).2

/-- The finite Lipschitz grid net contains at most `(m+1) · 3^m` functions.

**Lean implementation helper.** -/
lemma lipschitzGridNet_card_le (m : ℕ) (hm : 0 < m) :
    (lipschitzGridNet m hm).card ≤ (m + 1) * 3 ^ m := by
  classical
  calc
    (lipschitzGridNet m hm).card ≤ Fintype.card (LipschitzGridCode m) := by
      unfold lipschitzGridNet
      exact Finset.card_image_le.trans_eq Finset.card_univ
    _ = (m + 1) * 3 ^ m := by
      simp [LipschitzGridCode]

/-- The chosen grid representatives form a `3/m`-cover of the unit-Lipschitz class.

**Lean implementation helper.** -/
lemma lipschitzGridNet_isCover (m : ℕ) (hm : 0 < m) :
    Metric.IsCover (3 / (m : ℝ≥0)) unitIntervalLipschitzClass
      (lipschitzGridNet m hm : Set (UnitInterval →ᵇ ℝ)) := by
  classical
  intro f hf
  let fs : ↥unitIntervalLipschitzClass := ⟨f, hf⟩
  let c := lipschitzGridCode m hm fs
  let g : ↥unitIntervalLipschitzClass := lipschitzGridRepresentative m hm c
  refine ⟨g.1, ?_, ?_⟩
  · exact Finset.mem_coe.mpr <| Finset.mem_image.mpr
      ⟨c, Finset.mem_univ c, rfl⟩
  · have hcode : lipschitzGridCode m hm g = lipschitzGridCode m hm fs := by
      exact lipschitzGridRepresentative_code m hm fs
    have hd := dist_le_three_div_of_lipschitzGridCode_eq m hm hcode
    simp only [Set.mem_setOf_eq]
    rw [edist_dist]
    rw [ENNReal.coe_nnreal_eq]
    apply ENNReal.ofReal_le_ofReal
    simpa [fs, g, dist_comm] using hd

/-- Exercise 8.9 at the exact combinatorial grid scale.

**Book Exercise 8.9.** -/
theorem exercise_8_9_coveringNumber_grid (m : ℕ) (hm : 0 < m) :
    Metric.coveringNumber (3 / (m : ℝ≥0)) unitIntervalLipschitzClass ≤
      ((m + 1) * 3 ^ m : ℕ) := by
  calc
    Metric.coveringNumber (3 / (m : ℝ≥0)) unitIntervalLipschitzClass ≤
        ((lipschitzGridNet m hm : Set (UnitInterval →ᵇ ℝ)).encard) :=
      (lipschitzGridNet_isCover m hm).coveringNumber_le_encard
        (lipschitzGridNet_subset m hm)
    _ = ((lipschitzGridNet m hm).card : ℕ∞) := by simp
    _ ≤ (((m + 1) * 3 ^ m : ℕ) : ℕ∞) := by
      exact_mod_cast lipschitzGridNet_card_le m hm

/-- For `3/m ≤ ε`, the unit-Lipschitz class has covering number at most `(m+1) · 3^m`.

**Lean implementation helper.** -/
theorem exercise_8_9_coveringNumber_of_grid {ε : ℝ≥0}
    (m : ℕ) (hm : 0 < m) (hmesh : (3 / (m : ℝ≥0)) ≤ ε) :
    Metric.coveringNumber ε unitIntervalLipschitzClass ≤
      ((m + 1) * 3 ^ m : ℕ) := by
  exact (Metric.coveringNumber_anti hmesh).trans
    (exercise_8_9_coveringNumber_grid m hm)

/-- The logarithm of the grid-code count `(m+1) · 3^m` is at most `3m`.

**Lean implementation helper.** -/
lemma log_lipschitzGridCode_card_le (m : ℕ) :
    Real.log (((m + 1) * 3 ^ m : ℕ) : ℝ) ≤ 3 * m := by
  rw [Nat.cast_mul, Nat.cast_pow, Real.log_mul (by positivity) (by positivity),
    Real.log_pow]
  norm_num only [Nat.cast_add, Nat.cast_one, Nat.cast_ofNat]
  have hfirst : Real.log ((m : ℝ) + 1) ≤ m := by
    simpa using Real.log_le_sub_one_of_pos (show 0 < (m : ℝ) + 1 by positivity)
  have hthree : Real.log (3 : ℝ) ≤ 2 := by
    have hthreeRaw :=
      Real.log_le_sub_one_of_pos (show (0 : ℝ) < 3 by norm_num)
    norm_num at hthreeRaw
    exact hthreeRaw
  have hm0 : (0 : ℝ) ≤ m := by positivity
  calc
    Real.log ((m : ℝ) + 1) + (m : ℝ) * Real.log 3 ≤
        (m : ℝ) + (m : ℝ) * 2 :=
      add_le_add hfirst (mul_le_mul_of_nonneg_left hthree hm0)
    _ = 3 * m := by ring

/-- Exact covering-entropy estimate for the full class
of `[0,1]`-valued one-Lipschitz functions on `[0,1]`. The constant is explicit: `log N(F, ‖·‖∞, ε) ≤ 12/ε` for `0 < ε ≤ 1`.
The covering number is Mathlib's authoritative extended-natural internal
covering number; the first conjunct certifies that its safe `toNat` value is
finite.

**Book Exercise 8.9.** -/
theorem exercise_8_9_lipschitz_coveringEntropy {ε : ℝ≥0}
    (hε : 0 < ε) (hε1 : ε ≤ 1) :
    Metric.coveringNumber ε unitIntervalLipschitzClass ≠ ⊤ ∧
      Real.log ((Metric.coveringNumber ε
        unitIntervalLipschitzClass).toNat : ℝ) ≤ 12 / (ε : ℝ) := by
  let m : ℕ := Nat.ceil (3 / (ε : ℝ))
  have hεR : (0 : ℝ) < ε := by exact_mod_cast hε
  have hεR1 : (ε : ℝ) ≤ 1 := by exact_mod_cast hε1
  have harg : (0 : ℝ) < 3 / (ε : ℝ) := by positivity
  have hm : 0 < m := Nat.ceil_pos.mpr harg
  have hm_lower : 3 / (ε : ℝ) ≤ (m : ℝ) := by
    exact Nat.le_ceil _
  have hmeshR : 3 / (m : ℝ) ≤ (ε : ℝ) := by
    have hmul : (3 : ℝ) ≤ (m : ℝ) * (ε : ℝ) :=
      (div_le_iff₀ hεR).mp hm_lower
    apply (div_le_iff₀ (show (0 : ℝ) < m by exact_mod_cast hm)).2
    simpa [mul_comm] using hmul
  have hmesh : (3 / (m : ℝ≥0)) ≤ ε := by
    exact_mod_cast hmeshR
  have hcover := exercise_8_9_coveringNumber_of_grid m hm hmesh
  have hfinite : Metric.coveringNumber ε unitIntervalLipschitzClass ≠ ⊤ :=
    ne_top_of_le_ne_top (ENat.coe_ne_top _) hcover
  refine ⟨hfinite, ?_⟩
  have hnat : (Metric.coveringNumber ε
      unitIntervalLipschitzClass).toNat ≤ (m + 1) * 3 ^ m := by
    exact ENat.toNat_le_toNat hcover (ENat.coe_ne_top _)
  have hcast : ((Metric.coveringNumber ε
      unitIntervalLipschitzClass).toNat : ℝ) ≤
      (((m + 1) * 3 ^ m : ℕ) : ℝ) := by exact_mod_cast hnat
  have hposNat : 0 < (Metric.coveringNumber ε
      unitIntervalLipschitzClass).toNat := by
    have hpos : (0 : ℕ∞) < Metric.coveringNumber ε
        unitIntervalLipschitzClass :=
      Metric.coveringNumber_pos_iff.mpr unitIntervalLipschitzClass_nonempty
    rw [← ENat.coe_toNat hfinite] at hpos
    exact_mod_cast hpos
  have hlogmono : Real.log ((Metric.coveringNumber ε
      unitIntervalLipschitzClass).toNat : ℝ) ≤
      Real.log (((m + 1) * 3 ^ m : ℕ) : ℝ) := by
    apply Real.log_le_log
    · exact_mod_cast hposNat
    · exact hcast
  have hlogcard := log_lipschitzGridCode_card_le m
  have hm_upper : (m : ℝ) ≤ 4 / (ε : ℝ) := by
    have hmceil : (m : ℝ) < 3 / (ε : ℝ) + 1 := by
      exact_mod_cast Nat.ceil_lt_add_one harg.le
    have hone : (1 : ℝ) ≤ 1 / (ε : ℝ) := by
      apply (le_div_iff₀ hεR).2
      simpa using hεR1
    calc
      (m : ℝ) ≤ 3 / (ε : ℝ) + 1 := hmceil.le
      _ ≤ 3 / (ε : ℝ) + 1 / (ε : ℝ) :=
        by simpa [add_comm] using add_le_add_left hone (3 / (ε : ℝ))
      _ = 4 / (ε : ℝ) := by ring
  calc
    Real.log ((Metric.coveringNumber ε
        unitIntervalLipschitzClass).toNat : ℝ) ≤
        Real.log (((m + 1) * 3 ^ m : ℕ) : ℝ) := hlogmono
    _ ≤ 3 * (m : ℝ) := hlogcard
    _ ≤ 12 / (ε : ℝ) := by
      calc
        3 * (m : ℝ) ≤ 3 * (4 / (ε : ℝ)) :=
          mul_le_mul_of_nonneg_left hm_upper (by norm_num)
        _ = 12 / (ε : ℝ) := by ring

/-- Construct a small covering net for the Lipschitz class. The literal exponential form printed in Exercise 8.9.

**Book Exercise 8.9.** -/
theorem exercise_8_9_lipschitz_coveringNumber_exp {ε : ℝ≥0}
    (hε : 0 < ε) (hε1 : ε ≤ 1) :
    ((Metric.coveringNumber ε unitIntervalLipschitzClass).toNat : ℝ) ≤
      Real.exp (12 / (ε : ℝ)) := by
  have h := (exercise_8_9_lipschitz_coveringEntropy hε hε1).2
  have hfinite := (exercise_8_9_lipschitz_coveringEntropy hε hε1).1
  have hpos : 0 < (Metric.coveringNumber ε
      unitIntervalLipschitzClass).toNat := by
    have hp : (0 : ℕ∞) < Metric.coveringNumber ε
        unitIntervalLipschitzClass :=
      Metric.coveringNumber_pos_iff.mpr unitIntervalLipschitzClass_nonempty
    rw [← ENat.coe_toNat hfinite] at hp
    exact_mod_cast hp
  rw [← Real.exp_log (show (0 : ℝ) <
    (Metric.coveringNumber ε unitIntervalLipschitzClass).toNat by exact_mod_cast hpos)]
  exact Real.exp_le_exp.mpr h

/-! ## The full, measurable Lipschitz empirical supremum -/

/-- The literal supremum in the normalized form (8.24) of Theorem 8.2.3.

**Book Theorem 8.2.3.** -/
def unitIntervalEmpiricalSup {n : ℕ} (ν : Measure UnitInterval)
    (sample : Fin n → UnitInterval) : ℝ :=
  sSup (Set.range fun f : ↥unitIntervalLipschitzClass =>
    |empiricalProcessValue ν sample f.1|)

/-- The empirical average of a bounded continuous function with range in `[-1,1]` has absolute value at most `1`.

**Lean implementation helper.** -/
lemma abs_empiricalAverage_bcf_le_one {n : ℕ} (hn : 0 < n)
    (sample : Fin n → UnitInterval) (f : ↥unitIntervalLipschitzClass) :
    |empiricalAverage sample f.1| ≤ 1 := by
  have hnR : (0 : ℝ) < n := by exact_mod_cast hn
  have hterm (i : Fin n) : |f.1 (sample i)| ≤ 1 := by
    rw [abs_of_nonneg (f.2.2 (sample i)).1]
    exact (f.2.2 (sample i)).2
  unfold empiricalAverage
  rw [abs_mul, abs_of_nonneg (inv_nonneg.mpr hnR.le)]
  calc
    (n : ℝ)⁻¹ * |∑ i, f.1 (sample i)| ≤
        (n : ℝ)⁻¹ * ∑ i, |f.1 (sample i)| := by
      gcongr
      exact Finset.abs_sum_le_sum_abs _ _
    _ ≤ (n : ℝ)⁻¹ * ∑ _i : Fin n, (1 : ℝ) := by
      gcongr with i
      exact hterm i
    _ = 1 := by simp [hn.ne']

/-- The integral of a bounded continuous function with range in `[-1,1]` has absolute value at most `1`.

**Lean implementation helper.** -/
lemma abs_integral_bcf_le_one [IsProbabilityMeasure ν]
    (f : ↥unitIntervalLipschitzClass) :
    |∫ x, f.1 x ∂ν| ≤ 1 := by
  have h := norm_integral_le_of_norm_le_const (μ := ν)
    (Filter.Eventually.of_forall fun x => by
      rw [Real.norm_eq_abs, abs_of_nonneg (f.2.2 x).1]
      exact (f.2.2 x).2)
  simpa [Real.norm_eq_abs] using h

/-- The centered empirical-process value of a `[-1,1]`-valued bounded continuous function has absolute value at most `2`.

**Lean implementation helper.** -/
lemma abs_empiricalProcessValue_bcf_le_two [IsProbabilityMeasure ν]
    {n : ℕ} (hn : 0 < n) (sample : Fin n → UnitInterval)
    (f : ↥unitIntervalLipschitzClass) :
    |empiricalProcessValue ν sample f.1| ≤ 2 := by
  unfold empiricalProcessValue
  calc
    |empiricalAverage sample f.1 - ∫ x, f.1 x ∂ν| ≤
        |empiricalAverage sample f.1| + |∫ x, f.1 x ∂ν| := abs_sub _ _
    _ ≤ 1 + 1 := add_le_add
      (abs_empiricalAverage_bcf_le_one hn sample f)
      (abs_integral_bcf_le_one f)
    _ = 2 := by norm_num

/-- Absolute empirical-process values over the unit-Lipschitz class are bounded above.

**Lean implementation helper.** -/
lemma unitIntervalEmpiricalSup_range_bddAbove [IsProbabilityMeasure ν]
    {n : ℕ} (hn : 0 < n) (sample : Fin n → UnitInterval) :
    BddAbove (Set.range fun f : ↥unitIntervalLipschitzClass =>
      |empiricalProcessValue ν sample f.1|) := by
  refine ⟨2, ?_⟩
  rintro y ⟨f, rfl⟩
  exact abs_empiricalProcessValue_bcf_le_two hn sample f

/-- Shows that the empirical-process supremum over unit-Lipschitz functions is nonnegative.

**Lean implementation helper.** -/
lemma unitIntervalEmpiricalSup_nonneg [IsProbabilityMeasure ν]
    {n : ℕ} (hn : 0 < n) (sample : Fin n → UnitInterval) :
    0 ≤ unitIntervalEmpiricalSup ν sample := by
  obtain ⟨f, hf⟩ := unitIntervalLipschitzClass_nonempty
  let fs : ↥unitIntervalLipschitzClass := ⟨f, hf⟩
  exact (abs_nonneg (empiricalProcessValue ν sample fs.1)).trans
    (le_csSup (unitIntervalEmpiricalSup_range_bddAbove hn sample)
      (Set.mem_range_self fs))

/-- The empirical-process supremum over unit-Lipschitz functions is at most `2`.

**Lean implementation helper.** -/
lemma unitIntervalEmpiricalSup_le_two [IsProbabilityMeasure ν]
    {n : ℕ} (hn : 0 < n) (sample : Fin n → UnitInterval) :
    unitIntervalEmpiricalSup ν sample ≤ 2 := by
  apply csSup_le
  · obtain ⟨f, hf⟩ := unitIntervalLipschitzClass_nonempty
    exact ⟨|empiricalProcessValue ν sample f|, ⟨⟨f, hf⟩, rfl⟩⟩
  · rintro y ⟨f, rfl⟩
    exact abs_empiricalProcessValue_bcf_le_two hn sample f

/-- The difference of empirical averages of two bounded continuous functions is at most their uniform distance.

**Lean implementation helper.** -/
lemma abs_empiricalAverage_bcf_sub_le_dist {n : ℕ} (hn : 0 < n)
    (sample : Fin n → UnitInterval) (f g : UnitInterval →ᵇ ℝ) :
    |empiricalAverage sample f - empiricalAverage sample g| ≤ dist f g := by
  have hnR : (0 : ℝ) < n := by exact_mod_cast hn
  have hterm (i : Fin n) : |f (sample i) - g (sample i)| ≤ dist f g := by
    simpa [Real.norm_eq_abs] using
      (f.abs_sub_coe_le_dist g (x := sample i))
  unfold empiricalAverage
  rw [← mul_sub, ← Finset.sum_sub_distrib, abs_mul,
    abs_of_nonneg (inv_nonneg.mpr hnR.le)]
  calc
    (n : ℝ)⁻¹ * |∑ i, (f (sample i) - g (sample i))| ≤
        (n : ℝ)⁻¹ * ∑ i, |f (sample i) - g (sample i)| := by
      gcongr
      exact Finset.abs_sum_le_sum_abs _ _
    _ ≤ (n : ℝ)⁻¹ * ∑ _i : Fin n, dist f g := by
      gcongr with i
      exact hterm i
    _ = dist f g := by simp [hn.ne']

/-- The difference of the integrals of two bounded continuous functions is at most their uniform distance.

**Lean implementation helper.** -/
lemma abs_integral_bcf_sub_le_dist [OpensMeasurableSpace UnitInterval]
    [IsProbabilityMeasure ν]
    (f g : UnitInterval →ᵇ ℝ) :
    |(∫ x, f x ∂ν) - ∫ x, g x ∂ν| ≤ dist f g := by
  rw [← integral_sub (BoundedContinuousFunction.integrable ν f)
    (BoundedContinuousFunction.integrable ν g)]
  have h := norm_integral_le_of_norm_le_const (μ := ν)
    (f := fun x => f x - g x)
    (C := dist f g) (Filter.Eventually.of_forall fun x => by
      simpa [Real.norm_eq_abs] using f.abs_sub_coe_le_dist g (x := x))
  simpa [Real.norm_eq_abs] using h

/-- The difference of two empirical-process values is at most twice the uniform distance between their functions.

**Lean implementation helper.** -/
lemma abs_empiricalProcessValue_bcf_sub_le_two_dist
    [OpensMeasurableSpace UnitInterval] [IsProbabilityMeasure ν]
    {n : ℕ} (hn : 0 < n)
    (sample : Fin n → UnitInterval) (f g : UnitInterval →ᵇ ℝ) :
    |empiricalProcessValue ν sample f -
        empiricalProcessValue ν sample g| ≤ 2 * dist f g := by
  have havg := abs_empiricalAverage_bcf_sub_le_dist hn sample f g
  have hint := abs_integral_bcf_sub_le_dist (ν := ν) f g
  unfold empiricalProcessValue
  calc
    |(empiricalAverage sample f - ∫ x, f x ∂ν) -
        (empiricalAverage sample g - ∫ x, g x ∂ν)| =
        |(empiricalAverage sample f - empiricalAverage sample g) -
          ((∫ x, f x ∂ν) - ∫ x, g x ∂ν)| := by
      congr 1
      all_goals ring
    _ ≤ |empiricalAverage sample f - empiricalAverage sample g| +
        |(∫ x, f x ∂ν) - ∫ x, g x ∂ν| := abs_sub _ _
    _ ≤ dist f g + dist f g := add_le_add havg hint
    _ = 2 * dist f g := by ring

/-- Shows that the finite Lipschitz grid net is nonempty.

**Lean implementation helper.** -/
lemma lipschitzGridNet_nonempty (m : ℕ) (hm : 0 < m) :
    (lipschitzGridNet m hm).Nonempty := by
  classical
  obtain ⟨f, hf⟩ := unitIntervalLipschitzClass_nonempty
  let fs : ↥unitIntervalLipschitzClass := ⟨f, hf⟩
  let c := lipschitzGridCode m hm fs
  exact ⟨(lipschitzGridRepresentative m hm c).1,
    Finset.mem_image.mpr ⟨c, Finset.mem_univ c, rfl⟩⟩

/-- Finite measurable approximation to the full empirical supremum.

**Lean implementation helper.** -/
noncomputable def lipschitzGridNetEmpiricalSup (m : ℕ) (hm : 0 < m)
    {n : ℕ} (ν : Measure UnitInterval) (sample : Fin n → UnitInterval) : ℝ :=
  by
    classical
    exact (lipschitzGridNet m hm).sup' (lipschitzGridNet_nonempty m hm)
      fun f => |empiricalProcessValue ν sample f|

/-- Shows that the empirical supremum over the finite grid net is measurable.

**Lean implementation helper.** -/
lemma measurable_lipschitzGridNetEmpiricalSup
    [OpensMeasurableSpace UnitInterval] [IsProbabilityMeasure ν]
    {n : ℕ} (m : ℕ) (hm : 0 < m) (X : Fin n → Ω → UnitInterval)
    (hXm : ∀ i, Measurable (X i)) :
    Measurable (fun ω => lipschitzGridNetEmpiricalSup m hm ν (fun i => X i ω)) := by
  classical
  unfold lipschitzGridNetEmpiricalSup
  have hraw : Measurable
      ((lipschitzGridNet m hm).sup' (lipschitzGridNet_nonempty m hm)
        fun f => fun ω => |empiricalProcessValue ν (fun i => X i ω) f|) := by
    apply Finset.measurable_sup' (lipschitzGridNet_nonempty m hm)
    intro f hf
    apply Measurable.abs
    unfold empiricalProcessValue empiricalAverage
    apply Measurable.sub_const
    apply Measurable.const_mul
    apply Finset.measurable_sum
    intro i _
    exact f.continuous.measurable.comp (hXm i)
  have heq :
      ((lipschitzGridNet m hm).sup' (lipschitzGridNet_nonempty m hm)
        fun f => fun ω => |empiricalProcessValue ν (fun i => X i ω) f|) =
      (fun ω => (lipschitzGridNet m hm).sup'
        (lipschitzGridNet_nonempty m hm)
          fun f => |empiricalProcessValue ν (fun i => X i ω) f|) := by
    funext ω
    simp only [Finset.sup'_apply]
  rw [← heq]
  exact hraw

/-- The empirical supremum over the finite grid net is no larger than the supremum over the full unit-Lipschitz class.

**Lean implementation helper.** -/
lemma lipschitzGridNetEmpiricalSup_le_full [IsProbabilityMeasure ν]
    {n : ℕ} (hn : 0 < n) (m : ℕ) (hm : 0 < m)
    (sample : Fin n → UnitInterval) :
    lipschitzGridNetEmpiricalSup m hm ν sample ≤
      unitIntervalEmpiricalSup ν sample := by
  apply Finset.sup'_le
  intro f hf
  let fs : ↥unitIntervalLipschitzClass :=
    ⟨f, lipschitzGridNet_subset m hm (Finset.mem_coe.mpr hf)⟩
  exact le_csSup (unitIntervalEmpiricalSup_range_bddAbove hn sample)
    (Set.mem_range_self fs)

/-- The full unit-Lipschitz empirical supremum is at most the grid-net supremum plus `6/m`.

**Lean implementation helper.** -/
lemma unitIntervalEmpiricalSup_le_lipschitzGridNet
    [OpensMeasurableSpace UnitInterval] [IsProbabilityMeasure ν]
    {n : ℕ} (hn : 0 < n) (m : ℕ) (hm : 0 < m)
    (sample : Fin n → UnitInterval) :
    unitIntervalEmpiricalSup ν sample ≤
      lipschitzGridNetEmpiricalSup m hm ν sample + 6 / (m : ℝ) := by
  apply csSup_le
  · obtain ⟨f, hf⟩ := unitIntervalLipschitzClass_nonempty
    exact ⟨|empiricalProcessValue ν sample f|, ⟨⟨f, hf⟩, rfl⟩⟩
  · rintro y ⟨f, rfl⟩
    obtain ⟨g, hgnet, hfg⟩ := lipschitzGridNet_isCover m hm f.2
    have hfgR : dist f.1 g ≤ 3 / (m : ℝ) := by
      have hfg' : edist f.1 g ≤ ((3 / (m : ℝ≥0) : ℝ≥0) : ℝ≥0∞) := by
        simpa only [Set.mem_setOf_eq] using hfg
      have ht := ENNReal.toReal_mono (by simp) hfg'
      rw [edist_dist, ENNReal.toReal_ofReal dist_nonneg,
        ENNReal.coe_toReal] at ht
      exact_mod_cast ht
    have hproc := abs_empiricalProcessValue_bcf_sub_le_two_dist
      (ν := ν) hn sample f.1 g
    have habs : |empiricalProcessValue ν sample f.1| ≤
        |empiricalProcessValue ν sample g| + 2 * dist f.1 g := by
      calc
        |empiricalProcessValue ν sample f.1| =
            |empiricalProcessValue ν sample g +
              (empiricalProcessValue ν sample f.1 -
                empiricalProcessValue ν sample g)| := by
          congr 1
          ring
        _ ≤
            |empiricalProcessValue ν sample g| +
              |empiricalProcessValue ν sample f.1 -
                empiricalProcessValue ν sample g| := by
          exact abs_add_le
            (empiricalProcessValue ν sample g : ℝ)
            (empiricalProcessValue ν sample f.1 -
              empiricalProcessValue ν sample g)
        _ ≤ |empiricalProcessValue ν sample g| + 2 * dist f.1 g :=
          by gcongr
    calc
      |empiricalProcessValue ν sample f.1| ≤
          |empiricalProcessValue ν sample g| + 2 * dist f.1 g := habs
      _ ≤ lipschitzGridNetEmpiricalSup m hm ν sample +
          2 * (3 / (m : ℝ)) := by
        apply add_le_add
        · unfold lipschitzGridNetEmpiricalSup
          have hgfin : g ∈ lipschitzGridNet m hm := by exact hgnet
          exact Finset.le_sup' (s := lipschitzGridNet m hm)
            (fun h => |empiricalProcessValue ν sample h|) hgfin
        · exact mul_le_mul_of_nonneg_left hfgR (by norm_num)
      _ = lipschitzGridNetEmpiricalSup m hm ν sample + 6 / (m : ℝ) := by ring

/-- Shows that the empirical-process supremum over unit-Lipschitz functions is measurable.

**Lean implementation helper.** -/
lemma measurable_unitIntervalEmpiricalSup
    [OpensMeasurableSpace UnitInterval] [IsProbabilityMeasure ν]
    {n : ℕ} (hn : 0 < n) (X : Fin n → Ω → UnitInterval)
    (hXm : ∀ i, Measurable (X i)) :
    Measurable (fun ω => unitIntervalEmpiricalSup ν (fun i => X i ω)) := by
  let Z : ℕ → Ω → ℝ := fun k ω =>
    lipschitzGridNetEmpiricalSup (k + 1) (by omega) ν (fun i => X i ω)
  apply measurable_of_tendsto_metrizable (f := Z)
  · intro k
    exact measurable_lipschitzGridNetEmpiricalSup (k + 1) (by omega) X hXm
  · rw [tendsto_pi_nhds]
    intro ω
    have hdiff : Tendsto (fun k =>
        unitIntervalEmpiricalSup ν (fun i => X i ω) - Z k ω)
        atTop (nhds 0) := by
      apply squeeze_zero'
      · exact Filter.Eventually.of_forall fun k =>
          sub_nonneg.mpr (lipschitzGridNetEmpiricalSup_le_full (ν := ν) hn (k + 1)
            (by omega) (fun i => X i ω))
      · exact Filter.Eventually.of_forall fun k => by
          have h := unitIntervalEmpiricalSup_le_lipschitzGridNet (ν := ν) hn (k + 1)
            (by omega) (fun i => X i ω)
          simpa [Z] using sub_le_iff_le_add'.2 h
      · simpa [div_eq_mul_inv] using
          (tendsto_one_div_add_atTop_nhds_zero_nat (𝕜 := ℝ)).const_mul 6
    have heq : (fun k => Z k ω) = fun k =>
        unitIntervalEmpiricalSup ν (fun i => X i ω) -
          (unitIntervalEmpiricalSup ν (fun i => X i ω) - Z k ω) := by
      funext k
      ring
    rw [heq]
    have hc : Tendsto
        (fun _ : ℕ => unitIntervalEmpiricalSup ν (fun i => X i ω))
        atTop (nhds (unitIntervalEmpiricalSup ν (fun i => X i ω))) :=
      tendsto_const_nhds
    simpa using hc.sub hdiff

/-- Shows that the empirical-process supremum over unit-Lipschitz functions is integrable.

**Lean implementation helper.** -/
lemma integrable_unitIntervalEmpiricalSup [IsProbabilityMeasure P]
    [OpensMeasurableSpace UnitInterval] [IsProbabilityMeasure ν]
    {n : ℕ} (hn : 0 < n)
    (X : Fin n → Ω → UnitInterval) (hXm : ∀ i, Measurable (X i)) :
    Integrable (fun ω => unitIntervalEmpiricalSup ν (fun i => X i ω)) P := by
  refine Integrable.of_bound
    (measurable_unitIntervalEmpiricalSup hn X hXm).aestronglyMeasurable 2 ?_
  exact Filter.Eventually.of_forall fun ω => by
    rw [Real.norm_eq_abs, abs_of_nonneg (unitIntervalEmpiricalSup_nonneg hn _)]
    exact unitIntervalEmpiricalSup_le_two hn _

/-! ## Finite-domain estimate for the full function class -/

/-- The left-endpoint projection onto the uniform `m`-grid.

**Lean implementation helper.** -/
def unitGridIndex (m : ℕ) (hm : 0 < m) (x : UnitInterval) : Fin (m + 1) :=
  ⟨Nat.floor ((m : ℝ) * (x : ℝ)), by
    apply Nat.lt_succ_of_le
    apply Nat.floor_le_of_le
    have hmR : (0 : ℝ) ≤ m := by positivity
    nlinarith [x.2.2]⟩

/-- Shows that the nearest lower grid index is measurable.

**Lean implementation helper.** -/
lemma measurable_unitGridIndex [OpensMeasurableSpace UnitInterval]
    (m : ℕ) (hm : 0 < m) : Measurable (unitGridIndex m hm) := by
  have hfloor : Measurable (fun x : UnitInterval =>
      Nat.floor ((m : ℝ) * (x : ℝ))) :=
    (measurable_const.mul measurable_subtype_coe).nat_floor
  apply measurable_to_countable'
  intro j
  have hj := hfloor (measurableSet_singleton j.val)
  convert hj using 1
  ext x
  simp [unitGridIndex, Fin.ext_iff]

/-- The lower grid point selected for `x` lies within `1/m` of `x`.

**Lean implementation helper.** -/
lemma dist_unitGridIndex_point_le (m : ℕ) (hm : 0 < m)
    (x : UnitInterval) :
    dist x (unitGridPoint m hm (unitGridIndex m hm x)) ≤ 1 / (m : ℝ) := by
  have hmR : (0 : ℝ) < m := by exact_mod_cast hm
  have hx0 : 0 ≤ (x : ℝ) := x.2.1
  let q : ℕ := Nat.floor ((m : ℝ) * (x : ℝ))
  have hq_lower : (q : ℝ) ≤ (m : ℝ) * (x : ℝ) :=
    Nat.floor_le (mul_nonneg hmR.le hx0)
  have hq_upper : (m : ℝ) * (x : ℝ) < (q : ℝ) + 1 :=
    Nat.lt_floor_add_one _
  have hgridle : (q : ℝ) / m ≤ (x : ℝ) := by
    apply (div_le_iff₀ hmR).2
    simpa [mul_comm] using hq_lower
  rw [Subtype.dist_eq, Real.dist_eq]
  change |(x : ℝ) - (q : ℝ) / m| ≤ 1 / (m : ℝ)
  rw [abs_of_nonneg (sub_nonneg.mpr hgridle)]
  apply (sub_le_iff_le_add).2
  rw [show 1 / (m : ℝ) + (q : ℝ) / m = ((q : ℝ) + 1) / m by ring]
  apply (le_div_iff₀ hmR).2
  simpa [mul_comm] using hq_upper.le

/-- Shows that the uniform grid point is monotone.

**Lean implementation helper.** -/
lemma unitGridPoint_monotone (m : ℕ) (hm : 0 < m) :
    Monotone (fun j : Fin (m + 1) => (unitGridPoint m hm j : ℝ)) := by
  intro i j hij
  apply (div_le_div_iff_of_pos_right (show (0 : ℝ) < m by exact_mod_cast hm)).2
  exact_mod_cast hij

/-- The increments between successive points of the uniform unit grid sum to `1`.

**Lean implementation helper.** -/
lemma sum_unitGrid_gaps (m : ℕ) (hm : 0 < m) :
    (∑ k : Fin m,
      chainIncrement (fun j : Fin (m + 1) =>
        (unitGridPoint m hm j : ℝ)) k) = 1 := by
  rw [sum_chainIncrement]
  simp [unitGridPoint, hm.ne']

/-- Pushing a measure and sample through the grid embedding transports the empirical-process value by composition.

**Lean implementation helper.** -/
lemma empiricalProcessValue_map_unitGridPoint
    [OpensMeasurableSpace UnitInterval] {m n : ℕ} (hm : 0 < m)
    (ρ : Measure (Fin (m + 1))) (sample : Fin n → Fin (m + 1))
    (f : UnitInterval →ᵇ ℝ) :
    empiricalProcessValue (Measure.map (unitGridPoint m hm) ρ)
        (fun i => unitGridPoint m hm (sample i)) f =
      empiricalProcessValue ρ sample (fun j => f (unitGridPoint m hm j)) := by
  unfold empiricalProcessValue empiricalAverage
  congr 1
  rw [integral_map (measurable_of_finite _).aemeasurable
    f.continuous.measurable.aestronglyMeasurable]

/-- The normalized full Lipschitz class satisfies the source bound on every
finite uniform grid. Unlike the older finite-class wrapper, the supremum here
is over every function in (8.24).

**Book Equation (8.24).** -/
theorem expected_unitIntervalEmpiricalSup_on_grid
    [OpensMeasurableSpace UnitInterval] [IsProbabilityMeasure P]
    {m n : ℕ} (hm : 0 < m) (hn : 0 < n)
    {ρ : Measure (Fin (m + 1))} [IsProbabilityMeasure ρ]
    (X : Fin n → Ω → Fin (m + 1)) (hXm : ∀ i, Measurable (X i))
    (hLaw : ∀ i, IdentDistrib (X i)
      (id : Fin (m + 1) → Fin (m + 1)) P ρ)
    (hindep : Set.Pairwise Set.univ fun i j => IndepFun (X i) (X j) P) :
    (∫ ω, unitIntervalEmpiricalSup (Measure.map (unitGridPoint m hm) ρ)
      (fun i => unitGridPoint m hm (X i ω)) ∂P) ≤ 1 / Real.sqrt n := by
  let grid : Fin (m + 1) → UnitInterval := unitGridPoint m hm
  have hgridm : Measurable grid := measurable_of_finite _
  letI : IsProbabilityMeasure (Measure.map grid ρ) :=
    Measure.isProbabilityMeasure_map hgridm.aemeasurable
  let gap : Fin m → ℝ := fun k =>
    (grid k.succ : ℝ) - (grid k.castSucc : ℝ)
  let E : Fin m → Ω → ℝ := fun k ω =>
    empiricalProcessValue ρ (fun i => X i ω) (chainUpperIndicator k)
  let D : Ω → ℝ := fun ω => ∑ k, gap k * |E k ω|
  have hgap (k : Fin m) : 0 ≤ gap k := by
    exact sub_nonneg.mpr (unitGridPoint_monotone m hm (Fin.castSucc_le_succ k))
  have hsumGap : ∑ k, gap k = 1 := by
    simpa only [gap, grid, chainIncrement] using sum_unitGrid_gaps m hm
  have hEmeas (k : Fin m) : Measurable (E k) := by
    unfold E empiricalProcessValue empiricalAverage
    apply Measurable.sub_const
    apply Measurable.const_mul
    apply Finset.measurable_sum
    intro i _
    exact (measurable_of_finite (chainUpperIndicator k)).comp (hXm i)
  have hEint (k : Fin m) : Integrable (E k) P := by
    let h : Fin (m + 1) → ℝ := chainUpperIndicator k
    have hhMeas : Measurable h := measurable_of_finite _
    have hhInt : Integrable h ρ := chainUpperIndicator_integrable k
    have hYi : ∀ i, Integrable (fun ω => h (X i ω)) P := fun i => by
      have hid : IdentDistrib (fun ω => h (X i ω)) h P ρ := by
        simpa [Function.comp_def] using (hLaw i).comp hhMeas
      exact hid.integrable_iff.mpr hhInt
    have havg := integrable_monteCarloAverage X h hYi
    have hproc := havg.sub (integrable_const (∫ x, h x ∂ρ))
    change Integrable (fun ω => monteCarloAverage X h ω - ∫ x, h x ∂ρ) P
    have heq : (fun ω => monteCarloAverage X h ω - ∫ x, h x ∂ρ) =
        monteCarloAverage X h - fun _ => ∫ x, h x ∂ρ := by
      funext ω
      rfl
    rw [heq]
    exact hproc
  have hDint : Integrable D P :=
    integrable_finsetSum Finset.univ fun k _ => (hEint k).abs.const_mul (gap k)
  have hDnonneg (ω : Ω) : 0 ≤ D ω :=
    Finset.sum_nonneg fun k _ => mul_nonneg (hgap k) (abs_nonneg _)
  have hpoint (ω : Ω) :
      unitIntervalEmpiricalSup (Measure.map grid ρ)
        (fun i => grid (X i ω)) ≤ D ω := by
    apply csSup_le
    · obtain ⟨f, hf⟩ := unitIntervalLipschitzClass_nonempty
      exact ⟨|empiricalProcessValue (Measure.map grid ρ)
        (fun i => grid (X i ω)) f|, ⟨⟨f, hf⟩, rfl⟩⟩
    · rintro y ⟨f, rfl⟩
      let g : Fin (m + 1) → ℝ := fun j => f.1 (grid j)
      have hdecomp := empiricalProcessValue_chain_decomposition (ν := ρ) hn
        (fun i => X i ω) g
      have hinc (k : Fin m) : |chainIncrement g k| ≤ gap k := by
        have hd := f.2.1.dist_le_mul (grid k.succ) (grid k.castSucc)
        have hgridDist : dist (grid k.succ) (grid k.castSucc) = gap k := by
          rw [Subtype.dist_eq, Real.dist_eq, abs_of_nonneg (hgap k)]
        simpa [g, chainIncrement, hgridDist, Real.dist_eq] using hd
      have hmap : empiricalProcessValue (Measure.map grid ρ)
          (fun i => grid (X i ω)) f.1 =
          empiricalProcessValue ρ (fun i => X i ω) g := by
        simpa [grid, g] using
          (empiricalProcessValue_map_unitGridPoint hm ρ
            (fun i => X i ω) f.1)
      change |empiricalProcessValue (Measure.map grid ρ)
        (fun i => grid (X i ω)) f.1| ≤ D ω
      rw [hmap]
      calc
        |empiricalProcessValue ρ (fun i => X i ω) g| =
            |∑ k, chainIncrement g k * E k ω| := by rw [hdecomp]
        _ ≤ ∑ k, |chainIncrement g k * E k ω| :=
          Finset.abs_sum_le_sum_abs _ _
        _ = ∑ k, |chainIncrement g k| * |E k ω| := by
          apply Finset.sum_congr rfl
          intro k _
          rw [abs_mul]
        _ ≤ ∑ k, gap k * |E k ω| := by
          apply Finset.sum_le_sum
          intro k _
          exact mul_le_mul_of_nonneg_right (hinc k) (abs_nonneg _)
        _ = D ω := rfl
  have hXgridm : ∀ i, Measurable (fun ω => grid (X i ω)) :=
    fun i => hgridm.comp (hXm i)
  have hsupInt : Integrable (fun ω =>
      unitIntervalEmpiricalSup (Measure.map grid ρ)
        (fun i => grid (X i ω))) P :=
    integrable_unitIntervalEmpiricalSup hn (fun i ω => grid (X i ω)) hXgridm
  calc
    (∫ ω, unitIntervalEmpiricalSup (Measure.map grid ρ)
        (fun i => grid (X i ω)) ∂P) ≤ ∫ ω, D ω ∂P :=
      integral_mono hsupInt hDint hpoint
    _ = ∑ k, gap k * ∫ ω, |E k ω| ∂P := by
      rw [integral_finsetSum Finset.univ
        (fun k _ => (hEint k).abs.const_mul (gap k))]
      simp_rw [integral_const_mul]
    _ ≤ ∑ k, gap k * (1 / Real.sqrt n) := by
      apply Finset.sum_le_sum
      intro k _
      exact mul_le_mul_of_nonneg_left
        (expected_abs_chain_indicator_process_le hn X hLaw hindep k) (hgap k)
    _ = (∑ k, gap k) * (1 / Real.sqrt n) := by rw [Finset.sum_mul]
    _ = 1 / Real.sqrt n := by rw [hsumGap, one_mul]

/-! ## Passage from grids to the actual interval -/

/-- Reconstruction after left-endpoint grid quantization.

**Lean implementation helper.** -/
def unitGridRound (m : ℕ) (hm : 0 < m) (x : UnitInterval) : UnitInterval :=
  unitGridPoint m hm (unitGridIndex m hm x)

/-- Shows that the grid-rounding map is measurable.

**Lean implementation helper.** -/
lemma measurable_unitGridRound [OpensMeasurableSpace UnitInterval]
    (m : ℕ) (hm : 0 < m) : Measurable (unitGridRound m hm) :=
  (measurable_of_finite _).comp (measurable_unitGridIndex m hm)

/-- Rounding to the lower uniform-grid point moves every point by at most `1/m`.

**Lean implementation helper.** -/
lemma dist_unitGridRound_le (m : ℕ) (hm : 0 < m) (x : UnitInterval) :
    dist x (unitGridRound m hm x) ≤ 1 / (m : ℝ) :=
  dist_unitGridIndex_point_le m hm x

/-- Rounding the sample to the grid changes the empirical average of a unit-Lipschitz function by at most `1/m`.

**Lean implementation helper.** -/
lemma abs_empiricalAverage_round_sub_le
    {m n : ℕ} (hm : 0 < m) (hn : 0 < n)
    (sample : Fin n → UnitInterval) (f : ↥unitIntervalLipschitzClass) :
    |empiricalAverage sample f.1 -
        empiricalAverage (fun i => unitGridRound m hm (sample i)) f.1| ≤
      1 / (m : ℝ) := by
  have hnR : (0 : ℝ) < n := by exact_mod_cast hn
  have hterm (i : Fin n) :
      |f.1 (sample i) - f.1 (unitGridRound m hm (sample i))| ≤
        1 / (m : ℝ) := by
    have hd := f.2.1.dist_le_mul (sample i) (unitGridRound m hm (sample i))
    have hround := dist_unitGridRound_le m hm (sample i)
    norm_num at hd
    simpa [Real.dist_eq] using hd.trans hround
  unfold empiricalAverage
  rw [← mul_sub, ← Finset.sum_sub_distrib, abs_mul,
    abs_of_nonneg (inv_nonneg.mpr hnR.le)]
  calc
    (n : ℝ)⁻¹ * |∑ i, (f.1 (sample i) -
        f.1 (unitGridRound m hm (sample i)))| ≤
        (n : ℝ)⁻¹ * ∑ i, |f.1 (sample i) -
          f.1 (unitGridRound m hm (sample i))| := by
      gcongr
      exact Finset.abs_sum_le_sum_abs _ _
    _ ≤ (n : ℝ)⁻¹ * ∑ _i : Fin n, (1 / (m : ℝ)) := by
      gcongr with i
      exact hterm i
    _ = 1 / (m : ℝ) := by simp [hn.ne']

/-- Pushing the measure through grid rounding changes the integral of a unit-Lipschitz function by at most `1/m`.

**Lean implementation helper.** -/
lemma abs_integral_round_sub_le
    [OpensMeasurableSpace UnitInterval] [IsProbabilityMeasure ν]
    {m : ℕ} (hm : 0 < m) (f : ↥unitIntervalLipschitzClass) :
    |(∫ x, f.1 x ∂ν) -
        ∫ x, f.1 x ∂Measure.map (unitGridRound m hm) ν| ≤
      1 / (m : ℝ) := by
  have hroundm := measurable_unitGridRound m hm
  rw [integral_map hroundm.aemeasurable
    f.1.continuous.measurable.aestronglyMeasurable]
  have hfint : Integrable f.1 ν := BoundedContinuousFunction.integrable ν f.1
  have hcompint : Integrable (fun x => f.1 (unitGridRound m hm x)) ν := by
    refine Integrable.of_bound
      (f.1.continuous.measurable.comp hroundm).aestronglyMeasurable 1 ?_
    exact Filter.Eventually.of_forall fun x => by
      rw [Real.norm_eq_abs, abs_of_nonneg (f.2.2 _).1]
      exact (f.2.2 _).2
  rw [← integral_sub hfint hcompint]
  have hbound : ∀ᵐ x ∂ν,
      ‖f.1 x - f.1 (unitGridRound m hm x)‖ ≤ 1 / (m : ℝ) := by
    exact Filter.Eventually.of_forall fun x => by
      have hd := f.2.1.dist_le_mul x (unitGridRound m hm x)
      have hr := dist_unitGridRound_le m hm x
      norm_num at hd
      simpa [Real.norm_eq_abs, Real.dist_eq] using hd.trans hr
  have hi := norm_integral_le_of_norm_le_const (μ := ν) hbound
  simpa [Real.norm_eq_abs] using hi

/-- Simultaneously rounding the measure and sample changes a unit-Lipschitz empirical-process value by at most `2/m`.

**Lean implementation helper.** -/
lemma abs_empiricalProcessValue_round_sub_le
    [OpensMeasurableSpace UnitInterval] [IsProbabilityMeasure ν]
    {m n : ℕ} (hm : 0 < m) (hn : 0 < n)
    (sample : Fin n → UnitInterval) (f : ↥unitIntervalLipschitzClass) :
    |empiricalProcessValue ν sample f.1 -
        empiricalProcessValue (Measure.map (unitGridRound m hm) ν)
          (fun i => unitGridRound m hm (sample i)) f.1| ≤
      2 / (m : ℝ) := by
  have havg := abs_empiricalAverage_round_sub_le hm hn sample f
  have hint := abs_integral_round_sub_le (ν := ν) hm f
  unfold empiricalProcessValue
  calc
    |(empiricalAverage sample f.1 - ∫ x, f.1 x ∂ν) -
        (empiricalAverage (fun i => unitGridRound m hm (sample i)) f.1 -
          ∫ x, f.1 x ∂Measure.map (unitGridRound m hm) ν)| =
      |(empiricalAverage sample f.1 -
          empiricalAverage (fun i => unitGridRound m hm (sample i)) f.1) -
        ((∫ x, f.1 x ∂ν) -
          ∫ x, f.1 x ∂Measure.map (unitGridRound m hm) ν)| := by
        congr 1
        ring
    _ ≤ |empiricalAverage sample f.1 -
          empiricalAverage (fun i => unitGridRound m hm (sample i)) f.1| +
        |(∫ x, f.1 x ∂ν) -
          ∫ x, f.1 x ∂Measure.map (unitGridRound m hm) ν| := abs_sub _ _
    _ ≤ 1 / (m : ℝ) + 1 / (m : ℝ) := add_le_add havg hint
    _ = 2 / (m : ℝ) := by ring

/-- The original unit-Lipschitz empirical supremum is at most the rounded supremum plus `2/m`.

**Lean implementation helper.** -/
lemma unitIntervalEmpiricalSup_le_round
    [OpensMeasurableSpace UnitInterval] [IsProbabilityMeasure ν]
    {m n : ℕ} (hm : 0 < m) (hn : 0 < n)
    (sample : Fin n → UnitInterval) :
    unitIntervalEmpiricalSup ν sample ≤
      unitIntervalEmpiricalSup (Measure.map (unitGridRound m hm) ν)
        (fun i => unitGridRound m hm (sample i)) + 2 / (m : ℝ) := by
  have hroundm := measurable_unitGridRound m hm
  letI : IsProbabilityMeasure (Measure.map (unitGridRound m hm) ν) :=
    Measure.isProbabilityMeasure_map hroundm.aemeasurable
  apply csSup_le
  · obtain ⟨f, hf⟩ := unitIntervalLipschitzClass_nonempty
    exact ⟨|empiricalProcessValue ν sample f|, ⟨⟨f, hf⟩, rfl⟩⟩
  · rintro y ⟨f, rfl⟩
    let a := empiricalProcessValue ν sample f.1
    let b := empiricalProcessValue (Measure.map (unitGridRound m hm) ν)
      (fun i => unitGridRound m hm (sample i)) f.1
    have hab : |a - b| ≤ 2 / (m : ℝ) :=
      abs_empiricalProcessValue_round_sub_le (ν := ν) hm hn sample f
    have hbsup : |b| ≤ unitIntervalEmpiricalSup
        (Measure.map (unitGridRound m hm) ν)
          (fun i => unitGridRound m hm (sample i)) :=
      le_csSup (unitIntervalEmpiricalSup_range_bddAbove hn _)
        (Set.mem_range_self f)
    calc
      |a| = |b + (a - b)| := by congr 1; ring
      _ ≤ |b| + |a - b| := abs_add_le _ _
      _ ≤ unitIntervalEmpiricalSup
          (Measure.map (unitGridRound m hm) ν)
            (fun i => unitGridRound m hm (sample i)) + 2 / (m : ℝ) :=
        add_le_add hbsup hab

/-- For the full class (8.24) of all `[0,1]`-valued one-Lipschitz functions on
`[0,1]`, the supremum is literally inside the expectation. It is measurable
by the finite nets constructed in Exercise 8.9, and its expected value is at
most `1/√n`.

**Book Theorem 8.2.3.** -/
theorem theorem_8_2_3_lipschitz_uniform_lln
    [OpensMeasurableSpace UnitInterval] [IsProbabilityMeasure P]
    [IsProbabilityMeasure ν] {n : ℕ} (hn : 0 < n)
    (X : Fin n → Ω → UnitInterval) (hXm : ∀ i, Measurable (X i))
    (hLaw : ∀ i, IdentDistrib (X i) (id : UnitInterval → UnitInterval) P ν)
    (hindep : Set.Pairwise Set.univ fun i j => IndepFun (X i) (X j) P) :
    (∫ ω, unitIntervalEmpiricalSup ν (fun i => X i ω) ∂P) ≤
      1 / Real.sqrt n := by
  have hfullInt := integrable_unitIntervalEmpiricalSup
    (P := P) (ν := ν) hn X hXm
  have hbound (m : ℕ) (hm : 0 < m) :
      (∫ ω, unitIntervalEmpiricalSup ν (fun i => X i ω) ∂P) ≤
        1 / Real.sqrt n + 2 / (m : ℝ) := by
    let q : UnitInterval → Fin (m + 1) := unitGridIndex m hm
    let r : Fin (m + 1) → UnitInterval := unitGridPoint m hm
    let ρ : Measure (Fin (m + 1)) := Measure.map q ν
    let Y : Fin n → Ω → Fin (m + 1) := fun i => q ∘ X i
    have hqm : Measurable q := measurable_unitGridIndex m hm
    have hrm : Measurable r := measurable_of_finite _
    haveI : IsProbabilityMeasure ρ := Measure.isProbabilityMeasure_map hqm.aemeasurable
    have hYm : ∀ i, Measurable (Y i) := fun i => hqm.comp (hXm i)
    have hYLaw : ∀ i, IdentDistrib (Y i)
        (id : Fin (m + 1) → Fin (m + 1)) P ρ := by
      intro i
      have hc := (hLaw i).comp hqm
      refine ⟨hc.aemeasurable_fst, measurable_id.aemeasurable, ?_⟩
      simpa [Y, ρ, q, Function.comp_def] using hc.map_eq
    have hYindep : Set.Pairwise Set.univ fun i j =>
        IndepFun (Y i) (Y j) P := by
      intro i _hi j _hj hij
      simpa [Y, Function.comp_def] using
        (hindep (Set.mem_univ i) (Set.mem_univ j) hij).comp hqm hqm
    have hgrid := expected_unitIntervalEmpiricalSup_on_grid
      (P := P) hm hn Y hYm hYLaw hYindep
    have hmap : Measure.map r ρ = Measure.map (unitGridRound m hm) ν := by
      rw [show ρ = Measure.map q ν by rfl, Measure.map_map hrm hqm]
      rfl
    rw [hmap] at hgrid
    have hroundm := measurable_unitGridRound m hm
    letI : IsProbabilityMeasure (Measure.map (unitGridRound m hm) ν) :=
      Measure.isProbabilityMeasure_map hroundm.aemeasurable
    have hroundXm : ∀ i, Measurable (fun ω => unitGridRound m hm (X i ω)) :=
      fun i => hroundm.comp (hXm i)
    have hroundInt := integrable_unitIntervalEmpiricalSup
      (P := P) (ν := Measure.map (unitGridRound m hm) ν) hn
      (fun i ω => unitGridRound m hm (X i ω)) hroundXm
    have hpoint : ∀ ω,
        unitIntervalEmpiricalSup ν (fun i => X i ω) ≤
          unitIntervalEmpiricalSup (Measure.map (unitGridRound m hm) ν)
            (fun i => unitGridRound m hm (X i ω)) + 2 / (m : ℝ) :=
      fun ω => unitIntervalEmpiricalSup_le_round (ν := ν) hm hn (fun i => X i ω)
    have hrhsInt : Integrable (fun ω =>
        unitIntervalEmpiricalSup (Measure.map (unitGridRound m hm) ν)
          (fun i => unitGridRound m hm (X i ω)) + 2 / (m : ℝ)) P :=
      hroundInt.add (integrable_const _)
    calc
      (∫ ω, unitIntervalEmpiricalSup ν (fun i => X i ω) ∂P) ≤
          ∫ ω, (unitIntervalEmpiricalSup
            (Measure.map (unitGridRound m hm) ν)
              (fun i => unitGridRound m hm (X i ω)) + 2 / (m : ℝ)) ∂P :=
        integral_mono hfullInt hrhsInt hpoint
      _ = (∫ ω, unitIntervalEmpiricalSup
            (Measure.map (unitGridRound m hm) ν)
              (fun i => unitGridRound m hm (X i ω)) ∂P) + 2 / (m : ℝ) := by
        rw [integral_add hroundInt (integrable_const _), integral_const]
        simp
      _ ≤ 1 / Real.sqrt n + 2 / (m : ℝ) := by
        gcongr
        simpa [Y, r, q, unitGridRound, Function.comp_def] using hgrid
  have hlim : Tendsto
      (fun k : ℕ => 1 / Real.sqrt n + 2 * (1 / ((k : ℝ) + 1)))
      atTop (nhds (1 / Real.sqrt n)) := by
    convert tendsto_const_nhds.add
      ((tendsto_one_div_add_atTop_nhds_zero_nat (𝕜 := ℝ)).const_mul 2) using 1
    all_goals norm_num
  apply ge_of_tendsto' hlim
  intro k
  simpa [div_eq_mul_inv, Nat.cast_add, Nat.cast_one] using
    hbound (k + 1) (by omega)

/-! ## Scaling back to the literal source class -/

/-- Full `L`-Lipschitz function class on `[0,1]`. The class in the printed equation (8.21), on the compact interval.

**Book Equation (8.21).** -/
def unitIntervalLipschitzBall (L : ℝ≥0) : Set (UnitInterval →ᵇ ℝ) :=
  {f | LipschitzWith L f}

/-- The literal empirical supremum over (8.21).

**Book Equation (8.21).** -/
def unitIntervalLipschitzEmpiricalSup (L : ℝ≥0) {n : ℕ}
    (ν : Measure UnitInterval) (sample : Fin n → UnitInterval) : ℝ :=
  sSup (Set.range fun f : ↥(unitIntervalLipschitzBall L) =>
    |empiricalProcessValue ν sample f.1|)

/-- The left endpoint `0` of the unit interval.

**Lean implementation helper.** -/
def unitIntervalZero : UnitInterval := ⟨0, by norm_num⟩

/-- Normalize an `L`-Lipschitz function by subtracting its value at zero,
scaling by `2L`, and translating by `1/2`.

**Lean implementation helper.** -/
noncomputable def normalizeUnitIntervalLipschitz (L : ℝ≥0)
    (f : UnitInterval →ᵇ ℝ) : UnitInterval →ᵇ ℝ :=
  (1 / (2 * (L : ℝ))) •
      (f - BoundedContinuousFunction.const UnitInterval (f unitIntervalZero)) +
    BoundedContinuousFunction.const UnitInterval (1 / 2 : ℝ)

/-- The normalized value of `f` at `x` is `(f(x)-f(0))/(2L) + 1/2`.

**Lean implementation helper.** -/
@[simp] lemma normalizeUnitIntervalLipschitz_apply (L : ℝ≥0)
    (f : UnitInterval →ᵇ ℝ) (x : UnitInterval) :
    normalizeUnitIntervalLipschitz L f x =
      (f x - f unitIntervalZero) / (2 * (L : ℝ)) + 1 / 2 := by
  simp [normalizeUnitIntervalLipschitz, div_eq_inv_mul]

/-- Normalizing a function in the radius-`L` Lipschitz ball yields a `[0,1]`-valued unit-Lipschitz function.

**Lean implementation helper.** -/
lemma normalizeUnitIntervalLipschitz_mem {L : ℝ≥0} (hL : 0 < L)
    (f : ↥(unitIntervalLipschitzBall L)) :
    normalizeUnitIntervalLipschitz L f.1 ∈ unitIntervalLipschitzClass := by
  have hLR : (0 : ℝ) < L := by exact_mod_cast hL
  constructor
  · apply LipschitzWith.of_dist_le_mul
    intro x y
    have hf := f.2.dist_le_mul x y
    change dist (normalizeUnitIntervalLipschitz L f.1 x)
        (normalizeUnitIntervalLipschitz L f.1 y) ≤ (1 : ℝ) * dist x y
    rw [Real.dist_eq]
    simp only [normalizeUnitIntervalLipschitz_apply]
    have hden : 0 < 2 * (L : ℝ) := by positivity
    have habs :
        |(f.1 x - f.1 unitIntervalZero) / (2 * (L : ℝ)) + 1 / 2 -
          ((f.1 y - f.1 unitIntervalZero) / (2 * (L : ℝ)) + 1 / 2)| =
          |f.1 x - f.1 y| / (2 * (L : ℝ)) := by
      rw [show (f.1 x - f.1 unitIntervalZero) / (2 * (L : ℝ)) + 1 / 2 -
          ((f.1 y - f.1 unitIntervalZero) / (2 * (L : ℝ)) + 1 / 2) =
          (f.1 x - f.1 y) / (2 * (L : ℝ)) by ring,
        abs_div, abs_of_pos hden]
    rw [habs]
    have hf' : |f.1 x - f.1 y| ≤ (L : ℝ) * dist x y := by
      simpa [Real.dist_eq] using hf
    calc
      |f.1 x - f.1 y| / (2 * (L : ℝ)) ≤
          ((L : ℝ) * dist x y) / (2 * (L : ℝ)) :=
        div_le_div_of_nonneg_right hf' hden.le
      _ = dist x y / 2 := by field_simp
      _ ≤ 1 * dist x y := by
        nlinarith [show 0 ≤ dist x y from dist_nonneg]
  · intro x
    have hbase := f.2.dist_le_mul x unitIntervalZero
    have hxdist : dist x unitIntervalZero ≤ 1 := by
      rw [Subtype.dist_eq, Real.dist_eq]
      change |(x : ℝ) - 0| ≤ 1
      rw [sub_zero, abs_of_nonneg x.2.1]
      exact x.2.2
    have hdiff : |f.1 x - f.1 unitIntervalZero| ≤ (L : ℝ) := by
      have hb : dist (f.1 x) (f.1 unitIntervalZero) ≤ (L : ℝ) :=
        hbase.trans (mul_le_of_le_one_right L.coe_nonneg hxdist)
      simpa [Real.dist_eq] using hb
    have hden : 0 < 2 * (L : ℝ) := by positivity
    have hlo : -(1 / 2 : ℝ) ≤
        (f.1 x - f.1 unitIntervalZero) / (2 * (L : ℝ)) := by
      apply (le_div_iff₀ hden).2
      have := (abs_le.mp hdiff).1
      nlinarith
    have hhi : (f.1 x - f.1 unitIntervalZero) / (2 * (L : ℝ)) ≤
        (1 / 2 : ℝ) := by
      apply (div_le_iff₀ hden).2
      have := (abs_le.mp hdiff).2
      nlinarith
    simp only [normalizeUnitIntervalLipschitz_apply]
    constructor <;> linarith

/-- An affine transformation `a f + b` multiplies the centered empirical-process value by `a` and cancels the constant `b`.

**Lean implementation helper.** -/
lemma empiricalProcessValue_affine_bcf
    [OpensMeasurableSpace UnitInterval] [IsProbabilityMeasure ν]
    {n : ℕ} (hn : 0 < n) (sample : Fin n → UnitInterval)
    (f : UnitInterval →ᵇ ℝ) (a b : ℝ) :
    empiricalProcessValue ν sample (fun x => a * f x + b) =
      a * empiricalProcessValue ν sample f := by
  have hfint := BoundedContinuousFunction.integrable ν f
  unfold empiricalProcessValue empiricalAverage
  rw [integral_add (hfint.const_mul a) (integrable_const b),
    integral_const_mul, integral_const]
  simp_rw [Finset.sum_add_distrib, ← Finset.mul_sum]
  have hnR : (n : ℝ) ≠ 0 := by exact_mod_cast hn.ne'
  simp only [Finset.sum_const, Finset.card_univ, Fintype.card_fin,
    nsmul_eq_mul]
  rw [probReal_univ]
  field_simp [hnR]
  ring

/-- For positive `L`, normalization factors an empirical-process value as `2L` times the normalized value.

**Lean implementation helper.** -/
lemma empiricalProcessValue_normalizeUnitIntervalLipschitz
    [OpensMeasurableSpace UnitInterval] [IsProbabilityMeasure ν]
    {L : ℝ≥0} (hL : 0 < L) {n : ℕ} (hn : 0 < n)
    (sample : Fin n → UnitInterval) (f : UnitInterval →ᵇ ℝ) :
    empiricalProcessValue ν sample f =
      2 * (L : ℝ) * empiricalProcessValue ν sample
        (normalizeUnitIntervalLipschitz L f) := by
  have hLR : (0 : ℝ) < L := by exact_mod_cast hL
  have haff := empiricalProcessValue_affine_bcf (ν := ν) hn sample f
    (1 / (2 * (L : ℝ)))
    (-(f unitIntervalZero) / (2 * (L : ℝ)) + 1 / 2)
  have heq : (fun x =>
      (1 / (2 * (L : ℝ))) * f x +
        (-(f unitIntervalZero) / (2 * (L : ℝ)) + 1 / 2)) =
      (fun x => normalizeUnitIntervalLipschitz L f x) := by
    funext x
    simp only [normalizeUnitIntervalLipschitz_apply]
    ring
  rw [heq] at haff
  rw [haff]
  field_simp

/-- A symmetric normalized class, convenient for quotienting out constants.

**Lean implementation helper.** -/
def signedUnitIntervalLipschitzClass : Set (UnitInterval →ᵇ ℝ) :=
  {f | LipschitzWith 1 f ∧ ∀ x, f x ∈ Set.Icc (-1 : ℝ) 1}

/-- Shows that the signed unit-Lipschitz class is nonempty.

**Lean implementation helper.** -/
lemma signedUnitIntervalLipschitzClass_nonempty :
    (signedUnitIntervalLipschitzClass : Set (UnitInterval →ᵇ ℝ)).Nonempty := by
  let z := BoundedContinuousFunction.const UnitInterval (0 : ℝ)
  refine ⟨z, ?_⟩
  constructor
  · change LipschitzWith 1 (fun _ : UnitInterval => (0 : ℝ))
    exact (LipschitzWith.const (0 : ℝ)).weaken (by simp)
  · intro x
    simp [z]

/-- Rescales a signed unit-Lipschitz function from range `[-1,1]` to range `[0,1]`.

**Lean implementation helper.** -/
noncomputable def signedLipschitzToUnit (f : UnitInterval →ᵇ ℝ) :
    UnitInterval →ᵇ ℝ :=
  (1 / 2 : ℝ) • f + BoundedContinuousFunction.const UnitInterval (1 / 2 : ℝ)

/-- The affine map from signed to unit range sends `f(x)` to `f(x)/2 + 1/2`.

**Lean implementation helper.** -/
@[simp] lemma signedLipschitzToUnit_apply (f : UnitInterval →ᵇ ℝ)
    (x : UnitInterval) : signedLipschitzToUnit f x = f x / 2 + 1 / 2 := by
  simp only [signedLipschitzToUnit, BoundedContinuousFunction.add_apply,
    BoundedContinuousFunction.smul_apply, BoundedContinuousFunction.const_apply,
    smul_eq_mul]
  ring

/-- Affine rescaling sends every `[-1,1]`-valued unit-Lipschitz function into the `[0,1]`-valued unit-Lipschitz class.

**Lean implementation helper.** -/
lemma signedLipschitzToUnit_mem
    (f : ↥signedUnitIntervalLipschitzClass) :
    signedLipschitzToUnit f.1 ∈ unitIntervalLipschitzClass := by
  constructor
  · apply LipschitzWith.of_dist_le_mul
    intro x y
    have hf := f.2.1.dist_le_mul x y
    change dist (signedLipschitzToUnit f.1 x)
        (signedLipschitzToUnit f.1 y) ≤ (1 : ℝ) * dist x y
    rw [Real.dist_eq]
    simp only [signedLipschitzToUnit_apply]
    have hf' : |f.1 x - f.1 y| ≤ dist x y := by
      simpa [Real.dist_eq] using hf
    rw [show f.1 x / 2 + 1 / 2 - (f.1 y / 2 + 1 / 2) =
      (f.1 x - f.1 y) / 2 by ring, abs_div]
    norm_num
    nlinarith [dist_nonneg (x := x) (y := y)]
  · intro x
    rcases f.2.2 x with ⟨hxlo, hxhi⟩
    simp only [signedLipschitzToUnit_apply]
    constructor <;> nlinarith

/-- Rescaling a signed unit-Lipschitz function to `[0,1]` divides its empirical-process value by two.

**Lean implementation helper.** -/
lemma empiricalProcessValue_signedLipschitzToUnit
    [OpensMeasurableSpace UnitInterval] [IsProbabilityMeasure ν]
    {n : ℕ} (hn : 0 < n) (sample : Fin n → UnitInterval)
    (f : UnitInterval →ᵇ ℝ) :
    empiricalProcessValue ν sample f =
      2 * empiricalProcessValue ν sample (signedLipschitzToUnit f) := by
  have h := empiricalProcessValue_affine_bcf (ν := ν) hn sample f
    (1 / 2) (1 / 2)
  have heq : (fun x => (1 / 2 : ℝ) * f x + 1 / 2) =
      (fun x => signedLipschitzToUnit f x) := by
    funext x
    simp [signedLipschitzToUnit]
  rw [heq] at h
  linarith

/-- One representative of every additive-constant class.

**Lean implementation helper.** -/
def anchoredUnitLipschitzClass : Set (UnitInterval →ᵇ ℝ) :=
  {f | LipschitzWith 1 f ∧ f unitIntervalZero = 0}

/-- Shows that the anchored unit-Lipschitz class is nonempty.

**Lean implementation helper.** -/
lemma anchoredUnitLipschitzClass_nonempty :
    (anchoredUnitLipschitzClass : Set (UnitInterval →ᵇ ℝ)).Nonempty := by
  let z := BoundedContinuousFunction.const UnitInterval (0 : ℝ)
  refine ⟨z, ?_⟩
  constructor
  · change LipschitzWith 1 (fun _ : UnitInterval => (0 : ℝ))
    exact (LipschitzWith.const (0 : ℝ)).weaken (by simp)
  · simp [z]

/-- Every anchored unit-Lipschitz function takes values in `[-1,1]`.

**Lean implementation helper.** -/
lemma anchoredUnitLipschitz_signed
    (f : ↥anchoredUnitLipschitzClass) :
    f.1 ∈ signedUnitIntervalLipschitzClass := by
  constructor
  · exact f.2.1
  · intro x
    have hd := f.2.1.dist_le_mul x unitIntervalZero
    have hxdist : dist x unitIntervalZero ≤ 1 := by
      rw [Subtype.dist_eq, Real.dist_eq]
      change |(x : ℝ) - 0| ≤ 1
      rw [sub_zero, abs_of_nonneg x.2.1]
      exact x.2.2
    have habs : |f.1 x| ≤ 1 := by
      have : dist (f.1 x) (f.1 unitIntervalZero) ≤ 1 := by
        norm_num at hd
        exact hd.trans hxdist
      simpa [f.2.2, Real.dist_eq] using this
    exact (abs_le.mp habs)

/-- Encodes an anchored unit-Lipschitz function by its quantized grid increments.

**Lean implementation helper.** -/
def anchoredLipschitzGridCode (m : ℕ) (hm : 0 < m)
    (f : ↥anchoredUnitLipschitzClass) : LipschitzGridCode m :=
  lipschitzGridCode m hm
    ⟨signedLipschitzToUnit f.1,
      signedLipschitzToUnit_mem ⟨f.1, anchoredUnitLipschitz_signed f⟩⟩

/-- Chooses an anchored unit-Lipschitz function realizing a given grid code.

**Lean implementation helper.** -/
noncomputable def anchoredLipschitzGridRepresentative (m : ℕ) (hm : 0 < m)
    (c : LipschitzGridCode m) : ↥anchoredUnitLipschitzClass := by
  classical
  exact if h : ∃ f : ↥anchoredUnitLipschitzClass,
      anchoredLipschitzGridCode m hm f = c then Classical.choose h
    else ⟨Classical.choose anchoredUnitLipschitzClass_nonempty,
      Classical.choose_spec anchoredUnitLipschitzClass_nonempty⟩

/-- The chosen anchored representative of a realizable grid code has exactly that code.

**Lean implementation helper.** -/
lemma anchoredLipschitzGridRepresentative_code (m : ℕ) (hm : 0 < m)
    (f : ↥anchoredUnitLipschitzClass) :
    anchoredLipschitzGridCode m hm
      (anchoredLipschitzGridRepresentative m hm
        (anchoredLipschitzGridCode m hm f)) =
      anchoredLipschitzGridCode m hm f := by
  classical
  unfold anchoredLipschitzGridRepresentative
  rw [dif_pos (show ∃ g : ↥anchoredUnitLipschitzClass,
    anchoredLipschitzGridCode m hm g = anchoredLipschitzGridCode m hm f from
      ⟨f, rfl⟩)]
  exact Classical.choose_spec (show ∃ g : ↥anchoredUnitLipschitzClass,
    anchoredLipschitzGridCode m hm g = anchoredLipschitzGridCode m hm f from
      ⟨f, rfl⟩)

/-- Forms the finite set of representatives of realizable anchored grid codes.

**Lean implementation helper.** -/
noncomputable def anchoredLipschitzGridNet (m : ℕ) (hm : 0 < m) :
    Finset (UnitInterval →ᵇ ℝ) := by
  classical
  exact (Finset.univ : Finset (LipschitzGridCode m)).image fun c =>
    (anchoredLipschitzGridRepresentative m hm c).1

/-- Shows that the finite anchored grid net is nonempty.

**Lean implementation helper.** -/
lemma anchoredLipschitzGridNet_nonempty (m : ℕ) (hm : 0 < m) :
    (anchoredLipschitzGridNet m hm).Nonempty := by
  classical
  let f : ↥anchoredUnitLipschitzClass :=
    ⟨Classical.choose anchoredUnitLipschitzClass_nonempty,
      Classical.choose_spec anchoredUnitLipschitzClass_nonempty⟩
  let c := anchoredLipschitzGridCode m hm f
  exact ⟨(anchoredLipschitzGridRepresentative m hm c).1,
    Finset.mem_image.mpr ⟨c, Finset.mem_univ c, rfl⟩⟩

/-- Shows that the finite anchored grid net lies in the ambient source set.

**Lean implementation helper.** -/
lemma anchoredLipschitzGridNet_subset (m : ℕ) (hm : 0 < m) :
    (anchoredLipschitzGridNet m hm : Set (UnitInterval →ᵇ ℝ)) ⊆
      anchoredUnitLipschitzClass := by
  classical
  intro f hf
  rcases Finset.mem_image.mp hf with ⟨c, hc, rfl⟩
  exact (anchoredLipschitzGridRepresentative m hm c).2

/-- Two anchored unit-Lipschitz functions with the same grid code are uniformly within `6/m` of one another.

**Lean implementation helper.** -/
lemma dist_le_six_div_of_anchoredCode_eq (m : ℕ) (hm : 0 < m)
    {f g : ↥anchoredUnitLipschitzClass}
    (hcode : anchoredLipschitzGridCode m hm f =
      anchoredLipschitzGridCode m hm g) :
    dist f.1 g.1 ≤ 6 / (m : ℝ) := by
  let fu : ↥unitIntervalLipschitzClass :=
    ⟨signedLipschitzToUnit f.1,
      signedLipschitzToUnit_mem ⟨f.1, anchoredUnitLipschitz_signed f⟩⟩
  let gu : ↥unitIntervalLipschitzClass :=
    ⟨signedLipschitzToUnit g.1,
      signedLipschitzToUnit_mem ⟨g.1, anchoredUnitLipschitz_signed g⟩⟩
  have hunit : dist fu.1 gu.1 ≤ 3 / (m : ℝ) :=
    dist_le_three_div_of_lipschitzGridCode_eq m hm hcode
  apply (BoundedContinuousFunction.dist_le (by positivity)).2
  intro x
  have heval := fu.1.abs_sub_coe_le_dist gu.1 (x := x)
  have hpoint : |f.1 x - g.1 x| =
      2 * |fu.1 x - gu.1 x| := by
    simp only [fu, gu, signedLipschitzToUnit_apply]
    rw [show f.1 x / 2 + 1 / 2 - (g.1 x / 2 + 1 / 2) =
      (f.1 x - g.1 x) / 2 by ring, abs_div]
    norm_num
    ring
  rw [Real.dist_eq, hpoint]
  calc
    2 * |fu.1 x - gu.1 x| ≤ 2 * dist fu.1 gu.1 := by
      gcongr
      simpa [Real.norm_eq_abs] using heval
    _ ≤ 2 * (3 / (m : ℝ)) := mul_le_mul_of_nonneg_left hunit (by norm_num)
    _ = 6 / (m : ℝ) := by ring

/-- The anchored grid representatives form a `6/m`-cover of the anchored unit-Lipschitz class.

**Lean implementation helper.** -/
lemma anchoredLipschitzGridNet_isCover (m : ℕ) (hm : 0 < m) :
    ∀ f ∈ anchoredUnitLipschitzClass, ∃ g ∈ anchoredLipschitzGridNet m hm,
      dist f g ≤ 6 / (m : ℝ) := by
  classical
  intro f hf
  let fs : ↥anchoredUnitLipschitzClass := ⟨f, hf⟩
  let c := anchoredLipschitzGridCode m hm fs
  let g := anchoredLipschitzGridRepresentative m hm c
  refine ⟨g.1, Finset.mem_image.mpr ⟨c, Finset.mem_univ c, rfl⟩, ?_⟩
  simpa [fs, g, dist_comm] using
    (dist_le_six_div_of_anchoredCode_eq m hm
      (anchoredLipschitzGridRepresentative_code m hm fs))

/-- Defines the supremum of absolute empirical-process values over anchored unit-Lipschitz functions.

**Lean implementation helper.** -/
def anchoredLipschitzEmpiricalSup {n : ℕ} (ν : Measure UnitInterval)
    (sample : Fin n → UnitInterval) : ℝ :=
  sSup (Set.range fun f : ↥anchoredUnitLipschitzClass =>
    |empiricalProcessValue ν sample f.1|)

/-- Absolute empirical-process values over the anchored unit-Lipschitz class are bounded above.

**Lean implementation helper.** -/
lemma anchoredLipschitzEmpiricalSup_range_bddAbove
    [OpensMeasurableSpace UnitInterval] [IsProbabilityMeasure ν]
    {n : ℕ} (hn : 0 < n) (sample : Fin n → UnitInterval) :
    BddAbove (Set.range fun f : ↥anchoredUnitLipschitzClass =>
      |empiricalProcessValue ν sample f.1|) := by
  refine ⟨4, ?_⟩
  rintro y ⟨f, rfl⟩
  let fs : ↥signedUnitIntervalLipschitzClass :=
    ⟨f.1, anchoredUnitLipschitz_signed f⟩
  let fu : ↥unitIntervalLipschitzClass :=
    ⟨signedLipschitzToUnit f.1, signedLipschitzToUnit_mem fs⟩
  change |empiricalProcessValue ν sample f.1| ≤ 4
  rw [empiricalProcessValue_signedLipschitzToUnit (ν := ν) hn sample f.1]
  have hb := abs_empiricalProcessValue_bcf_le_two (ν := ν) hn sample fu
  calc
    |2 * empiricalProcessValue ν sample (signedLipschitzToUnit f.1)| =
        2 * |empiricalProcessValue ν sample (signedLipschitzToUnit f.1)| := by
      rw [abs_mul]
      norm_num
    _ ≤ 2 * 2 := mul_le_mul_of_nonneg_left hb (by norm_num)
    _ = 4 := by norm_num

/-- Defines the corresponding empirical supremum over the finite anchored grid net.

**Lean implementation helper.** -/
noncomputable def anchoredLipschitzGridNetEmpiricalSup
    (m : ℕ) (hm : 0 < m) {n : ℕ} (ν : Measure UnitInterval)
    (sample : Fin n → UnitInterval) : ℝ := by
  classical
  exact (anchoredLipschitzGridNet m hm).sup'
    (anchoredLipschitzGridNet_nonempty m hm)
      fun f => |empiricalProcessValue ν sample f|

/-- Shows that the anchored Lipschitz empirical supremum is nonnegative.

**Lean implementation helper.** -/
lemma anchoredLipschitzEmpiricalSup_nonneg
    [OpensMeasurableSpace UnitInterval] [IsProbabilityMeasure ν]
    {n : ℕ} (hn : 0 < n) (sample : Fin n → UnitInterval) :
    0 ≤ anchoredLipschitzEmpiricalSup ν sample := by
  let f : ↥anchoredUnitLipschitzClass :=
    ⟨Classical.choose anchoredUnitLipschitzClass_nonempty,
      Classical.choose_spec anchoredUnitLipschitzClass_nonempty⟩
  exact (abs_nonneg (empiricalProcessValue ν sample f.1)).trans
    (le_csSup (anchoredLipschitzEmpiricalSup_range_bddAbove hn sample)
      (Set.mem_range_self f))

/-- The anchored unit-Lipschitz empirical supremum is at most `4`.

**Lean implementation helper.** -/
lemma anchoredLipschitzEmpiricalSup_le_four
    [OpensMeasurableSpace UnitInterval] [IsProbabilityMeasure ν]
    {n : ℕ} (hn : 0 < n) (sample : Fin n → UnitInterval) :
    anchoredLipschitzEmpiricalSup ν sample ≤ 4 := by
  apply csSup_le
  · let f : ↥anchoredUnitLipschitzClass :=
      ⟨Classical.choose anchoredUnitLipschitzClass_nonempty,
        Classical.choose_spec anchoredUnitLipschitzClass_nonempty⟩
    exact ⟨|empiricalProcessValue ν sample f.1|, Set.mem_range_self f⟩
  · rintro y ⟨f, rfl⟩
    let fs : ↥signedUnitIntervalLipschitzClass :=
      ⟨f.1, anchoredUnitLipschitz_signed f⟩
    let fu : ↥unitIntervalLipschitzClass :=
      ⟨signedLipschitzToUnit f.1, signedLipschitzToUnit_mem fs⟩
    change |empiricalProcessValue ν sample f.1| ≤ 4
    rw [empiricalProcessValue_signedLipschitzToUnit (ν := ν) hn sample f.1]
    have hb := abs_empiricalProcessValue_bcf_le_two (ν := ν) hn sample fu
    calc
      |2 * empiricalProcessValue ν sample (signedLipschitzToUnit f.1)| =
          2 * |empiricalProcessValue ν sample
            (signedLipschitzToUnit f.1)| := by
        rw [abs_mul]
        norm_num
      _ ≤ 2 * 2 := mul_le_mul_of_nonneg_left hb (by norm_num)
      _ = 4 := by norm_num

/-- Shows that the finite-net anchored empirical supremum is measurable.

**Lean implementation helper.** -/
lemma measurable_anchoredLipschitzGridNetEmpiricalSup
    [OpensMeasurableSpace UnitInterval] [IsProbabilityMeasure ν]
    {n : ℕ} (m : ℕ) (hm : 0 < m) (X : Fin n → Ω → UnitInterval)
    (hXm : ∀ i, Measurable (X i)) : Measurable (fun ω =>
      anchoredLipschitzGridNetEmpiricalSup m hm ν (fun i => X i ω)) := by
  classical
  unfold anchoredLipschitzGridNetEmpiricalSup
  have hraw : Measurable
      ((anchoredLipschitzGridNet m hm).sup'
        (anchoredLipschitzGridNet_nonempty m hm) fun f => fun ω =>
          |empiricalProcessValue ν (fun i => X i ω) f|) := by
    apply Finset.measurable_sup' (anchoredLipschitzGridNet_nonempty m hm)
    intro f hf
    apply Measurable.abs
    unfold empiricalProcessValue empiricalAverage
    apply Measurable.sub_const
    apply Measurable.const_mul
    apply Finset.measurable_sum
    intro i _
    exact f.continuous.measurable.comp (hXm i)
  have heq :
      ((anchoredLipschitzGridNet m hm).sup'
        (anchoredLipschitzGridNet_nonempty m hm) fun f => fun ω =>
          |empiricalProcessValue ν (fun i => X i ω) f|) =
      (fun ω => (anchoredLipschitzGridNet m hm).sup'
        (anchoredLipschitzGridNet_nonempty m hm) fun f =>
          |empiricalProcessValue ν (fun i => X i ω) f|) := by
    funext ω
    simp only [Finset.sup'_apply]
  rw [← heq]
  exact hraw

/-- The anchored grid-net empirical supremum is no larger than the supremum over the full anchored class.

**Lean implementation helper.** -/
lemma anchoredGridNetEmpiricalSup_le_full
    [OpensMeasurableSpace UnitInterval] [IsProbabilityMeasure ν]
    {n : ℕ} (hn : 0 < n) (m : ℕ) (hm : 0 < m)
    (sample : Fin n → UnitInterval) :
    anchoredLipschitzGridNetEmpiricalSup m hm ν sample ≤
      anchoredLipschitzEmpiricalSup ν sample := by
  apply Finset.sup'_le
  intro f hf
  let fs : ↥anchoredUnitLipschitzClass :=
    ⟨f, anchoredLipschitzGridNet_subset m hm (by exact hf)⟩
  exact le_csSup (anchoredLipschitzEmpiricalSup_range_bddAbove hn sample)
    (Set.mem_range_self fs)

/-- The full anchored empirical supremum is at most the anchored grid-net supremum plus `12/m`.

**Lean implementation helper.** -/
lemma anchoredEmpiricalSup_le_gridNet
    [OpensMeasurableSpace UnitInterval] [IsProbabilityMeasure ν]
    {n : ℕ} (hn : 0 < n) (m : ℕ) (hm : 0 < m)
    (sample : Fin n → UnitInterval) :
    anchoredLipschitzEmpiricalSup ν sample ≤
      anchoredLipschitzGridNetEmpiricalSup m hm ν sample +
        12 / (m : ℝ) := by
  apply csSup_le
  · let f : ↥anchoredUnitLipschitzClass :=
      ⟨Classical.choose anchoredUnitLipschitzClass_nonempty,
        Classical.choose_spec anchoredUnitLipschitzClass_nonempty⟩
    exact ⟨|empiricalProcessValue ν sample f.1|, Set.mem_range_self f⟩
  · rintro y ⟨f, rfl⟩
    obtain ⟨g, hgnet, hfg⟩ :=
      anchoredLipschitzGridNet_isCover m hm f.1 f.2
    have hproc := abs_empiricalProcessValue_bcf_sub_le_two_dist
      (ν := ν) hn sample f.1 g
    have habs : |empiricalProcessValue ν sample f.1| ≤
        |empiricalProcessValue ν sample g| + 2 * dist f.1 g := by
      calc
        |empiricalProcessValue ν sample f.1| =
            |empiricalProcessValue ν sample g +
              (empiricalProcessValue ν sample f.1 -
                empiricalProcessValue ν sample g)| := by congr 1; ring
        _ ≤ |empiricalProcessValue ν sample g| +
            |empiricalProcessValue ν sample f.1 -
              empiricalProcessValue ν sample g| := abs_add_le _ _
        _ ≤ |empiricalProcessValue ν sample g| + 2 * dist f.1 g := by
          gcongr
    calc
      |empiricalProcessValue ν sample f.1| ≤
          |empiricalProcessValue ν sample g| + 2 * dist f.1 g := habs
      _ ≤ anchoredLipschitzGridNetEmpiricalSup m hm ν sample +
          2 * (6 / (m : ℝ)) := by
        apply add_le_add
        · unfold anchoredLipschitzGridNetEmpiricalSup
          exact Finset.le_sup' (s := anchoredLipschitzGridNet m hm)
            (fun h => |empiricalProcessValue ν sample h|) (by exact hgnet)
        · exact mul_le_mul_of_nonneg_left hfg (by norm_num)
      _ = anchoredLipschitzGridNetEmpiricalSup m hm ν sample +
          12 / (m : ℝ) := by ring

/-- Shows that the anchored Lipschitz empirical supremum is measurable.

**Lean implementation helper.** -/
lemma measurable_anchoredLipschitzEmpiricalSup
    [OpensMeasurableSpace UnitInterval] [IsProbabilityMeasure ν]
    {n : ℕ} (hn : 0 < n) (X : Fin n → Ω → UnitInterval)
    (hXm : ∀ i, Measurable (X i)) :
    Measurable (fun ω => anchoredLipschitzEmpiricalSup ν (fun i => X i ω)) := by
  let Z : ℕ → Ω → ℝ := fun k ω =>
    anchoredLipschitzGridNetEmpiricalSup (k + 1) (by omega) ν
      (fun i => X i ω)
  apply measurable_of_tendsto_metrizable (f := Z)
  · intro k
    exact measurable_anchoredLipschitzGridNetEmpiricalSup
      (k + 1) (by omega) X hXm
  · rw [tendsto_pi_nhds]
    intro ω
    have hdiff : Tendsto (fun k =>
        anchoredLipschitzEmpiricalSup ν (fun i => X i ω) - Z k ω)
        atTop (nhds 0) := by
      apply squeeze_zero'
      · exact Filter.Eventually.of_forall fun k => sub_nonneg.mpr
          (anchoredGridNetEmpiricalSup_le_full (ν := ν) hn (k + 1)
            (by omega) (fun i => X i ω))
      · exact Filter.Eventually.of_forall fun k => by
          have h := anchoredEmpiricalSup_le_gridNet (ν := ν) hn (k + 1)
            (by omega) (fun i => X i ω)
          simpa [Z] using sub_le_iff_le_add'.2 h
      · simpa [div_eq_mul_inv] using
          (tendsto_one_div_add_atTop_nhds_zero_nat (𝕜 := ℝ)).const_mul 12
    have heq : (fun k => Z k ω) = fun k =>
        anchoredLipschitzEmpiricalSup ν (fun i => X i ω) -
          (anchoredLipschitzEmpiricalSup ν (fun i => X i ω) - Z k ω) := by
      funext k
      ring
    rw [heq]
    have hc : Tendsto
        (fun _ : ℕ => anchoredLipschitzEmpiricalSup ν (fun i => X i ω))
        atTop (nhds (anchoredLipschitzEmpiricalSup ν (fun i => X i ω))) :=
      tendsto_const_nhds
    simpa using hc.sub hdiff

/-- The anchored empirical supremum is at most twice the `[0,1]`-valued unit-Lipschitz supremum.

**Lean implementation helper.** -/
lemma anchoredLipschitzEmpiricalSup_le_two_unit
    [OpensMeasurableSpace UnitInterval] [IsProbabilityMeasure ν]
    {n : ℕ} (hn : 0 < n) (sample : Fin n → UnitInterval) :
    anchoredLipschitzEmpiricalSup ν sample ≤
      2 * unitIntervalEmpiricalSup ν sample := by
  apply csSup_le
  · let f : ↥anchoredUnitLipschitzClass :=
      ⟨Classical.choose anchoredUnitLipschitzClass_nonempty,
        Classical.choose_spec anchoredUnitLipschitzClass_nonempty⟩
    exact ⟨|empiricalProcessValue ν sample f.1|, Set.mem_range_self f⟩
  · rintro y ⟨f, rfl⟩
    let fs : ↥signedUnitIntervalLipschitzClass :=
      ⟨f.1, anchoredUnitLipschitz_signed f⟩
    let fu : ↥unitIntervalLipschitzClass :=
      ⟨signedLipschitzToUnit f.1, signedLipschitzToUnit_mem fs⟩
    change |empiricalProcessValue ν sample f.1| ≤
      2 * unitIntervalEmpiricalSup ν sample
    rw [empiricalProcessValue_signedLipschitzToUnit (ν := ν) hn sample f.1,
      abs_mul]
    norm_num
    exact le_csSup (unitIntervalEmpiricalSup_range_bddAbove hn sample)
      (Set.mem_range_self fu)

/-- Shows that the anchored Lipschitz empirical supremum is integrable.

**Lean implementation helper.** -/
lemma integrable_anchoredLipschitzEmpiricalSup
    [OpensMeasurableSpace UnitInterval] [IsProbabilityMeasure P]
    [IsProbabilityMeasure ν] {n : ℕ} (hn : 0 < n)
    (X : Fin n → Ω → UnitInterval) (hXm : ∀ i, Measurable (X i)) :
    Integrable (fun ω => anchoredLipschitzEmpiricalSup ν (fun i => X i ω)) P := by
  refine Integrable.of_bound
    (measurable_anchoredLipschitzEmpiricalSup hn X hXm).aestronglyMeasurable 4 ?_
  exact Filter.Eventually.of_forall fun ω => by
    rw [Real.norm_eq_abs, abs_of_nonneg (anchoredLipschitzEmpiricalSup_nonneg hn _)]
    exact anchoredLipschitzEmpiricalSup_le_four hn _

/-! ### The literal `L`-Lipschitz class -/

/-- Remove the irrelevant additive constant and divide by the Lipschitz constant.

**Lean implementation helper.** -/
noncomputable def sourceLipschitzToAnchored (L : ℝ≥0)
    (f : UnitInterval →ᵇ ℝ) : UnitInterval →ᵇ ℝ :=
  (1 / (L : ℝ)) •
    (f - BoundedContinuousFunction.const UnitInterval (f unitIntervalZero))

/-- Anchoring and rescaling a radius-`L` Lipschitz function sends `f(x)` to `(f(x)-f(0))/L`.

**Lean implementation helper.** -/
@[simp] lemma sourceLipschitzToAnchored_apply (L : ℝ≥0)
    (f : UnitInterval →ᵇ ℝ) (x : UnitInterval) :
    sourceLipschitzToAnchored L f x =
      (f x - f unitIntervalZero) / (L : ℝ) := by
  simp [sourceLipschitzToAnchored, div_eq_inv_mul]

/-- For positive `L`, anchoring and rescaling sends the radius-`L` Lipschitz ball into the anchored unit-Lipschitz class.

**Lean implementation helper.** -/
lemma sourceLipschitzToAnchored_mem {L : ℝ≥0} (hL : 0 < L)
    (f : ↥(unitIntervalLipschitzBall L)) :
    sourceLipschitzToAnchored L f.1 ∈ anchoredUnitLipschitzClass := by
  have hLR : (0 : ℝ) < L := by exact_mod_cast hL
  constructor
  · apply LipschitzWith.of_dist_le_mul
    intro x y
    have hf := f.2.dist_le_mul x y
    change dist (sourceLipschitzToAnchored L f.1 x)
        (sourceLipschitzToAnchored L f.1 y) ≤ (1 : ℝ) * dist x y
    rw [Real.dist_eq]
    simp only [sourceLipschitzToAnchored_apply]
    have hdiff :
        |(f.1 x - f.1 unitIntervalZero) / (L : ℝ) -
          (f.1 y - f.1 unitIntervalZero) / (L : ℝ)| =
          |f.1 x - f.1 y| / (L : ℝ) := by
      rw [show (f.1 x - f.1 unitIntervalZero) / (L : ℝ) -
          (f.1 y - f.1 unitIntervalZero) / (L : ℝ) =
          (f.1 x - f.1 y) / (L : ℝ) by ring,
        abs_div, abs_of_pos hLR]
    rw [hdiff]
    have hf' : |f.1 x - f.1 y| ≤ (L : ℝ) * dist x y := by
      simpa [Real.dist_eq] using hf
    calc
      |f.1 x - f.1 y| / (L : ℝ) ≤
          ((L : ℝ) * dist x y) / (L : ℝ) :=
        div_le_div_of_nonneg_right hf' hLR.le
      _ = 1 * dist x y := by field_simp
  · simp [sourceLipschitzToAnchored]

/-- For positive `L`, an empirical-process value equals `L` times the value of the anchored rescaling.

**Lean implementation helper.** -/
lemma empiricalProcessValue_sourceLipschitzToAnchored
    [OpensMeasurableSpace UnitInterval] [IsProbabilityMeasure ν]
    {L : ℝ≥0} (hL : 0 < L) {n : ℕ} (hn : 0 < n)
    (sample : Fin n → UnitInterval) (f : UnitInterval →ᵇ ℝ) :
    empiricalProcessValue ν sample f =
      (L : ℝ) * empiricalProcessValue ν sample
        (sourceLipschitzToAnchored L f) := by
  have hLR : (0 : ℝ) < L := by exact_mod_cast hL
  have haff := empiricalProcessValue_affine_bcf (ν := ν) hn sample f
    (1 / (L : ℝ)) (-(f unitIntervalZero) / (L : ℝ))
  have heq : (fun x =>
      (1 / (L : ℝ)) * f x + (-f unitIntervalZero) / (L : ℝ)) =
      (fun x => sourceLipschitzToAnchored L f x) := by
    funext x
    simp only [sourceLipschitzToAnchored_apply]
    ring
  rw [heq] at haff
  rw [haff]
  field_simp

/-- Scaling an anchored representative produces a member of the literal source
class.

**Lean implementation helper.** -/
noncomputable def anchoredToSourceLipschitz (L : ℝ≥0)
    (f : UnitInterval →ᵇ ℝ) : UnitInterval →ᵇ ℝ :=
  (L : ℝ) • f

/-- Scaling an anchored unit-Lipschitz function by `L` sends `f(x)` to `L f(x)`.

**Lean implementation helper.** -/
@[simp] lemma anchoredToSourceLipschitz_apply (L : ℝ≥0)
    (f : UnitInterval →ᵇ ℝ) (x : UnitInterval) :
    anchoredToSourceLipschitz L f x = (L : ℝ) * f x := by
  simp [anchoredToSourceLipschitz]

/-- Scaling an anchored unit-Lipschitz function by `L` places it in the radius-`L` Lipschitz ball.

**Lean implementation helper.** -/
lemma anchoredToSourceLipschitz_mem (L : ℝ≥0)
    (f : ↥anchoredUnitLipschitzClass) :
    anchoredToSourceLipschitz L f.1 ∈ unitIntervalLipschitzBall L := by
  apply LipschitzWith.of_dist_le_mul
  intro x y
  have hf := f.2.1.dist_le_mul x y
  change dist (anchoredToSourceLipschitz L f.1 x)
      (anchoredToSourceLipschitz L f.1 y) ≤ (L : ℝ) * dist x y
  rw [Real.dist_eq]
  simp only [anchoredToSourceLipschitz_apply]
  rw [show (L : ℝ) * f.1 x - (L : ℝ) * f.1 y =
    (L : ℝ) * (f.1 x - f.1 y) by ring, abs_mul,
    abs_of_nonneg L.coe_nonneg]
  have hf' : |f.1 x - f.1 y| ≤ dist x y := by
    simpa [Real.dist_eq] using hf
  exact mul_le_mul_of_nonneg_left hf' L.coe_nonneg

/-- Scaling an anchored function by `L` multiplies its empirical-process value by `L`.

**Lean implementation helper.** -/
lemma empiricalProcessValue_anchoredToSourceLipschitz
    [OpensMeasurableSpace UnitInterval] [IsProbabilityMeasure ν]
    {n : ℕ} (hn : 0 < n) (sample : Fin n → UnitInterval)
    (L : ℝ≥0) (f : UnitInterval →ᵇ ℝ) :
    empiricalProcessValue ν sample (anchoredToSourceLipschitz L f) =
      (L : ℝ) * empiricalProcessValue ν sample f := by
  have h := empiricalProcessValue_affine_bcf (ν := ν) hn sample f
    (L : ℝ) 0
  simpa [anchoredToSourceLipschitz] using h

/-- For positive `L`, the radius-`L` Lipschitz empirical supremum equals `L` times the anchored unit-Lipschitz supremum.

**Lean implementation helper.** -/
lemma unitIntervalLipschitzEmpiricalSup_eq_mul_anchored_of_pos
    [OpensMeasurableSpace UnitInterval] [IsProbabilityMeasure ν]
    {L : ℝ≥0} (hL : 0 < L) {n : ℕ} (hn : 0 < n)
    (sample : Fin n → UnitInterval) :
    unitIntervalLipschitzEmpiricalSup L ν sample =
      (L : ℝ) * anchoredLipschitzEmpiricalSup ν sample := by
  let sourceRange : Set ℝ := Set.range fun
    f : ↥(unitIntervalLipschitzBall L) =>
      |empiricalProcessValue ν sample f.1|
  let anchoredRange : Set ℝ := Set.range fun
    f : ↥anchoredUnitLipschitzClass =>
      |empiricalProcessValue ν sample f.1|
  have hrange : sourceRange = (L : ℝ) • anchoredRange := by
    ext y
    constructor
    · rintro ⟨f, rfl⟩
      let g : ↥anchoredUnitLipschitzClass :=
        ⟨sourceLipschitzToAnchored L f.1,
          sourceLipschitzToAnchored_mem hL f⟩
      rw [Set.mem_smul_set]
      refine ⟨|empiricalProcessValue ν sample g.1|,
        Set.mem_range_self g, ?_⟩
      simp only [smul_eq_mul]
      rw [← abs_of_pos (show (0 : ℝ) < L by exact_mod_cast hL),
        ← abs_mul]
      exact congrArg abs
        (empiricalProcessValue_sourceLipschitzToAnchored
          (ν := ν) hL hn sample f.1).symm
    · rw [Set.mem_smul_set]
      rintro ⟨z, ⟨g, rfl⟩, rfl⟩
      let f : ↥(unitIntervalLipschitzBall L) :=
        ⟨anchoredToSourceLipschitz L g.1,
          anchoredToSourceLipschitz_mem L g⟩
      refine ⟨f, ?_⟩
      simp only [smul_eq_mul]
      rw [← abs_of_nonneg L.coe_nonneg, ← abs_mul]
      exact congrArg abs
        (empiricalProcessValue_anchoredToSourceLipschitz
          (ν := ν) hn sample L g.1)
  unfold unitIntervalLipschitzEmpiricalSup anchoredLipschitzEmpiricalSup
  change sSup sourceRange = (L : ℝ) * sSup anchoredRange
  rw [hrange, Real.sSup_smul_of_nonneg L.coe_nonneg]
  rfl

/-- Every function in the zero-radius Lipschitz ball has zero centered empirical-process value.

**Lean implementation helper.** -/
lemma empiricalProcessValue_zeroLipschitz_eq_zero
    [OpensMeasurableSpace UnitInterval] [IsProbabilityMeasure ν]
    {n : ℕ} (hn : 0 < n) (sample : Fin n → UnitInterval)
    (f : ↥(unitIntervalLipschitzBall 0)) :
    empiricalProcessValue ν sample f.1 = 0 := by
  have hconst : ∀ x : UnitInterval, f.1 x = f.1 unitIntervalZero := by
    intro x
    have hd := f.2.dist_le_mul x unitIntervalZero
    have hd0 : dist (f.1 x) (f.1 unitIntervalZero) = 0 := by
      apply le_antisymm
      · simpa using hd
      · exact dist_nonneg
    exact dist_eq_zero.mp hd0
  have hfun : (fun x => f.1 x) =
      (fun _ : UnitInterval => f.1 unitIntervalZero) := funext hconst
  change empiricalProcessValue ν sample (fun x => f.1 x) = 0
  rw [hfun]
  exact empiricalProcessValue_const hn sample (f.1 unitIntervalZero)

/-- The empirical supremum over the zero-radius Lipschitz ball is zero.

**Lean implementation helper.** -/
lemma unitIntervalLipschitzEmpiricalSup_zero
    [OpensMeasurableSpace UnitInterval] [IsProbabilityMeasure ν]
    {n : ℕ} (hn : 0 < n) (sample : Fin n → UnitInterval) :
    unitIntervalLipschitzEmpiricalSup 0 ν sample = 0 := by
  let z : ↥(unitIntervalLipschitzBall 0) :=
    ⟨BoundedContinuousFunction.const UnitInterval (0 : ℝ), by
      change LipschitzWith 0 (fun _ : UnitInterval => (0 : ℝ))
      exact LipschitzWith.const (0 : ℝ)⟩
  have hrange : (Set.range fun f : ↥(unitIntervalLipschitzBall 0) =>
      |empiricalProcessValue ν sample f.1|) = {0} := by
    ext y
    constructor
    · rintro ⟨f, rfl⟩
      change |empiricalProcessValue ν sample f.1| ∈ {0}
      rw [empiricalProcessValue_zeroLipschitz_eq_zero hn sample f]
      simp
    · intro hy
      have hy0 : y = 0 := by simpa using hy
      subst y
      refine ⟨z, ?_⟩
      change |empiricalProcessValue ν sample z.1| = 0
      rw [empiricalProcessValue_zeroLipschitz_eq_zero hn sample z]
      simp
  unfold unitIntervalLipschitzEmpiricalSup
  rw [hrange, csSup_singleton]

/-- Shows that the empirical supremum over the radius-`L` Lipschitz ball is measurable.

**Lean implementation helper.** -/
lemma measurable_unitIntervalLipschitzEmpiricalSup
    [OpensMeasurableSpace UnitInterval] [IsProbabilityMeasure ν]
    {n : ℕ} (hn : 0 < n) (L : ℝ≥0) (X : Fin n → Ω → UnitInterval)
    (hXm : ∀ i, Measurable (X i)) :
    Measurable (fun ω =>
      unitIntervalLipschitzEmpiricalSup L ν (fun i => X i ω)) := by
  by_cases hL0 : L = 0
  · subst L
    have heq : (fun ω =>
        unitIntervalLipschitzEmpiricalSup 0 ν (fun i => X i ω)) =
        (fun _ => (0 : ℝ)) := by
      funext ω
      exact unitIntervalLipschitzEmpiricalSup_zero hn _
    rw [heq]
    exact measurable_const
  · have hL : 0 < L := bot_lt_iff_ne_bot.mpr hL0
    have heq : (fun ω =>
        unitIntervalLipschitzEmpiricalSup L ν (fun i => X i ω)) =
        (fun ω => (L : ℝ) *
          anchoredLipschitzEmpiricalSup ν (fun i => X i ω)) := by
      funext ω
      exact unitIntervalLipschitzEmpiricalSup_eq_mul_anchored_of_pos hL hn _
    rw [heq]
    exact (measurable_anchoredLipschitzEmpiricalSup hn X hXm).const_mul _

/-- Shows that the empirical supremum over the radius-`L` Lipschitz ball is integrable.

**Lean implementation helper.** -/
lemma integrable_unitIntervalLipschitzEmpiricalSup
    [OpensMeasurableSpace UnitInterval] [IsProbabilityMeasure P]
    [IsProbabilityMeasure ν] {n : ℕ} (hn : 0 < n) (L : ℝ≥0)
    (X : Fin n → Ω → UnitInterval) (hXm : ∀ i, Measurable (X i)) :
    Integrable (fun ω =>
      unitIntervalLipschitzEmpiricalSup L ν (fun i => X i ω)) P := by
  by_cases hL0 : L = 0
  · subst L
    have heq : (fun ω =>
        unitIntervalLipschitzEmpiricalSup 0 ν (fun i => X i ω)) =
        (fun _ => (0 : ℝ)) := by
      funext ω
      exact unitIntervalLipschitzEmpiricalSup_zero hn _
    rw [heq]
    exact integrable_zero Ω ℝ P
  · have hL : 0 < L := bot_lt_iff_ne_bot.mpr hL0
    have heq : (fun ω =>
        unitIntervalLipschitzEmpiricalSup L ν (fun i => X i ω)) =
        (fun ω => (L : ℝ) *
          anchoredLipschitzEmpiricalSup ν (fun i => X i ω)) := by
      funext ω
      exact unitIntervalLipschitzEmpiricalSup_eq_mul_anchored_of_pos hL hn _
    rw [heq]
    exact (integrable_anchoredLipschitzEmpiricalSup hn X hXm).const_mul _

/-- The radius-`L` Lipschitz empirical supremum is at most `2L` times the `[0,1]`-valued unit-Lipschitz supremum.

**Lean implementation helper.** -/
lemma unitIntervalLipschitzEmpiricalSup_le_two_mul
    [OpensMeasurableSpace UnitInterval] [IsProbabilityMeasure ν]
    {n : ℕ} (hn : 0 < n) (L : ℝ≥0)
    (sample : Fin n → UnitInterval) :
    unitIntervalLipschitzEmpiricalSup L ν sample ≤
      (2 * (L : ℝ)) * unitIntervalEmpiricalSup ν sample := by
  by_cases hL0 : L = 0
  · subst L
    rw [unitIntervalLipschitzEmpiricalSup_zero hn]
    norm_num
  · have hL : 0 < L := bot_lt_iff_ne_bot.mpr hL0
    rw [unitIntervalLipschitzEmpiricalSup_eq_mul_anchored_of_pos hL hn]
    calc
      (L : ℝ) * anchoredLipschitzEmpiricalSup ν sample ≤
          (L : ℝ) * (2 * unitIntervalEmpiricalSup ν sample) :=
        mul_le_mul_of_nonneg_left
          (anchoredLipschitzEmpiricalSup_le_two_unit hn sample) L.coe_nonneg
      _ = (2 * (L : ℝ)) * unitIntervalEmpiricalSup ν sample := by ring

/-- Uniform law of large numbers for all `L`-Lipschitz functions on `[0,1]`, at rate `L/sqrt n`. For all real-valued `L`-Lipschitz functions on `[0,1]`, the expectation of
the supremum of the empirical-process error is at most `2L/√n`. Additive
constants disappear from the empirical process; the preceding measurable
finite-net construction makes the uncountable supremum a genuine random
variable.

**Book Theorem 8.2.3.** -/
theorem theorem_8_2_3_lipschitz_uniform_lln_general
    [OpensMeasurableSpace UnitInterval] [IsProbabilityMeasure P]
    [IsProbabilityMeasure ν] (L : ℝ≥0) {n : ℕ} (hn : 0 < n)
    (X : Fin n → Ω → UnitInterval) (hXm : ∀ i, Measurable (X i))
    (hLaw : ∀ i, IdentDistrib (X i) (id : UnitInterval → UnitInterval) P ν)
    (hindep : Set.Pairwise Set.univ fun i j => IndepFun (X i) (X j) P) :
    (∫ ω, unitIntervalLipschitzEmpiricalSup L ν (fun i => X i ω) ∂P) ≤
      2 * (L : ℝ) / Real.sqrt n := by
  have hsourceInt := integrable_unitIntervalLipschitzEmpiricalSup
    (P := P) (ν := ν) hn L X hXm
  have hunitInt := integrable_unitIntervalEmpiricalSup
    (P := P) (ν := ν) hn X hXm
  have hpoint : ∀ ω,
      unitIntervalLipschitzEmpiricalSup L ν (fun i => X i ω) ≤
        (2 * (L : ℝ)) * unitIntervalEmpiricalSup ν (fun i => X i ω) :=
    fun ω => unitIntervalLipschitzEmpiricalSup_le_two_mul hn L _
  have hnormalized := theorem_8_2_3_lipschitz_uniform_lln
    (P := P) (ν := ν) hn X hXm hLaw hindep
  calc
    (∫ ω, unitIntervalLipschitzEmpiricalSup L ν (fun i => X i ω) ∂P) ≤
        ∫ ω, (2 * (L : ℝ)) *
          unitIntervalEmpiricalSup ν (fun i => X i ω) ∂P :=
      integral_mono hsourceInt (hunitInt.const_mul _) hpoint
    _ = (2 * (L : ℝ)) *
        (∫ ω, unitIntervalEmpiricalSup ν (fun i => X i ω) ∂P) := by
      rw [integral_const_mul]
    _ ≤ (2 * (L : ℝ)) * (1 / Real.sqrt n) :=
      mul_le_mul_of_nonneg_left hnormalized (by positivity)
    _ = 2 * (L : ℝ) / Real.sqrt n := by ring

/-- A single sample realizes the uniform bound from Theorem 8.2.3
simultaneously for the full (generally infinite) class of `L`-Lipschitz
functions on `[0,1]`.

**Book Remark 8.2.4.** -/
theorem remark_8_2_4_exists_good_lipschitz_sample
    [OpensMeasurableSpace UnitInterval] [IsProbabilityMeasure P]
    [IsProbabilityMeasure ν] {L : ℝ≥0} (hL : 0 < L)
    {n : ℕ} (hn : 0 < n)
    (X : Fin n → Ω → UnitInterval) (hXm : ∀ i, Measurable (X i))
    (hLaw : ∀ i, IdentDistrib (X i) (id : UnitInterval → UnitInterval) P ν)
    (hindep : Set.Pairwise Set.univ fun i j => IndepFun (X i) (X j) P) :
    ∃ ω, unitIntervalLipschitzEmpiricalSup L ν (fun i => X i ω) <
      4 * (L : ℝ) / Real.sqrt n := by
  let Z : Ω → ℝ := fun ω =>
    unitIntervalLipschitzEmpiricalSup L ν (fun i => X i ω)
  have hZint : Integrable Z P :=
    integrable_unitIntervalLipschitzEmpiricalSup hn L X hXm
  have hZ0 : ∀ ω, 0 ≤ Z ω := by
    intro ω
    change 0 ≤ unitIntervalLipschitzEmpiricalSup L ν (fun i => X i ω)
    rw [unitIntervalLipschitzEmpiricalSup_eq_mul_anchored_of_pos hL hn]
    exact mul_nonneg L.coe_nonneg
      (anchoredLipschitzEmpiricalSup_nonneg hn _)
  have hmean : ∫ ω, Z ω ∂P ≤ 2 * (L : ℝ) / Real.sqrt n :=
    theorem_8_2_3_lipschitz_uniform_lln_general L hn X hXm hLaw hindep
  have hB : 0 < 2 * (L : ℝ) / Real.sqrt n := by
    have hnR : (0 : ℝ) < n := by exact_mod_cast hn
    positivity
  obtain ⟨ω, hω⟩ := exists_lt_two_mul_of_integral_le hZint hZ0 hB hmean
  refine ⟨ω, ?_⟩
  change unitIntervalLipschitzEmpiricalSup L ν (fun i => X i ω) < _ at hω
  convert hω using 1 <;> ring

end

end HDP.Chapter8

end Source_03_EmpiricalProcesses

/-! ## Material formerly in `04_VCDimension.lean` -/

section Source_04_VCDimension

/-!
# Book Chapter 8, §8.3.1: VC dimension and finite examples

`HDP.BooleanClass α = Set (Set α)` models an arbitrary class of Boolean
functions by identifying each function with the set on which it equals one.
Its VC predicates quantify over arbitrary finite samples and do
not assume that either the domain or the class is finite.

For compatibility with the earlier finite combinatorial development, this
module also retains `HDP.Chapter8.BooleanFamily = Finset (Finset α)` and its
Mathlib `Finset.Shatters`/`Finset.vcDim` wrappers.  Those declarations are
finite trace helpers, not replacements for the general source definitions.

The Euclidean half-space example is proved for the actual infinite class: the
lower bound explicitly shatters an affine simplex and the upper bound follows
from Radon's theorem.
-/

open scoped BigOperators

namespace HDP

/-- A Boolean class on `α` is a set of supports of zero-one functions.
Neither the domain nor the class is required to be finite. -/
abbrev BooleanClass (α : Type*) := Set (Set α)

namespace BooleanClass

variable {α : Type*}

/-- The trace of a set on a finite sample.

**Lean implementation helper.** -/
noncomputable def trace (s : Finset α) (u : Set α) : Finset α := by
  classical
  exact s.filter fun x => x ∈ u

/-- Characterizes membership in the trace of a set on a finite support.

**Lean implementation helper.** -/
@[simp]
theorem mem_trace {s : Finset α} {u : Set α} {x : α} :
    x ∈ trace s u ↔ x ∈ s ∧ x ∈ u := by
  classical
  simp [trace]

/-- A Boolean class shatters a finite sample when it realizes every labeling
of that sample. This is the source-faithful predicate underlying Definition
8.3.1.

**Book Definition 8.3.1.** -/
def Shatters (F : BooleanClass α) (s : Finset α) : Prop := by
  classical
  exact ∀ t : Finset α, t ⊆ s → ∃ u ∈ F, trace s u = t

/-- VC dimension is the largest size of a shattered subset, with an infinite case. `VCDimLE F d` says that no finite sample of cardinality greater than `d`
is shattered by `F`. It remains meaningful when the domain and class are
infinite.

**Book Definition 8.3.1.** -/
def VCDimLE (F : BooleanClass α) (d : ℕ) : Prop :=
  ∀ s : Finset α, F.Shatters s → s.card ≤ d

/-- A safe finite-value formulation of `vc(F) = d`: `d` is an upper bound and
some `d`-point sample is shattered. Classes of infinite VC dimension simply
satisfy no proposition of this form.

**Lean implementation helper.** -/
def VCDimEq (F : BooleanClass α) (d : ℕ) : Prop :=
  F.VCDimLE d ∧ ∃ s : Finset α, F.Shatters s ∧ s.card = d

/-- Shattering is inherited by smaller finite samples.

**Lean implementation helper.** -/
theorem Shatters.mono_right {F : BooleanClass α} {s t : Finset α}
    (h : t ⊆ s) (hs : F.Shatters s) : F.Shatters t := by
  classical
  intro u hu
  obtain ⟨a, haF, ha⟩ := hs u (hu.trans h)
  refine ⟨a, haF, ?_⟩
  ext x
  simp only [mem_trace]
  constructor
  · rintro ⟨hxt, hxa⟩
    have hxs : x ∈ s := h hxt
    have : x ∈ u := by
      rw [← ha]
      exact mem_trace.mpr ⟨hxs, hxa⟩
    exact this
  · intro hxu
    exact ⟨hu hxu, by
      have hxs : x ∈ s := h (hu hxu)
      have : x ∈ trace s a := by rw [ha]; exact hxu
      exact (mem_trace.mp this).2⟩

end BooleanClass
end HDP

namespace HDP.Chapter8

variable {α : Type*}

/-! ## Source-faithful infinite interval class -/

/-- Any finite set of real numbers with more than two elements contains three strictly increasing elements.

**Lean implementation helper.** -/
private theorem exists_real_ordered_triple {s : Finset ℝ}
    (hs : 2 < s.card) :
    ∃ x ∈ s, ∃ y ∈ s, ∃ z ∈ s, x < y ∧ y < z := by
  obtain ⟨a, ha, b, hb, c, hc, hab, hac, hbc⟩ := Finset.two_lt_card.mp hs
  rcases lt_or_gt_of_ne hab with hab' | hba
  · rcases lt_trichotomy c a with hca | hca | hac'
    · exact ⟨c, hc, a, ha, b, hb, hca, hab'⟩
    · exact (hac hca.symm).elim
    · rcases lt_trichotomy c b with hcb | hcb | hbc'
      · exact ⟨a, ha, c, hc, b, hb, hac', hcb⟩
      · exact (hbc hcb.symm).elim
      · exact ⟨a, ha, b, hb, c, hc, hab', hbc'⟩
  · rcases lt_trichotomy c b with hcb | hcb | hbc'
    · exact ⟨c, hc, b, hb, a, ha, hcb, hba⟩
    · exact (hbc hcb.symm).elim
    · rcases lt_trichotomy c a with hca | hca | hac'
      · exact ⟨b, hb, c, hc, a, ha, hbc', hca⟩
      · exact (hac hca.symm).elim
      · exact ⟨b, hb, a, ha, c, hc, hba, hac'⟩

/-- The actual Boolean class of all closed intervals in `ℝ`.

**Lean implementation helper.** -/
def realClosedIntervals : HDP.BooleanClass ℝ :=
  {u | ∃ a b : ℝ, u = Set.Icc a b}

/-- A subset of `{0,1}` containing neither point is empty.

**Lean implementation helper.** -/
private theorem finset_eq_empty_of_subset_pair
    {t : Finset ℝ} (ht : t ⊆ ({0, 1} : Finset ℝ))
    (h0 : (0 : ℝ) ∉ t) (h1 : (1 : ℝ) ∉ t) :
    t = ∅ := by
  ext x
  constructor
  · intro hx
    have hxpair := ht hx
    simp only [Finset.mem_insert, Finset.mem_singleton] at hxpair
    rcases hxpair with rfl | rfl
    · exact (h0 hx).elim
    · exact (h1 hx).elim
  · simp

/-- A subset of `{0,1}` containing `0` but not `1` is `{0}`.

**Lean implementation helper.** -/
private theorem finset_eq_singleton_zero_of_subset_pair
    {t : Finset ℝ} (ht : t ⊆ ({0, 1} : Finset ℝ))
    (h0 : (0 : ℝ) ∈ t) (h1 : (1 : ℝ) ∉ t) :
    t = {0} := by
  ext x
  constructor
  · intro hx
    have hxpair := ht hx
    simp only [Finset.mem_insert, Finset.mem_singleton] at hxpair
    rcases hxpair with rfl | rfl
    · simp
    · exact (h1 hx).elim
  · intro hx
    simp only [Finset.mem_singleton] at hx
    subst x
    exact h0

/-- A subset of `{0,1}` containing `1` but not `0` is `{1}`.

**Lean implementation helper.** -/
private theorem finset_eq_singleton_one_of_subset_pair
    {t : Finset ℝ} (ht : t ⊆ ({0, 1} : Finset ℝ))
    (h0 : (0 : ℝ) ∉ t) (h1 : (1 : ℝ) ∈ t) :
    t = {1} := by
  ext x
  constructor
  · intro hx
    have hxpair := ht hx
    simp only [Finset.mem_insert, Finset.mem_singleton] at hxpair
    rcases hxpair with rfl | rfl
    · exact (h0 hx).elim
    · simp
  · intro hx
    simp only [Finset.mem_singleton] at hx
    subst x
    exact h1

/-- A subset of `{0,1}` containing both points is all of `{0,1}`.

**Lean implementation helper.** -/
private theorem finset_eq_pair_of_subset_pair
    {t : Finset ℝ} (ht : t ⊆ ({0, 1} : Finset ℝ))
    (h0 : (0 : ℝ) ∈ t) (h1 : (1 : ℝ) ∈ t) :
    t = {0, 1} := by
  apply Finset.Subset.antisymm ht
  intro x hx
  simp only [Finset.mem_insert, Finset.mem_singleton] at hx
  rcases hx with rfl | rfl
  · exact h0
  · exact h1

/-- The two-point sample `{0,1}` is shattered by real closed intervals.

**Lean implementation helper.** -/
theorem realClosedIntervals_shatter_pair :
    realClosedIntervals.Shatters ({0, 1} : Finset ℝ) := by
  classical
  intro t ht
  by_cases h0 : (0 : ℝ) ∈ t <;> by_cases h1 : (1 : ℝ) ∈ t
  · have ht' := finset_eq_pair_of_subset_pair ht h0 h1
    refine ⟨Set.Icc (0 : ℝ) 1, ⟨0, 1, rfl⟩, ?_⟩
    rw [ht']
    ext x
    simp only [HDP.BooleanClass.mem_trace, Finset.mem_insert,
      Finset.mem_singleton, Set.mem_Icc]
    constructor
    · exact fun h => h.1
    · intro h
      refine ⟨h, ?_⟩
      rcases h with rfl | rfl <;> norm_num
  · have ht' := finset_eq_singleton_zero_of_subset_pair ht h0 h1
    refine ⟨Set.Icc (0 : ℝ) 0, ⟨0, 0, rfl⟩, ?_⟩
    rw [ht']
    ext x
    simp only [HDP.BooleanClass.mem_trace, Finset.mem_insert,
      Finset.mem_singleton, Set.mem_Icc]
    constructor
    · rintro ⟨hpair, hx⟩
      rcases hpair with rfl | rfl
      · rfl
      · norm_num at hx
    · intro hx
      subst x
      norm_num
  · have ht' := finset_eq_singleton_one_of_subset_pair ht h0 h1
    refine ⟨Set.Icc (1 : ℝ) 1, ⟨1, 1, rfl⟩, ?_⟩
    rw [ht']
    ext x
    simp only [HDP.BooleanClass.mem_trace, Finset.mem_insert,
      Finset.mem_singleton, Set.mem_Icc]
    constructor
    · rintro ⟨hpair, hx⟩
      rcases hpair with rfl | rfl
      · norm_num at hx
      · rfl
    · intro hx
      subst x
      norm_num
  · have ht' := finset_eq_empty_of_subset_pair ht h0 h1
    refine ⟨Set.Icc (1 : ℝ) 0, ⟨1, 0, rfl⟩, ?_⟩
    rw [ht']
    ext x
    simp [HDP.BooleanClass.mem_trace]

/-- No three-point subset of `ℝ` is shattered by closed intervals.

**Lean implementation helper.** -/
theorem realClosedIntervals_vcDimLE : realClosedIntervals.VCDimLE 2 := by
  classical
  intro s hs
  by_contra hcard
  have htwo : 2 < s.card := Nat.lt_of_not_ge hcard
  obtain ⟨x, hx, y, hy, z, hz, hxy, hyz⟩ := exists_real_ordered_triple htwo
  have htarget : ({x, z} : Finset ℝ) ⊆ s := by
    intro w hw
    simp only [Finset.mem_insert, Finset.mem_singleton] at hw
    rcases hw with rfl | rfl
    · exact hx
    · exact hz
  obtain ⟨u, ⟨a, b, rfl⟩, hu⟩ := hs ({x, z} : Finset ℝ) htarget
  have hxI : x ∈ Set.Icc a b := by
    have : x ∈ HDP.BooleanClass.trace s (Set.Icc a b) := by
      rw [hu]
      simp
    exact (HDP.BooleanClass.mem_trace.mp this).2
  have hzI : z ∈ Set.Icc a b := by
    have : z ∈ HDP.BooleanClass.trace s (Set.Icc a b) := by
      rw [hu]
      simp
    exact (HDP.BooleanClass.mem_trace.mp this).2
  have hyI : y ∈ Set.Icc a b := ⟨hxI.1.trans hxy.le, hyz.le.trans hzI.2⟩
  have : y ∈ ({x, z} : Finset ℝ) := by
    rw [← hu]
    exact HDP.BooleanClass.mem_trace.mpr ⟨hy, hyI⟩
  simp only [Finset.mem_insert, Finset.mem_singleton] at this
  rcases this with h | h
  · exact (ne_of_lt hxy) h.symm
  · exact (ne_of_lt hyz) h

/-- Indicators of real intervals have VC dimension two. The class of all closed intervals in
`ℝ` has VC dimension exactly two.

**Book Example 8.3.2.** -/
theorem example_8_3_2_real_closed_intervals :
    HDP.BooleanClass.VCDimEq realClosedIntervals 2 := by
  exact ⟨realClosedIntervals_vcDimLE, {0, 1},
    realClosedIntervals_shatter_pair, by simp⟩

/-- The authoritative finite model of a class of Boolean functions: a member
`u : Finset α` is the support of one Boolean function. -/
abbrev BooleanFamily (α : Type*) [DecidableEq α] := Finset (Finset α)

/-- Restrict a support `u` to the finite sample `s`, retaining the sample as
the ambient subtype.

**Lean implementation helper.** -/
def restrictSupport [DecidableEq α] (s u : Finset α) : Finset s :=
  s.attach.filter fun x => (x : α) ∈ u

/-- Characterizes membership in the restriction to a finite support.

**Lean implementation helper.** -/
@[simp]
theorem mem_restrictSupport [DecidableEq α] {s u : Finset α} {x : s} :
    x ∈ restrictSupport s u ↔ (x : α) ∈ u := by
  simp [restrictSupport]

/-- The finite family of all distinct restrictions of `F` to `s`.

**Lean implementation helper.** -/
def traceFamily [DecidableEq α] (F : BooleanFamily α) (s : Finset α) :
    BooleanFamily s :=
  F.image (restrictSupport s)

/-- Characterizes membership in the family of all traces on a finite support.

**Lean implementation helper.** -/
@[simp]
theorem mem_traceFamily [DecidableEq α] {F : BooleanFamily α} {s : Finset α}
    {v : Finset s} :
    v ∈ traceFamily F s ↔ ∃ u ∈ F, restrictSupport s u = v := by
  simp [traceFamily]

/-- `F.Shatters s` says that every binary labeling of `s` is the restriction of
some member of `F`; `F.vcDim` is the largest cardinality of such an `s`. The displayed equivalence is Mathlib's exact trace characterization.

**Book Definition 8.3.1.** -/
theorem definition_8_3_1_shatters_iff [DecidableEq α]
    (F : BooleanFamily α) (s : Finset α) :
    F.Shatters s ↔ F.image (fun u => s ∩ u) = s.powerset :=
  Finset.shatters_iff

/-- Every finite VC dimension is bounded by the cardinality of its ambient
finite type.

**Lean implementation helper.** -/
theorem vcDim_le_card [Fintype α] [DecidableEq α] (F : BooleanFamily α) :
    F.vcDim ≤ Fintype.card α := by
  unfold Finset.vcDim
  exact Finset.sup_le fun s _ => Finset.card_le_univ s

/-- The full Boolean class shatters the whole finite domain.

**Lean implementation helper.** -/
theorem vcDim_univ [Fintype α] [DecidableEq α] :
    (Finset.univ : BooleanFamily α).vcDim = Fintype.card α := by
  apply le_antisymm (vcDim_le_card _)
  have h := (Finset.univ_shatters (s := (Finset.univ : Finset α))).card_le_vcDim
  simpa using h

/-- A finite subset of a line is order-convex when it contains every point of
the ambient ordered sample lying between two of its points.

**Lean implementation helper.** -/
def IsOrderConvexFinset [LinearOrder α] (u : Finset α) : Prop :=
  ∀ ⦃x⦄, x ∈ u → ∀ ⦃y⦄, y ∈ u → ∀ z, x ≤ z → z ≤ y → z ∈ u

/-- Any finite subset of a linear order with more than two elements contains a strictly increasing triple.

**Lean implementation helper.** -/
private theorem exists_ordered_triple [LinearOrder α] {s : Finset α}
    (hs : 2 < s.card) :
    ∃ x ∈ s, ∃ y ∈ s, ∃ z ∈ s, x < y ∧ y < z := by
  obtain ⟨a, ha, b, hb, c, hc, hab, hac, hbc⟩ := Finset.two_lt_card.mp hs
  rcases lt_or_gt_of_ne hab with hab' | hba
  · rcases lt_trichotomy c a with hca | hca | hac'
    · exact ⟨c, hc, a, ha, b, hb, hca, hab'⟩
    · exact (hac hca.symm).elim
    · rcases lt_trichotomy c b with hcb | hcb | hbc'
      · exact ⟨a, ha, c, hc, b, hb, hac', hcb⟩
      · exact (hbc hcb.symm).elim
      · exact ⟨a, ha, b, hb, c, hc, hab', hbc'⟩
  · rcases lt_trichotomy c b with hcb | hcb | hbc'
    · exact ⟨c, hc, b, hb, a, ha, hcb, hba⟩
    · exact (hbc hcb.symm).elim
    · rcases lt_trichotomy c a with hca | hca | hac'
      · exact ⟨b, hb, c, hc, a, ha, hbc', hca⟩
      · exact (hac hca.symm).elim
      · exact ⟨b, hb, a, ha, c, hc, hba, hac'⟩

/-- The obstruction in : any finite family
whose supports are order-convex has VC dimension at most two. Applied to the
traces of closed intervals on a finite ordered sample, this is the source's
upper-bound argument.

**Book Example 8.3.2 (intervals).** -/
theorem example_8_3_2_interval_upper [LinearOrder α]
    (F : BooleanFamily α)
    (hconv : ∀ u ∈ F, IsOrderConvexFinset u) :
    F.vcDim ≤ 2 := by
  unfold Finset.vcDim
  apply Finset.sup_le
  intro s hs
  rw [Finset.mem_shatterer] at hs
  by_contra hcard
  have htwo : 2 < s.card := Nat.lt_of_not_ge hcard
  obtain ⟨x, hx, y, hy, z, hz, hxy, hyz⟩ := exists_ordered_triple htwo
  have htarget : ({x, z} : Finset α) ⊆ s := by
    intro w hw
    simp only [Finset.mem_insert, Finset.mem_singleton] at hw
    rcases hw with rfl | rfl
    · exact hx
    · exact hz
  obtain ⟨u, huF, hu⟩ := hs htarget
  have hxu : x ∈ u := by
    have : x ∈ s ∩ u := by simp [hu]
    exact Finset.mem_inter.mp this |>.2
  have hzu : z ∈ u := by
    have : z ∈ s ∩ u := by simp [hu]
    exact Finset.mem_inter.mp this |>.2
  have hyu : y ∈ u := hconv u huF hxu hzu y hxy.le hyz.le
  have : y ∈ ({x, z} : Finset α) := by
    rw [← hu]
    exact Finset.mem_inter.mpr ⟨hy, hyu⟩
  simp only [Finset.mem_insert, Finset.mem_singleton] at this
  rcases this with h | h
  · exact (ne_of_lt hxy) h.symm
  · exact (ne_of_lt hyz) h

/-- The two-point trace family realized by intervals. Every one of the four
labelings of two ordered points occurs.

**Lean implementation helper.** -/
def twoPointIntervalTraces : BooleanFamily (Fin 2) := Finset.univ

/-- This declaration formalizes the statement identified as Example 8.3.2 (intervals) in the source.

**Book Example 8.3.2 (intervals).** -/
theorem example_8_3_2_interval_lower :
    twoPointIntervalTraces.vcDim = 2 := by
  simpa [twoPointIntervalTraces] using (vcDim_univ ( α := Fin 2))

/-- All labelings of the `d+1` vertices of a simplex. Geometrically these
are precisely the finite labelings used in the standard half-space lower
bound: disjoint faces of a simplex can be strictly separated.

**Lean implementation helper.** -/
def simplexLabelFamily (d : ℕ) : BooleanFamily (Fin (d + 1)) := Finset.univ

/-- Legacy finite general-position certificate: three abstract simplex vertices
realize all eight binary labelings. The source-faithful class of actual
Euclidean half-planes is handled below.

**Lean implementation helper.** -/
theorem example_8_3_3_halfplanes_finite_certificate :
    (simplexLabelFamily 2).vcDim = 3 := by
  simpa [simplexLabelFamily] using (vcDim_univ (α := Fin 3))

/-- The support sets `{2}`, `{1}`, `{0}`, and `univ` encode the four binary
strings `001, 010, 100, 111` from Book Example 8.3.4.

**Book Example 8.3.4.** -/
def binaryStringFamily : BooleanFamily (Fin 3) :=
  {{2}, {1}, {0}, Finset.univ}

/-- The four strings `001,010,100,111` have VC dimension two.

**Book Example 8.3.4.** -/
theorem example_8_3_4 : binaryStringFamily.vcDim = 2 := by
  decide

/-- The concrete pair of coordinates `1,3` in Example 8.3.4 is shattered.

**Book Example 8.3.4.** -/
theorem example_8_3_4_shatters_pair :
    binaryStringFamily.Shatters ({0, 2} : Finset (Fin 3)) := by
  decide

/-- Corrected count for Example 8.3.4 as used around Pajor's lemma: once the
empty set is included, the family shatters seven subsets, not six.

**Book Example 8.3.4.** -/
theorem example_8_3_4_shatterer_card : binaryStringFamily.shatterer.card = 7 := by
  decide

/-- Legacy finite simplex-labeling certificate used by downstream finite
combinatorial wrappers. This declaration by itself contains no Euclidean
half-spaces; the source-faithful Example 8.3.5 is
`example_8_3_5_euclidean_halfspaces` below.

**Book Example 8.3.5.** -/
theorem example_8_3_5_halfspaces (n : ℕ) :
    (simplexLabelFamily n).vcDim = n + 1 := by
  simpa [simplexLabelFamily] using (vcDim_univ (α := Fin (n + 1)))

/-- A closed affine half-space with normal `a` and threshold `b`.

**Lean implementation helper.** -/
def closedAffineHalfspace {E : Type*} [NormedAddCommGroup E]
    [InnerProductSpace ℝ E] (a : E) (b : ℝ) : Set E :=
  {x | inner ℝ a x ≤ b}

/-- The actual (generally infinite) Boolean class of all closed affine
half-spaces in `ℝ^n`.

**Lean implementation helper.** -/
def euclideanHalfspaces (n : ℕ) :
    HDP.BooleanClass (EuclideanSpace ℝ (Fin n)) :=
  {u | ∃ a b, u = closedAffineHalfspace a b}

/-- The standard affine simplex `0, e₁, ..., eₙ` in `ℝ^n`.

**Lean implementation helper.** -/
noncomputable def euclideanSimplex (n : ℕ) :
    Finset (EuclideanSpace ℝ (Fin n)) :=
  insert 0 (Finset.univ.image fun i : Fin n => EuclideanSpace.single i 1)

/-- Distinct coordinates determine distinct Euclidean standard basis vectors.

**Lean implementation helper.** -/
private theorem euclidean_single_injective (n : ℕ) :
    Function.Injective (fun i : Fin n =>
      (EuclideanSpace.single i 1 : EuclideanSpace ℝ (Fin n))) := by
  intro i j hij
  by_contra hne
  have hcoord := congrArg (fun x : EuclideanSpace ℝ (Fin n) => x i) hij
  simp [hne] at hcoord

/-- The zero vector is not a Euclidean standard basis vector.

**Lean implementation helper.** -/
private theorem zero_not_mem_euclidean_single_image (n : ℕ) :
    (0 : EuclideanSpace ℝ (Fin n)) ∉
      Finset.univ.image (fun i : Fin n => EuclideanSpace.single i 1) := by
  intro h
  obtain ⟨i, -, hi⟩ := Finset.mem_image.mp h
  have hcoord := congrArg (fun x : EuclideanSpace ℝ (Fin n) => x i) hi
  simp at hcoord

/-- The coordinate simplex in dimension `n` has `n+1` vertices.

**Lean implementation helper.** -/
theorem card_euclideanSimplex (n : ℕ) :
    (euclideanSimplex n).card = n + 1 := by
  classical
  rw [euclideanSimplex,
    Finset.card_insert_of_notMem (zero_not_mem_euclidean_single_image n),
    Finset.card_image_of_injective Finset.univ (euclidean_single_injective n)]
  simp

/-- Every labeling of the standard affine simplex is cut out by an explicit
closed affine half-space.

**Lean implementation helper.** -/
theorem euclideanHalfspaces_shatter_simplex (n : ℕ) :
    (euclideanHalfspaces n).Shatters (euclideanSimplex n) := by
  classical
  intro t ht
  let b : ℝ := if (0 : EuclideanSpace ℝ (Fin n)) ∈ t then 1 else -1
  let a : EuclideanSpace ℝ (Fin n) := WithLp.toLp 2 fun i : Fin n =>
    if EuclideanSpace.single i 1 ∈ t then b - 1 else b + 1
  refine ⟨closedAffineHalfspace a b, ⟨a, b, rfl⟩, ?_⟩
  ext x
  simp only [HDP.BooleanClass.mem_trace]
  constructor
  · rintro ⟨hxs, hxH⟩
    rw [euclideanSimplex, Finset.mem_insert] at hxs
    rcases hxs with rfl | hxs
    · by_contra hxnot
      simp [closedAffineHalfspace, b, hxnot] at hxH
      norm_num at hxH
    · obtain ⟨i, -, rfl⟩ := Finset.mem_image.mp hxs
      by_contra hxnot
      simp [closedAffineHalfspace, a, b, hxnot,
        EuclideanSpace.inner_single_right] at hxH
      norm_num at hxH
  · intro hxt
    refine ⟨ht hxt, ?_⟩
    have hxs := ht hxt
    rw [euclideanSimplex, Finset.mem_insert] at hxs
    rcases hxs with hx0 | hximage
    · subst x
      simp [closedAffineHalfspace, b, hxt]
    · obtain ⟨i, -, rfl⟩ := Finset.mem_image.mp hximage
      simp [closedAffineHalfspace, a, b, hxt,
        EuclideanSpace.inner_single_right]

/-- No `n+2` points in `ℝ^n` can be shattered by affine half-spaces. The
proof applies Radon's theorem and labels one part of the Radon partition by
one and the other by zero; convexity then gives an impossible common point.

**Lean implementation helper.** -/
theorem euclideanHalfspaces_vcDimLE (n : ℕ) :
    (euclideanHalfspaces n).VCDimLE (n + 1) := by
  classical
  intro s hs
  by_contra hcard
  have hlarge : n + 2 ≤ s.card := by omega
  obtain ⟨q, hqs, hqcard⟩ := Finset.exists_subset_card_eq hlarge
  have hq : (euclideanHalfspaces n).Shatters q :=
    HDP.BooleanClass.Shatters.mono_right hqs hs
  let f : q → EuclideanSpace ℝ (Fin n) := fun x => x.1
  have hdep : ¬ AffineIndependent ℝ f := by
    rw [← finrank_vectorSpan_le_iff_not_affineIndependent ℝ f (n := n)]
    · calc
        Module.finrank ℝ (vectorSpan ℝ (Set.range f)) ≤
            Module.finrank ℝ (EuclideanSpace ℝ (Fin n)) :=
          Submodule.finrank_le _
        _ = n := finrank_euclideanSpace_fin
    · simp [hqcard]
  obtain ⟨I, p, hpI, hpIc⟩ := Convex.radon_partition hdep
  let J : Finset q := Finset.univ.filter fun x => x ∈ I
  let e : q ↪ EuclideanSpace ℝ (Fin n) :=
    ⟨fun x => x.1, Subtype.val_injective⟩
  let t : Finset (EuclideanSpace ℝ (Fin n)) := J.map e
  have htq : t ⊆ q := by
    intro x hxt
    obtain ⟨i, hiJ, rfl⟩ := Finset.mem_map.mp hxt
    exact i.2
  obtain ⟨H, hHF, htrace⟩ := hq t htq
  obtain ⟨a, b, rfl⟩ := hHF
  have hI : f '' I ⊆ closedAffineHalfspace a b := by
    rintro x ⟨i, hiI, rfl⟩
    have hit : i.1 ∈ t := by
      apply Finset.mem_map.mpr
      exact ⟨i, by simp [J, hiI], rfl⟩
    have : i.1 ∈ HDP.BooleanClass.trace q (closedAffineHalfspace a b) := by
      rw [htrace]
      exact hit
    exact (HDP.BooleanClass.mem_trace.mp this).2
  have hIc : f '' Iᶜ ⊆ {x | b < inner ℝ a x} := by
    rintro x ⟨i, hiIc, rfl⟩
    have hiNotI : i ∉ I := hiIc
    have hit : i.1 ∉ t := by
      intro hit
      obtain ⟨j, hjJ, hji⟩ := Finset.mem_map.mp hit
      have : j = i := Subtype.ext hji
      subst j
      exact hiNotI (by simpa [J] using hjJ)
    have hiq : i.1 ∈ q := i.2
    have hiNotH : i.1 ∉ closedAffineHalfspace a b := by
      intro hiH
      apply hit
      rw [← htrace]
      exact HDP.BooleanClass.mem_trace.mpr ⟨hiq, hiH⟩
    simpa [closedAffineHalfspace, not_le] using hiNotH
  have hlinear : IsLinearMap ℝ
      (fun x : EuclideanSpace ℝ (Fin n) => inner ℝ a x) :=
    (innerSL ℝ a).isLinear
  have hp_le : p ∈ closedAffineHalfspace a b :=
    (convexHull_min hI (convex_halfSpace_le hlinear b)) hpI
  have hp_gt : p ∈ {x | b < inner ℝ a x} :=
    (convexHull_min hIc (convex_halfSpace_gt hlinear b)) hpIc
  change inner ℝ a p ≤ b at hp_le
  change b < inner ℝ a p at hp_gt
  exact (not_lt_of_ge hp_le) hp_gt

/-- Affine half-spaces in `R^n` have VC dimension `n+1`.

**Book Example 8.3.5.** -/
theorem example_8_3_5_euclidean_halfspaces (n : ℕ) :
    HDP.BooleanClass.VCDimEq (euclideanHalfspaces n) (n + 1) := by
  exact ⟨euclideanHalfspaces_vcDimLE n,
    euclideanSimplex n, euclideanHalfspaces_shatter_simplex n,
    card_euclideanSimplex n⟩

/-- Affine half-planes in `R^2` have VC dimension three. The full infinite class of affine
half-planes in `ℝ²` has VC dimension exactly three.

**Book Example 8.3.3.** -/
theorem example_8_3_3_euclidean_halfplanes :
    HDP.BooleanClass.VCDimEq (euclideanHalfspaces 2) 3 := by
  simpa using example_8_3_5_euclidean_halfspaces 2

/-- Affine half-spaces in `R^n` have VC dimension `n+1`.

**Book Example 8.3.5.** -/
theorem exercise_8_17_halfspaces_vc_dimension (n : ℕ) :
    HDP.BooleanClass.VCDimEq (euclideanHalfspaces n) (n + 1) :=
  example_8_3_5_euclidean_halfspaces n

/-- VC dimension often roughly matches parameter count; for half-spaces it exactly matches `n+1`. For the simplex trace certificate the VC dimension equals the number `n+1`
of affine parameters. The source correctly presents the general
parameter-count rule only as a heuristic.

**Book Remark 8.3.6.** -/
theorem remark_8_3_6_simplex_parameter_count (n : ℕ) :
    (simplexLabelFamily n).vcDim = n + 1 :=
  example_8_3_5_halfspaces n

end HDP.Chapter8

end Source_04_VCDimension

/-! ## Material formerly in `05_PajorSauerShelah.lean` -/

section Source_05_PajorSauerShelah

/-!
# Book Chapter 8, §8.3.2--8.3.3: Pajor and Sauer--Shelah

The main combinatorial results are direct source-numbered wrappers around
Mathlib's authoritative finite set-family API.  The real-valued second
Sauer--Shelah estimate uses the binomial partial-sum estimate already proved
in Chapter 4, with a separate `vcDim = 0` branch so that no division by zero
is hidden.
-/

open scoped BigOperators

namespace HDP.Chapter8

variable {α : Type*} [DecidableEq α]

/-- A finite Boolean family lies between `2^vc` and `2^n`. Equation (8.27), lower bound in its exact finite form: a class that
shatters `s` contains at least all `2 ^ |s|` traces.

**Book Equation (8.27).** -/
theorem card_family_lower_of_shatters (F : BooleanFamily α) {s : Finset α}
    (hs : F.Shatters s) :
    2 ^ s.card ≤ F.card := by
  rw [← Finset.card_powerset]
  rw [← Finset.shatters_iff.mp hs]
  exact Finset.card_image_le

/-- A finite Boolean family lies between `2^vc` and `2^n`. Equation (8.27), the trivial upper bound by the full Boolean class.

**Book Equation (8.27).** -/
theorem card_family_le_two_pow [Fintype α] (F : BooleanFamily α) :
    F.card ≤ 2 ^ Fintype.card α := by
  calc
    F.card ≤ (Finset.univ : BooleanFamily α).card :=
      Finset.card_le_card (Finset.subset_univ F)
    _ = 2 ^ Fintype.card α := by simp

/-- Pajor: a finite Boolean family has at least as many shattered subsets as functions. The number of members of a finite
Boolean class is at most the number of subsets it shatters.

**Book Lemma 8.3.7.** -/
theorem lemma_8_3_7_pajor (F : BooleanFamily α) :
    F.card ≤ F.shatterer.card :=
  Finset.card_le_card_shatterer F

/-- The `x₀ = 3`, label-zero restricted family in Book Example 8.3.8.

**Book Example 8.3.8.** -/
def pajorSplitZero : BooleanFamily (Fin 2) := {{1}, {0}}

/-- The `x₀ = 3`, label-one restricted family in Book Example 8.3.8.

**Book Example 8.3.8.** -/
def pajorSplitOne : BooleanFamily (Fin 2) := {∅, Finset.univ}

/-- The
restricted family has two functions and shatters three subsets: the empty
set and the two singletons.

**Book Example 8.3.8.** -/
theorem example_8_3_8_zero_branch :
    pajorSplitZero.card = 2 ∧ pajorSplitZero.shatterer.card = 3 := by
  decide

/-- This
restricted family likewise shatters the empty set and both singletons.

**Book Example 8.3.8.** -/
theorem example_8_3_8_one_branch :
    pajorSplitOne.card = 2 ∧ pajorSplitOne.shatterer.card = 3 := by
  decide

/-- Applying Pajor's splitting to the four-string class yields seven shattered subsets. The original
four-function family shatters seven subsets once the empty set required by
Pajor's lemma is counted.

**Book Example 8.3.8.** -/
theorem example_8_3_8_full_family :
    binaryStringFamily.card = 4 ∧ binaryStringFamily.shatterer.card = 7 := by
  decide

/-- Sauer--Shelah bounds a class by the binomial sum up to its VC dimension.

**Book Lemma 8.3.9.** -/
theorem lemma_8_3_9_sauer_shelah [Fintype α] (F : BooleanFamily α) :
    F.card ≤ ∑ k ∈ Finset.Iic F.vcDim, (Fintype.card α).choose k :=
  (Finset.card_le_card_shatterer F).trans
    Finset.card_shatterer_le_sum_vcDim

/-- The safe `d = 0` branch of Sauer--Shelah: a finite Boolean class of VC
dimension zero has at most one member.

**Lean implementation helper.** -/
theorem lemma_8_3_9_zero_vc (F : BooleanFamily α) (hF : F.vcDim = 0) :
    F.card ≤ 1 := by
  calc
    F.card ≤ F.shatterer.card := lemma_8_3_7_pajor F
    _ ≤ ({∅} : BooleanFamily α).card := by
      apply Finset.card_le_card
      intro s hs
      have hcard := (Finset.mem_shatterer.mp hs).card_le_vcDim
      rw [hF] at hcard
      have hs0 : s = ∅ := Finset.card_eq_zero.mp (Nat.eq_zero_of_le_zero hcard)
      simp [hs0]
    _ = 1 := by simp

/-- Sauer--Shelah bounds a class by the binomial sum up to its VC dimension. The source's
second displayed inequality is meaningful only for positive `d`; this
wrapper states that guard explicitly.

**Book Lemma 8.3.9.** -/
theorem lemma_8_3_9_real_bound [Fintype α] (F : BooleanFamily α)
    (hd : 1 ≤ F.vcDim) :
    (F.card : ℝ) ≤
      (Real.exp 1 * (Fintype.card α : ℝ) / (F.vcDim : ℝ)) ^ F.vcDim := by
  have hdn : F.vcDim ≤ Fintype.card α := vcDim_le_card F
  have hnat : F.card ≤
      HDP.Chapter4.hammingBallVolume (Fintype.card α) F.vcDim := by
    simpa only [HDP.Chapter4.hammingBallVolume,
      ← Nat.range_succ_eq_Iic] using lemma_8_3_9_sauer_shelah F
  have hcast : (F.card : ℝ) ≤
      (HDP.Chapter4.hammingBallVolume (Fintype.card α) F.vcDim : ℝ) := by
    exact_mod_cast hnat
  exact hcast.trans (HDP.Chapter4.binomialPartialSum_le
    (Fintype.card α) F.vcDim hd hdn)

end HDP.Chapter8

end Source_05_PajorSauerShelah

/-! ## Material formerly in `06_GrowthFunctions.lean` -/

section Source_06_GrowthFunctions

/-!
# Book Chapter 8, §8.3.4: growth functions and VC stability

The growth function is finite here because the ambient domain is finite.  Its
value is the largest number of distinct traces on an `n`-point sample.  The
definitions retain empty and out-of-range branches explicitly: if no
`n`-point sample exists, the supremum is zero.
-/

open scoped BigOperators

namespace HDP.Chapter8

variable {α : Type*} [DecidableEq α]

/-- The trace family, kept in the original ambient type. Every member is a
subset of the sample `s`.

**Lean implementation helper.** -/
def rawTraceFamily (F : BooleanFamily α) (s : Finset α) : BooleanFamily α :=
  F.image fun u => s ∩ u

/-- Characterizes membership in the raw trace family.

**Lean implementation helper.** -/
@[simp]
theorem mem_rawTraceFamily {F : BooleanFamily α} {s v : Finset α} :
    v ∈ rawTraceFamily F s ↔ ∃ u ∈ F, s ∩ u = v := by
  simp [rawTraceFamily]

/-- Restricting every function to `s` cannot create a newly shattered set.

**Lean implementation helper.** -/
theorem shatters_of_rawTraceFamily_shatters
    {F : BooleanFamily α} {s q : Finset α}
    (hq : (rawTraceFamily F s).Shatters q) :
    F.Shatters q := by
  have hqs : q ⊆ s := by
    obtain ⟨v, hv, hqv⟩ := hq.exists_superset
    obtain ⟨u, hu, rfl⟩ := mem_rawTraceFamily.mp hv
    exact hqv.trans Finset.inter_subset_left
  intro t ht
  obtain ⟨v, hv, hqv⟩ := hq ht
  obtain ⟨u, hu, rfl⟩ := mem_rawTraceFamily.mp hv
  refine ⟨u, hu, ?_⟩
  calc
    q ∩ u = q ∩ (s ∩ u) := by
      ext x
      simp only [Finset.mem_inter]
      constructor
      · rintro ⟨hxq, hxu⟩
        exact ⟨hxq, hqs hxq, hxu⟩
      · rintro ⟨hxq, -, hxu⟩
        exact ⟨hxq, hxu⟩
    _ = t := hqv

/-- A shattered subset of the sample remains shattered after restriction to
that sample.

**Lean implementation helper.** -/
theorem rawTraceFamily_shatters_of_shatters
    {F : BooleanFamily α} {s q : Finset α}
    (hqs : q ⊆ s) (hq : F.Shatters q) :
    (rawTraceFamily F s).Shatters q := by
  intro t ht
  obtain ⟨u, hu, hqu⟩ := hq ht
  refine ⟨s ∩ u, mem_rawTraceFamily.mpr ⟨u, hu, rfl⟩, ?_⟩
  calc
    q ∩ (s ∩ u) = q ∩ u := by
      ext x
      simp only [Finset.mem_inter]
      constructor
      · rintro ⟨hxq, -, hxu⟩
        exact ⟨hxq, hxu⟩
      · rintro ⟨hxq, hxu⟩
        exact ⟨hxq, hqs hxq, hxu⟩
    _ = t := hqu

/-- All subsets of `s` having cardinality at most `d`.

**Lean implementation helper.** -/
def subsetsUpTo (s : Finset α) (d : ℕ) : Finset (Finset α) :=
  (Finset.range (d + 1)).biUnion fun k => s.powersetCard k

/-- The number of subsets of `s` having size at most `d` is bounded by the sum of the first `d+1` binomial coefficients.

**Lean implementation helper.** -/
theorem card_subsetsUpTo_le (s : Finset α) (d : ℕ) :
    (subsetsUpTo s d).card ≤ ∑ k ∈ Finset.range (d + 1), s.card.choose k := by
  simpa [subsetsUpTo] using
    (Finset.card_biUnion_le (s := Finset.range (d + 1))
      (t := fun k => s.powersetCard k))

/-- Sauer--Shelah for a trace on a fixed sample, allowing any upper bound
`d` on the original VC dimension.

**Lean implementation helper.** -/
theorem card_rawTraceFamily_le_binomial (F : BooleanFamily α)
    (s : Finset α) (d : ℕ) (hd : F.vcDim ≤ d) :
    (rawTraceFamily F s).card ≤
      ∑ k ∈ Finset.range (d + 1), s.card.choose k := by
  calc
    (rawTraceFamily F s).card ≤ (rawTraceFamily F s).shatterer.card :=
      Finset.card_le_card_shatterer _
    _ ≤ (subsetsUpTo s d).card := by
      apply Finset.card_le_card
      intro q hq
      have hqTrace : (rawTraceFamily F s).Shatters q :=
        Finset.mem_shatterer.mp hq
      have hqF : F.Shatters q := shatters_of_rawTraceFamily_shatters hqTrace
      have hqCard : q.card ≤ d := hqF.card_le_vcDim.trans hd
      have hqs : q ⊆ s := by
        obtain ⟨v, hv, hqv⟩ := hqTrace.exists_superset
        obtain ⟨u, hu, rfl⟩ := mem_rawTraceFamily.mp hv
        exact hqv.trans Finset.inter_subset_left
      rw [subsetsUpTo, Finset.mem_biUnion]
      exact ⟨q.card, by simpa using hqCard,
        Finset.mem_powersetCard.mpr ⟨hqs, rfl⟩⟩
    _ ≤ ∑ k ∈ Finset.range (d + 1), s.card.choose k :=
      card_subsetsUpTo_le s d

/-- The growth function is the largest trace-cardinality on an `n`-point sample. It is the maximum number of distinct restrictions to an `n`-point subset of
the domain.

**Book Definition 8.3.10.** -/
def growthFunction [Fintype α] (F : BooleanFamily α) (n : ℕ) : ℕ :=
  ((Finset.univ : Finset (Finset α)).filter fun s => s.card = n).sup
    fun s => (rawTraceFamily F s).card

/-- Every concrete `n`-point trace is bounded by the growth function.

**Lean implementation helper.** -/
theorem card_rawTraceFamily_le_growthFunction [Fintype α]
    (F : BooleanFamily α) {s : Finset α} {n : ℕ} (hs : s.card = n) :
    (rawTraceFamily F s).card ≤ growthFunction F n := by
  unfold growthFunction
  refine Finset.le_sup
    (s := (Finset.univ : Finset (Finset α)).filter fun t => t.card = n)
    (f := fun t => (rawTraceFamily F t).card) (b := s) ?_
  exact Finset.mem_filter.mpr ⟨Finset.mem_univ _, hs⟩

/-- The finite Sauer--Shelah growth bound following Definition 8.3.10.

**Book Definition 8.3.10.** -/
theorem growthFunction_le_binomial [Fintype α]
    (F : BooleanFamily α) (n d : ℕ) (hd : F.vcDim ≤ d) :
    growthFunction F n ≤
      ∑ k ∈ Finset.range (d + 1), n.choose k := by
  unfold growthFunction
  apply Finset.sup_le
  intro s hs
  simp only [Finset.mem_filter, Finset.mem_univ, true_and] at hs
  simpa [hs] using card_rawTraceFamily_le_binomial F s d hd

/-- The safe `d = 0` growth branch.

**Lean implementation helper.** -/
theorem growthFunction_le_one_of_vcDim_zero [Fintype α]
    (F : BooleanFamily α) (n : ℕ) (hF : F.vcDim = 0) :
    growthFunction F n ≤ 1 := by
  have hle : F.vcDim ≤ 0 := by simp [hF]
  simpa using growthFunction_le_binomial F n 0 hle

/-- Growth function lies between `2^d` and the Sauer--Shelah polynomial bound. Positive-VC real form of the upper growth estimate in equation (8.30).

**Book Equation (8.30).** -/
theorem growthFunction_real_bound [Fintype α]
    (F : BooleanFamily α) (n : ℕ)
    (hd : 1 ≤ F.vcDim) (hdn : F.vcDim ≤ n) :
    (growthFunction F n : ℝ) ≤
      (Real.exp 1 * (n : ℝ) / (F.vcDim : ℝ)) ^ F.vcDim := by
  have hnat : growthFunction F n ≤
      HDP.Chapter4.hammingBallVolume n F.vcDim := by
    simpa only [HDP.Chapter4.hammingBallVolume] using
      growthFunction_le_binomial F n F.vcDim (le_refl _)
  have hcast : (growthFunction F n : ℝ) ≤
      (HDP.Chapter4.hammingBallVolume n F.vcDim : ℝ) := by
    exact_mod_cast hnat
  exact hcast.trans (HDP.Chapter4.binomialPartialSum_le n F.vcDim hd hdn)

/-- Growth function lies between `2^d` and the Sauer--Shelah polynomial bound. A shattered set inside an `n`-point sample gives the matching lower
growth bound. This is the safe finite form of the lower half of (8.30).

**Book Equation (8.30).** -/
theorem growthFunction_lower_of_shatters [Fintype α]
    (F : BooleanFamily α) {q s : Finset α} {n : ℕ}
    (hq : F.Shatters q) (hqs : q ⊆ s) (hs : s.card = n) :
    2 ^ q.card ≤ growthFunction F n := by
  calc
    2 ^ q.card ≤ (rawTraceFamily F s).card :=
      card_family_lower_of_shatters _
        (rawTraceFamily_shatters_of_shatters hqs hq)
    _ ≤ growthFunction F n := card_rawTraceFamily_le_growthFunction F hs

/-- Pointwise conjunction of two finite Boolean classes.

**Lean implementation helper.** -/
def andFamily (F G : BooleanFamily α) : BooleanFamily α :=
  F.biUnion fun u => G.image fun v => u ∩ v

/-- Pointwise disjunction of two finite Boolean classes.

**Lean implementation helper.** -/
def orFamily (F G : BooleanFamily α) : BooleanFamily α :=
  F.biUnion fun u => G.image fun v => u ∪ v

/-- The number of traces of a conjunction family is at most the product of the two constituent trace counts.

**Lean implementation helper.** -/
private theorem card_rawTraceFamily_and_le (F G : BooleanFamily α)
    (s : Finset α) :
    (rawTraceFamily (andFamily F G) s).card ≤
      (rawTraceFamily F s).card * (rawTraceFamily G s).card := by
  let P := (rawTraceFamily F s).product (rawTraceFamily G s)
  let C := P.image fun p => p.1 ∩ p.2
  calc
    (rawTraceFamily (andFamily F G) s).card ≤ C.card := by
      apply Finset.card_le_card
      intro w hw
      obtain ⟨h, hh, rfl⟩ := mem_rawTraceFamily.mp hw
      simp only [andFamily, Finset.mem_biUnion, Finset.mem_image] at hh
      obtain ⟨u, hu, v, hv, rfl⟩ := hh
      apply Finset.mem_image.mpr
      refine ⟨(s ∩ u, s ∩ v), ?_, ?_⟩
      · exact Finset.mem_product.mpr
          ⟨mem_rawTraceFamily.mpr ⟨u, hu, rfl⟩,
            mem_rawTraceFamily.mpr ⟨v, hv, rfl⟩⟩
      · ext x
        simp only [Finset.mem_inter]
        tauto
    _ ≤ P.card := Finset.card_image_le
    _ = (rawTraceFamily F s).card * (rawTraceFamily G s).card := by
      simp [P]

/-- The number of traces of a disjunction family is at most the product of the two constituent trace counts.

**Lean implementation helper.** -/
private theorem card_rawTraceFamily_or_le (F G : BooleanFamily α)
    (s : Finset α) :
    (rawTraceFamily (orFamily F G) s).card ≤
      (rawTraceFamily F s).card * (rawTraceFamily G s).card := by
  let P := (rawTraceFamily F s).product (rawTraceFamily G s)
  let C := P.image fun p => p.1 ∪ p.2
  calc
    (rawTraceFamily (orFamily F G) s).card ≤ C.card := by
      apply Finset.card_le_card
      intro w hw
      obtain ⟨h, hh, rfl⟩ := mem_rawTraceFamily.mp hw
      simp only [orFamily, Finset.mem_biUnion, Finset.mem_image] at hh
      obtain ⟨u, hu, v, hv, rfl⟩ := hh
      apply Finset.mem_image.mpr
      refine ⟨(s ∩ u, s ∩ v), ?_, ?_⟩
      · exact Finset.mem_product.mpr
          ⟨mem_rawTraceFamily.mpr ⟨u, hu, rfl⟩,
            mem_rawTraceFamily.mpr ⟨v, hv, rfl⟩⟩
      · ext x
        simp only [Finset.mem_inter, Finset.mem_union]
        tauto
    _ ≤ P.card := Finset.card_image_le
    _ = (rawTraceFamily F s).card * (rawTraceFamily G s).card := by
      simp [P]

/-- A Boolean family whose trace counts are bounded by products of those of `F` and `G` has VC dimension at most ten times `max(VC(F),VC(G))`.

**Lean implementation helper.** -/
private theorem vcDim_combine_le_ten_max
    (F G H : BooleanFamily α)
    (htrace : ∀ s, (rawTraceFamily H s).card ≤
      (rawTraceFamily F s).card * (rawTraceFamily G s).card) :
    H.vcDim ≤ 10 * max F.vcDim G.vcDim := by
  let d := max F.vcDim G.vcDim
  unfold Finset.vcDim
  apply Finset.sup_le
  intro q hqMem
  have hq : H.Shatters q := Finset.mem_shatterer.mp hqMem
  have hFd : F.vcDim ≤ d := le_max_left _ _
  have hGd : G.vcDim ≤ d := le_max_right _ _
  by_cases hd0 : d = 0
  · have hqRaw : (rawTraceFamily H q).Shatters q :=
      rawTraceFamily_shatters_of_shatters (Finset.Subset.rfl) hq
    have hlower : 2 ^ q.card ≤ (rawTraceFamily H q).card :=
      card_family_lower_of_shatters _ hqRaw
    have hFone : (rawTraceFamily F q).card ≤ 1 := by
      have h := card_rawTraceFamily_le_binomial F q 0 (by simpa [d, hd0] using hFd)
      simpa using h
    have hGone : (rawTraceFamily G q).card ≤ 1 := by
      have h := card_rawTraceFamily_le_binomial G q 0 (by simpa [d, hd0] using hGd)
      simpa using h
    have : 2 ^ q.card ≤ 1 :=
      hlower.trans ((htrace q).trans (Nat.mul_le_mul hFone hGone))
    have hq0 : q.card = 0 := by
      by_contra hne
      have hqpos : 0 < q.card := Nat.pos_of_ne_zero hne
      have hpowpos : 0 < 2 ^ (q.card - 1) := pow_pos (by omega) _
      have htwo : 2 ≤ 2 ^ q.card := by
        rw [show q.card = (q.card - 1) + 1 by omega, pow_succ]
        omega
      omega
    simp [hq0]
  · have hd : 1 ≤ d := Nat.one_le_iff_ne_zero.mpr hd0
    by_contra hbad
    have hlarge : 10 * d < q.card := Nat.lt_of_not_ge hbad
    obtain ⟨r, hrq, hrcard⟩ :=
      Finset.exists_subset_card_eq (Nat.succ_le_iff.mpr hlarge)
    have hr : H.Shatters r := hq.mono_right hrq
    have hrRaw : (rawTraceFamily H r).Shatters r :=
      rawTraceFamily_shatters_of_shatters (Finset.Subset.rfl) hr
    have hlowerNat : 2 ^ r.card ≤ (rawTraceFamily H r).card :=
      card_family_lower_of_shatters _ hrRaw
    have hupperFNat := card_rawTraceFamily_le_binomial F r d hFd
    have hupperGNat := card_rawTraceFamily_le_binomial G r d hGd
    have hdr : d ≤ r.card := by omega
    let B : ℝ := Real.exp 1 * (r.card : ℝ) / (d : ℝ)
    have hupperF : ((rawTraceFamily F r).card : ℝ) ≤ B ^ d := by
      have hcast : ((rawTraceFamily F r).card : ℝ) ≤
          (HDP.Chapter4.hammingBallVolume r.card d : ℝ) := by
        exact_mod_cast (show (rawTraceFamily F r).card ≤
          HDP.Chapter4.hammingBallVolume r.card d by
            simpa only [HDP.Chapter4.hammingBallVolume] using hupperFNat)
      exact hcast.trans (HDP.Chapter4.binomialPartialSum_le r.card d hd hdr)
    have hupperG : ((rawTraceFamily G r).card : ℝ) ≤ B ^ d := by
      have hcast : ((rawTraceFamily G r).card : ℝ) ≤
          (HDP.Chapter4.hammingBallVolume r.card d : ℝ) := by
        exact_mod_cast (show (rawTraceFamily G r).card ≤
          HDP.Chapter4.hammingBallVolume r.card d by
            simpa only [HDP.Chapter4.hammingBallVolume] using hupperGNat)
      exact hcast.trans (HDP.Chapter4.binomialPartialSum_le r.card d hd hdr)
    have hmain : (2 : ℝ) ^ r.card ≤ B ^ d * B ^ d := by
      calc
        (2 : ℝ) ^ r.card ≤ ((rawTraceFamily H r).card : ℝ) := by
          exact_mod_cast hlowerNat
        _ ≤ ((rawTraceFamily F r).card : ℝ) *
            ((rawTraceFamily G r).card : ℝ) := by
          exact_mod_cast htrace r
        _ ≤ B ^ d * B ^ d :=
          mul_le_mul hupperF hupperG (by positivity) (by positivity)
    have hdR : (0 : ℝ) < d := by exact_mod_cast hd
    have hratio : (r.card : ℝ) / (d : ℝ) ≤ 11 := by
      rw [hrcard]
      have honeDiv : (1 : ℝ) / d ≤ 1 := (div_le_one hdR).mpr (by exact_mod_cast hd)
      calc
        (((10 * d).succ : ℕ) : ℝ) / (d : ℝ) =
            10 + 1 / (d : ℝ) := by
          push_cast
          field_simp
        _ ≤ 10 + 1 := by linarith
        _ = 11 := by norm_num
    have hBpos : 0 < B := by
      dsimp [B]
      have hrpos : (0 : ℝ) < r.card := by rw [hrcard]; positivity
      exact div_pos (mul_pos (Real.exp_pos 1) hrpos) hdR
    have hBnonneg : 0 ≤ B := hBpos.le
    have hBlt : B < 32 := by
      have he : Real.exp 1 < (32 : ℝ) / 11 :=
        Real.exp_one_lt_d9.trans (by norm_num)
      calc
        B ≤ Real.exp 1 * 11 := by
          dsimp [B]
          rw [mul_div_assoc]
          exact mul_le_mul_of_nonneg_left hratio (Real.exp_pos 1).le
        _ < ((32 : ℝ) / 11) * 11 :=
          mul_lt_mul_of_pos_right he (by norm_num)
        _ = 32 := by norm_num
    have hpow : B ^ d < (32 : ℝ) ^ d :=
      pow_lt_pow_left₀ hBlt hBnonneg (Nat.ne_of_gt hd)
    have hcontra : B ^ d * B ^ d < (2 : ℝ) ^ r.card := by
      calc
        B ^ d * B ^ d < (32 : ℝ) ^ d * B ^ d :=
          mul_lt_mul_of_pos_right hpow (pow_pos hBpos d)
        _ ≤ (32 : ℝ) ^ d * (32 : ℝ) ^ d :=
          mul_le_mul_of_nonneg_left hpow.le (by positivity)
        _ = (32 : ℝ) ^ (2 * d) := by
          rw [← pow_add]
          congr 1
          omega
        _ = (2 : ℝ) ^ (10 * d) := by
          rw [show (32 : ℝ) = 2 ^ 5 by norm_num, ← pow_mul]
          congr 1
          omega
        _ < (2 : ℝ) ^ r.card :=
          pow_lt_pow_right₀ (by norm_num) (by omega)
    exact (not_lt_of_ge hmain) hcontra

/-- VC dimension is stable under conjunction and disjunction, with universal-multiple bounds. Pointwise conjunction of two
finite Boolean classes has VC dimension at most ten times the larger input
VC dimension. The proof includes the `d = 0` branch explicitly.

**Book Proposition 8.3.11.** -/
theorem proposition_8_3_11_and (F G : BooleanFamily α) :
    (andFamily F G).vcDim ≤ 10 * max F.vcDim G.vcDim :=
  vcDim_combine_le_ten_max F G (andFamily F G)
    (card_rawTraceFamily_and_le F G)

/-- VC dimension is stable under conjunction and disjunction, with universal-multiple bounds.

**Book Proposition 8.3.11.** -/
theorem proposition_8_3_11_or (F G : BooleanFamily α) :
    (orFamily F G).vcDim ≤ 10 * max F.vcDim G.vcDim :=
  vcDim_combine_le_ten_max F G (orFamily F G)
    (card_rawTraceFamily_or_le F G)

/-! ## Arbitrary Boolean classes

The source definitions do not assume that either the domain or the class is
finite.  The next bridge takes the finite set of traces on one sample and
allows the finite Sauer--Shelah argument above to be applied without replacing
the original class by a finite surrogate.
-/

/-- The finite family of all traces of an arbitrary Boolean class on `s`.
The classical choice is confined to this finite representation; the public
Boolean class itself carries no decidable-equality or finiteness assumption.

**Lean implementation helper.** -/
noncomputable def arbitraryTraceFamily {β : Type*}
    (F : HDP.BooleanClass β) (s : Finset β) : Finset (Finset β) := by
  classical
  exact s.powerset.filter fun t => ∃ u ∈ F, HDP.BooleanClass.trace s u = t

/-- Characterizes membership in the finite trace family of an arbitrary Boolean class.

**Lean implementation helper.** -/
@[simp]
theorem mem_arbitraryTraceFamily {β : Type*} {F : HDP.BooleanClass β}
    {s t : Finset β} :
    t ∈ arbitraryTraceFamily F s ↔
      t ⊆ s ∧ ∃ u ∈ F, HDP.BooleanClass.trace s u = t := by
  classical
  simp [arbitraryTraceFamily]

/-- A set shattered by the finite trace family is already shattered by the
original arbitrary class.

**Lean implementation helper.** -/
theorem shatters_of_arbitraryTraceFamily_shatters {β : Type*}
    [DecidableEq β]
    {F : HDP.BooleanClass β} {s q : Finset β}
    (hq : (arbitraryTraceFamily F s).Shatters q) :
    F.Shatters q := by
  classical
  have hqs : q ⊆ s := by
    obtain ⟨v, hv, hqv⟩ := hq.exists_superset
    exact hqv.trans (mem_arbitraryTraceFamily.mp hv).1
  intro t ht
  obtain ⟨v, hv, hqv⟩ := hq ht
  obtain ⟨-, u, huF, huv⟩ := mem_arbitraryTraceFamily.mp hv
  refine ⟨u, huF, ?_⟩
  ext x
  rw [← hqv]
  simp only [HDP.BooleanClass.mem_trace, Finset.mem_inter]
  constructor
  · rintro ⟨hxq, hxu⟩
    refine ⟨hxq, ?_⟩
    rw [← huv]
    exact HDP.BooleanClass.mem_trace.mpr ⟨hqs hxq, hxu⟩
  · rintro ⟨hxq, hxv⟩
    have hxtrace : x ∈ HDP.BooleanClass.trace s u := by simpa [huv] using hxv
    exact ⟨hxq, (HDP.BooleanClass.mem_trace.mp hxtrace).2⟩

/-- A finite trace family inherits every finite VC upper bound of the
arbitrary class from which it was cut.

**Lean implementation helper.** -/
theorem arbitraryTraceFamily_vcDim_le {β : Type*} [DecidableEq β]
    {F : HDP.BooleanClass β} {s : Finset β} {d : ℕ}
    (hF : F.VCDimLE d) :
    (arbitraryTraceFamily F s).vcDim ≤ d := by
  classical
  unfold Finset.vcDim
  apply Finset.sup_le
  intro q hq
  exact hF q (shatters_of_arbitraryTraceFamily_shatters
    (Finset.mem_shatterer.mp hq))

/-- The extended-natural supremum is safe even when the ambient domain is
infinite. Each individual trace is finite, and the Sauer bound below shows
that finite VC dimension makes this supremum finite.

**Book Definition 8.3.10.** -/
noncomputable def growthFunctionGeneral {β : Type*}
    (F : HDP.BooleanClass β) (n : ℕ) : ℕ∞ :=
  ⨆ s : Finset β,
    if s.card = n then ((arbitraryTraceFamily F s).card : ℕ∞) else 0

/-- Every `n`-point trace is bounded by the arbitrary-class growth function.

**Lean implementation helper.** -/
theorem card_arbitraryTraceFamily_le_growthFunctionGeneral {β : Type*}
    (F : HDP.BooleanClass β) {s : Finset β} {n : ℕ} (hs : s.card = n) :
    ((arbitraryTraceFamily F s).card : ℕ∞) ≤ growthFunctionGeneral F n := by
  simpa [growthFunctionGeneral, hs] using
    (le_iSup (fun t : Finset β =>
      if t.card = n then ((arbitraryTraceFamily F t).card : ℕ∞) else 0) s)

/-- Sauer--Shelah bounds every fixed trace of an arbitrary class.

**Lean implementation helper.** -/
theorem card_arbitraryTraceFamily_le_binomial {β : Type*}
    (F : HDP.BooleanClass β) (s : Finset β) (d : ℕ)
    (hF : F.VCDimLE d) :
    (arbitraryTraceFamily F s).card ≤
      ∑ k ∈ Finset.range (d + 1), s.card.choose k := by
  classical
  let T := arbitraryTraceFamily F s
  calc
    T.card ≤ T.shatterer.card := Finset.card_le_card_shatterer T
    _ ≤ (subsetsUpTo s d).card := by
      apply Finset.card_le_card
      intro q hq
      have hqT : T.Shatters q := Finset.mem_shatterer.mp hq
      have hqF : F.Shatters q :=
        shatters_of_arbitraryTraceFamily_shatters (s := s) hqT
      have hqCard : q.card ≤ d := hF q hqF
      have hqs : q ⊆ s := by
        obtain ⟨v, hv, hqv⟩ := hqT.exists_superset
        exact hqv.trans (mem_arbitraryTraceFamily.mp hv).1
      rw [subsetsUpTo, Finset.mem_biUnion]
      exact ⟨q.card, by simpa using hqCard,
        Finset.mem_powersetCard.mpr ⟨hqs, rfl⟩⟩
    _ ≤ ∑ k ∈ Finset.range (d + 1), s.card.choose k :=
      card_subsetsUpTo_le s d

/-- The arbitrary-class growth function satisfies the source's binomial
upper bound whenever the VC dimension is at most `d`.

**Lean implementation helper.** -/
theorem growthFunctionGeneral_le_binomial {β : Type*}
    (F : HDP.BooleanClass β) (n d : ℕ) (hF : F.VCDimLE d) :
    growthFunctionGeneral F n ≤
      (∑ k ∈ Finset.range (d + 1), n.choose k : ℕ) := by
  classical
  unfold growthFunctionGeneral
  apply iSup_le
  intro s
  by_cases hs : s.card = n
  · simp only [hs, if_true]
    exact_mod_cast (by
      simpa [hs] using card_arbitraryTraceFamily_le_binomial F s d hF)
  · simp [hs]

/-- Pointwise conjunction of two arbitrary Boolean classes.

**Lean implementation helper.** -/
def andBooleanClass {β : Type*}
    (F G : HDP.BooleanClass β) : HDP.BooleanClass β :=
  {u | ∃ f ∈ F, ∃ g ∈ G, u = f ∩ g}

/-- Pointwise disjunction of two arbitrary Boolean classes.

**Lean implementation helper.** -/
def orBooleanClass {β : Type*}
    (F G : HDP.BooleanClass β) : HDP.BooleanClass β :=
  {u | ∃ f ∈ F, ∃ g ∈ G, u = f ∪ g}

/-- If the conjunction of two Boolean classes shatters `s`, then the conjunction of their trace families also shatters `s`.

**Lean implementation helper.** -/
private theorem and_traceFamily_shatters {β : Type*} [DecidableEq β]
    {F G : HDP.BooleanClass β} {s : Finset β}
    (hs : (andBooleanClass F G).Shatters s) :
    (andFamily (arbitraryTraceFamily F s)
      (arbitraryTraceFamily G s)).Shatters s := by
  classical
  intro t ht
  obtain ⟨u, ⟨f, hfF, g, hgG, rfl⟩, hu⟩ := hs t ht
  refine ⟨HDP.BooleanClass.trace s f ∩ HDP.BooleanClass.trace s g, ?_, ?_⟩
  · simp only [andFamily, Finset.mem_biUnion, Finset.mem_image]
    refine ⟨HDP.BooleanClass.trace s f, ?_,
      HDP.BooleanClass.trace s g, ?_, rfl⟩
    · exact mem_arbitraryTraceFamily.mpr
        ⟨fun x hx => (HDP.BooleanClass.mem_trace.mp hx).1,
          f, hfF, rfl⟩
    · exact mem_arbitraryTraceFamily.mpr
        ⟨fun x hx => (HDP.BooleanClass.mem_trace.mp hx).1,
          g, hgG, rfl⟩
  · rw [← hu]
    ext x
    simp only [Finset.mem_inter, HDP.BooleanClass.mem_trace, Set.mem_inter_iff]
    tauto

/-- If the disjunction of two Boolean classes shatters `s`, then the disjunction of their trace families also shatters `s`.

**Lean implementation helper.** -/
private theorem or_traceFamily_shatters {β : Type*} [DecidableEq β]
    {F G : HDP.BooleanClass β} {s : Finset β}
    (hs : (orBooleanClass F G).Shatters s) :
    (orFamily (arbitraryTraceFamily F s)
      (arbitraryTraceFamily G s)).Shatters s := by
  classical
  intro t ht
  obtain ⟨u, ⟨f, hfF, g, hgG, rfl⟩, hu⟩ := hs t ht
  refine ⟨HDP.BooleanClass.trace s f ∪ HDP.BooleanClass.trace s g, ?_, ?_⟩
  · simp only [orFamily, Finset.mem_biUnion, Finset.mem_image]
    refine ⟨HDP.BooleanClass.trace s f, ?_,
      HDP.BooleanClass.trace s g, ?_, rfl⟩
    · exact mem_arbitraryTraceFamily.mpr
        ⟨fun x hx => (HDP.BooleanClass.mem_trace.mp hx).1,
          f, hfF, rfl⟩
    · exact mem_arbitraryTraceFamily.mpr
        ⟨fun x hx => (HDP.BooleanClass.mem_trace.mp hx).1,
          g, hgG, rfl⟩
  · rw [← hu]
    ext x
    simp only [Finset.mem_inter, Finset.mem_union,
      HDP.BooleanClass.mem_trace, Set.mem_union]
    tauto

/-- VC dimension is stable under conjunction and disjunction, with universal-multiple bounds.

**Book Proposition 8.3.11.** -/
theorem proposition_8_3_11_and_general {β : Type*}
    (F G : HDP.BooleanClass β) (d e : ℕ)
    (hF : F.VCDimLE d) (hG : G.VCDimLE e) :
    (andBooleanClass F G).VCDimLE (10 * max d e) := by
  classical
  intro s hs
  have hfinite := and_traceFamily_shatters hs
  calc
    s.card ≤ (andFamily (arbitraryTraceFamily F s)
        (arbitraryTraceFamily G s)).vcDim := hfinite.card_le_vcDim
    _ ≤ 10 * max (arbitraryTraceFamily F s).vcDim
        (arbitraryTraceFamily G s).vcDim :=
      proposition_8_3_11_and _ _
    _ ≤ 10 * max d e := Nat.mul_le_mul_left 10
      (max_le_max (arbitraryTraceFamily_vcDim_le hF)
        (arbitraryTraceFamily_vcDim_le hG))

/-- VC dimension is stable under conjunction and disjunction, with universal-multiple bounds.

**Book Proposition 8.3.11.** -/
theorem proposition_8_3_11_or_general {β : Type*}
    (F G : HDP.BooleanClass β) (d e : ℕ)
    (hF : F.VCDimLE d) (hG : G.VCDimLE e) :
    (orBooleanClass F G).VCDimLE (10 * max d e) := by
  classical
  intro s hs
  have hfinite := or_traceFamily_shatters hs
  calc
    s.card ≤ (orFamily (arbitraryTraceFamily F s)
        (arbitraryTraceFamily G s)).vcDim := hfinite.card_le_vcDim
    _ ≤ 10 * max (arbitraryTraceFamily F s).vcDim
        (arbitraryTraceFamily G s).vcDim :=
      proposition_8_3_11_or _ _
    _ ≤ 10 * max d e := Nat.mul_le_mul_left 10
      (max_le_max (arbitraryTraceFamily_vcDim_le hF)
        (arbitraryTraceFamily_vcDim_le hG))

/-! ## The actual Euclidean strip class -/

/-- All closed affine strips in `ℝ^n`. Negative half-widths simply describe
the empty set, so no unnecessary sign hypothesis is built into the class.

**Lean implementation helper.** -/
def euclideanStrips (n : ℕ) :
    HDP.BooleanClass (EuclideanSpace ℝ (Fin n)) :=
  {u | ∃ a b c, u = {x | |inner ℝ a x - b| ≤ c}}

/-- Every Euclidean strip is the intersection of two Euclidean halfspaces.

**Lean implementation helper.** -/
private theorem euclideanStrips_subset_and_halfspaces (n : ℕ) :
    euclideanStrips n ⊆
      andBooleanClass (euclideanHalfspaces n) (euclideanHalfspaces n) := by
  intro u hu
  obtain ⟨a, b, c, rfl⟩ := hu
  refine ⟨closedAffineHalfspace a (b + c), ⟨a, b + c, rfl⟩,
    closedAffineHalfspace (-a) (c - b), ⟨-a, c - b, rfl⟩, ?_⟩
  ext x
  simp only [Set.mem_setOf_eq, Set.mem_inter_iff, closedAffineHalfspace,
    inner_neg_left, abs_le]
  constructor
  · rintro ⟨hlower, hupper⟩
    constructor <;> linarith
  · rintro ⟨hupper, hlower⟩
    constructor <;> linarith

/-- The actual class
of all affine strips in `ℝ^n` has VC dimension at most `10(n+1)`.

**Book Example 8.3.12 (strips).** -/
theorem example_8_3_12_euclidean_strips (n : ℕ) :
    (euclideanStrips n).VCDimLE (10 * (n + 1)) := by
  intro s hs
  have hcombined :
      (andBooleanClass (euclideanHalfspaces n) (euclideanHalfspaces n)).Shatters s := by
    intro t ht
    obtain ⟨u, hu, htrace⟩ := hs t ht
    exact ⟨u, euclideanStrips_subset_and_halfspaces n hu, htrace⟩
  have h := proposition_8_3_11_and_general
    (euclideanHalfspaces n) (euclideanHalfspaces n) (n + 1) (n + 1)
    (euclideanHalfspaces_vcDimLE n) (euclideanHalfspaces_vcDimLE n)
  simpa using h s hcombined

/-- The looser constant printed in the source.

**Lean implementation helper.** -/
theorem example_8_3_12_euclidean_strips_source (n : ℕ) :
    (euclideanStrips n).VCDimLE (20 * (n + 1)) := by
  intro s hs
  exact (example_8_3_12_euclidean_strips n s hs).trans (by omega)

/-- The source's positive-dimensional simplification.

**Lean implementation helper.** -/
theorem example_8_3_12_euclidean_strips_source_le_forty
    (n : ℕ) (hn : 1 ≤ n) :
    (euclideanStrips n).VCDimLE (40 * n) := by
  intro s hs
  exact (example_8_3_12_euclidean_strips_source n s hs).trans (by omega)

/-- A finite family whose members are intersections of two half-space trace
families. This is the combinatorial content used for strips.

**Lean implementation helper.** -/
def stripTraceFamily (n : ℕ) : BooleanFamily (Fin (n + 1)) :=
  andFamily (simplexLabelFamily n) (simplexLabelFamily n)

/-- Euclidean strips have controlled VC dimension as intersections of two half-spaces. Intersections
of two half-space trace classes have VC dimension at most `10(n+1)`, hence at
most `20n` in positive dimension. The latter implication carries the
necessary `1 ≤ n` guard.

**Book Example 8.3.12.** -/
theorem example_8_3_12_strips (n : ℕ) :
    (stripTraceFamily n).vcDim ≤ 10 * (n + 1) := by
  simpa [stripTraceFamily, example_8_3_5_halfspaces] using
    proposition_8_3_11_and (simplexLabelFamily n) (simplexLabelFamily n)

/-- The trace family of Euclidean strips in dimension `n` has VC dimension at most `20n`.

**Lean implementation helper.** -/
theorem example_8_3_12_strips_le_twenty (n : ℕ) (hn : 1 ≤ n) :
    (stripTraceFamily n).vcDim ≤ 20 * n := by
  exact (example_8_3_12_strips n).trans (by omega)

/-- The (looser) constant displayed in the source: `20(n+1)`.

**Lean implementation helper.** -/
theorem example_8_3_12_strips_source (n : ℕ) :
    (stripTraceFamily n).vcDim ≤ 20 * (n + 1) := by
  exact (example_8_3_12_strips n).trans (by omega)

/-- The second source display, with the necessary positive-dimension guard.

**Lean implementation helper.** -/
theorem example_8_3_12_strips_source_le_forty (n : ℕ) (hn : 1 ≤ n) :
    (stripTraceFamily n).vcDim ≤ 40 * n := by
  exact (example_8_3_12_strips_source n).trans (by omega)

end HDP.Chapter8

end Source_06_GrowthFunctions

/-! ## Material formerly in `07_VCCovering.lean` -/

section Source_07_VCCovering

/-!
# Book Chapter 8, §8.3.4: VC covering numbers

This file gives a finite, measurable version of the VC covering argument.
Boolean functions are the supports in `BooleanFamily α`; their authoritative
metric realization is in `Lp ℝ 2 μ`.  In particular, points equal only almost
everywhere are identified by Mathlib's `Lp` quotient.

The source states Theorem 8.3.13 for an arbitrary class without spelling out
measurability or finiteness.  Here the domain and class are finite and all
singletons are measurable.  Lemma 8.3.14 is stated on an explicit probability
space carrying independent sample coordinates with common law `μ`; the sample
size is required to be positive.  These hypotheses are exactly what the
Hoeffding and finite-union steps use.
-/

open MeasureTheory ProbabilityTheory Set
open scoped BigOperators ENNReal NNReal

namespace HDP.Chapter8

noncomputable section

variable {α Ω : Type*} [DecidableEq α]
  {mα : MeasurableSpace α} [MeasurableSingletonClass α]
  {mΩ : MeasurableSpace Ω} {μ : Measure α} {P : Measure Ω}

variable [IsFiniteMeasure μ]

/-! ## The Boolean `L²` metric: equation (8.31) -/

/-- Returns `1` on the finite set `u` and `0` outside `u`.

**Lean implementation helper.** -/
def booleanValue (u : Finset α) (x : α) : ℝ :=
  (u : Set α).indicator (fun _ => 1) x

omit [DecidableEq α] in
/-- The zero-one membership function equals `1` at points inside the finite set.

**Lean implementation helper.** -/
@[simp]
theorem booleanValue_eq_one {u : Finset α} {x : α} (hx : x ∈ u) :
    booleanValue u x = 1 := by simp [booleanValue, hx]

omit [DecidableEq α] in
/-- The zero-one membership function equals `0` at points outside the finite set.

**Lean implementation helper.** -/
@[simp]
theorem booleanValue_eq_zero {u : Finset α} {x : α} (hx : x ∉ u) :
    booleanValue u x = 0 := by simp [booleanValue, hx]

omit [DecidableEq α] in
/-- Shows that the zero-one membership function is measurable.

**Lean implementation helper.** -/
theorem measurable_booleanValue (u : Finset α) : Measurable (booleanValue u) := by
  exact measurable_const.indicator u.measurableSet

/-- A Boolean support as an element of the authoritative Mathlib `L²` space.

**Lean implementation helper.** -/
def booleanLp (μ : Measure α) [IsFiniteMeasure μ] (u : Finset α) : Lp ℝ 2 μ :=
  indicatorConstLp 2 u.measurableSet (by finiteness) 1

/-- Population squared `L²` distance. For Boolean functions this is the
probability of their symmetric difference.

**Lean implementation helper.** -/
def booleanL2Sq (μ : Measure α) (u v : Finset α) : ℝ :=
  μ.real (symmDiff (u : Set α) (v : Set α))

/-- Equation (8.31), left-hand side.

**Book Equation (8.31).** -/
def booleanL2Dist (μ : Measure α) (u v : Finset α) : ℝ :=
  Real.sqrt (booleanL2Sq μ u v)

omit [DecidableEq α] in
/-- The squared difference of two zero-one membership functions is the indicator of their symmetric difference.

**Lean implementation helper.** -/
theorem boolean_difference_sq_eq_indicator (u v : Finset α) :
    (fun x => (booleanValue u x - booleanValue v x) ^ 2) =
      (symmDiff (u : Set α) (v : Set α)).indicator (fun _ => (1 : ℝ)) := by
  classical
  funext x
  by_cases hu : x ∈ u <;> by_cases hv : x ∈ v <;>
    simp [booleanValue, hu, hv, Set.mem_symmDiff]

omit [DecidableEq α] [IsFiniteMeasure μ] in
/-- The integral in equation (8.31) is exactly the measure of the symmetric
difference.

**Book Equation (8.31).** -/
theorem integral_boolean_difference_sq (u v : Finset α) :
    (∫ x, (booleanValue u x - booleanValue v x) ^ 2 ∂μ) =
      booleanL2Sq μ u v := by
  classical
  rw [boolean_difference_sq_eq_indicator]
  exact integral_indicator_one ((u.measurableSet).symmDiff v.measurableSet)

omit [DecidableEq α] in
/-- Boolean `L2` distance equals square-root symmetric-difference probability. The book's Boolean `L²` distance agrees both
with the square-root integral and with distance in Mathlib's `Lp ℝ 2 μ`.

**Book Equation (8.31).** -/
theorem equation_8_31 (u v : Finset α) :
    dist (booleanLp μ u) (booleanLp μ v) =
      booleanL2Dist μ u v ∧
    booleanL2Dist μ u v =
      Real.sqrt (∫ x, (booleanValue u x - booleanValue v x) ^ 2 ∂μ) := by
  classical
  constructor
  · rw [booleanLp, booleanLp, dist_indicatorConstLp_eq_norm,
      norm_indicatorConstLp (by norm_num) (by norm_num)]
    simp only [norm_one, one_mul, ENNReal.toReal_ofNat]
    rw [show (1 / (2 : ℝ)) = (1 / 2 : ℝ) by norm_num,
      ← Real.sqrt_eq_rpow]
    simp [booleanL2Dist, booleanL2Sq]
  · rw [integral_boolean_difference_sq]
    rfl

omit [DecidableEq α] [MeasurableSingletonClass α] [IsFiniteMeasure μ] in
/-- Shows that the squared `L²` distance between Boolean functions is nonnegative.

**Lean implementation helper.** -/
theorem booleanL2Sq_nonneg (u v : Finset α) : 0 ≤ booleanL2Sq μ u v :=
  measureReal_nonneg

omit [DecidableEq α] [MeasurableSingletonClass α] [IsFiniteMeasure μ] in
/-- The square of the Boolean `L²` distance equals the corresponding squared-distance integral.

**Lean implementation helper.** -/
theorem booleanL2Dist_sq (u v : Finset α) :
    (booleanL2Dist μ u v) ^ 2 = booleanL2Sq μ u v := by
  exact Real.sq_sqrt (booleanL2Sq_nonneg u v)

/-! ## Empirical `L²`: equation (8.32) -/

/-- Squared empirical `L²` distance on a deterministic sample.

**Lean implementation helper.** -/
def empiricalBooleanL2Sq {n : ℕ} (sample : Fin n → α)
    (u v : Finset α) : ℝ :=
  empiricalAverage sample fun x => (booleanValue u x - booleanValue v x) ^ 2

/-- Equation (8.32), including the square root.

**Book Equation (8.32).** -/
def empiricalBooleanL2Dist {n : ℕ} (sample : Fin n → α)
    (u v : Finset α) : ℝ :=
  Real.sqrt (empiricalBooleanL2Sq sample u v)

omit [DecidableEq α] in
/-- Empirical Boolean `L2` distance is the sample squared-difference average.

**Book Equation (8.32).** -/
theorem equation_8_32 {n : ℕ} (sample : Fin n → α) (u v : Finset α) :
    empiricalBooleanL2Dist sample u v =
      Real.sqrt ((n : ℝ)⁻¹ *
        ∑ i, (booleanValue u (sample i) - booleanValue v (sample i)) ^ 2) := by
  rfl

/-! ## Hoeffding dimension reduction: equations (8.33)--(8.34) -/

/-- The `{0,1}` loss whose population mean is squared Boolean `L²` distance.

**Lean implementation helper.** -/
def booleanPairLoss (u v : Finset α) (x : α) : ℝ :=
  (booleanValue u x - booleanValue v x) ^ 2

omit [DecidableEq α] in
/-- Shows that the pairwise squared Boolean loss is measurable.

**Lean implementation helper.** -/
theorem measurable_booleanPairLoss (u v : Finset α) :
    Measurable (booleanPairLoss u v) := by
  exact ((measurable_booleanValue u).sub (measurable_booleanValue v)).pow_const 2

omit [DecidableEq α] in
/-- The squared loss between two Boolean functions always lies in `[0,1]`.

**Lean implementation helper.** -/
theorem booleanPairLoss_mem_Icc (u v : Finset α) (x : α) :
    booleanPairLoss u v x ∈ Set.Icc (0 : ℝ) 1 := by
  classical
  by_cases hu : x ∈ u <;> by_cases hv : x ∈ v <;>
    simp [booleanPairLoss, booleanValue, hu, hv]

omit [DecidableEq α] [IsFiniteMeasure μ] in
/-- The expected squared Boolean pair loss equals the squared Boolean `L²` distance.

**Lean implementation helper.** -/
theorem integral_booleanPairLoss (u v : Finset α) :
    (∫ x, booleanPairLoss u v x ∂μ) = booleanL2Sq μ u v := by
  classical
  exact integral_boolean_difference_sq u v

/-- The lower-deviation event for one pair of Boolean functions.

**Lean implementation helper.** -/
def pairLowerDeviationEvent {n : ℕ} (X : Fin n → Ω → α)
    (μ : Measure α) (u v : Finset α) (δ : ℝ) : Set Ω :=
  {ω | empiricalBooleanL2Sq (fun i => X i ω) u v ≤
    booleanL2Sq μ u v - δ}

omit [DecidableEq α] [IsFiniteMeasure μ] in
/-- The one-pair Hoeffding estimate used in Lemma 8.3.14. The coordinates
are explicitly independent and have common law `μ`; the exact exponent here
comes from applying Chapter 2's bounded Hoeffding theorem to the negative
`{0,1}` pair losses.

**Book Lemma 8.3.14.** -/
theorem pairLowerDeviationEvent_measure_le {n : ℕ}
    [IsProbabilityMeasure μ] [IsProbabilityMeasure P]
    (hn : 0 < n) (X : Fin n → Ω → α)
    (hXlaw : ∀ i, HasLaw (X i) μ P) (hXind : iIndepFun X P)
    (u v : Finset α) {δ : ℝ} (hδ : 0 ≤ δ) :
    P.real (pairLowerDeviationEvent X μ u v δ) ≤
      Real.exp (-2 * (n : ℝ) * δ ^ 2) := by
  classical
  let Z : Fin n → Ω → ℝ := fun i ω => -booleanPairLoss u v (X i ω)
  have hZm : ∀ i, AEMeasurable (Z i) P := by
    intro i
    exact ((measurable_booleanPairLoss u v).neg.aemeasurable.comp_aemeasurable
      (hXlaw i).aemeasurable)
  have hZbounds : ∀ i, ∀ᵐ ω ∂P, Z i ω ∈ Set.Icc (-1 : ℝ) 0 := by
    intro i
    filter_upwards [] with ω
    have h := booleanPairLoss_mem_Icc u v (X i ω)
    exact ⟨by linarith [h.2], by linarith [h.1]⟩
  have hZind : iIndepFun Z P := by
    exact hXind.comp (fun _ x => -booleanPairLoss u v x)
      (fun _ => (measurable_booleanPairLoss u v).neg)
  have hmean (i : Fin n) :
      (∫ ω, Z i ω ∂P) = -booleanL2Sq μ u v := by
    rw [show Z i = fun ω => -booleanPairLoss u v (X i ω) by rfl,
      integral_neg]
    congr 1
    calc
      (∫ ω, booleanPairLoss u v (X i ω) ∂P) =
          ∫ x, booleanPairLoss u v x ∂μ := by
        simpa only [Function.comp_apply] using
          (hXlaw i).integral_comp
            (measurable_booleanPairLoss u v).aestronglyMeasurable
      _ = booleanL2Sq μ u v := integral_booleanPairLoss u v
  have hHoeffding := HDP.Chapter2.hoeffding_bounded
    (μ := P) (X := Z) (a := fun _ => (-1 : ℝ)) (b := fun _ => 0)
    hZm hZbounds hZind (t := (n : ℝ) * δ)
    (mul_nonneg (Nat.cast_nonneg n) hδ)
  have hsubset : pairLowerDeviationEvent X μ u v δ ⊆
      {ω | (n : ℝ) * δ ≤
        ∑ i, (Z i ω - ∫ ω', Z i ω' ∂P)} := by
    intro ω hω
    have hnR : (0 : ℝ) < n := by exact_mod_cast hn
    have hsum :
        ∑ i, booleanPairLoss u v (X i ω) ≤
          (n : ℝ) * (booleanL2Sq μ u v - δ) := by
      calc
        ∑ i, booleanPairLoss u v (X i ω) =
            (n : ℝ) * empiricalBooleanL2Sq (fun i => X i ω) u v := by
          rw [empiricalBooleanL2Sq, empiricalAverage]
          field_simp
          simp [booleanPairLoss]
        _ ≤ (n : ℝ) * (booleanL2Sq μ u v - δ) :=
          mul_le_mul_of_nonneg_left hω hnR.le
    have htarget : (n : ℝ) * δ ≤
        (n : ℝ) * booleanL2Sq μ u v -
          ∑ i, booleanPairLoss u v (X i ω) := by
      nlinarith
    calc
      (n : ℝ) * δ ≤ (n : ℝ) * booleanL2Sq μ u v -
          ∑ i, booleanPairLoss u v (X i ω) := htarget
      _ = ∑ i, (Z i ω - ∫ ω', Z i ω' ∂P) := by
        rw [Finset.sum_sub_distrib]
        simp_rw [hmean]
        simp only [Z, Finset.sum_neg_distrib, Finset.sum_const,
          Finset.card_univ, Fintype.card_fin, nsmul_eq_mul,
          sub_neg_eq_add]
        ring
  have hbound := (measureReal_mono hsubset).trans hHoeffding
  convert hbound using 1
  · congr 1
  · simp only [Finset.sum_const, Finset.card_univ, Fintype.card_fin,
      nsmul_eq_mul, sub_neg_eq_add, zero_add, one_pow, mul_one]
    have hnR0 : (n : ℝ) ≠ 0 := by exact_mod_cast hn.ne'
    field_simp [hnR0]

/-- Ordered pairs in `G` whose population `L²` distance is larger than `ε`.

**Lean implementation helper.** -/
def vcSeparatedPairs (μ : Measure α) (G : BooleanFamily α) (ε : ℝ) :
    Finset (Finset α × Finset α) :=
  (G ×ˢ G).filter fun p => ε < booleanL2Dist μ p.1 p.2

/-- The union of the bad lower-deviation events used in the source proof.

**Lean implementation helper.** -/
def dimensionReductionBadEvent {n : ℕ} (X : Fin n → Ω → α)
    (μ : Measure α) (G : BooleanFamily α) (ε : ℝ) : Set Ω :=
  ⋃ p ∈ vcSeparatedPairs μ G ε,
    pairLowerDeviationEvent X μ p.1 p.2 (ε ^ 2 / 4)

/-- The good event is defined as the complement of the explicit finite union,
so its probability is well-defined without hiding an arbitrary intersection.

**Lean implementation helper.** -/
def dimensionReductionGoodEvent {n : ℕ} (X : Fin n → Ω → α)
    (μ : Measure α) (G : BooleanFamily α) (ε : ℝ) : Set Ω :=
  (dimensionReductionBadEvent X μ G ε)ᶜ

omit [DecidableEq α] in
/-- Shows that the empirical squared Boolean distance is measurable.

**Lean implementation helper.** -/
theorem measurable_empiricalBooleanL2Sq {n : ℕ} (X : Fin n → Ω → α)
    (hXm : ∀ i, Measurable (X i)) (u v : Finset α) :
    Measurable fun ω => empiricalBooleanL2Sq (fun i => X i ω) u v := by
  unfold empiricalBooleanL2Sq empiricalAverage
  exact (Finset.measurable_sum Finset.univ fun i _ =>
    (measurable_booleanPairLoss u v).comp (hXm i)).const_mul _

omit [DecidableEq α] [IsFiniteMeasure μ] in
/-- Shows that the lower-deviation event for a Boolean pair is measurable.

**Lean implementation helper.** -/
theorem measurable_pairLowerDeviationEvent {n : ℕ} (X : Fin n → Ω → α)
    (hXm : ∀ i, Measurable (X i)) (u v : Finset α) (δ : ℝ) :
    MeasurableSet (pairLowerDeviationEvent X μ u v δ) := by
  exact measurableSet_le
    (measurable_empiricalBooleanL2Sq X hXm u v) measurable_const

omit [IsFiniteMeasure μ] in
/-- Shows that the Boolean dimension-reduction failure event is measurable.

**Lean implementation helper.** -/
theorem measurable_dimensionReductionBadEvent {n : ℕ}
    (X : Fin n → Ω → α) (hXm : ∀ i, Measurable (X i))
    (G : BooleanFamily α) (ε : ℝ) :
    MeasurableSet (dimensionReductionBadEvent X μ G ε) := by
  unfold dimensionReductionBadEvent
  exact Finset.measurableSet_biUnion _ fun p _ =>
    measurable_pairLowerDeviationEvent X hXm p.1 p.2 _

omit [MeasurableSingletonClass α] [IsFiniteMeasure μ] in
/-- The set of ordered separated pairs from a finite Boolean family has cardinality at most the square of the family size.

**Lean implementation helper.** -/
theorem card_vcSeparatedPairs_le (G : BooleanFamily α) (ε : ℝ) :
    (vcSeparatedPairs μ G ε).card ≤ G.card ^ 2 := by
  calc
    (vcSeparatedPairs μ G ε).card ≤ (G ×ˢ G).card := Finset.card_filter_le _ _
    _ = G.card ^ 2 := by simp [pow_two]

omit [IsFiniteMeasure μ] in
/-- The finite union
bound and the one-pair Hoeffding estimate give the displayed class-size
factor. Our one-sided estimate gives factor `1`; the book's coarser factor
`2` follows immediately below.

**Book Equation (8.34).** -/
theorem equation_8_34_bad_probability {n : ℕ}
    [IsProbabilityMeasure μ] [IsProbabilityMeasure P]
    (hn : 0 < n) (X : Fin n → Ω → α)
    (hXlaw : ∀ i, HasLaw (X i) μ P) (hXind : iIndepFun X P)
    (G : BooleanFamily α) {ε : ℝ} (_hε : 0 ≤ ε) :
    P.real (dimensionReductionBadEvent X μ G ε) ≤
      (G.card : ℝ) ^ 2 * Real.exp (-(n : ℝ) * ε ^ 4 / 8) := by
  have hδ : 0 ≤ ε ^ 2 / 4 := div_nonneg (sq_nonneg ε) (by norm_num)
  calc
    P.real (dimensionReductionBadEvent X μ G ε) ≤
        ∑ p ∈ vcSeparatedPairs μ G ε,
          P.real (pairLowerDeviationEvent X μ p.1 p.2 (ε ^ 2 / 4)) := by
      exact measureReal_biUnion_finset_le _ _
    _ ≤ ∑ _p ∈ vcSeparatedPairs μ G ε,
          Real.exp (-2 * (n : ℝ) * (ε ^ 2 / 4) ^ 2) := by
      exact Finset.sum_le_sum fun p _ =>
        pairLowerDeviationEvent_measure_le hn X hXlaw hXind p.1 p.2 hδ
    _ = ((vcSeparatedPairs μ G ε).card : ℝ) *
