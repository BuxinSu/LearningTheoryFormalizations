/-- The reverse Gaussian
Chevet inequality holds for arbitrary nonempty finite sets with the explicit
universal constant `1/2`.

**Book Exercise 8.39(b).** -/
theorem exercise_8_39b_gaussian_chevet_reverse {m n : ℕ}
    (T : Finset (EuclideanSpace ℝ (Fin n)))
    (S : Finset (EuclideanSpace ℝ (Fin m)))
    [Nonempty ↥T] [Nonempty ↥S]
    (hT : T.Nonempty) (hS : S.Nonempty) :
    (1 / 2 : ℝ) *
        (HDP.Chapter7.gaussianWidth T * HDP.Chapter7.finiteRadius S +
          HDP.Chapter7.gaussianWidth S * HDP.Chapter7.finiteRadius T) ≤
      HDP.Chapter7.expectedFiniteSupremum
        (stdGaussian (EuclideanSpace ℝ (Fin m × Fin n)))
        (finiteGaussianMatrixChevetProcess T S) := by
  let X := finiteGaussianMatrixChevetProcess T S
  obtain ⟨u0, hu0, huMax⟩ := Finset.exists_mem_eq_sup' hT norm
  obtain ⟨v0, hv0, hvMax⟩ := Finset.exists_mem_eq_sup' hS norm
  let u : ↥T := ⟨u0, hu0⟩
  let v : ↥S := ⟨v0, hv0⟩
  let Xu := rankOneCanonicalGaussianProcess
    (fun _ : ↥S => u0) (fun q : ↥S => q.1)
  let Xv := rankOneCanonicalGaussianProcess
    (fun q : ↥T => q.1) (fun _ : ↥T => v0)
  have hcoordX : ∀ p, Integrable (X p)
      (stdGaussian (EuclideanSpace ℝ (Fin m × Fin n))) := by
    intro p
    have hG := HDP.Chapter7.canonicalGaussianProcess_isGaussian
      (fun q : ChevetIndex T S => rankOneGaussianPoint q.1.1 q.2.1)
    simpa [X, finiteGaussianMatrixChevetProcess,
      rankOneCanonicalGaussianProcess] using
      (hG.hasGaussianLaw_eval p).integrable
  have hcoordXu : ∀ q, Integrable (Xu q)
      (stdGaussian (EuclideanSpace ℝ (Fin m × Fin n))) := by
    intro q
    simpa [Xu, rankOneCanonicalGaussianProcess] using
      ((HDP.Chapter7.canonicalGaussianProcess_isGaussian
        (fun z : ↥S => rankOneGaussianPoint u0 z.1)).hasGaussianLaw_eval q).integrable
  have hcoordXv : ∀ q, Integrable (Xv q)
      (stdGaussian (EuclideanSpace ℝ (Fin m × Fin n))) := by
    intro q
    simpa [Xv, rankOneCanonicalGaussianProcess] using
      ((HDP.Chapter7.canonicalGaussianProcess_isGaussian
        (fun z : ↥T => rankOneGaussianPoint z.1 v0)).hasGaussianLaw_eval q).integrable
  have hXint := integrable_finiteProcessSup_of_integrable X hcoordX
  have hXuint := integrable_finiteProcessSup_of_integrable Xu hcoordXu
  have hXvint := integrable_finiteProcessSup_of_integrable Xv hcoordXv
  have hpointU : ∀ g, finiteProcessSup Xu g ≤ finiteProcessSup X g := by
    intro g
    unfold finiteProcessSup
    apply Finset.sup'_le
    intro q hq
    let p : ChevetIndex T S := (u, q)
    calc
      Xu q g = X p g := by rfl
      _ ≤ Finset.univ.sup' Finset.univ_nonempty (fun p => X p g) :=
        Finset.le_sup' (fun p => X p g) (Finset.mem_univ p)
  have hpointV : ∀ g, finiteProcessSup Xv g ≤ finiteProcessSup X g := by
    intro g
    unfold finiteProcessSup
    apply Finset.sup'_le
    intro q hq
    let p : ChevetIndex T S := (q, v)
    calc
      Xv q g = X p g := by rfl
      _ ≤ Finset.univ.sup' Finset.univ_nonempty (fun p => X p g) :=
        Finset.le_sup' (fun p => X p g) (Finset.mem_univ p)
  have hlowerU : ‖u0‖ * HDP.Chapter7.gaussianWidth S ≤
      HDP.Chapter7.expectedFiniteSupremum
        (stdGaussian (EuclideanSpace ℝ (Fin m × Fin n))) X := by
    rw [← expectedFiniteSupremum_rankOne_fixed_left u0 S hS]
    unfold HDP.Chapter7.expectedFiniteSupremum
    change (∫ g, finiteProcessSup Xu g
        ∂stdGaussian (EuclideanSpace ℝ (Fin m × Fin n))) ≤
      ∫ g, finiteProcessSup X g
        ∂stdGaussian (EuclideanSpace ℝ (Fin m × Fin n))
    exact integral_mono hXuint hXint hpointU
  have hlowerV : ‖v0‖ * HDP.Chapter7.gaussianWidth T ≤
      HDP.Chapter7.expectedFiniteSupremum
        (stdGaussian (EuclideanSpace ℝ (Fin m × Fin n))) X := by
    rw [← expectedFiniteSupremum_rankOne_fixed_right v0 T hT]
    unfold HDP.Chapter7.expectedFiniteSupremum
    change (∫ g, finiteProcessSup Xv g
        ∂stdGaussian (EuclideanSpace ℝ (Fin m × Fin n))) ≤
      ∫ g, finiteProcessSup X g
        ∂stdGaussian (EuclideanSpace ℝ (Fin m × Fin n))
    exact integral_mono hXvint hXint hpointV
  have huRad : ‖u0‖ = HDP.Chapter7.finiteRadius T := by
    rw [HDP.Chapter7.finiteRadius_eq_sup' T hT, huMax]
  have hvRad : ‖v0‖ = HDP.Chapter7.finiteRadius S := by
    rw [HDP.Chapter7.finiteRadius_eq_sup' S hS, hvMax]
  rw [huRad] at hlowerU
  rw [hvRad] at hlowerV
  have hwT := HDP.Chapter7.gaussianWidth_nonneg T hT
  have hwS := HDP.Chapter7.gaussianWidth_nonneg S hS
  have hrT := finiteRadius_nonneg T hT
  have hrS := finiteRadius_nonneg S hS
  change _ ≤ HDP.Chapter7.expectedFiniteSupremum
    (stdGaussian (EuclideanSpace ℝ (Fin m × Fin n))) X
  nlinarith [mul_nonneg hwT hrS, mul_nonneg hwS hrT]

/-! ### Sharp support-function comparison when one factor contains zero -/

omit hMM in
/-- The rank-one Gaussian metric is dominated by the support-function
comparison metric in which the scale of the first canonical process is the
norm of the right index and the second scale is the outer radius of the left
family. This is the finite-dimensional algebraic core of the
Chevet--Khaoulani comparison.

**Lean implementation helper.** -/
theorem rankOneGaussianPoint_sub_norm_sq_le_radial_fixed {m n : ℕ}
    (u w : EuclideanSpace ℝ (Fin n))
    (v z : EuclideanSpace ℝ (Fin m))
    (rT : ℝ) (hrT : 0 ≤ rT)
    (hu : ‖u‖ ≤ rT) (hw : ‖w‖ ≤ rT) :
    ‖rankOneGaussianPoint u v - rankOneGaussianPoint w z‖ ^ 2 ≤
      ‖‖v‖ • u - ‖z‖ • w‖ ^ 2 + rT ^ 2 * ‖v - z‖ ^ 2 := by
  have hA : inner ℝ u w ≤ rT ^ 2 := by
    calc
      inner ℝ u w ≤ ‖u‖ * ‖w‖ := real_inner_le_norm u w
      _ ≤ rT ^ 2 := by nlinarith [norm_nonneg u, norm_nonneg w]
  have hB : inner ℝ v z ≤ ‖v‖ * ‖z‖ := real_inner_le_norm v z
  have hprod :
      0 ≤ (rT ^ 2 - inner ℝ u w) *
        (‖v‖ * ‖z‖ - inner ℝ v z) :=
    mul_nonneg (sub_nonneg.mpr hA) (sub_nonneg.mpr hB)
  rw [rankOneGaussianPoint_sub_norm_sq,
    norm_sub_sq_real, norm_sub_sq_real]
  simp only [norm_smul, Real.norm_eq_abs, abs_norm, inner_smul_left,
    inner_smul_right, starRingEnd_apply, star_trivial, mul_pow]
  nlinarith [sq_nonneg (‖v‖ - ‖z‖)]

/-- The comparison process used when the left support set contains zero.
For a fixed right index `v`, its first component has exactly the same law as
the Gaussian matrix applied at `v`; the second component pays only the outer
radius of the left family.

**Lean implementation helper.** -/
def finiteChevetSupportProcess {m n : ℕ}
    (T : Finset (EuclideanSpace ℝ (Fin n)))
    (S : Finset (EuclideanSpace ℝ (Fin m)))
    (rT : ℝ) :
    HDP.RandomProcess (ChevetIndex T S)
      (EuclideanSpace ℝ (Fin n) × EuclideanSpace ℝ (Fin m)) :=
  sumCanonicalGaussianProcess
    (fun p : ChevetIndex T S => ‖p.2.1‖ • p.1.1)
    (fun p : ChevetIndex T S => rT • p.2.1)

omit hMM in
/-- Pointwise maximum comparison for the support-function process. The
assumption `0 ∈ T` is used only to make the support function nonnegative, so
that the variable radial factor can be replaced by `rad(S)` without loss.

**Lean implementation helper.** -/
theorem finiteProcessSup_chevetSupportProcess_le {m n : ℕ}
    (T : Finset (EuclideanSpace ℝ (Fin n)))
    (S : Finset (EuclideanSpace ℝ (Fin m)))
    [Nonempty ↥T] [Nonempty ↥S]
    (hT : T.Nonempty) (hS : S.Nonempty)
    (hzero : 0 ∈ T) :
    ∀ gh,
      finiteProcessSup
          (finiteChevetSupportProcess T S
            (HDP.Chapter7.finiteRadius T)) gh ≤
        finiteProcessSup
          (finiteChevetGaussianProcess T S
            (HDP.Chapter7.finiteRadius S)
            (HDP.Chapter7.finiteRadius T)) gh := by
  intro gh
  let rT := HDP.Chapter7.finiteRadius T
  let rS := HDP.Chapter7.finiteRadius S
  have hrT : 0 ≤ rT := finiteRadius_nonneg T hT
  have hrS : 0 ≤ rS := finiteRadius_nonneg S hS
  have hsupport0 : 0 ≤ HDP.Chapter7.finiteGaussianSupport T gh.1 := by
    rw [HDP.Chapter7.finiteGaussianSupport_eq_sup' T hT]
    have hle := Finset.le_sup' (fun x => inner ℝ gh.1 x) hzero
    simpa using hle
  rw [finiteProcessSup_chevetGaussianProcess T S hT hS hrS hrT]
  unfold finiteProcessSup
  apply Finset.sup'_le
  intro p hp
  have hu := Finset.le_sup' (fun x => inner ℝ gh.1 x) p.1.2
  have hv := Finset.le_sup' (fun y => inner ℝ gh.2 y) p.2.2
  have hvrad := HDP.Chapter7.norm_le_finiteRadius S hS p.2.2
  have hu' : inner ℝ p.1.1 gh.1 ≤
      HDP.Chapter7.finiteGaussianSupport T gh.1 := by
    rw [real_inner_comm]
    rw [HDP.Chapter7.finiteGaussianSupport_eq_sup' T hT]
    exact hu
  have hv' : inner ℝ p.2.1 gh.2 ≤
      HDP.Chapter7.finiteGaussianSupport S gh.2 := by
    rw [real_inner_comm]
    rw [HDP.Chapter7.finiteGaussianSupport_eq_sup' S hS]
    exact hv
  simp only [finiteChevetSupportProcess, sumCanonicalGaussianProcess,
    inner_smul_left, starRingEnd_apply, star_trivial]
  change ‖p.2.1‖ * inner ℝ p.1.1 gh.1 +
      rT * inner ℝ p.2.1 gh.2 ≤
    rS * HDP.Chapter7.finiteGaussianSupport T gh.1 +
      rT * HDP.Chapter7.finiteGaussianSupport S gh.2
  exact add_le_add
    ((mul_le_mul_of_nonneg_left hu' (norm_nonneg _)).trans
      (mul_le_mul_of_nonneg_right hvrad hsupport0))
    (mul_le_mul_of_nonneg_left hv' hrT)

omit hMM in
/-- Sharp Gaussian Chevet upper bound for arbitrary finite radii when the
left support family contains the origin.

**Lean implementation helper.** -/
theorem gaussian_chevet_of_zero_mem_left {m n : ℕ}
    (T : Finset (EuclideanSpace ℝ (Fin n)))
    (S : Finset (EuclideanSpace ℝ (Fin m)))
    [Nonempty ↥T] [Nonempty ↥S]
    (hT : T.Nonempty) (hS : S.Nonempty)
    (hzero : 0 ∈ T) :
    HDP.Chapter7.expectedFiniteSupremum
        (stdGaussian (EuclideanSpace ℝ (Fin m × Fin n)))
        (finiteGaussianMatrixChevetProcess T S) ≤
      HDP.Chapter7.gaussianWidth T * HDP.Chapter7.finiteRadius S +
        HDP.Chapter7.gaussianWidth S * HDP.Chapter7.finiteRadius T := by
  let u : ChevetIndex T S → EuclideanSpace ℝ (Fin n) := fun p => p.1.1
  let v : ChevetIndex T S → EuclideanSpace ℝ (Fin m) := fun p => p.2.1
  let rT := HDP.Chapter7.finiteRadius T
  let rS := HDP.Chapter7.finiteRadius S
  let X := rankOneCanonicalGaussianProcess u v
  let Y := finiteChevetSupportProcess T S rT
  have hXG : IsGaussianProcess X
      (stdGaussian (EuclideanSpace ℝ (Fin m × Fin n))) := by
    simpa [X, rankOneCanonicalGaussianProcess] using
      HDP.Chapter7.canonicalGaussianProcess_isGaussian
        (fun p : ChevetIndex T S => rankOneGaussianPoint (u p) (v p))
  have hX0 : HDP.IsCenteredProcess X
      (stdGaussian (EuclideanSpace ℝ (Fin m × Fin n))) := by
    simpa [X, rankOneCanonicalGaussianProcess] using
      HDP.Chapter7.canonicalGaussianProcess_centered
        (fun p : ChevetIndex T S => rankOneGaussianPoint (u p) (v p))
  have hYG : IsGaussianProcess Y
      ((stdGaussian (EuclideanSpace ℝ (Fin n))).prod
        (stdGaussian (EuclideanSpace ℝ (Fin m)))) := by
    simpa [Y, finiteChevetSupportProcess] using
      sumCanonicalGaussianProcess_isGaussian
        (fun p : ChevetIndex T S => ‖p.2.1‖ • p.1.1)
        (fun p : ChevetIndex T S => rT • p.2.1)
  have hY0 : HDP.IsCenteredProcess Y
      ((stdGaussian (EuclideanSpace ℝ (Fin n))).prod
        (stdGaussian (EuclideanSpace ℝ (Fin m)))) := by
    simpa [Y, finiteChevetSupportProcess] using
      sumCanonicalGaussianProcess_centered
        (fun p : ChevetIndex T S => ‖p.2.1‖ • p.1.1)
        (fun p : ChevetIndex T S => rT • p.2.1)
  have hinc : ∀ p q,
      HDP.Chapter7.processIncrementSecondMoment
          (stdGaussian (EuclideanSpace ℝ (Fin m × Fin n))) X p q ≤
        HDP.Chapter7.processIncrementSecondMoment
          ((stdGaussian (EuclideanSpace ℝ (Fin n))).prod
            (stdGaussian (EuclideanSpace ℝ (Fin m)))) Y p q := by
    intro p q
    rw [show X = rankOneCanonicalGaussianProcess u v from rfl,
      rankOneCanonicalGaussianProcess_incrementSecondMoment,
      show Y = sumCanonicalGaussianProcess
        (fun z : ChevetIndex T S => ‖z.2.1‖ • z.1.1)
        (fun z : ChevetIndex T S => rT • z.2.1) from rfl,
      sumCanonicalGaussianProcess_incrementSecondMoment]
    have hmain := rankOneGaussianPoint_sub_norm_sq_le_radial_fixed
      p.1.1 q.1.1 p.2.1 q.2.1 rT (finiteRadius_nonneg T hT)
      (HDP.Chapter7.norm_le_finiteRadius T hT p.1.2)
      (HDP.Chapter7.norm_le_finiteRadius T hT q.1.2)
    have hscale : rT ^ 2 * ‖p.2.1 - q.2.1‖ ^ 2 =
        ‖rT • p.2.1 - rT • q.2.1‖ ^ 2 := by
      rw [← smul_sub, norm_smul, Real.norm_eq_abs,
        abs_of_nonneg (finiteRadius_nonneg T hT)]
      ring
    exact hmain.trans_eq (congrArg
      (fun x => ‖‖p.2.1‖ • p.1.1 - ‖q.2.1‖ • q.1.1‖ ^ 2 + x) hscale)
  have hcomp := HDP.Chapter7.sudakovFernique
    (stdGaussian (EuclideanSpace ℝ (Fin m × Fin n)))
    ((stdGaussian (EuclideanSpace ℝ (Fin n))).prod
      (stdGaussian (EuclideanSpace ℝ (Fin m))))
    X Y hXG hYG hX0 hY0 hinc
  have hYcoord : ∀ p, Integrable (Y p)
      ((stdGaussian (EuclideanSpace ℝ (Fin n))).prod
        (stdGaussian (EuclideanSpace ℝ (Fin m)))) := by
    intro p
    exact (hYG.hasGaussianLaw_eval p).integrable
  have hFcoord : ∀ p, Integrable
      (finiteChevetGaussianProcess T S rS rT p)
      ((stdGaussian (EuclideanSpace ℝ (Fin n))).prod
        (stdGaussian (EuclideanSpace ℝ (Fin m)))) := by
    intro p
    have hproc : finiteChevetGaussianProcess T S rS rT =
        sumCanonicalGaussianProcess
          (fun z : ChevetIndex T S => rS • z.1.1)
          (fun z : ChevetIndex T S => rT • z.2.1) := by
      funext z gh
      simp only [finiteChevetGaussianProcess, sumCanonicalGaussianProcess,
        inner_smul_left, starRingEnd_apply, star_trivial]
      rw [real_inner_comm z.1.1 gh.1, real_inner_comm z.2.1 gh.2]
    rw [hproc]
    exact ((sumCanonicalGaussianProcess_isGaussian
      (fun z : ChevetIndex T S => rS • z.1.1)
      (fun z : ChevetIndex T S => rT • z.2.1)).hasGaussianLaw_eval p).integrable
  have hYmax := integrable_finiteProcessSup_of_integrable Y hYcoord
  have hFmax := integrable_finiteProcessSup_of_integrable
    (finiteChevetGaussianProcess T S rS rT) hFcoord
  have hYle : HDP.Chapter7.expectedFiniteSupremum
      ((stdGaussian (EuclideanSpace ℝ (Fin n))).prod
        (stdGaussian (EuclideanSpace ℝ (Fin m)))) Y ≤
      HDP.Chapter7.expectedFiniteSupremum
      ((stdGaussian (EuclideanSpace ℝ (Fin n))).prod
        (stdGaussian (EuclideanSpace ℝ (Fin m))))
        (finiteChevetGaussianProcess T S rS rT) := by
    unfold HDP.Chapter7.expectedFiniteSupremum
    exact integral_mono hYmax hFmax
      (finiteProcessSup_chevetSupportProcess_le T S hT hS hzero)
  change HDP.Chapter7.expectedFiniteSupremum
      (stdGaussian (EuclideanSpace ℝ (Fin m × Fin n))) X ≤ _
  calc
    _ ≤ HDP.Chapter7.expectedFiniteSupremum
        ((stdGaussian (EuclideanSpace ℝ (Fin n))).prod
          (stdGaussian (EuclideanSpace ℝ (Fin m)))) Y := hcomp
    _ ≤ HDP.Chapter7.expectedFiniteSupremum
        ((stdGaussian (EuclideanSpace ℝ (Fin n))).prod
          (stdGaussian (EuclideanSpace ℝ (Fin m))))
          (finiteChevetGaussianProcess T S rS rT) := hYle
    _ = HDP.Chapter7.gaussianWidth T * HDP.Chapter7.finiteRadius S +
        HDP.Chapter7.gaussianWidth S * HDP.Chapter7.finiteRadius T := by
      rw [expectedFiniteSupremum_chevetGaussianProcess T S hT hS
        (finiteRadius_nonneg S hS) (finiteRadius_nonneg T hT)]
      ring

