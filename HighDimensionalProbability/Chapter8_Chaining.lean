    have hrAbsorb : HDP.Chapter7.finiteRadius T ≤
        2 * u * HDP.Chapter7.finiteRadius T := by
      nlinarith [mul_nonneg hu hr0]
    have hinside :
        (HDP.gamma2 (fun s t : ↥A => ENNReal.ofReal (d s t))).toReal +
            u * finiteDistanceDiameter d ≤
          (2 * majorizingMeasureLowerConstant + 2) *
            (HDP.Chapter7.gaussianWidth T +
              u * HDP.Chapter7.finiteRadius T) := by
      calc
        (HDP.gamma2 (fun s t : ↥A => ENNReal.ofReal (d s t))).toReal +
              u * finiteDistanceDiameter d ≤
            majorizingMeasureLowerConstant *
                (HDP.Chapter7.gaussianWidth T +
                  HDP.Chapter7.finiteRadius T) +
              u * (2 * HDP.Chapter7.finiteRadius T) := by
          exact add_le_add hgamma'
            (mul_le_mul_of_nonneg_left (by simpa [d] using hdiam) hu)
        _ ≤ (2 * majorizingMeasureLowerConstant + 2) *
            (HDP.Chapter7.gaussianWidth T +
              u * HDP.Chapter7.finiteRadius T) := by
          have hM := majorizingMeasureLowerConstant_pos.le
          have huR := mul_nonneg hu hr0
          have hMr := mul_le_mul_of_nonneg_left hrAbsorb hM
          nlinarith
    have hthreshold :
        genericChainingHighProbabilityConstant * K *
            ((HDP.gamma2
              (fun s t : ↥A => ENNReal.ofReal (d s t))).toReal +
                u * finiteDistanceDiameter d) ≤
          exercise837HighProbabilityConstant * K *
            (HDP.Chapter7.gaussianWidth T +
              u * HDP.Chapter7.finiteRadius T) := by
      calc
        genericChainingHighProbabilityConstant * K *
            ((HDP.gamma2
              (fun s t : ↥A => ENNReal.ofReal (d s t))).toReal +
                u * finiteDistanceDiameter d) ≤
            genericChainingHighProbabilityConstant * K *
              ((2 * majorizingMeasureLowerConstant + 2) *
                (HDP.Chapter7.gaussianWidth T +
                  u * HDP.Chapter7.finiteRadius T)) :=
          mul_le_mul_of_nonneg_left hinside
            (mul_nonneg genericChainingHighProbabilityConstant_pos.le hK)
        _ = exercise837HighProbabilityConstant * K *
            (HDP.Chapter7.gaussianWidth T +
              u * HDP.Chapter7.finiteRadius T) := by
          simp [exercise837HighProbabilityConstant]
          ring
    calc
      μ {ω | exercise837HighProbabilityConstant * K *
            (HDP.Chapter7.gaussianWidth T +
              u * HDP.Chapter7.finiteRadius T) <
          finiteProcessAbsoluteSup (finiteEuclideanProcess T X) ω} ≤
          μ {ω | genericChainingHighProbabilityConstant * K *
              ((HDP.gamma2
                (fun s t : ↥A => ENNReal.ofReal (d s t))).toReal +
                  u * finiteDistanceDiameter d) <
            finiteProcessOscillation Z ω} := by
        apply measure_mono
        intro ω hω
        exact lt_of_le_of_lt hthreshold
          (hω.trans_le (by
            simpa [Z, A] using
              finiteProcessAbsoluteSup_le_insertZeroOscillation
                T X hzero ω))
      _ ≤ ENNReal.ofReal (2 * Real.exp (-u ^ 2)) := htail

/-- Universal constant in Exercise 8.37(c).

**Book Exercise 8.37(c).** -/
def exercise837MomentConstant : ℝ :=
  8 * Real.sqrt 5 * exercise837HighProbabilityConstant

/-- The moment constant used in Exercise 8.37 is positive.

**Lean implementation helper.** -/
theorem exercise837MomentConstant_pos :
    0 < exercise837MomentConstant := by
  exact mul_pos
    (mul_pos (by norm_num) (Real.sqrt_pos.2 (by norm_num)))
    exercise837HighProbabilityConstant_pos

/-- Expectation, high-probability, and moment consequences of Talagrand comparison. The real-valued `lpNormRV` is finite here because the high-probability bound
from part (b) gives a Gaussian tail for the finite absolute supremum.

**Book Exercise 8.37.** -/
theorem exercise_8_37c_moments
    {n : ℕ} {Ω : Type} [MeasurableSpace Ω]
    (μ : Measure Ω) [IsProbabilityMeasure μ]
    (T : Finset (EuclideanSpace ℝ (Fin n))) [Nonempty ↥T]
    (hT : T.Nonempty)
    (X : EuclideanSpace ℝ (Fin n) → Ω → ℝ)
    (hXm : ∀ x ∈ insert 0 T, Measurable (X x))
    (hzero : X 0 = 0)
    {K p : ℝ} (hK : 0 ≤ K) (hp : 1 ≤ p)
    (hinc : ∀ x ∈ insert 0 T, ∀ y ∈ insert 0 T,
      HDP.SubGaussian (fun ω => X x ω - X y ω) μ ∧
        HDP.psi2Norm (fun ω => X x ω - X y ω) μ ≤ K * ‖x - y‖) :
    HDP.Chapter1.lpNormRV
        (finiteProcessAbsoluteSup (finiteEuclideanProcess T X)) p μ ≤
      exercise837MomentConstant * Real.sqrt p * K *
        HDP.Chapter7.gaussianComplexity T := by
  classical
  let S : Ω → ℝ := finiteProcessAbsoluteSup (finiteEuclideanProcess T X)
  let G : ℝ := HDP.Chapter7.gaussianComplexity T
  let L : ℝ := exercise837HighProbabilityConstant * K * G
  have hG : 0 ≤ G := HDP.Chapter7.gaussianComplexity_nonneg T
  have hL0 : 0 ≤ L := by
    dsimp [L]
    exact mul_nonneg
      (mul_nonneg exercise837HighProbabilityConstant_pos.le hK) hG
  have hSm : Measurable S := by
    apply measurable_finiteProcessAbsoluteSup
    intro x
    exact hXm x.1 (by simp [x.2])
  have hS0 (ω : Ω) : 0 ≤ S ω := by
    unfold S finiteProcessAbsoluteSup
    obtain ⟨x, hx⟩ := hT
    exact (abs_nonneg (finiteEuclideanProcess T X ⟨x, hx⟩ ω)).trans
      (Finset.le_sup'
        (fun z : ↥T => |finiteEuclideanProcess T X z ω|)
        (Finset.mem_univ ⟨x, hx⟩))
  have hTint : ∀ x : ↥T, Integrable (finiteEuclideanProcess T X x) μ := by
    intro x
    have hxsub : HDP.SubGaussian (finiteEuclideanProcess T X x) μ := by
      have hx := (hinc x.1 (by simp [x.2]) 0 (by simp)).1
      simpa [finiteEuclideanProcess, hzero] using hx
    exact (hxsub.memLp (hXm x.1 (by simp [x.2])).aemeasurable
      (show (1 : ℝ) ≤ 1 by rfl)).integrable (by norm_num)
  have hSint : Integrable S μ :=
    integrable_finiteProcessAbsoluteSup _ hTint
  have hwidth : HDP.Chapter7.gaussianWidth T ≤ G := by
    exact HDP.Chapter7.gaussianWidth_le_gaussianComplexity T
  have hradius : HDP.Chapter7.finiteRadius T ≤ 2 * G := by
    exact finiteRadius_le_two_gaussianComplexity T hT
  by_cases hLzero : L = 0
  · have hKG : K * G = 0 := by
      have hCne : exercise837HighProbabilityConstant ≠ 0 :=
        exercise837HighProbabilityConstant_pos.ne'
      have hprod : exercise837HighProbabilityConstant * (K * G) = 0 := by
        simpa [L, mul_assoc] using hLzero
      exact (mul_eq_zero.mp hprod).resolve_left hCne
    have hExp := exercise_8_37a_expectation μ T hT X hXm hzero hK hinc
    have hEzero : ∫ ω, S ω ∂μ = 0 := by
      apply le_antisymm
      · calc
          (∫ ω, S ω ∂μ) ≤
              exercise837ExpectationConstant * K * G := by
            simpa [S, G] using hExp
          _ = exercise837ExpectationConstant * (K * G) := by ring
          _ = 0 := by rw [hKG, mul_zero]
      · exact integral_nonneg hS0
    have hSae : S =ᵐ[μ] 0 :=
      (integral_eq_zero_iff_of_nonneg hS0 hSint).mp hEzero
    have hp0 : 0 < p := lt_of_lt_of_le one_pos hp
    have hlp : HDP.Chapter1.lpNormRV S p μ = 0 := by
      rw [HDP.Chapter1.lpNormRV]
      have hzint : (∫ ω, |S ω| ^ p ∂μ) = 0 := by
        apply integral_eq_zero_of_ae
        filter_upwards [hSae] with ω hω
        simp [hω, Real.zero_rpow hp0.ne']
      rw [hzint, Real.zero_rpow (one_div_pos.mpr hp0).ne']
    rw [show finiteProcessAbsoluteSup (finiteEuclideanProcess T X) = S from rfl,
      hlp]
    rw [show exercise837MomentConstant * Real.sqrt p * K * G =
        (exercise837MomentConstant * Real.sqrt p) * (K * G) by ring,
      hKG, mul_zero]
  · have hL : 0 < L := lt_of_le_of_ne hL0 (Ne.symm hLzero)
    have hpure : ∀ t : ℝ, 0 ≤ t →
        μ {ω | t ≤ |S ω|} ≤
          ENNReal.ofReal
            (2 * Real.exp (-t ^ 2 / (8 * L) ^ 2)) := by
      intro t ht
      by_cases htSmall : t < 4 * L
      · calc
          μ {ω | t ≤ |S ω|} ≤ 1 := prob_le_one
          _ ≤ ENNReal.ofReal
              (2 * Real.exp (-t ^ 2 / (8 * L) ^ 2)) := by
            rw [show (1 : ℝ≥0∞) = ENNReal.ofReal 1 by norm_num]
            apply ENNReal.ofReal_le_ofReal
            have hden : 0 < (8 * L) ^ 2 := sq_pos_of_pos (by positivity)
            have hratio : t ^ 2 / (8 * L) ^ 2 < 1 / 4 := by
              rw [div_lt_iff₀ hden]
              nlinarith [sq_nonneg t, sq_nonneg L]
            have hexp := Real.add_one_le_exp (-t ^ 2 / (8 * L) ^ 2)
            have hbase : (3 / 4 : ℝ) <
                Real.exp (-t ^ 2 / (8 * L) ^ 2) := by
              calc
                (3 / 4 : ℝ) < 1 - t ^ 2 / (8 * L) ^ 2 := by
                  nlinarith
                _ ≤ Real.exp (-t ^ 2 / (8 * L) ^ 2) := by
                  calc
                    1 - t ^ 2 / (8 * L) ^ 2 =
                        -t ^ 2 / (8 * L) ^ 2 + 1 := by ring
                    _ ≤ Real.exp (-t ^ 2 / (8 * L) ^ 2) := hexp
            nlinarith
      · have htLarge : 4 * L ≤ t := le_of_not_gt htSmall
        let u : ℝ := t / (4 * L)
        have hu : 0 ≤ u := by positivity
        have huOne : 1 ≤ u := by
          dsimp [u]
          rw [le_div_iff₀ (by positivity : 0 < 4 * L)]
          simpa using htLarge
        have htail := exercise_8_37b_highProbability μ T hT X hXm
          hzero hK hu hinc
        have htpos : 0 < t := lt_of_lt_of_le (by positivity : 0 < 4 * L) htLarge
        have hthreshold :
            exercise837HighProbabilityConstant * K *
                (HDP.Chapter7.gaussianWidth T +
                  u * HDP.Chapter7.finiteRadius T) < t := by
          have hu0 := hu
          have hleft :
              exercise837HighProbabilityConstant * K *
                  (HDP.Chapter7.gaussianWidth T +
                    u * HDP.Chapter7.finiteRadius T) ≤
                L * (1 + 2 * u) := by
            calc
              exercise837HighProbabilityConstant * K *
                  (HDP.Chapter7.gaussianWidth T +
                    u * HDP.Chapter7.finiteRadius T) ≤
                  exercise837HighProbabilityConstant * K *
                    (G + u * (2 * G)) := by
                exact mul_le_mul_of_nonneg_left
                  (add_le_add hwidth
                    (mul_le_mul_of_nonneg_left hradius hu))
                  (mul_nonneg exercise837HighProbabilityConstant_pos.le hK)
              _ = L * (1 + 2 * u) := by
                simp [L]
                ring
          have huEq : 2 * L * u = t / 2 := by
            dsimp [u]
            field_simp [hL.ne']
            norm_num
          have hLt : L + t / 2 < t := by nlinarith
          calc
            exercise837HighProbabilityConstant * K *
                (HDP.Chapter7.gaussianWidth T +
                  u * HDP.Chapter7.finiteRadius T) ≤
                L * (1 + 2 * u) := hleft
            _ = L + 2 * L * u := by ring
            _ = L + t / 2 := by rw [huEq]
            _ < t := hLt
        have hexparg : -u ^ 2 ≤ -t ^ 2 / (8 * L) ^ 2 := by
          dsimp [u]
          have hLsq : 0 < L ^ 2 := sq_pos_of_pos hL
          have htSq : 0 ≤ t ^ 2 := sq_nonneg t
          field_simp [hL.ne']
          nlinarith
        calc
          μ {ω | t ≤ |S ω|} ≤
              μ {ω | exercise837HighProbabilityConstant * K *
                  (HDP.Chapter7.gaussianWidth T +
                    u * HDP.Chapter7.finiteRadius T) <
                finiteProcessAbsoluteSup (finiteEuclideanProcess T X) ω} := by
            apply measure_mono
            intro ω hω
            change t ≤ |S ω| at hω
            change exercise837HighProbabilityConstant * K *
                (HDP.Chapter7.gaussianWidth T +
                  u * HDP.Chapter7.finiteRadius T) < S ω
            rw [abs_of_nonneg (hS0 ω)] at hω
            exact hthreshold.trans_le hω
          _ ≤ ENNReal.ofReal (2 * Real.exp (-u ^ 2)) := htail
          _ ≤ ENNReal.ofReal
              (2 * Real.exp (-t ^ 2 / (8 * L) ^ 2)) := by
            apply ENNReal.ofReal_le_ofReal
            exact mul_le_mul_of_nonneg_left
              (Real.exp_le_exp.mpr hexparg) (by norm_num)
    have htailSub := HDP.psi2Norm_le_of_tail_bound hSm.aemeasurable
      (show 0 < 8 * L by positivity) hpure
    have hmom := htailSub.1.moment_bound hSm.aemeasurable hp
    calc
      HDP.Chapter1.lpNormRV
          (finiteProcessAbsoluteSup (finiteEuclideanProcess T X)) p μ =
          HDP.Chapter1.lpNormRV S p μ := rfl
      _ ≤ HDP.psi2Norm S μ * Real.sqrt p := hmom
      _ ≤ (Real.sqrt 5 * (8 * L)) * Real.sqrt p := by
        exact mul_le_mul_of_nonneg_right htailSub.2 (Real.sqrt_nonneg p)
      _ = exercise837MomentConstant * Real.sqrt p * K * G := by
        simp [exercise837MomentConstant, L]
        ring

/-! ## The product-Gaussian comparison process -/

/-- The Gaussian process indexed by pairs of deterministic vectors,
`Y_i(g,h) = ⟪u_i,g⟫ + ⟪v_i,h⟫`. Scale factors can be absorbed directly
into `u` and `v`; this is the comparison process used in Chevet's inequality.

**Lean implementation helper.** -/
def sumCanonicalGaussianProcess
    {I E F : Type*}
    [NormedAddCommGroup E] [InnerProductSpace ℝ E]
    [NormedAddCommGroup F] [InnerProductSpace ℝ F]
    (u : I → E) (v : I → F) : HDP.RandomProcess I (E × F) :=
  fun i p => inner ℝ (u i) p.1 + inner ℝ (v i) p.2

omit hMM in
/-- The product-Gaussian comparison process is Gaussian, including when one
of the two deterministic families is degenerate.

**Lean implementation helper.** -/
theorem sumCanonicalGaussianProcess_isGaussian
    {I E F : Type*}
    [NormedAddCommGroup E] [InnerProductSpace ℝ E]
    [FiniteDimensional ℝ E] [MeasurableSpace E] [BorelSpace E]
    [NormedAddCommGroup F] [InnerProductSpace ℝ F]
    [FiniteDimensional ℝ F] [MeasurableSpace F] [BorelSpace F]
    (u : I → E) (v : I → F) :
    IsGaussianProcess (sumCanonicalGaussianProcess u v)
      ((stdGaussian E).prod (stdGaussian F)) := by
  refine ⟨fun J => ?_⟩
  let f : E → (J → ℝ) := fun g i => inner ℝ (u i) g
  let h : F → (J → ℝ) := fun z i => inner ℝ (v i) z
  have hfm : Measurable f := by
    apply measurable_pi_lambda
    intro i
    exact ((innerSL ℝ) (u i)).continuous.measurable
  have hhm : Measurable h := by
    apply measurable_pi_lambda
    intro i
    exact ((innerSL ℝ) (v i)).continuous.measurable
  have hfG : HasGaussianLaw f (stdGaussian E) := by
    have hbase :=
      (HDP.Chapter7.canonicalGaussianProcess_isGaussian u).hasGaussianLaw J
    refine hbase.congr (ae_of_all _ fun g => ?_)
    ext i
    rfl
  have hhG : HasGaussianLaw h (stdGaussian F) := by
    have hbase :=
      (HDP.Chapter7.canonicalGaussianProcess_isGaussian v).hasGaussianLaw J
    refine hbase.congr (ae_of_all _ fun z => ?_)
    ext i
    rfl
  have hfst : HasGaussianLaw (fun p : E × F => f p.1)
      ((stdGaussian E).prod (stdGaussian F)) := by
    refine ⟨?_⟩
    have hmap : ((stdGaussian E).prod (stdGaussian F)).map
        (fun p : E × F => f p.1) = (stdGaussian E).map f := by
      rw [show (fun p : E × F => f p.1) = f ∘ Prod.fst by rfl,
        ← Measure.map_map hfm measurable_fst,
        (measurePreserving_fst (μ := stdGaussian E)
          (ν := stdGaussian F)).map_eq]
    rw [hmap]
    exact hfG.isGaussian_map
  have hsnd : HasGaussianLaw (fun p : E × F => h p.2)
      ((stdGaussian E).prod (stdGaussian F)) := by
    refine ⟨?_⟩
    have hmap : ((stdGaussian E).prod (stdGaussian F)).map
        (fun p : E × F => h p.2) = (stdGaussian F).map h := by
      rw [show (fun p : E × F => h p.2) = h ∘ Prod.snd by rfl,
        ← Measure.map_map hhm measurable_snd,
        (measurePreserving_snd (μ := stdGaussian E)
          (ν := stdGaussian F)).map_eq]
    rw [hmap]
    exact hhG.isGaussian_map
  have hind : (fun p : E × F => f p.1) ⟂ᵢ[
      (stdGaussian E).prod (stdGaussian F)] (fun p : E × F => h p.2) :=
    indepFun_prod (X := f) (Y := h) hfm hhm
  have hadd := iIndepFun.hasGaussianLaw_fun_add hfst hsnd hind
  refine hadd.congr (ae_of_all _ fun p => ?_)
  ext i
  rfl

