/-! ## The finite VC covering theorem -/

/-- The finite Boolean class realized in Mathlib's authoritative `L²` space.

**Lean implementation helper.** -/
def booleanLpClass (μ : Measure α) [IsFiniteMeasure μ]
    (F : BooleanFamily α) : Set (Lp ℝ 2 μ) :=
  booleanLp μ '' (F : Set (Finset α))

/-- The `L²` indicator image of a finite Boolean family is a finite set.

**Lean implementation helper.** -/
theorem finite_booleanLpClass (F : BooleanFamily α) :
    (booleanLpClass μ F).Finite :=
  F.finite_toSet.image _

/-- The natural-valued packing number is safe here because the Boolean class
is finite.

**Lean implementation helper.** -/
def booleanPackingNumber (μ : Measure α) [IsFiniteMeasure μ]
    (F : BooleanFamily α) (ε : ℝ≥0) : ℕ :=
  HDP.finitePackingNumber ε (booleanLpClass μ F)
    ((HDP.finite_covering_packing_of_finite (finite_booleanLpClass (μ := μ) F) ε).2)

/-- The Boolean packing number agrees, after coercion, with the metric packing number of the associated `L²` indicator class.

**Lean implementation helper.** -/
@[simp, norm_cast]
theorem coe_booleanPackingNumber (F : BooleanFamily α) (ε : ℝ≥0) :
    (booleanPackingNumber μ F ε : ℕ∞) =
      Metric.packingNumber ε (booleanLpClass μ F) := by
  exact HDP.coe_finitePackingNumber _ _ _

/-- Intermediate finite VC covering bound (explicit
dimension-reduction form).** If `n` is large enough for the exact Hoeffding
union bound of Lemma 8.3.14, then the `L²(μ)` covering number is bounded by
the `n`-point Sauer--Shelah sum. The source subsequently chooses `n = O(ε⁻⁴ log M)`, where `M` is the packing
number, and solves the resulting elementary self-bound to write the result as
`(2/ε)^(C d)`. This declaration retains the stronger checkable finite bound
and the exact numerical condition; it has no hidden universal constant and no
measurability or infinitude assumptions left implicit.

**Book Lemma 8.3.14.** -/
theorem theorem_8_3_13_dimension_reduction_packing_bound [Finite α]
    [IsProbabilityMeasure μ]
    (F : BooleanFamily α) {d n : ℕ} (hd : F.vcDim ≤ d) (hn : 0 < n)
    (ε : ℝ≥0) (hε : 0 < ε)
    (hsize : (booleanPackingNumber μ F ε : ℝ) ^ 2 *
      Real.exp (-(n : ℝ) * (ε : ℝ) ^ 4 / 8) ≤ 1 / 100) :
    Metric.packingNumber ε (booleanLpClass μ F) ≤
      (∑ k ∈ Finset.range (d + 1), n.choose k : ℕ) := by
  letI := Fintype.ofFinite α
  let K : Set (Lp ℝ 2 μ) := booleanLpClass μ F
  have hKfin : K.Finite := finite_booleanLpClass (μ := μ) F
  have hpack : Metric.packingNumber ε K ≠ ⊤ :=
    (HDP.finite_covering_packing_of_finite hKfin ε).2
  let C : Set (Lp ℝ 2 μ) := Metric.maximalSeparatedSet ε K
  have hCfin : C.Finite := by
    apply Set.encard_ne_top_iff.mp
    rw [show C = Metric.maximalSeparatedSet ε K by rfl,
      Metric.encard_maximalSeparatedSet hpack]
    exact hpack
  letI : Fintype C := hCfin.fintype
  have hrepr_exists (x : C) :
      ∃ u ∈ F, booleanLp μ u = (x : Lp ℝ 2 μ) := by
    have hxK : (x : Lp ℝ 2 μ) ∈ K := Metric.maximalSeparatedSet_subset x.property
    simpa [K, booleanLpClass] using hxK
  let repr : C → Finset α := fun x => (hrepr_exists x).choose
  have hrepr_mem (x : C) : repr x ∈ F := (hrepr_exists x).choose_spec.1
  have hrepr_eq (x : C) : booleanLp μ (repr x) = (x : Lp ℝ 2 μ) :=
    (hrepr_exists x).choose_spec.2
  have hrepr_inj : Function.Injective repr := by
    intro x y hxy
    apply Subtype.ext
    rw [← hrepr_eq x, ← hrepr_eq y, hxy]
  let G : BooleanFamily α := Finset.univ.image repr
  have hGF : G ⊆ F := by
    intro u hu
    obtain ⟨x, -, rfl⟩ := Finset.mem_image.mp hu
    exact hrepr_mem x
  have hGvc : G.vcDim ≤ d := by
    exact (Finset.vcDim_mono hGF).trans hd
  have hGcard : G.card = Fintype.card C := by
    simpa [G] using Finset.card_image_of_injective Finset.univ hrepr_inj
  have hpack_eq : (G.card : ℕ∞) = Metric.packingNumber ε K := by
    rw [hGcard, Set.coe_fintypeCard]
    exact Metric.encard_maximalSeparatedSet hpack
  have hpackingNat : G.card = booleanPackingNumber μ F ε := by
    have hcoe : (G.card : ℕ∞) = (booleanPackingNumber μ F ε : ℕ∞) :=
      hpack_eq.trans (by
        exact (coe_booleanPackingNumber (μ := μ) F ε).symm)
    exact_mod_cast hcoe
  have hGsep : ∀ u ∈ G, ∀ v ∈ G, u ≠ v →
      (ε : ℝ) < booleanL2Dist μ u v := by
    intro u hu v hv huv
    obtain ⟨x, -, hxu⟩ := Finset.mem_image.mp hu
    obtain ⟨y, -, hyv⟩ := Finset.mem_image.mp hv
    have hxy : x ≠ y := by
      intro h
      apply huv
      rw [← hxu, ← hyv, h]
    have hxyval : (x : Lp ℝ 2 μ) ≠ (y : Lp ℝ 2 μ) := by
      intro h
      exact hxy (Subtype.ext h)
    have hsepC := Metric.isSeparated_maximalSeparatedSet x.property y.property hxyval
    have hdist : (ε : ℝ) < dist (x : Lp ℝ 2 μ) (y : Lp ℝ 2 μ) := by
      simpa [edist_dist] using hsepC
    rw [← hrepr_eq x, ← hrepr_eq y] at hdist
    simpa [← hxu, ← hyv] using (hdist.trans_eq (equation_8_31 (μ := μ) _ _).1)
  have hGsize : (G.card : ℝ) ^ 2 *
      Real.exp (-(n : ℝ) * (ε : ℝ) ^ 4 / 8) ≤ 1 / 100 := by
    simpa [hpackingNat] using hsize
  have hGbound := separated_family_card_le_binomial (μ := μ) hn G hGvc hε
    hGsep hGsize
  calc
    Metric.packingNumber ε (booleanLpClass μ F) = (G.card : ℕ∞) := by
      simpa [K] using hpack_eq.symm
    _ ≤ (∑ k ∈ Finset.range (d + 1), n.choose k : ℕ) := by
      exact_mod_cast hGbound

