/-- A finite maximum of integrable coordinates is integrable.

**Lean implementation helper.** -/
theorem integrable_finiteProcessSup_of_integrable
    {I Ξ : Type*} [Fintype I] [Nonempty I]
    [MeasurableSpace Ξ] {ν : Measure Ξ}
    (Z : HDP.RandomProcess I Ξ) (hZ : ∀ i, Integrable (Z i) ν) :
    Integrable (finiteProcessSup Z) ν := by
  rw [show finiteProcessSup Z = Finset.univ.sup' Finset.univ_nonempty Z by
    funext x
    simp [finiteProcessSup]]
  refine Finset.sup'_induction Finset.univ_nonempty Z
    (p := fun f : Ξ → ℝ => Integrable f ν) ?_ ?_
  · intro f hf g hg
    exact hf.sup hg
  · intro i hi
    exact hZ i

