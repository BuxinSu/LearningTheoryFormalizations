/-- The joint finite-subfamily control is exactly the source expression
`w(T) rad(S) + w(S) rad(T)` when each arbitrary-set quantity is interpreted
by Remark 7.2.1's directed finite-subfamily envelope.

**Book Remark 7.2.1.** -/
theorem gaussianChevetControlEnvelope_eq_width_radius {m n : ℕ}
    (T : Set (EuclideanSpace ℝ (Fin n)))
    (S : Set (EuclideanSpace ℝ (Fin m)))
    (hT : T.Nonempty) (hS : S.Nonempty) :
    gaussianChevetControlEnvelope T S =
      setGaussianWidthEnvelope T * setRadiusEnvelope S +
        setGaussianWidthEnvelope S * setRadiusEnvelope T := by
  classical
  letI : Nonempty (NonemptyFiniteSubset T) := by
    obtain ⟨x, hx⟩ := hT
    exact ⟨⟨{x}, by simp, by simpa using hx⟩⟩
  letI : Nonempty (NonemptyFiniteSubset S) := by
    obtain ⟨y, hy⟩ := hS
    exact ⟨⟨{y}, by simp, by simpa using hy⟩⟩
  apply le_antisymm
  · apply iSup_le
    intro U
    apply iSup_le
    intro V
    exact add_le_add
      (mul_le_mul'
        (le_iSup (fun W : NonemptyFiniteSubset T =>
          ENNReal.ofReal (HDP.Chapter7.gaussianWidth W.carrier)) U)
        (le_iSup (fun W : NonemptyFiniteSubset S =>
          ENNReal.ofReal (HDP.Chapter7.finiteRadius W.carrier)) V))
      (mul_le_mul'
        (le_iSup (fun W : NonemptyFiniteSubset S =>
          ENNReal.ofReal (HDP.Chapter7.gaussianWidth W.carrier)) V)
        (le_iSup (fun W : NonemptyFiniteSubset T =>
          ENNReal.ofReal (HDP.Chapter7.finiteRadius W.carrier)) U))
  · simp only [setGaussianWidthEnvelope, setRadiusEnvelope,
      ENNReal.iSup_mul, ENNReal.mul_iSup]
    refine ENNReal.iSup_add_iSup_le fun V₁ U₂ => ?_
    refine ENNReal.iSup_add_iSup_le fun U₁ V₂ => ?_
    let U := U₁.union U₂
    let V := V₁.union V₂
    have hwU := finiteSubsetGaussianWidthNN_mono U₁ U
      (NonemptyFiniteSubset.subset_union_left U₁ U₂)
    have hrU := finiteSubsetRadiusNN_mono U₂ U
      (NonemptyFiniteSubset.subset_union_right U₁ U₂)
    have hwV := finiteSubsetGaussianWidthNN_mono V₂ V
      (NonemptyFiniteSubset.subset_union_right V₁ V₂)
    have hrV := finiteSubsetRadiusNN_mono V₁ V
      (NonemptyFiniteSubset.subset_union_left V₁ V₂)
    calc
      ENNReal.ofReal (HDP.Chapter7.gaussianWidth U₁.carrier) *
            ENNReal.ofReal (HDP.Chapter7.finiteRadius V₁.carrier) +
          ENNReal.ofReal (HDP.Chapter7.gaussianWidth V₂.carrier) *
            ENNReal.ofReal (HDP.Chapter7.finiteRadius U₂.carrier) ≤
          finiteGaussianChevetControlNN U V := by
        exact add_le_add (mul_le_mul' hwU hrV) (mul_le_mul' hwV hrU)
      _ ≤ gaussianChevetControlEnvelope T S :=
        le_iSup_of_le U (le_iSup
          (fun V : NonemptyFiniteSubset S =>
            finiteGaussianChevetControlNN U V) V)

