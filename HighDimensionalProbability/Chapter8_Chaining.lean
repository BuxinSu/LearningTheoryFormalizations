            (HDP.Chapter7.gaussianWidth T +
              HDP.Chapter7.finiteRadius T) := by
      calc
        (HDP.gamma2 (fun s t : ↥A => ENNReal.ofReal (d s t))).toReal ≤
            majorizingMeasureLowerConstant * HDP.Chapter7.gaussianWidth A := by
