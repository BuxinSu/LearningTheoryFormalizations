/-- The radius of a nonempty finite set is controlled by twice its Gaussian
complexity.

**Lean implementation helper.** -/
theorem finiteRadius_le_two_gaussianComplexity
    {n : ℕ} (T : Finset (EuclideanSpace ℝ (Fin n)))
    (hT : T.Nonempty) :
    HDP.Chapter7.finiteRadius T ≤
      2 * HDP.Chapter7.gaussianComplexity T := by
  classical
  rw [HDP.Chapter7.finiteRadius_eq_sup' T hT]
  apply Finset.sup'_le
  intro y hy
  have habs :
      (∫ g : EuclideanSpace ℝ (Fin n), |inner ℝ g y|
        ∂stdGaussian (EuclideanSpace ℝ (Fin n))) =
        (Real.sqrt 2 / Real.sqrt Real.pi) * ‖y‖ := by
    have h := HDP.Chapter7.gaussianWidth_diameterSymmetricPair_eq y
    rw [HDP.Chapter7.gaussianWidth] at h
    simpa only [HDP.Chapter7.finiteGaussianSupport_diameterSymmetricPair]
      using h
  have hhalf : (1 / 2 : ℝ) ≤ Real.sqrt 2 / Real.sqrt Real.pi := by
    have hs2 : 0 ≤ Real.sqrt 2 := Real.sqrt_nonneg _
    have hspi : 0 < Real.sqrt Real.pi := Real.sqrt_pos.2 Real.pi_pos
    rw [le_div_iff₀ hspi]
    have hs2sq : (Real.sqrt 2) ^ 2 = 2 := Real.sq_sqrt (by norm_num)
    have hspisq : (Real.sqrt Real.pi) ^ 2 = Real.pi :=
      Real.sq_sqrt Real.pi_pos.le
    nlinarith [Real.pi_lt_four]
  have hpoint (g : EuclideanSpace ℝ (Fin n)) :
      |inner ℝ g y| ≤ HDP.Chapter7.finiteGaussianAbsSupport T g := by
    rw [HDP.Chapter7.finiteGaussianAbsSupport_eq_sup' T hT]
    exact Finset.le_sup' (fun x => |inner ℝ g x|) hy
  have hint := integral_mono
    (HDP.Chapter7.integrable_inner_stdGaussian y).abs
    (HDP.Chapter7.integrable_finiteGaussianAbsSupport T) hpoint
  rw [habs, ← HDP.Chapter7.gaussianComplexity] at hint
  have hlower := mul_le_mul_of_nonneg_right hhalf (norm_nonneg y)
  nlinarith

