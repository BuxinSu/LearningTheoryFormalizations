theorem finiteRadius_nonneg {n : ℕ}
    (T : Finset (EuclideanSpace ℝ (Fin n))) (hT : T.Nonempty) :
    0 ≤ HDP.Chapter7.finiteRadius T := by
  have hT' := hT
