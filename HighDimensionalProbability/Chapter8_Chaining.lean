/-- The elementary comparison `a+b ≤ √2·√(a²+b²)` used after (8.52).

**Book Equation (8.52).** -/
theorem add_le_sqrtTwo_mul_sqrt_sq_add_sq {a b : ℝ}
    (ha : 0 ≤ a) (hb : 0 ≤ b) :
    a + b ≤ Real.sqrt 2 * Real.sqrt (a ^ 2 + b ^ 2) := by
  have hs : 0 ≤ a ^ 2 + b ^ 2 := by positivity
  have hsqrt : 0 ≤ Real.sqrt (a ^ 2 + b ^ 2) := Real.sqrt_nonneg _
  have hsqrt2 : 0 ≤ Real.sqrt 2 := Real.sqrt_nonneg _
  have hsq : (a + b) ^ 2 ≤
      (Real.sqrt 2 * Real.sqrt (a ^ 2 + b ^ 2)) ^ 2 := by
    rw [mul_pow, Real.sq_sqrt (by norm_num : (0 : ℝ) ≤ 2),
      Real.sq_sqrt hs]
    nlinarith [sq_nonneg (a - b)]
  exact (sq_le_sq₀ (add_nonneg ha hb) (mul_nonneg hsqrt2 hsqrt)).1 hsq

/-! ## The source-facing Chevet bound -/

/-- A concrete universal constant for the finite form of Theorem 8.6.1.

**Book Theorem 8.6.1.** -/
def chevetConstant : ℝ :=
  talagrandComparisonConstant * Real.sqrt 30 * Real.sqrt 2

/-- Shows that the chevet constant is strictly positive.

**Lean implementation helper.** -/
theorem chevetConstant_pos : 0 < chevetConstant := by
  exact mul_pos (mul_pos talagrandComparisonConstant_pos (Real.sqrt_pos.2 (by norm_num)))
    (Real.sqrt_pos.2 (by norm_num))

/-- The rows are independent, centered subgaussian vectors with vector `ψ₂` norm
at most `K`. For nonempty finite sets `T` and `S`, the expected supremum of
the associated bilinear process is controlled by the two Gaussian widths and
opposite radii. The proof reconstructs (8.52), compares with the explicit
product-Gaussian process, and evaluates its maximum exactly. This theorem carries `[MajorizingMeasureLowerPrinciple]` because its proof
uses Theorem 8.5.6. Existence of that deep lower majorizing-measure
principle, which the source states without proof, is isolated as category B
in the book-level `Appendix.lean`; no instance is supplied by the root import
graph.

**Book Theorem 8.6.1.** -/
theorem theorem_8_6_1_subgaussian_chevet {m n : ℕ}
    [IsProbabilityMeasure μ]
    (A : Fin m → Ω → EuclideanSpace ℝ (Fin n))
    (hM : ∀ i x, Measurable (fun ω => inner ℝ (A i ω) x))
    (hsub : ∀ i, HDP.SubGaussianVector (A i) μ)
    (hmean : ∀ i x, ∫ ω, inner ℝ (A i ω) x ∂μ = 0)
    (hindep : iIndepFun A μ)
    (hbounded : ∀ i, BddAbove {r : ℝ |
      ∃ x : EuclideanSpace ℝ (Fin n), ‖x‖ = 1 ∧
        r = HDP.psi2Norm (fun ω => inner ℝ (A i ω) x) μ})
    {K : ℝ} (hK : 0 ≤ K)
    (hpsi : ∀ i, HDP.psi2NormVector (A i) μ ≤ K)
    (T : Finset (EuclideanSpace ℝ (Fin n)))
    (S : Finset (EuclideanSpace ℝ (Fin m)))
    [Nonempty ↥T] [Nonempty ↥S]
    (hT : T.Nonempty) (hS : S.Nonempty) :
    HDP.Chapter7.expectedFiniteSupremum μ (finiteChevetProcess A T S) ≤
      chevetConstant * K *
        (HDP.Chapter7.gaussianWidth T * HDP.Chapter7.finiteRadius S +
          HDP.Chapter7.gaussianWidth S * HDP.Chapter7.finiteRadius T) := by
  let rS : ℝ := HDP.Chapter7.finiteRadius S
  let rT : ℝ := HDP.Chapter7.finiteRadius T
  let U : ChevetIndex T S → EuclideanSpace ℝ (Fin n) :=
    fun p => rS • p.1.1
  let V : ChevetIndex T S → EuclideanSpace ℝ (Fin m) :=
    fun p => rT • p.2.1
  let X : HDP.RandomProcess (ChevetIndex T S) Ω :=
    finiteChevetProcess A T S
  let Y := sumCanonicalGaussianProcess U V
  have hrS : 0 ≤ rS := finiteRadius_nonneg S hS
  have hrT : 0 ≤ rT := finiteRadius_nonneg T hT
  have hAm : ∀ i x, AEMeasurable (fun ω => inner ℝ (A i ω) x) μ :=
    fun i x => (hM i x).aemeasurable
  have hAint : ∀ i x, Integrable (fun ω => inner ℝ (A i ω) x) μ := by
    intro i x
    exact ((hsub i x).memLp (hAm i x) (p := 2) (by norm_num)).integrable
      (by norm_num)
  have hXm : ∀ p, Measurable (X p) := by
    simpa [X] using finiteChevetProcess_measurable A T S hM
  have hXint : ∀ p, Integrable (X p) μ := by
    intro p
    change Integrable (rowBilinearProcess A p.1.1 p.2.1) μ
    unfold rowBilinearProcess
    apply integrable_finsetSum
    intro i hi
    exact (hAint i p.1.1).const_mul (p.2.1 i)
  have hXcenter : HDP.IsCenteredProcess X μ := by
    simpa [X] using finiteChevetProcess_centered A T S hAint hmean
  let Kc : ℝ := Real.sqrt 30 * Real.sqrt 2 * K
  have hKc : 0 ≤ Kc := by
    dsimp [Kc]
    positivity
  have hinc : ∀ s t,
      HDP.SubGaussian (fun ω => X t ω - X s ω) μ ∧
        HDP.psi2Norm (fun ω => X t ω - X s ω) μ ≤
          Kc * Real.sqrt (‖U t - U s‖ ^ 2 + ‖V t - V s‖ ^ 2) := by
    intro s t
    have hrow := equation_8_52_row_increment A hAm hsub hmean hindep
      hbounded hK hpsi t.1.1 s.1.1 t.2.1 s.2.1
    have hvt : ‖t.2.1‖ ≤ rS :=
      HDP.Chapter7.norm_le_finiteRadius S hS t.2.2
    have hws : ‖s.1.1‖ ≤ rT :=
      HDP.Chapter7.norm_le_finiteRadius T hT s.1.2
    have hfirst : ‖t.1.1 - s.1.1‖ * ‖t.2.1‖ ≤
        rS * ‖t.1.1 - s.1.1‖ := by
      have := mul_le_mul_of_nonneg_left hvt (norm_nonneg (t.1.1 - s.1.1))
      nlinarith
    have hsecond : ‖s.1.1‖ * ‖t.2.1 - s.2.1‖ ≤
        rT * ‖t.2.1 - s.2.1‖ :=
      mul_le_mul_of_nonneg_right hws (norm_nonneg (t.2.1 - s.2.1))
    have hsum :
        ‖t.1.1 - s.1.1‖ * ‖t.2.1‖ +
            ‖s.1.1‖ * ‖t.2.1 - s.2.1‖ ≤
          rS * ‖t.1.1 - s.1.1‖ +
            rT * ‖t.2.1 - s.2.1‖ :=
      add_le_add hfirst hsecond
    have hroot := add_le_sqrtTwo_mul_sqrt_sq_add_sq
      (mul_nonneg hrS (norm_nonneg (t.1.1 - s.1.1)))
      (mul_nonneg hrT (norm_nonneg (t.2.1 - s.2.1)))
    have hmetric :
        Real.sqrt
            ((rS * ‖t.1.1 - s.1.1‖) ^ 2 +
              (rT * ‖t.2.1 - s.2.1‖) ^ 2) =
          Real.sqrt (‖U t - U s‖ ^ 2 + ‖V t - V s‖ ^ 2) := by
      congr 1
      simp only [U, V, ← smul_sub, norm_smul, Real.norm_eq_abs,
        abs_of_nonneg hrS, abs_of_nonneg hrT]
    refine ⟨?_, ?_⟩
    · simpa [X, finiteChevetProcess] using hrow.1
    · have hcoef : 0 ≤ Real.sqrt 30 * K :=
        mul_nonneg (Real.sqrt_nonneg _) hK
      calc
        HDP.psi2Norm (fun ω => X t ω - X s ω) μ ≤
            Real.sqrt 30 * K *
              (‖t.1.1 - s.1.1‖ * ‖t.2.1‖ +
                ‖s.1.1‖ * ‖t.2.1 - s.2.1‖) := by
          simpa [X, finiteChevetProcess] using hrow.2
        _ ≤ Real.sqrt 30 * K *
              (rS * ‖t.1.1 - s.1.1‖ +
                rT * ‖t.2.1 - s.2.1‖) :=
          mul_le_mul_of_nonneg_left hsum hcoef
        _ ≤ Real.sqrt 30 * K *
              (Real.sqrt 2 * Real.sqrt
                ((rS * ‖t.1.1 - s.1.1‖) ^ 2 +
                  (rT * ‖t.2.1 - s.2.1‖) ^ 2)) :=
          mul_le_mul_of_nonneg_left hroot hcoef
        _ = Kc * Real.sqrt (‖U t - U s‖ ^ 2 + ‖V t - V s‖ ^ 2) := by
          rw [← hmetric]
          dsimp [Kc]
          ring
  have hcomp := talagrandComparison_sumCanonical μ X hXm hXint hXcenter
    U V hKc hinc
  have hYeq : Y = finiteChevetGaussianProcess T S rS rT := by
    funext p gh
    change inner ℝ (rS • p.1.1) gh.1 + inner ℝ (rT • p.2.1) gh.2 =
      rS * inner ℝ gh.1 p.1.1 + rT * inner ℝ gh.2 p.2.1
    rw [inner_smul_left, inner_smul_left,
      real_inner_comm p.1.1 gh.1, real_inner_comm p.2.1 gh.2]
    simp
  have hEY : HDP.Chapter7.expectedFiniteSupremum
      ((stdGaussian (EuclideanSpace ℝ (Fin n))).prod
        (stdGaussian (EuclideanSpace ℝ (Fin m)))) Y =
      rS * HDP.Chapter7.gaussianWidth T +
        rT * HDP.Chapter7.gaussianWidth S := by
    rw [hYeq]
    exact expectedFiniteSupremum_chevetGaussianProcess T S hT hS hrS hrT
  change HDP.Chapter7.expectedFiniteSupremum μ X ≤ _
  calc
    HDP.Chapter7.expectedFiniteSupremum μ X ≤
        talagrandComparisonConstant * Kc *
          HDP.Chapter7.expectedFiniteSupremum
            ((stdGaussian (EuclideanSpace ℝ (Fin n))).prod
              (stdGaussian (EuclideanSpace ℝ (Fin m)))) Y := hcomp
    _ = chevetConstant * K *
        (HDP.Chapter7.gaussianWidth T * HDP.Chapter7.finiteRadius S +
          HDP.Chapter7.gaussianWidth S * HDP.Chapter7.finiteRadius T) := by
      rw [hEY]
      simp only [chevetConstant, Kc, rS, rT]
      ring

/-- The source explicitly notes that the same conclusion holds when independent
subgaussian rows are replaced by independent subgaussian columns. A column
family in `ℝ^m` is a row family after exchanging the two ambient dimensions;
this wrapper records that symmetric public interface without duplicating the
proof.

**Book Theorem 8.6.1.** -/
theorem theorem_8_6_1_subgaussian_chevet_columns {m n : ℕ}
    [IsProbabilityMeasure μ]
    (A : Fin n → Ω → EuclideanSpace ℝ (Fin m))
    (hM : ∀ j x, Measurable (fun ω => inner ℝ (A j ω) x))
    (hsub : ∀ j, HDP.SubGaussianVector (A j) μ)
    (hmean : ∀ j x, ∫ ω, inner ℝ (A j ω) x ∂μ = 0)
    (hindep : iIndepFun A μ)
    (hbounded : ∀ j, BddAbove {r : ℝ |
      ∃ x : EuclideanSpace ℝ (Fin m), ‖x‖ = 1 ∧
        r = HDP.psi2Norm (fun ω => inner ℝ (A j ω) x) μ})
    {K : ℝ} (hK : 0 ≤ K)
    (hpsi : ∀ j, HDP.psi2NormVector (A j) μ ≤ K)
    (S : Finset (EuclideanSpace ℝ (Fin m)))
    (T : Finset (EuclideanSpace ℝ (Fin n)))
    [Nonempty ↥S] [Nonempty ↥T]
    (hS : S.Nonempty) (hT : T.Nonempty) :
    HDP.Chapter7.expectedFiniteSupremum μ (finiteChevetProcess A S T) ≤
      chevetConstant * K *
        (HDP.Chapter7.gaussianWidth S * HDP.Chapter7.finiteRadius T +
          HDP.Chapter7.gaussianWidth T * HDP.Chapter7.finiteRadius S) :=
  theorem_8_6_1_subgaussian_chevet A hM hsub hmean hindep hbounded
    hK hpsi S T hS hT

/-- The Chevet bound specializes to an expected operator-norm estimate. On finite subsets of the two Euclidean unit spheres, Chevet's inequality has
the familiar `sqrt n + sqrt m` scale. Taking successively finer finite nets
is the source's route to the full operator norm; the earlier Chapter 4 API
provides the corresponding full-sphere matrix statement directly.

**Book Remark 8.6.2.** -/
theorem remark_8_6_2_finite_unit_sphere_bound {m n : ℕ}
    [IsProbabilityMeasure μ]
    (A : Fin m → Ω → EuclideanSpace ℝ (Fin n))
    (hM : ∀ i x, Measurable (fun ω => inner ℝ (A i ω) x))
    (hsub : ∀ i, HDP.SubGaussianVector (A i) μ)
    (hmean : ∀ i x, ∫ ω, inner ℝ (A i ω) x ∂μ = 0)
    (hindep : iIndepFun A μ)
    (hbounded : ∀ i, BddAbove {r : ℝ |
      ∃ x : EuclideanSpace ℝ (Fin n), ‖x‖ = 1 ∧
        r = HDP.psi2Norm (fun ω => inner ℝ (A i ω) x) μ})
    {K : ℝ} (hK : 0 ≤ K)
    (hpsi : ∀ i, HDP.psi2NormVector (A i) μ ≤ K)
    (T : Finset (EuclideanSpace ℝ (Fin n)))
    (S : Finset (EuclideanSpace ℝ (Fin m)))
    [Nonempty ↥T] [Nonempty ↥S]
    (hT : T.Nonempty) (hS : S.Nonempty)
    (hunitT : ∀ x ∈ T, ‖x‖ ≤ 1)
    (hunitS : ∀ y ∈ S, ‖y‖ ≤ 1) :
    HDP.Chapter7.expectedFiniteSupremum μ (finiteChevetProcess A T S) ≤
      chevetConstant * K * (Real.sqrt n + Real.sqrt m) := by
  have hbase := theorem_8_6_1_subgaussian_chevet A hM hsub hmean hindep
    hbounded hK hpsi T S hT hS
  have hwT : HDP.Chapter7.gaussianWidth T ≤ Real.sqrt n :=
    euclideanUnitBall_gaussianWidth_le_sqrt_card T hT hunitT
  have hwS : HDP.Chapter7.gaussianWidth S ≤ Real.sqrt m :=
    euclideanUnitBall_gaussianWidth_le_sqrt_card S hS hunitS
  have hrT : HDP.Chapter7.finiteRadius T ≤ 1 := by
    rw [HDP.Chapter7.finiteRadius_eq_sup' T hT]
    rw [Finset.sup'_le_iff]
    exact hunitT
  have hrS : HDP.Chapter7.finiteRadius S ≤ 1 := by
    rw [HDP.Chapter7.finiteRadius_eq_sup' S hS]
    rw [Finset.sup'_le_iff]
    exact hunitS
  have hprodT : HDP.Chapter7.gaussianWidth T *
      HDP.Chapter7.finiteRadius S ≤ Real.sqrt n := by
    have hmul := mul_le_mul hwT hrS (finiteRadius_nonneg S hS)
      (Real.sqrt_nonneg n)
    simpa using hmul
  have hprodS : HDP.Chapter7.gaussianWidth S *
      HDP.Chapter7.finiteRadius T ≤ Real.sqrt m := by
    have hmul := mul_le_mul hwS hrT (finiteRadius_nonneg T hT)
      (Real.sqrt_nonneg m)
    simpa using hmul
  exact hbase.trans (mul_le_mul_of_nonneg_left
    (add_le_add hprodT hprodS)
    (mul_nonneg chevetConstant_pos.le hK))

