/-! ## Material formerly in `10_GammaTwo.lean` -/

section Source_10_GammaTwo

/-!
# Book Chapter 8, §8.5.1: admissible chains and the gamma-two functional

The book uses infinite admissible sequences.  On a finite index type one may
truncate at the first level equal to the whole type and then repeat that level;
all later distances are zero.  `FiniteAdmissibleChain` records exactly this
finite certificate.  The authoritative value is `ENNReal` so divergence is not
silently converted to a real number.  `finiteGamma2` is the real wrapper and
therefore asks for the explicit finiteness certificate required by the book's
finite reduction.
-/

open scoped BigOperators ENNReal

namespace HDP

noncomputable section

/-- A finite certificate for an admissible sequence from (8.43).

The levels are indexed from zero through `terminal`; the last level is the
whole finite index type.  Extending the sequence constantly after `terminal`
recovers the source's infinite admissible sequence. -/
structure FiniteAdmissibleChain (T : Type*) [Fintype T] [Nonempty T] where
  terminal : ℕ
  level : Fin (terminal + 1) → Finset T
  level_nonempty : ∀ k, (level k).Nonempty
  level_zero_card : (level ⟨0, Nat.zero_lt_succ terminal⟩).card = 1
  level_card_le : ∀ k, (level k).card ≤ 2 ^ (2 ^ (k : ℕ))
  level_terminal : level ⟨terminal, Nat.lt_succ_self terminal⟩ = Finset.univ

/-- Every natural number `n` is at most `2^n`.

**Lean implementation helper.** -/
private theorem nat_le_two_pow (n : ℕ) : n ≤ 2 ^ n := by
  induction n with
  | zero => simp
  | succ n ih =>
      cases n with
      | zero => norm_num
      | succ n =>
          rw [pow_succ]
          omega

/-- Every finite nonempty type admits a source-admissible chain. This also
shows that the infimum in `gamma2` is not taken over an empty collection.

**Lean implementation helper.** -/
noncomputable def canonicalFiniteAdmissibleChain
    (T : Type*) [Fintype T] [Nonempty T] : FiniteAdmissibleChain T := by
  classical
  let t0 : T := Classical.choice (inferInstance : Nonempty T)
  let n := Fintype.card T
  let L : Fin (n + 1) → Finset T := fun k =>
    if (k : ℕ) = n then Finset.univ else {t0}
  have hn0 : n ≠ 0 := Fintype.card_ne_zero
  have hnle : n ≤ 2 ^ (2 ^ n) :=
    (nat_le_two_pow n).trans
      (Nat.pow_le_pow_right (by norm_num : 0 < 2) (nat_le_two_pow n))
  refine
    { terminal := n
      level := L
      level_nonempty := ?_
      level_zero_card := ?_
      level_card_le := ?_
      level_terminal := ?_ }
  · intro k
    by_cases hk : (k : ℕ) = n
    · simp [L, hk]
    · simp [L, hk]
  · change (if (0 : ℕ) = n then (Finset.univ : Finset T) else {t0}).card = 1
    rw [if_neg (Ne.symm hn0)]
    simp
  · intro k
    by_cases hk : (k : ℕ) = n
    · have hlevel : L k = (Finset.univ : Finset T) := by simp [L, hk]
      rw [hlevel, Finset.card_univ, hk]
      exact hnle
    · have hlevel : L k = ({t0} : Finset T) := by simp [L, hk]
      rw [hlevel, Finset.card_singleton]
      exact Nat.one_le_two_pow
  · simp [L]

/-- Distance from `t` to a nonempty finite set, with values in `ENNReal`.
This is the finite version of the footnote following (8.43).

**Book Equation (8.43).** -/
def finiteSetEDistance {T : Type*} (d : T → T → ℝ≥0∞)
    (S : Finset T) (hS : S.Nonempty) (t : T) : ℝ≥0∞ :=
  S.inf' hS (d t)

/-- The extended distance from `t` to a nonempty finite set is no greater than the distance from `t` to any chosen member.

**Lean implementation helper.** -/
theorem finiteSetEDistance_le {T : Type*} (d : T → T → ℝ≥0∞)
    {S : Finset T} (hS : S.Nonempty) {t s : T} (hs : s ∈ S) :
    finiteSetEDistance d S hS t ≤ d t s := by
  exact Finset.inf'_le (d t) hs

/-- A point belonging to a nonempty finite set has zero extended distance to that set.

**Lean implementation helper.** -/
@[simp] theorem finiteSetEDistance_self {T : Type*}
    (d : T → T → ℝ≥0∞) (hdiag : ∀ t, d t t = 0)
    {S : Finset T} (hS : S.Nonempty) {t : T} (ht : t ∈ S) :
    finiteSetEDistance d S hS t = 0 := by
  apply le_antisymm
  · exact (finiteSetEDistance_le d hS (t := t) (s := t) ht).trans_eq (hdiag t)
  · exact bot_le

/-- The `k`-th `γ₂` weight is
`ENNReal.ofReal (sqrt (2^k))`, avoiding a potentially invalid direct
real-to-extended-real cast.

**Book Equation (8.45).** -/
def gammaTwoWeight (k : ℕ) : ℝ≥0∞ :=
  ENNReal.ofReal (Real.sqrt ((2 : ℝ) ^ k))

/-- The level-zero `γ₂` weight is `1`.

**Lean implementation helper.** -/
@[simp] theorem gammaTwoWeight_zero : gammaTwoWeight 0 = 1 := by
  simp [gammaTwoWeight]

/-- Cost of one point for a fixed admissible chain.

**Lean implementation helper.** -/
def chainPointCost {T : Type*} [Fintype T] [Nonempty T]
    (d : T → T → ℝ≥0∞) (A : FiniteAdmissibleChain T) (t : T) : ℝ≥0∞ :=
  ∑ k : Fin (A.terminal + 1),
    gammaTwoWeight (k : ℕ) * finiteSetEDistance d (A.level k) (A.level_nonempty k) t

/-- The supremal cost of an admissible chain. Finiteness of `T` makes this
an actual maximum.

**Lean implementation helper.** -/
def chainCost {T : Type*} [Fintype T] [Nonempty T]
    (d : T → T → ℝ≥0∞) (A : FiniteAdmissibleChain T) : ℝ≥0∞ :=
  Finset.univ.sup' Finset.univ_nonempty (chainPointCost d A)

/-- `gamma2` is the infimum, over admissible chains, of the worst weighted multiscale approximation cost. For a finite metric or pseudometric index type this is the infimum of the
supremal weighted approximation cost over all admissible finite chains.
Every chain extends to the source's infinite sequence by repeating its last,
universal level.

**Book Definition 8.5.1.** -/
def gamma2 {T : Type*} [Fintype T] [Nonempty T]
    (d : T → T → ℝ≥0∞) : ℝ≥0∞ :=
  ⨅ A : FiniteAdmissibleChain T, chainCost d A

/-- Shows that the `γ₂` functional is nonnegative.

**Lean implementation helper.** -/
theorem gamma2_nonneg {T : Type*} [Fintype T] [Nonempty T]
    (d : T → T → ℝ≥0∞) : 0 ≤ gamma2 d := bot_le

/-- Choose a chain with cost within factor two of `gamma2`. Every explicit admissible sequence gives an upper bound on gamma-two.

**Book Equation (8.46).** -/
theorem gamma2_le_chainCost {T : Type*} [Fintype T] [Nonempty T]
    (d : T → T → ℝ≥0∞) (A : FiniteAdmissibleChain T) :
    gamma2 d ≤ chainCost d A := by
  exact iInf_le _ A

/-- A pointwise enlargement of the distance can only enlarge the cost of a
fixed chain. This is the monotonicity ingredient used by comparison results.

**Lean implementation helper.** -/
theorem chainPointCost_mono {T : Type*} [Fintype T] [Nonempty T]
    {d e : T → T → ℝ≥0∞} (hde : ∀ s t, d s t ≤ e s t)
    (A : FiniteAdmissibleChain T) (t : T) :
    chainPointCost d A t ≤ chainPointCost e A t := by
  apply Finset.sum_le_sum
  intro k _
  gcongr
  apply Finset.le_inf' (A.level_nonempty k)
  intro s hs
  exact (Finset.inf'_le (d t) hs).trans (hde t s)

/-- Shows that the cost of an admissible chain is monotone.

**Lean implementation helper.** -/
theorem chainCost_mono {T : Type*} [Fintype T] [Nonempty T]
    {d e : T → T → ℝ≥0∞} (hde : ∀ s t, d s t ≤ e s t)
    (A : FiniteAdmissibleChain T) : chainCost d A ≤ chainCost e A := by
  unfold chainCost
  apply Finset.sup'_le
  intro t ht
  exact (chainPointCost_mono hde A t).trans
    (Finset.le_sup' (chainPointCost e A) ht)

/-- Shows that the `γ₂` functional is monotone.

**Lean implementation helper.** -/
theorem gamma2_mono {T : Type*} [Fintype T] [Nonempty T]
    {d e : T → T → ℝ≥0∞} (hde : ∀ s t, d s t ≤ e s t) :
    gamma2 d ≤ gamma2 e := by
  unfold gamma2
  exact iInf_mono fun A ↦ chainCost_mono hde A

/-- Real-valued gamma-two. It is intentionally unavailable without a proof
that the authoritative extended value is finite.

**Lean implementation helper.** -/
def finiteGamma2 {T : Type*} [Fintype T] [Nonempty T]
    (d : T → T → ℝ≥0∞) (_hfinite : gamma2 d ≠ ⊤) : ℝ :=
  (gamma2 d).toReal

/-- Shows that the finite-set `γ₂` functional is nonnegative.

**Lean implementation helper.** -/
theorem finiteGamma2_nonneg {T : Type*} [Fintype T] [Nonempty T]
    (d : T → T → ℝ≥0∞) (hfinite : gamma2 d ≠ ⊤) :
    0 ≤ finiteGamma2 d hfinite := ENNReal.toReal_nonneg

end

end HDP

end Source_10_GammaTwo

/-! ## Material formerly in `11_GenericChaining.lean` -/

section Source_11_GenericChaining

/-!
# Book Chapter 8, §8.5.2: the generic-chaining upper bound

This file proves the finite form of the generic-chaining theorem.  The proof
does not take a scale estimate as an extra hypothesis: nearest-point
projections are constructed from an admissible chain, and the scale tails are
deduced from `HDP.HasSubGaussianIncrementsWith` and the Chapter 2 subgaussian
maximal machinery.

Distances used by the random process are real-valued.  The same distance is
embedded with `ENNReal.ofReal` when passed to the authoritative `HDP.gamma2`.
The explicit nonnegativity, diagonal, symmetry, and triangle hypotheses are
the safe kernel form of the source's metric-space assumption.
-/

open MeasureTheory ProbabilityTheory Set Filter
open scoped BigOperators ENNReal NNReal Topology

namespace HDP.Chapter8

noncomputable section

variable {T Ω : Type*} [Fintype T] [Nonempty T]
  {mΩ : MeasurableSpace Ω} {μ : Measure Ω}

/-! ## Real costs and nearest projections -/

/-- Real distance from `t` to a nonempty finite set.

**Lean implementation helper.** -/
def finiteSetDistance (d : T → T → ℝ) (S : Finset T)
    (hS : S.Nonempty) (t : T) : ℝ :=
  S.inf' hS (d t)

omit [Fintype T] [Nonempty T] in
/-- Shows that the real distance from a point to a finite set is nonnegative.

**Lean implementation helper.** -/
theorem finiteSetDistance_nonneg (d : T → T → ℝ)
    (hd : ∀ s t, 0 ≤ d s t) {S : Finset T} (hS : S.Nonempty) (t : T) :
    0 ≤ finiteSetDistance d S hS t := by
  apply Finset.le_inf' hS
  intro s hs
  exact hd t s

/-- A chosen best approximation to `t` in a finite nonempty set.

**Lean implementation helper.** -/
def nearestFinitePoint (d : T → T → ℝ) (S : Finset T)
    (hS : S.Nonempty) (t : T) : T :=
  Classical.choose (Finset.exists_mem_eq_inf' hS (d t))

omit [Fintype T] [Nonempty T] in
/-- A selected nearest point belongs to the nonempty finite set from which it is chosen.

**Lean implementation helper.** -/
theorem nearestFinitePoint_mem (d : T → T → ℝ) (S : Finset T)
    (hS : S.Nonempty) (t : T) : nearestFinitePoint d S hS t ∈ S :=
  (Classical.choose_spec (Finset.exists_mem_eq_inf' hS (d t))).1

omit [Fintype T] [Nonempty T] in
/-- The selected nearest point realizes the minimum real distance from `t` to the finite set.

**Lean implementation helper.** -/
theorem nearestFinitePoint_distance (d : T → T → ℝ) (S : Finset T)
    (hS : S.Nonempty) (t : T) :
    d t (nearestFinitePoint d S hS t) = finiteSetDistance d S hS t :=
  (Classical.choose_spec (Finset.exists_mem_eq_inf' hS (d t))).2.symm

/-- Generic-chain telescoping expansion. The nearest-point projection associated with an admissible chain. At the
terminal level it is definitionally forced to be the original point, which
makes the telescoping endpoint exact even for a pseudometric.

**Book Equation (8.47).** -/
def admissibleProjection (d : T → T → ℝ)
    (A : HDP.FiniteAdmissibleChain T) (k : Fin (A.terminal + 1)) (t : T) : T :=
  if (k : ℕ) = A.terminal then t
  else nearestFinitePoint d (A.level k) (A.level_nonempty k) t

/-- The nearest-point projection onto an admissible-chain level belongs to that level.

**Lean implementation helper.** -/
theorem admissibleProjection_mem (d : T → T → ℝ)
    (A : HDP.FiniteAdmissibleChain T) (k : Fin (A.terminal + 1)) (t : T) :
    admissibleProjection d A k t ∈ A.level k := by
  classical
  by_cases hk : (k : ℕ) = A.terminal
  · have hk' : k = ⟨A.terminal, Nat.lt_succ_self _⟩ := Fin.eq_of_val_eq hk
    subst k
    simp [admissibleProjection, A.level_terminal]
  · simp [admissibleProjection, hk, nearestFinitePoint_mem]

/-- Distance to an admissible projection equals the minimum distance to the corresponding chain level.

**Lean implementation helper.** -/
theorem admissibleProjection_distance (d : T → T → ℝ)
    (hd0 : ∀ t, d t t = 0) (hd : ∀ s t, 0 ≤ d s t)
    (A : HDP.FiniteAdmissibleChain T) (k : Fin (A.terminal + 1)) (t : T) :
    d t (admissibleProjection d A k t) =
      finiteSetDistance d (A.level k) (A.level_nonempty k) t := by
  classical
  by_cases hk : (k : ℕ) = A.terminal
  · have hk' : k = ⟨A.terminal, Nat.lt_succ_self _⟩ := Fin.eq_of_val_eq hk
    subst k
    have hle : finiteSetDistance d
        (A.level ⟨A.terminal, Nat.lt_succ_self _⟩)
        (A.level_nonempty ⟨A.terminal, Nat.lt_succ_self _⟩) t ≤ 0 := by
      unfold finiteSetDistance
      calc
        (A.level ⟨A.terminal, Nat.lt_succ_self _⟩).inf'
            (A.level_nonempty ⟨A.terminal, Nat.lt_succ_self _⟩) (d t) ≤
            d t t := Finset.inf'_le _ (by simp [A.level_terminal])
        _ = 0 := hd0 t
    have hge := finiteSetDistance_nonneg d hd
      (A.level_nonempty ⟨A.terminal, Nat.lt_succ_self _⟩) t
    rw [show admissibleProjection d A
        ⟨A.terminal, Nat.lt_succ_self _⟩ t = t by
          simp [admissibleProjection], hd0]
    exact le_antisymm hge hle
  · simp [admissibleProjection, hk, nearestFinitePoint_distance]

/-- The unique point in the zeroth level.

**Lean implementation helper.** -/
def admissibleAnchor (A : HDP.FiniteAdmissibleChain T) : T :=
  Classical.choose (A.level_nonempty ⟨0, Nat.zero_lt_succ _⟩)

/-- The chosen admissible-chain anchor belongs to the level-zero singleton.

**Lean implementation helper.** -/
theorem admissibleAnchor_mem (A : HDP.FiniteAdmissibleChain T) :
    admissibleAnchor A ∈ A.level ⟨0, Nat.zero_lt_succ _⟩ :=
  Classical.choose_spec (A.level_nonempty ⟨0, Nat.zero_lt_succ _⟩)

/-- Projection onto level zero is the admissible-chain anchor.

**Lean implementation helper.** -/
theorem admissibleProjection_zero (d : T → T → ℝ)
    (A : HDP.FiniteAdmissibleChain T) (t : T) :
    admissibleProjection d A ⟨0, Nat.zero_lt_succ _⟩ t = admissibleAnchor A := by
  exact Finset.card_le_one.mp A.level_zero_card.le
    _ (admissibleProjection_mem d A _ t) _ (admissibleAnchor_mem A)

/-- Projection onto the terminal level fixes every index.

**Lean implementation helper.** -/
@[simp] theorem admissibleProjection_terminal (d : T → T → ℝ)
    (A : HDP.FiniteAdmissibleChain T) (t : T) :
    admissibleProjection d A ⟨A.terminal, Nat.lt_succ_self _⟩ t = t := by
  simp [admissibleProjection]

/-- An admissible nearest-point chain as the telescoping interface from §8.1.

**Book Section 8.1.** -/
def admissibleDudleyChain (d : T → T → ℝ)
    (A : HDP.FiniteAdmissibleChain T) : FiniteDudleyChain T A.terminal where
  anchor := admissibleAnchor A
  projection k t :=
    if hk : k < A.terminal + 1 then admissibleProjection d A ⟨k, hk⟩ t else t
  coarse t := by
    exact admissibleProjection_zero d A t
  exact t := by
    rw [dif_pos (Nat.lt_succ_self _)]
    exact admissibleProjection_terminal d A t

/-- Real form of the weight in the gamma-two functional.

**Lean implementation helper.** -/
def realGammaTwoWeight (k : ℕ) : ℝ := Real.sqrt ((2 : ℝ) ^ k)

/-- Shows that the real `γ₂` scale weight is nonnegative.

**Lean implementation helper.** -/
theorem realGammaTwoWeight_nonneg (k : ℕ) : 0 ≤ realGammaTwoWeight k :=
  Real.sqrt_nonneg _

/-- Shows that the real `γ₂` scale weight is strictly positive.

**Lean implementation helper.** -/
theorem realGammaTwoWeight_pos (k : ℕ) : 0 < realGammaTwoWeight k := by
  exact Real.sqrt_pos.mpr (by positivity)

/-- The real level-zero `γ₂` weight is `1`.

**Lean implementation helper.** -/
@[simp] theorem realGammaTwoWeight_zero : realGammaTwoWeight 0 = 1 := by
  simp [realGammaTwoWeight]

/-- Each successor real `γ₂` weight is at most twice the preceding weight.

**Lean implementation helper.** -/
theorem realGammaTwoWeight_succ_le_two (k : ℕ) :
    realGammaTwoWeight (k + 1) ≤ 2 * realGammaTwoWeight k := by
  have hsq : realGammaTwoWeight (k + 1) ^ 2 =
      2 * realGammaTwoWeight k ^ 2 := by
    simp only [realGammaTwoWeight]
    rw [Real.sq_sqrt (by positivity), Real.sq_sqrt (by positivity), pow_succ]
    ring
  nlinarith [realGammaTwoWeight_nonneg k,
    realGammaTwoWeight_nonneg (k + 1)]

/-- Real cost of one point for a fixed admissible chain.

**Lean implementation helper.** -/
def realChainPointCost (d : T → T → ℝ)
    (A : HDP.FiniteAdmissibleChain T) (t : T) : ℝ :=
  ∑ k : Fin (A.terminal + 1),
    realGammaTwoWeight (k : ℕ) *
      finiteSetDistance d (A.level k) (A.level_nonempty k) t

/-- Dudley chain cost has supremum inside the scale sum. Real maximum cost of a fixed admissible chain.

**Book Equation (8.44).** -/
def realChainCost (d : T → T → ℝ)
    (A : HDP.FiniteAdmissibleChain T) : ℝ :=
  Finset.univ.sup' Finset.univ_nonempty (realChainPointCost d A)

/-- Shows that the weighted chain cost at one point is nonnegative.

**Lean implementation helper.** -/
theorem realChainPointCost_nonneg (d : T → T → ℝ)
    (hd : ∀ s t, 0 ≤ d s t) (A : HDP.FiniteAdmissibleChain T) (t : T) :
    0 ≤ realChainPointCost d A t := by
  exact Finset.sum_nonneg fun k _ =>
    mul_nonneg (realGammaTwoWeight_nonneg _) (finiteSetDistance_nonneg d hd _ _)

/-- Bounds the weighted chain cost at one point by the worst real chain cost.

**Lean implementation helper.** -/
theorem realChainPointCost_le_realChainCost (d : T → T → ℝ)
    (A : HDP.FiniteAdmissibleChain T) (t : T) :
    realChainPointCost d A t ≤ realChainCost d A :=
  Finset.le_sup' _ (Finset.mem_univ t)

/-- Shows that the worst real chain cost is nonnegative.

**Lean implementation helper.** -/
theorem realChainCost_nonneg (d : T → T → ℝ)
    (hd : ∀ s t, 0 ≤ d s t) (A : HDP.FiniteAdmissibleChain T) :
    0 ≤ realChainCost d A := by
  let t : T := Classical.choice inferInstance
  exact (realChainPointCost_nonneg d hd A t).trans
    (realChainPointCost_le_realChainCost d A t)

omit [Fintype T] [Nonempty T] in
/-- Converting a nonnegative real distance to an extended distance commutes with distance to a nonempty finite set.

**Lean implementation helper.** -/
theorem finiteSetEDistance_ofReal (d : T → T → ℝ)
    (_hd : ∀ s t, 0 ≤ d s t) {S : Finset T} (hS : S.Nonempty) (t : T) :
    HDP.finiteSetEDistance (fun x y => ENNReal.ofReal (d x y)) S hS t =
      ENNReal.ofReal (finiteSetDistance d S hS t) := by
  obtain ⟨s, hs, hmin⟩ := Finset.exists_mem_eq_inf' hS (d t)
  apply le_antisymm
  · calc
      HDP.finiteSetEDistance (fun x y => ENNReal.ofReal (d x y)) S hS t ≤
          ENNReal.ofReal (d t s) := HDP.finiteSetEDistance_le _ hS hs
      _ = ENNReal.ofReal (finiteSetDistance d S hS t) := by
        rw [finiteSetDistance, hmin]
  · apply Finset.le_inf' hS
    intro s hs
    exact ENNReal.ofReal_le_ofReal (Finset.inf'_le (d t) hs)

/-- For an extended distance obtained from a nonnegative real distance, pointwise chain cost is the extended-real coercion of the real pointwise cost.

**Lean implementation helper.** -/
theorem chainPointCost_ofReal (d : T → T → ℝ)
    (hd : ∀ s t, 0 ≤ d s t) (A : HDP.FiniteAdmissibleChain T) (t : T) :
    HDP.chainPointCost (fun x y => ENNReal.ofReal (d x y)) A t =
      ENNReal.ofReal (realChainPointCost d A t) := by
  rw [realChainPointCost, HDP.chainPointCost,
    ENNReal.ofReal_sum_of_nonneg]
  · apply Finset.sum_congr rfl
    intro k hk
    rw [finiteSetEDistance_ofReal d hd]
    rw [ENNReal.ofReal_mul (realGammaTwoWeight_nonneg _)]
    rfl
  · intro k hk
    exact mul_nonneg (realGammaTwoWeight_nonneg _)
      (finiteSetDistance_nonneg d hd _ _)

/-- For an extended distance obtained from a nonnegative real distance, total chain cost is the extended-real coercion of the real chain cost.

**Lean implementation helper.** -/
theorem chainCost_ofReal (d : T → T → ℝ)
    (hd : ∀ s t, 0 ≤ d s t) (A : HDP.FiniteAdmissibleChain T) :
    HDP.chainCost (fun x y => ENNReal.ofReal (d x y)) A =
      ENNReal.ofReal (realChainCost d A) := by
  obtain ⟨t, ht, hmax⟩ := Finset.exists_mem_eq_sup'
    (Finset.univ_nonempty : (Finset.univ : Finset T).Nonempty)
    (realChainPointCost d A)
  apply le_antisymm
  · unfold HDP.chainCost
    apply Finset.sup'_le
    intro s hs
    rw [chainPointCost_ofReal d hd]
    exact ENNReal.ofReal_le_ofReal
      ((Finset.le_sup' (realChainPointCost d A) hs))
  · calc
      ENNReal.ofReal (realChainCost d A) =
          ENNReal.ofReal (realChainPointCost d A t) := by
            rw [realChainCost, hmax]
      _ = HDP.chainPointCost (fun x y => ENNReal.ofReal (d x y)) A t :=
        (chainPointCost_ofReal d hd A t).symm
      _ ≤ HDP.chainCost (fun x y => ENNReal.ofReal (d x y)) A :=
        Finset.le_sup' _ ht

/-- A chain cost induced by a finite nonnegative real distance is finite as an extended real number.

**Lean implementation helper.** -/
theorem chainCost_ofReal_ne_top (d : T → T → ℝ)
    (hd : ∀ s t, 0 ≤ d s t) (A : HDP.FiniteAdmissibleChain T) :
    HDP.chainCost (fun x y => ENNReal.ofReal (d x y)) A ≠ ⊤ := by
  rw [chainCost_ofReal d hd]
  exact ENNReal.ofReal_ne_top

/-- Taking `toReal` of a chain cost induced from a real distance recovers the real chain cost.

**Lean implementation helper.** -/
theorem chainCost_toReal_ofReal (d : T → T → ℝ)
    (hd : ∀ s t, 0 ≤ d s t) (A : HDP.FiniteAdmissibleChain T) :
    (HDP.chainCost (fun x y => ENNReal.ofReal (d x y)) A).toReal =
      realChainCost d A := by
  rw [chainCost_ofReal d hd, ENNReal.toReal_ofReal (realChainCost_nonneg d hd A)]

/-! ## Edges and the scale maximal inequalities -/

/-- Distinct projection edges at scale `k → k+1`. Repeated points of `T`
which give the same edge are deliberately deduplicated before the union bound.

**Lean implementation helper.** -/
def admissibleEdges (d : T → T → ℝ) (A : HDP.FiniteAdmissibleChain T)
    (k : ℕ) : Finset (T × T) := by
  classical
  exact if hk : k < A.terminal then
      Finset.univ.image fun t =>
        (admissibleProjection d A ⟨k + 1, by omega⟩ t,
          admissibleProjection d A ⟨k, by omega⟩ t)
    else ∅

/-- Characterizes membership in the set of adjacent projection edges.

**Lean implementation helper.** -/
theorem mem_admissibleEdges (d : T → T → ℝ)
    (A : HDP.FiniteAdmissibleChain T) {k : ℕ} (hk : k < A.terminal)
    {p : T × T} :
    p ∈ admissibleEdges d A k ↔ ∃ t : T,
      (admissibleProjection d A ⟨k + 1, by omega⟩ t,
        admissibleProjection d A ⟨k, by omega⟩ t) = p := by
  classical
  simp [admissibleEdges, hk]

/-- Every edge at scale `k` joins a point of level `k+1` to a point of level `k`.

**Lean implementation helper.** -/
theorem admissibleEdges_subset_levels (d : T → T → ℝ)
    (A : HDP.FiniteAdmissibleChain T) {k : ℕ} (hk : k < A.terminal) :
    admissibleEdges d A k ⊆
      (A.level ⟨k + 1, by omega⟩).product (A.level ⟨k, by omega⟩) := by
  classical
  intro p hp
  obtain ⟨t, rfl⟩ := (mem_admissibleEdges d A hk).mp hp
  exact Finset.mem_product.mpr
    ⟨admissibleProjection_mem d A _ t, admissibleProjection_mem d A _ t⟩

/-- Every natural number `n` is at most `2^n`.

**Lean implementation helper.** -/
private theorem nat_le_two_pow_self (n : ℕ) : n ≤ 2 ^ n := by
  induction n with
  | zero => simp
  | succ n ih =>
      cases n with
      | zero => norm_num
      | succ n => rw [pow_succ]; omega

/-- The number of distinct edges at scale `k` is controlled solely by the
admissibility cardinalities, not by the cardinality of the ambient class.

**Lean implementation helper.** -/
theorem card_admissibleEdges_le (d : T → T → ℝ)
    (A : HDP.FiniteAdmissibleChain T) {k : ℕ} (hk : k < A.terminal) :
    (admissibleEdges d A k).card ≤ 2 ^ (2 ^ (k + 2)) := by
  calc
    (admissibleEdges d A k).card ≤
        (A.level ⟨k + 1, by omega⟩).card *
          (A.level ⟨k, by omega⟩).card := by
      rw [← Finset.card_product]
      exact Finset.card_le_card (admissibleEdges_subset_levels d A hk)
    _ ≤ 2 ^ (2 ^ (k + 1)) * 2 ^ (2 ^ k) :=
      Nat.mul_le_mul (A.level_card_le ⟨k + 1, by omega⟩)
        (A.level_card_le ⟨k, by omega⟩)
    _ = 2 ^ (2 ^ (k + 1) + 2 ^ k) := by rw [← pow_add]
    _ ≤ 2 ^ (2 ^ (k + 2)) := by
      apply Nat.pow_le_pow_right (by norm_num)
      rw [show 2 ^ (k + 1) = 2 * 2 ^ k by rw [pow_succ]; ring,
        show 2 ^ (k + 2) = 4 * 2 ^ k by
          rw [show k + 2 = k + 1 + 1 by omega, pow_succ, pow_succ]
          ring]
      omega

/-- Increment carried by an edge.

**Lean implementation helper.** -/
def edgeIncrement (X : HDP.RandomProcess T Ω) (p : T × T) : Ω → ℝ :=
  fun ω => X p.1 ω - X p.2 ω

omit [Fintype T] [Nonempty T] in
/-- Shows that the process increment along a chaining edge is measurable.

**Lean implementation helper.** -/
theorem measurable_edgeIncrement (X : HDP.RandomProcess T Ω)
    (hXm : ∀ t, Measurable (X t)) (p : T × T) :
    Measurable (edgeIncrement X p) :=
  (hXm p.1).sub (hXm p.2)

omit [Fintype T] [Nonempty T] in
/-- Single-edge subgaussian tail at scale `2^{k/2}`. Chapter 2's subgaussian tail, specialized to one projection edge.

**Book Equation (8.49).** -/
theorem edgeIncrement_tail [IsProbabilityMeasure μ]
    (X : HDP.RandomProcess T Ω) (hXm : ∀ t, Measurable (X t))
    (d : T → T → ℝ) (hd : ∀ s t, 0 ≤ d s t)
    {K u : ℝ} (hK : 0 < K) (hu : 0 ≤ u)
    (hinc : HDP.HasSubGaussianIncrementsWith X μ d K)
    (p : T × T) :
    μ {ω | 8 * K * u * d p.1 p.2 < |edgeIncrement X p ω|} ≤
      ENNReal.ofReal (2 * Real.exp (-(8 * u) ^ 2)) := by
  by_cases hp0 : d p.1 p.2 = 0
  · have hsub := (hinc.2 p.2 p.1).1
    have hpsi : HDP.psi2Norm (edgeIncrement X p) μ = 0 := by
      apply le_antisymm
      · exact (hinc.2 p.2 p.1).2.trans_eq (by simp [hp0])
      · exact HDP.psi2Norm_nonneg _ _
    have hae : edgeIncrement X p =ᵐ[μ] 0 :=
      (HDP.psi2Norm_eq_zero_iff
        (measurable_edgeIncrement X hXm p).aemeasurable hsub).mp hpsi
    have hz : μ {ω | 8 * K * u * d p.1 p.2 < |edgeIncrement X p ω|} = 0 := by
      apply measure_mono_null (t := {ω | edgeIncrement X p ω ≠ 0})
      · intro ω hω
        simp only [mem_setOf_eq, hp0, mul_zero, abs_pos] at hω
        exact hω
      · rw [measure_eq_zero_iff_ae_notMem]
        filter_upwards [hae] with ω hω
        simp [hω]
    rw [hz]
    exact bot_le
  · have hdp : 0 < d p.1 p.2 := lt_of_le_of_ne (hd _ _) (Ne.symm hp0)
    have hKd : 0 < K * d p.1 p.2 := mul_pos hK hdp
    have hmgf := HDP.psi2MGF_le_two_of_ge
      (measurable_edgeIncrement X hXm p).aemeasurable
      (hinc.2 p.2 p.1).1 (hinc.2 p.2 p.1).2 hKd
    have htail := HDP.subgaussian_iii_to_i
      (measurable_edgeIncrement X hXm p).aemeasurable hKd hmgf
      (show 0 ≤ 8 * K * u * d p.1 p.2 by positivity)
    refine (measure_mono (show
      {ω | 8 * K * u * d p.1 p.2 < |edgeIncrement X p ω|} ⊆
        {ω | 8 * K * u * d p.1 p.2 ≤ |edgeIncrement X p ω|} by
          intro ω hω
          change 8 * K * u * d p.1 p.2 < |edgeIncrement X p ω| at hω
          exact hω.le)).trans ?_
    convert htail using 1
    · congr 3
    · field_simp [hK.ne', hp0]

/-- The square of the chaining weight is the corresponding dyadic scale.

**Lean implementation helper.** -/
theorem realGammaTwoWeight_sq (k : ℕ) :
    realGammaTwoWeight k ^ 2 = (2 : ℝ) ^ k := by
  exact Real.sq_sqrt (by positivity)

/-- Every finite partial sum of `∑ 2^(-(k+1))` is at most `1`.

**Lean implementation helper.** -/
private theorem geometric_half_sum_le_one (n : ℕ) :
    (∑ k ∈ Finset.range n, (1 / 2 : ℝ) ^ (k + 1)) ≤ 1 := by
  have heq : ∀ n : ℕ,
      (∑ k ∈ Finset.range n, (1 / 2 : ℝ) ^ (k + 1)) =
        1 - (1 / 2 : ℝ) ^ n := by
    intro m
    induction m with
    | zero => simp
    | succ m ih =>
        rw [Finset.sum_range_succ, ih]
        ring
  rw [heq]
  have hpow : 0 ≤ (1 / 2 : ℝ) ^ n := by positivity
  linarith

/-- The admissible edge-count factor times the scale-`k` subgaussian tail is bounded by `2 exp(-u²)·2^(-(k+1))`.

**Lean implementation helper.** -/
private theorem scale_count_times_tail_le (k : ℕ) {u : ℝ} (hu : 1 ≤ u) :
    ((2 ^ (2 ^ (k + 2)) : ℕ) : ℝ) *
        (2 * Real.exp (-(8 * (u * realGammaTwoWeight (k + 1))) ^ 2)) ≤
      2 * Real.exp (-u ^ 2) * (1 / 2 : ℝ) ^ (k + 1) := by
  have hu0 : 0 ≤ u := zero_le_one.trans hu
  have hu2 : 1 ≤ u ^ 2 := by nlinarith
  have hkpow : (k + 1 : ℝ) ≤ ((2 : ℝ) ^ (k + 1)) := by
    exact_mod_cast nat_le_two_pow_self (k + 1)
  have hlog2pos : 0 < Real.log 2 := Real.log_pos (by norm_num)
  have hlog2le : Real.log 2 ≤ 1 := by
    rw [← Real.log_exp 1]
    exact Real.strictMonoOn_log.monotoneOn
      (by norm_num) (Real.exp_pos 1) (by nlinarith [Real.exp_one_gt_d9])
  have hpowcast : ((2 ^ (2 ^ (k + 2)) : ℕ) : ℝ) =
      (2 : ℝ) ^ (2 ^ (k + 2)) := by norm_num
  have htwoexp : (2 : ℝ) ≤ Real.exp 1 := by
    nlinarith [Real.exp_one_gt_d9]
  have hcount : ((2 ^ (2 ^ (k + 2)) : ℕ) : ℝ) ≤
      Real.exp ((2 ^ (k + 2) : ℕ) : ℝ) := by
    rw [hpowcast]
    calc
      (2 : ℝ) ^ (2 ^ (k + 2)) ≤
          (Real.exp 1) ^ (2 ^ (k + 2)) :=
        pow_le_pow_left₀ (by norm_num) htwoexp _
      _ = Real.exp (((2 ^ (k + 2) : ℕ) : ℝ) * 1) :=
        (Real.exp_nat_mul 1 (2 ^ (k + 2))).symm
      _ = Real.exp ((2 ^ (k + 2) : ℕ) : ℝ) := by ring_nf
  have hscale : ((2 ^ (k + 2) : ℕ) : ℝ) -
      (8 * (u * realGammaTwoWeight (k + 1))) ^ 2 ≤
        -u ^ 2 - ((k + 1 : ℝ) * Real.log 2) := by
    rw [show (8 * (u * realGammaTwoWeight (k + 1))) ^ 2 =
      64 * u ^ 2 * realGammaTwoWeight (k + 1) ^ 2 by ring,
      realGammaTwoWeight_sq]
    push_cast
    have hkpow0 : 0 ≤ (2 : ℝ) ^ (k + 1) := by positivity
    have hlogterm : (k + 1 : ℝ) * Real.log 2 ≤ (2 : ℝ) ^ (k + 1) := by
      calc
        (k + 1 : ℝ) * Real.log 2 ≤ (k + 1 : ℝ) * 1 := by
          gcongr
        _ ≤ (2 : ℝ) ^ (k + 1) := by simpa using hkpow
    have hpowstep : (2 : ℝ) ^ (k + 2) = 2 * (2 : ℝ) ^ (k + 1) := by
      rw [show k + 2 = (k + 1) + 1 by omega, pow_succ]
      ring
    rw [hpowstep]
    nlinarith [mul_nonneg (zero_le_one.trans hu2) hkpow0]
  calc
    ((2 ^ (2 ^ (k + 2)) : ℕ) : ℝ) *
          (2 * Real.exp (-(8 * (u * realGammaTwoWeight (k + 1))) ^ 2)) ≤
        Real.exp ((2 ^ (k + 2) : ℕ) : ℝ) *
          (2 * Real.exp (-(8 * (u * realGammaTwoWeight (k + 1))) ^ 2)) :=
      mul_le_mul_of_nonneg_right hcount (by positivity)
    _ = 2 * Real.exp (((2 ^ (k + 2) : ℕ) : ℝ) -
        (8 * (u * realGammaTwoWeight (k + 1))) ^ 2) := by
      rw [show Real.exp ((2 ^ (k + 2) : ℕ) : ℝ) *
          (2 * Real.exp (-(8 * (u * realGammaTwoWeight (k + 1))) ^ 2)) =
          2 * (Real.exp ((2 ^ (k + 2) : ℕ) : ℝ) *
            Real.exp (-(8 * (u * realGammaTwoWeight (k + 1))) ^ 2)) by ring,
        ← Real.exp_add]
      congr 2
    _ ≤ 2 * Real.exp (-u ^ 2 - ((k + 1 : ℝ) * Real.log 2)) := by
      exact mul_le_mul_of_nonneg_left (Real.exp_le_exp.mpr hscale) (by norm_num)
    _ = 2 * Real.exp (-u ^ 2) * (1 / 2 : ℝ) ^ (k + 1) := by
      rw [show (k + 1 : ℝ) = ((k + 1 : ℕ) : ℝ) by norm_num,
        Real.exp_sub, Real.exp_nat_mul,
        Real.exp_log (by norm_num : (0 : ℝ) < 2), one_div, inv_pow]
      ring

/-- Bad edge events at one scale.

**Lean implementation helper.** -/
def genericChainBadAtScale (X : HDP.RandomProcess T Ω)
    (d : T → T → ℝ) (A : HDP.FiniteAdmissibleChain T)
    (K u : ℝ) (k : ℕ) : Set Ω :=
  ⋃ p ∈ admissibleEdges d A k,
    {ω | 8 * K * (u * realGammaTwoWeight (k + 1)) * d p.1 p.2 <
      |edgeIncrement X p ω|}

/-- All bad edge events in a finite admissible chain.

**Lean implementation helper.** -/
def genericChainBad (X : HDP.RandomProcess T Ω)
    (d : T → T → ℝ) (A : HDP.FiniteAdmissibleChain T)
    (K u : ℝ) : Set Ω :=
  ⋃ k ∈ Finset.range A.terminal, genericChainBadAtScale X d A K u k

/-- Single-edge subgaussian tail at scale `2^{k/2}`.

**Book Equation (8.49).** -/
theorem measure_genericChainBadAtScale [IsProbabilityMeasure μ]
    (X : HDP.RandomProcess T Ω) (hXm : ∀ t, Measurable (X t))
    (d : T → T → ℝ) (hd : ∀ s t, 0 ≤ d s t)
    (A : HDP.FiniteAdmissibleChain T) {K u : ℝ}
    (hK : 0 < K) (hu : 1 ≤ u)
    (hinc : HDP.HasSubGaussianIncrementsWith X μ d K)
    {k : ℕ} (hk : k < A.terminal) :
    μ (genericChainBadAtScale X d A K u k) ≤
      ENNReal.ofReal
        (2 * Real.exp (-u ^ 2) * (1 / 2 : ℝ) ^ (k + 1)) := by
  let q : ℝ := 2 * Real.exp
    (-(8 * (u * realGammaTwoWeight (k + 1))) ^ 2)
  have hq0 : 0 ≤ q := by positivity
  calc
    μ (genericChainBadAtScale X d A K u k) ≤
        ∑ p ∈ admissibleEdges d A k,
          μ {ω | 8 * K * (u * realGammaTwoWeight (k + 1)) * d p.1 p.2 <
            |edgeIncrement X p ω|} := by
      exact measure_biUnion_finset_le _ _
    _ ≤ ∑ _p ∈ admissibleEdges d A k, ENNReal.ofReal q := by
      apply Finset.sum_le_sum
      intro p hp
      exact edgeIncrement_tail X hXm d hd hK
        (mul_nonneg (zero_le_one.trans hu) (realGammaTwoWeight_nonneg _)) hinc p
    _ = ENNReal.ofReal (∑ _p ∈ admissibleEdges d A k, q) := by
      exact (ENNReal.ofReal_sum_of_nonneg (fun _ _ => hq0)).symm
    _ ≤ ENNReal.ofReal
        (2 * Real.exp (-u ^ 2) * (1 / 2 : ℝ) ^ (k + 1)) := by
      apply ENNReal.ofReal_le_ofReal
      have hcard : ((admissibleEdges d A k).card : ℝ) ≤
          ((2 ^ (2 ^ (k + 2)) : ℕ) : ℝ) := by
        exact_mod_cast card_admissibleEdges_le d A hk
      calc
        (∑ _p ∈ admissibleEdges d A k, q) =
            ((admissibleEdges d A k).card : ℝ) * q := by simp
        _ ≤ ((2 ^ (2 ^ (k + 2)) : ℕ) : ℝ) * q :=
          mul_le_mul_of_nonneg_right hcard hq0
        _ ≤ 2 * Real.exp (-u ^ 2) * (1 / 2 : ℝ) ^ (k + 1) :=
          scale_count_times_tail_le k hu

/-- The generic-chain failure event has probability at most `2 exp(-u²)`.

**Lean implementation helper.** -/
theorem measure_genericChainBad [IsProbabilityMeasure μ]
    (X : HDP.RandomProcess T Ω) (hXm : ∀ t, Measurable (X t))
    (d : T → T → ℝ) (hd : ∀ s t, 0 ≤ d s t)
    (A : HDP.FiniteAdmissibleChain T) {K u : ℝ}
    (hK : 0 < K) (hu : 1 ≤ u)
    (hinc : HDP.HasSubGaussianIncrementsWith X μ d K) :
    μ (genericChainBad X d A K u) ≤
      ENNReal.ofReal (2 * Real.exp (-u ^ 2)) := by
  calc
    μ (genericChainBad X d A K u) ≤
        ∑ k ∈ Finset.range A.terminal,
          μ (genericChainBadAtScale X d A K u k) :=
      measure_biUnion_finset_le _ _
    _ ≤ ∑ k ∈ Finset.range A.terminal,
        ENNReal.ofReal
          (2 * Real.exp (-u ^ 2) * (1 / 2 : ℝ) ^ (k + 1)) := by
      exact Finset.sum_le_sum fun k hk =>
        measure_genericChainBadAtScale X hXm d hd A hK hu hinc
          (Finset.mem_range.mp hk)
    _ = ENNReal.ofReal (∑ k ∈ Finset.range A.terminal,
        2 * Real.exp (-u ^ 2) * (1 / 2 : ℝ) ^ (k + 1)) := by
      exact (ENNReal.ofReal_sum_of_nonneg (fun _ _ => by positivity)).symm
    _ ≤ ENNReal.ofReal (2 * Real.exp (-u ^ 2)) := by
      apply ENNReal.ofReal_le_ofReal
      have hfactor :
          (∑ k ∈ Finset.range A.terminal,
            2 * Real.exp (-u ^ 2) * (1 / 2 : ℝ) ^ (k + 1)) =
          2 * Real.exp (-u ^ 2) *
            (∑ k ∈ Finset.range A.terminal, (1 / 2 : ℝ) ^ (k + 1)) := by
        rw [Finset.mul_sum]
      rw [hfactor]
      simpa using mul_le_mul_of_nonneg_left
        (geometric_half_sum_le_one A.terminal)
        (show 0 ≤ 2 * Real.exp (-u ^ 2) by positivity)

/-! ## Deterministic summation on the good event -/

/-- Desired simultaneous weighted increment control.

**Book Equation (8.48).** -/
theorem edgeIncrement_le_of_notMem_genericChainBad
    (X : HDP.RandomProcess T Ω) (d : T → T → ℝ)
    (A : HDP.FiniteAdmissibleChain T) {K u : ℝ} {ω : Ω}
    (hgood : ω ∉ genericChainBad X d A K u)
    {k : ℕ} (hk : k < A.terminal) {p : T × T}
    (hp : p ∈ admissibleEdges d A k) :
    |edgeIncrement X p ω| ≤
      8 * K * (u * realGammaTwoWeight (k + 1)) * d p.1 p.2 := by
  by_contra hbad
  have hpbad : ω ∈ genericChainBadAtScale X d A K u k := by
    exact mem_iUnion_of_mem p (mem_iUnion_of_mem hp (by
      change 8 * K * (u * realGammaTwoWeight (k + 1)) * d p.1 p.2 <
        |edgeIncrement X p ω|
      exact lt_of_not_ge hbad))
  exact hgood (mem_iUnion_of_mem k
    (mem_iUnion_of_mem (Finset.mem_range.mpr hk) hpbad))

/-- The weighted sum of distances to consecutive admissible-chain levels is at most three times the pointwise chain cost.

**Lean implementation helper.** -/
private theorem weightedProjectionDistanceSum_le
    (d : T → T → ℝ) (hd : ∀ s t, 0 ≤ d s t)
    (A : HDP.FiniteAdmissibleChain T) (t : T) :
    (∑ i : Fin A.terminal,
      realGammaTwoWeight (i.succ : ℕ) *
        (finiteSetDistance d (A.level i.succ) (A.level_nonempty i.succ) t +
          finiteSetDistance d (A.level i.castSucc)
            (A.level_nonempty i.castSucc) t)) ≤
      3 * realChainPointCost d A t := by
  let a : Fin (A.terminal + 1) → ℝ := fun j =>
    realGammaTwoWeight (j : ℕ) *
      finiteSetDistance d (A.level j) (A.level_nonempty j) t
  have ha0 : ∀ j, 0 ≤ a j := fun j =>
    mul_nonneg (realGammaTwoWeight_nonneg _)
      (finiteSetDistance_nonneg d hd _ _)
  have hsucc :
      (∑ i : Fin A.terminal,
        realGammaTwoWeight (i.succ : ℕ) *
          finiteSetDistance d (A.level i.succ) (A.level_nonempty i.succ) t) ≤
        realChainPointCost d A t := by
    change (∑ i : Fin A.terminal, a i.succ) ≤ ∑ j, a j
    rw [Fin.sum_univ_succ]
    exact le_add_of_nonneg_left (ha0 0)
  have hprev :
      (∑ i : Fin A.terminal,
        realGammaTwoWeight (i.succ : ℕ) *
          finiteSetDistance d (A.level i.castSucc)
            (A.level_nonempty i.castSucc) t) ≤
        2 * realChainPointCost d A t := by
    calc
      (∑ i : Fin A.terminal,
          realGammaTwoWeight (i.succ : ℕ) *
            finiteSetDistance d (A.level i.castSucc)
              (A.level_nonempty i.castSucc) t) ≤
          ∑ i : Fin A.terminal,
            2 * (realGammaTwoWeight (i : ℕ) *
              finiteSetDistance d (A.level i.castSucc)
                (A.level_nonempty i.castSucc) t) := by
        apply Finset.sum_le_sum
        intro i hi
        have hdist := finiteSetDistance_nonneg d hd
          (A.level_nonempty i.castSucc) t
        calc
          realGammaTwoWeight (i.succ : ℕ) *
              finiteSetDistance d (A.level i.castSucc)
                (A.level_nonempty i.castSucc) t ≤
              (2 * realGammaTwoWeight (i : ℕ)) *
                finiteSetDistance d (A.level i.castSucc)
                  (A.level_nonempty i.castSucc) t :=
            mul_le_mul_of_nonneg_right
              (realGammaTwoWeight_succ_le_two (i : ℕ)) hdist
          _ = 2 * (realGammaTwoWeight (i : ℕ) *
              finiteSetDistance d (A.level i.castSucc)
                (A.level_nonempty i.castSucc) t) := by ring
      _ = 2 * (∑ i : Fin A.terminal,
          realGammaTwoWeight (i : ℕ) *
            finiteSetDistance d (A.level i.castSucc)
              (A.level_nonempty i.castSucc) t) := by rw [Finset.mul_sum]
      _ ≤ 2 * realChainPointCost d A t := by
        gcongr
        change (∑ i : Fin A.terminal, a i.castSucc) ≤ ∑ j, a j
        rw [Fin.sum_univ_castSucc]
        exact le_add_of_nonneg_right (ha0 (Fin.last A.terminal))
  rw [show (∑ i : Fin A.terminal,
      realGammaTwoWeight (i.succ : ℕ) *
        (finiteSetDistance d (A.level i.succ) (A.level_nonempty i.succ) t +
          finiteSetDistance d (A.level i.castSucc)
            (A.level_nonempty i.castSucc) t)) =
      (∑ i : Fin A.terminal,
        realGammaTwoWeight (i.succ : ℕ) *
          finiteSetDistance d (A.level i.succ) (A.level_nonempty i.succ) t) +
      (∑ i : Fin A.terminal,
        realGammaTwoWeight (i.succ : ℕ) *
          finiteSetDistance d (A.level i.castSucc)
            (A.level_nonempty i.castSucc) t) by
        simp_rw [mul_add]
        exact Finset.sum_add_distrib]
  calc
    (∑ i : Fin A.terminal,
        realGammaTwoWeight (i.succ : ℕ) *
          finiteSetDistance d (A.level i.succ) (A.level_nonempty i.succ) t) +
      (∑ i : Fin A.terminal,
        realGammaTwoWeight (i.succ : ℕ) *
          finiteSetDistance d (A.level i.castSucc)
            (A.level_nonempty i.castSucc) t) ≤
        realChainPointCost d A t + 2 * realChainPointCost d A t :=
      add_le_add hsucc hprev
    _ = 3 * realChainPointCost d A t := by ring

/-- On the simultaneous good event, nearest-point chaining is bounded by the
point cost of the chosen admissible chain.

**Lean implementation helper.** -/
theorem finiteProcessIncrementSup_le_of_notMem_genericChainBad
    (X : HDP.RandomProcess T Ω) (d : T → T → ℝ)
    (hd : ∀ s t, 0 ≤ d s t) (hsymm : ∀ s t, d s t = d t s)
    (htri : ∀ r s t, d r t ≤ d r s + d s t)
    (hd0 : ∀ t, d t t = 0)
    (A : HDP.FiniteAdmissibleChain T) {K u : ℝ} {ω : Ω}
    (hK0 : 0 ≤ K) (hu0 : 0 ≤ u)
    (hgood : ω ∉ genericChainBad X d A K u) :
    finiteProcessIncrementSup X (admissibleAnchor A) ω ≤
      24 * K * u * realChainCost d A := by
  unfold finiteProcessIncrementSup
  apply Finset.sup'_le
  intro t ht
  let C := admissibleDudleyChain d A
  rw [show admissibleAnchor A = C.anchor by rfl,
    finiteDudleyChain_telescope C X t ω]
  calc
    |∑ k ∈ Finset.range A.terminal, dudleyScaleIncrement C X k t ω| ≤
        ∑ k ∈ Finset.range A.terminal,
          |dudleyScaleIncrement C X k t ω| :=
      Finset.abs_sum_le_sum_abs _ _
    _ = ∑ i : Fin A.terminal,
        |dudleyScaleIncrement C X (i : ℕ) t ω| := by
      simpa using (Fin.sum_univ_eq_sum_range
        (fun k => |dudleyScaleIncrement C X k t ω|) A.terminal).symm
    _ ≤ ∑ i : Fin A.terminal,
        8 * K * (u * realGammaTwoWeight (i.succ : ℕ)) *
          d (admissibleProjection d A i.succ t)
            (admissibleProjection d A i.castSucc t) := by
      apply Finset.sum_le_sum
      intro i hi
      let p : T × T :=
        (admissibleProjection d A i.succ t,
          admissibleProjection d A i.castSucc t)
      have hp : p ∈ admissibleEdges d A (i : ℕ) :=
        (mem_admissibleEdges d A i.isLt).mpr ⟨t, rfl⟩
      have hedge := edgeIncrement_le_of_notMem_genericChainBad
        X d A hgood i.isLt hp
      have hsuccFin :
          (⟨(i : ℕ) + 1, by omega⟩ : Fin (A.terminal + 1)) = i.succ :=
        Fin.eq_of_val_eq rfl
      have hcastFin :
          (⟨(i : ℕ), by omega⟩ : Fin (A.terminal + 1)) = i.castSucc :=
        Fin.eq_of_val_eq rfl
      simpa [C, admissibleDudleyChain, dudleyScaleIncrement,
        edgeIncrement, p, i.isLt, hsuccFin, hcastFin] using hedge
    _ ≤ ∑ i : Fin A.terminal,
        8 * K * u * realGammaTwoWeight (i.succ : ℕ) *
          (finiteSetDistance d (A.level i.succ)
              (A.level_nonempty i.succ) t +
            finiteSetDistance d (A.level i.castSucc)
              (A.level_nonempty i.castSucc) t) := by
      apply Finset.sum_le_sum
      intro i hi
      have htriangle :
          d (admissibleProjection d A i.succ t)
              (admissibleProjection d A i.castSucc t) ≤
            finiteSetDistance d (A.level i.succ)
                (A.level_nonempty i.succ) t +
              finiteSetDistance d (A.level i.castSucc)
                (A.level_nonempty i.castSucc) t := by
        calc
          d (admissibleProjection d A i.succ t)
              (admissibleProjection d A i.castSucc t) ≤
              d (admissibleProjection d A i.succ t) t +
                d t (admissibleProjection d A i.castSucc t) :=
            htri _ t _
          _ = d t (admissibleProjection d A i.succ t) +
                d t (admissibleProjection d A i.castSucc t) := by
            rw [hsymm]
          _ = _ := by
            rw [admissibleProjection_distance d hd0 hd,
              admissibleProjection_distance d hd0 hd]
      have hcoef : 0 ≤ 8 * K * u * realGammaTwoWeight (i.succ : ℕ) := by
        exact mul_nonneg
          (mul_nonneg (mul_nonneg (by norm_num) hK0) hu0)
          (realGammaTwoWeight_nonneg _)
      calc
        8 * K * (u * realGammaTwoWeight (i.succ : ℕ)) *
            d (admissibleProjection d A i.succ t)
              (admissibleProjection d A i.castSucc t) =
            (8 * K * u * realGammaTwoWeight (i.succ : ℕ)) *
              d (admissibleProjection d A i.succ t)
                (admissibleProjection d A i.castSucc t) := by ring
        _ ≤ (8 * K * u * realGammaTwoWeight (i.succ : ℕ)) *
            (finiteSetDistance d (A.level i.succ)
                (A.level_nonempty i.succ) t +
              finiteSetDistance d (A.level i.castSucc)
                (A.level_nonempty i.castSucc) t) :=
          mul_le_mul_of_nonneg_left htriangle hcoef
    _ = 8 * K * u * (∑ i : Fin A.terminal,
        realGammaTwoWeight (i.succ : ℕ) *
          (finiteSetDistance d (A.level i.succ)
              (A.level_nonempty i.succ) t +
            finiteSetDistance d (A.level i.castSucc)
              (A.level_nonempty i.castSucc) t)) := by
      rw [Finset.mul_sum]
      apply Finset.sum_congr rfl
      intro i hi
      ring
    _ ≤ 8 * K * u * (3 * realChainPointCost d A t) := by
      gcongr
      exact weightedProjectionDistanceSum_le d hd A t
    _ ≤ 8 * K * u * (3 * realChainCost d A) := by
      gcongr
      exact realChainPointCost_le_realChainCost d A t
    _ = 24 * K * u * realChainCost d A := by ring

/-- The anchored process supremum exceeds `24 K u` times the real chain cost with probability at most `2 exp(-u²)`.

**Lean implementation helper.** -/
theorem genericChain_incrementSup_tail [IsProbabilityMeasure μ]
    (X : HDP.RandomProcess T Ω) (hXm : ∀ t, Measurable (X t))
    (d : T → T → ℝ) (hd : ∀ s t, 0 ≤ d s t)
    (hsymm : ∀ s t, d s t = d t s)
    (htri : ∀ r s t, d r t ≤ d r s + d s t)
    (hd0 : ∀ t, d t t = 0)
    (A : HDP.FiniteAdmissibleChain T) {K u : ℝ}
    (hK : 0 < K) (hu : 1 ≤ u)
    (hinc : HDP.HasSubGaussianIncrementsWith X μ d K) :
    μ {ω | 24 * K * u * realChainCost d A <
        finiteProcessIncrementSup X (admissibleAnchor A) ω} ≤
      ENNReal.ofReal (2 * Real.exp (-u ^ 2)) := by
  calc
    μ {ω | 24 * K * u * realChainCost d A <
        finiteProcessIncrementSup X (admissibleAnchor A) ω} ≤
        μ (genericChainBad X d A K u) := by
      apply measure_mono
      intro ω hω
      by_contra hgood
      have hle := finiteProcessIncrementSup_le_of_notMem_genericChainBad
        X d hd hsymm htri hd0 A hK.le (zero_le_one.trans hu) hgood
      exact (not_lt_of_ge hle) hω
    _ ≤ ENNReal.ofReal (2 * Real.exp (-u ^ 2)) :=
      measure_genericChainBad X hXm d hd A hK hu hinc

/-- The anchored supremum for one positive-cost admissible chain is itself
subgaussian. This is the integrated Chapter 2 maximal inequality used in the
expectation theorem; no scale bound is assumed.

**Lean implementation helper.** -/
theorem genericChain_incrementSup_subGaussian [IsProbabilityMeasure μ]
    (X : HDP.RandomProcess T Ω) (hXm : ∀ t, Measurable (X t))
    (d : T → T → ℝ) (hd : ∀ s t, 0 ≤ d s t)
    (hsymm : ∀ s t, d s t = d t s)
    (htri : ∀ r s t, d r t ≤ d r s + d s t)
    (hd0 : ∀ t, d t t = 0)
    (A : HDP.FiniteAdmissibleChain T) {K : ℝ}
    (hK : 0 < K) (hcost : 0 < realChainCost d A)
    (hinc : HDP.HasSubGaussianIncrementsWith X μ d K) :
    HDP.SubGaussian (finiteProcessIncrementSup X (admissibleAnchor A)) μ ∧
      HDP.psi2Norm (finiteProcessIncrementSup X (admissibleAnchor A)) μ ≤
        Real.sqrt 5 * (4 * (24 * K * realChainCost d A)) := by
  let B : ℝ := 24 * K * realChainCost d A
  have hB : 0 < B := by dsimp [B]; positivity
  have hZm : Measurable (finiteProcessIncrementSup X (admissibleAnchor A)) :=
    measurable_finiteProcessIncrementSup X (admissibleAnchor A) hXm
  apply HDP.psi2Norm_le_of_tail_bound hZm.aemeasurable (show 0 < 4 * B by positivity)
  intro t ht
  by_cases htlarge : 2 * B < t
  · let u : ℝ := t / (2 * B)
    have hu : 1 ≤ u := by
      dsimp [u]
      rw [le_div_iff₀ (by positivity : 0 < 2 * B)]
      linarith
    have hsubset :
        {ω | t ≤ |finiteProcessIncrementSup X (admissibleAnchor A) ω|} ⊆
          {ω | 24 * K * u * realChainCost d A <
            finiteProcessIncrementSup X (admissibleAnchor A) ω} := by
      intro ω hω
      change t ≤ |finiteProcessIncrementSup X (admissibleAnchor A) ω| at hω
      rw [abs_of_nonneg
        (finiteProcessIncrementSup_nonneg X (admissibleAnchor A) ω)] at hω
      have hhalf : 24 * K * u * realChainCost d A = t / 2 := by
        dsimp [u, B]
        field_simp [hK.ne', hcost.ne']
      change 24 * K * u * realChainCost d A <
        finiteProcessIncrementSup X (admissibleAnchor A) ω
      rw [hhalf]
      exact lt_of_lt_of_le (by linarith : t / 2 < t) hω
    calc
      μ {ω | t ≤ |finiteProcessIncrementSup X (admissibleAnchor A) ω|} ≤
          μ {ω | 24 * K * u * realChainCost d A <
            finiteProcessIncrementSup X (admissibleAnchor A) ω} :=
        measure_mono hsubset
      _ ≤ ENNReal.ofReal (2 * Real.exp (-u ^ 2)) :=
        genericChain_incrementSup_tail X hXm d hd hsymm htri hd0 A hK hu hinc
      _ ≤ ENNReal.ofReal (2 * Real.exp (-t ^ 2 / (4 * B) ^ 2)) := by
        apply ENNReal.ofReal_le_ofReal
        apply mul_le_mul_of_nonneg_left (Real.exp_le_exp.mpr ?_) (by norm_num)
        dsimp [u]
        have hB0 : B ≠ 0 := hB.ne'
        field_simp [hB0]
        nlinarith [sq_nonneg t, sq_nonneg B]
  · have htB : t ≤ 2 * B := le_of_not_gt htlarge
    calc
      μ {ω | t ≤ |finiteProcessIncrementSup X (admissibleAnchor A) ω|} ≤ 1 :=
        prob_le_one
      _ ≤ ENNReal.ofReal (2 * Real.exp (-t ^ 2 / (4 * B) ^ 2)) := by
        rw [show (1 : ENNReal) = ENNReal.ofReal 1 by norm_num]
        apply ENNReal.ofReal_le_ofReal
        have hexpArg : -t ^ 2 / (4 * B) ^ 2 ≥ -(1 / 4 : ℝ) := by
          have ht2 : t ^ 2 ≤ (2 * B) ^ 2 := by nlinarith
          have hB0 : B ≠ 0 := hB.ne'
          field_simp [hB0]
          nlinarith [sq_nonneg B]
        have hexp : (3 / 4 : ℝ) ≤ Real.exp (-t ^ 2 / (4 * B) ^ 2) := by
          calc
            (3 / 4 : ℝ) = -(1 / 4 : ℝ) + 1 := by norm_num
            _ ≤ Real.exp (-(1 / 4 : ℝ)) := Real.add_one_le_exp _
            _ ≤ Real.exp (-t ^ 2 / (4 * B) ^ 2) :=
              Real.exp_le_exp.mpr hexpArg
        nlinarith

/-- Generic-chain telescoping expansion. Expectation form for a fixed positive-cost chain.

**Book Equation (8.47).** -/
theorem genericChainingBoundForChain [IsProbabilityMeasure μ]
    (X : HDP.RandomProcess T Ω) (hXm : ∀ t, Measurable (X t))
    (d : T → T → ℝ) (hd : ∀ s t, 0 ≤ d s t)
    (hsymm : ∀ s t, d s t = d t s)
    (htri : ∀ r s t, d r t ≤ d r s + d s t)
    (hd0 : ∀ t, d t t = 0)
    (A : HDP.FiniteAdmissibleChain T) {K : ℝ}
    (hK : 0 < K) (hcost : 0 < realChainCost d A)
    (hinc : HDP.HasSubGaussianIncrementsWith X μ d K) :
    ∫ ω, finiteProcessIncrementSup X (admissibleAnchor A) ω ∂μ ≤
      96 * Real.sqrt 5 * K * realChainCost d A := by
  obtain ⟨hsub, hpsi⟩ := genericChain_incrementSup_subGaussian
    X hXm d hd hsymm htri hd0 A hK hcost hinc
  let Z := finiteProcessIncrementSup X (admissibleAnchor A)
  have hZm : Measurable Z :=
    measurable_finiteProcessIncrementSup X (admissibleAnchor A) hXm
  have hmom := hsub.moment_bound hZm.aemeasurable (show (1 : ℝ) ≤ 1 by rfl)
  have hL1 : HDP.Chapter1.lpNormRV Z 1 μ = ∫ ω, Z ω ∂μ := by
    dsimp [Z]
    rw [HDP.Chapter1.lpNormRV]
    simp_rw [Real.rpow_one, abs_of_nonneg
      (finiteProcessIncrementSup_nonneg X (admissibleAnchor A) _)]
    rw [show (1 : ℝ) / 1 = 1 by norm_num, Real.rpow_one]
  calc
    (∫ ω, finiteProcessIncrementSup X (admissibleAnchor A) ω ∂μ) =
        HDP.Chapter1.lpNormRV Z 1 μ := hL1.symm
    _ ≤ HDP.psi2Norm Z μ * Real.sqrt 1 := hmom
    _ = HDP.psi2Norm Z μ := by norm_num
    _ ≤ Real.sqrt 5 * (4 * (24 * K * realChainCost d A)) := hpsi
    _ = 96 * Real.sqrt 5 * K * realChainCost d A := by ring

/-- Zero real chain cost forces every index to have zero distance from the admissible anchor.

**Lean implementation helper.** -/
theorem distance_anchor_eq_zero_of_chainCost_eq_zero
    (d : T → T → ℝ) (hd : ∀ s t, 0 ≤ d s t)
    (hd0 : ∀ t, d t t = 0) (A : HDP.FiniteAdmissibleChain T)
    (hcost : realChainCost d A = 0) (t : T) :
    d t (admissibleAnchor A) = 0 := by
  have hpoint : realChainPointCost d A t = 0 := by
    apply le_antisymm
    · exact (realChainPointCost_le_realChainCost d A t).trans_eq hcost
    · exact realChainPointCost_nonneg d hd A t
  have hrest : 0 ≤ ∑ i : Fin A.terminal,
      realGammaTwoWeight (i.succ : ℕ) *
        finiteSetDistance d (A.level i.succ) (A.level_nonempty i.succ) t := by
    exact Finset.sum_nonneg fun i _ => mul_nonneg
      (realGammaTwoWeight_nonneg _)
      (finiteSetDistance_nonneg d hd _ _)
  have hfirst : finiteSetDistance d
      (A.level ⟨0, Nat.zero_lt_succ _⟩)
      (A.level_nonempty ⟨0, Nat.zero_lt_succ _⟩) t = 0 := by
    have hsplit := Fin.sum_univ_succ (fun j : Fin (A.terminal + 1) =>
      realGammaTwoWeight (j : ℕ) *
        finiteSetDistance d (A.level j) (A.level_nonempty j) t)
    rw [← realChainPointCost] at hsplit
    simp only [Fin.val_zero, realGammaTwoWeight_zero, one_mul] at hsplit
    rw [hpoint] at hsplit
    have hnonneg := finiteSetDistance_nonneg d hd
      (A.level_nonempty ⟨0, Nat.zero_lt_succ _⟩) t
    have hsplit' : 0 = finiteSetDistance d
        (A.level ⟨0, Nat.zero_lt_succ _⟩)
        (A.level_nonempty ⟨0, Nat.zero_lt_succ _⟩) t +
        ∑ i : Fin A.terminal,
          realGammaTwoWeight (i.succ : ℕ) *
            finiteSetDistance d (A.level i.succ) (A.level_nonempty i.succ) t := by
      simpa using hsplit
    linarith
  calc
    d t (admissibleAnchor A) =
        d t (admissibleProjection d A ⟨0, Nat.zero_lt_succ _⟩ t) := by
      rw [admissibleProjection_zero]
    _ = finiteSetDistance d (A.level ⟨0, Nat.zero_lt_succ _⟩)
        (A.level_nonempty ⟨0, Nat.zero_lt_succ _⟩) t :=
      admissibleProjection_distance d hd0 hd A _ t
    _ = 0 := hfirst

/-- If the increment scale or real chain cost vanishes, the anchored finite-process supremum is almost everywhere zero.

**Lean implementation helper.** -/
theorem finiteProcessIncrementSup_ae_zero_of_scale_zero
    [IsProbabilityMeasure μ]
    (X : HDP.RandomProcess T Ω) (hXm : ∀ t, Measurable (X t))
    (d : T → T → ℝ) (hd : ∀ s t, 0 ≤ d s t)
    (hd0 : ∀ t, d t t = 0) (A : HDP.FiniteAdmissibleChain T)
    {K : ℝ} (hinc : HDP.HasSubGaussianIncrementsWith X μ d K)
    (hzero : K = 0 ∨ realChainCost d A = 0) :
    finiteProcessIncrementSup X (admissibleAnchor A) =ᵐ[μ] 0 := by
  have hcoord : ∀ t : T,
      (fun ω => X t ω - X (admissibleAnchor A) ω) =ᵐ[μ] 0 := by
    intro t
    have hsub := (hinc.2 (admissibleAnchor A) t).1
    have hpsi : HDP.psi2Norm
        (fun ω => X t ω - X (admissibleAnchor A) ω) μ = 0 := by
      apply le_antisymm
      · refine (hinc.2 (admissibleAnchor A) t).2.trans_eq ?_
        rcases hzero with hK | hcost
        · simp [hK]
        · rw [distance_anchor_eq_zero_of_chainCost_eq_zero d hd hd0 A hcost t]
          simp
      · exact HDP.psi2Norm_nonneg _ _
    exact (HDP.psi2Norm_eq_zero_iff
      ((hXm t).sub (hXm (admissibleAnchor A))).aemeasurable hsub).mp hpsi
  have hall : ∀ᵐ ω ∂μ, ∀ t ∈ (Finset.univ : Finset T),
      X t ω - X (admissibleAnchor A) ω = 0 := by
    exact (Finset.univ.eventually_all).2 fun t ht => hcoord t
  filter_upwards [hall] with ω hω
  apply le_antisymm
  · unfold finiteProcessIncrementSup
    apply Finset.sup'_le
    intro t ht
    simp [hω t ht]
  · exact finiteProcessIncrementSup_nonneg X (admissibleAnchor A) ω

/-- Fixed-chain expectation bound including the `K=0` and zero-cost branches.

**Lean implementation helper.** -/
theorem genericChainingBoundForChain_safe [IsProbabilityMeasure μ]
    (X : HDP.RandomProcess T Ω) (hXm : ∀ t, Measurable (X t))
    (d : T → T → ℝ) (hd : ∀ s t, 0 ≤ d s t)
    (hsymm : ∀ s t, d s t = d t s)
    (htri : ∀ r s t, d r t ≤ d r s + d s t)
    (hd0 : ∀ t, d t t = 0)
    (A : HDP.FiniteAdmissibleChain T) {K : ℝ}
    (hinc : HDP.HasSubGaussianIncrementsWith X μ d K) :
    ∫ ω, finiteProcessIncrementSup X (admissibleAnchor A) ω ∂μ ≤
      96 * Real.sqrt 5 * K * realChainCost d A := by
  have hK0 := hinc.1
  have hcost0 := realChainCost_nonneg d hd A
  by_cases hK : K = 0
  · have hz := finiteProcessIncrementSup_ae_zero_of_scale_zero
      X hXm d hd hd0 A hinc (Or.inl hK)
    rw [integral_congr_ae hz]
    simp [hK]
  · by_cases hcost : realChainCost d A = 0
    · have hz := finiteProcessIncrementSup_ae_zero_of_scale_zero
        X hXm d hd hd0 A hinc (Or.inr hcost)
      rw [integral_congr_ae hz]
      simp [hcost]
    · exact genericChainingBoundForChain X hXm d hd hsymm htri hd0 A
        (lt_of_le_of_ne hK0 (Ne.symm hK))
        (lt_of_le_of_ne hcost0 (Ne.symm hcost)) hinc

/-- Integrability of a finite anchored increment maximum from coordinate
integrability.

**Lean implementation helper.** -/
theorem integrable_finiteProcessIncrementSup
    (X : HDP.RandomProcess T Ω) (t0 : T)
    (hXint : ∀ t, Integrable (X t) μ) :
    Integrable (finiteProcessIncrementSup X t0) μ := by
  have hraw : Integrable
      (Finset.univ.sup' Finset.univ_nonempty fun t =>
        fun ω => |X t ω - X t0 ω|) μ :=
    Finset.sup'_induction Finset.univ_nonempty
      (fun t => fun ω => |X t ω - X t0 ω|)
      (p := fun f : Ω → ℝ => Integrable f μ)
      (fun _ hf _ hg => hf.sup hg)
      (fun t _ => (hXint t).sub (hXint t0) |>.abs)
  have heq : (Finset.univ.sup' Finset.univ_nonempty fun t =>
      fun ω => |X t ω - X t0 ω|) = finiteProcessIncrementSup X t0 := by
    funext ω
    simp only [finiteProcessIncrementSup, Finset.sup'_apply]
  rwa [heq] at hraw

/-- A centered finite process is bounded by its expected anchored oscillation.

**Lean implementation helper.** -/
theorem expectedFiniteSupremum_le_incrementSup
    (X : HDP.RandomProcess T Ω) (_hXm : ∀ t, Measurable (X t))
    (hXint : ∀ t, Integrable (X t) μ)
    (hcenter : HDP.IsCenteredProcess X μ) (t0 : T) :
    HDP.Chapter7.expectedFiniteSupremum μ X ≤
      ∫ ω, finiteProcessIncrementSup X t0 ω ∂μ := by
  have hinc := integrable_finiteProcessIncrementSup X t0 hXint
  have hsup : Integrable (finiteProcessSup X) μ := by
    have hraw : Integrable
        (Finset.univ.sup' Finset.univ_nonempty fun t => X t) μ :=
      Finset.sup'_induction Finset.univ_nonempty (fun t => X t)
        (p := fun f : Ω → ℝ => Integrable f μ)
        (fun _ hf _ hg => hf.sup hg) (fun t _ => hXint t)
    have heq : (Finset.univ.sup' Finset.univ_nonempty fun t => X t) =
        finiteProcessSup X := by
      funext ω
      simp only [finiteProcessSup, Finset.sup'_apply]
    rwa [heq] at hraw
  have hdom : ∀ ω, finiteProcessSup X ω ≤
      X t0 ω + finiteProcessIncrementSup X t0 ω := by
    intro ω
    unfold finiteProcessSup
    apply Finset.sup'_le
    intro t ht
    have hle : |X t ω - X t0 ω| ≤ finiteProcessIncrementSup X t0 ω := by
      unfold finiteProcessIncrementSup
      exact Finset.le_sup' (fun s => |X s ω - X t0 ω|) ht
    calc
      X t ω = X t0 ω + (X t ω - X t0 ω) := by ring
      _ ≤ X t0 ω + |X t ω - X t0 ω| :=
        add_le_add (le_refl _) (le_abs_self _)
      _ ≤ X t0 ω + finiteProcessIncrementSup X t0 ω :=
        add_le_add (le_refl _) hle
  change (∫ ω, finiteProcessSup X ω ∂μ) ≤ _
  calc
    (∫ ω, finiteProcessSup X ω ∂μ) ≤
        ∫ ω, (X t0 ω + finiteProcessIncrementSup X t0 ω) ∂μ :=
      integral_mono hsup ((hXint t0).add hinc) hdom
    _ = ∫ ω, finiteProcessIncrementSup X t0 ω ∂μ := by
      rw [integral_add (hXint t0) hinc, hcenter t0, zero_add]

/-- The finite real distance always gives a finite authoritative gamma-two.

**Lean implementation helper.** -/
theorem gamma2_ofReal_ne_top (d : T → T → ℝ) (hd : ∀ s t, 0 ≤ d s t) :
    HDP.gamma2 (fun s t => ENNReal.ofReal (d s t)) ≠ ⊤ := by
  let A := HDP.canonicalFiniteAdmissibleChain T
  exact ne_top_of_le_ne_top (chainCost_ofReal_ne_top d hd A)
    (HDP.gamma2_le_chainCost _ A)

/-- The universal constant used by the finite generic-chaining proof.

**Lean implementation helper.** -/
def genericChainingConstant : ℝ := 96 * Real.sqrt 5

/-- Shows that the generic chaining constant is strictly positive.

**Lean implementation helper.** -/
theorem genericChainingConstant_pos : 0 < genericChainingConstant := by
  dsimp [genericChainingConstant]
  positivity

/-- Generic chaining bounds the expected supremum by `C K gamma2`.

**Book Theorem 8.5.2.** -/
theorem genericChainingBound [IsProbabilityMeasure μ]
    (X : HDP.RandomProcess T Ω) (hXm : ∀ t, Measurable (X t))
    (hXint : ∀ t, Integrable (X t) μ)
    (hcenter : HDP.IsCenteredProcess X μ)
    (d : T → T → ℝ) (hd : ∀ s t, 0 ≤ d s t)
    (hsymm : ∀ s t, d s t = d t s)
    (htri : ∀ r s t, d r t ≤ d r s + d s t)
    (hd0 : ∀ t, d t t = 0) {K : ℝ}
    (hinc : HDP.HasSubGaussianIncrementsWith X μ d K) :
    HDP.Chapter7.expectedFiniteSupremum μ X ≤
      genericChainingConstant * K *
        (HDP.gamma2 (fun s t => ENNReal.ofReal (d s t))).toReal := by
  let c := genericChainingConstant * K
  have hc : 0 ≤ c := mul_nonneg genericChainingConstant_pos.le hinc.1
  by_cases hc0 : c = 0
  · have hK : K = 0 := by
      rcases mul_eq_zero.mp hc0 with h | h
      · exact (genericChainingConstant_pos.ne' h).elim
      · exact h
    let A := HDP.canonicalFiniteAdmissibleChain T
    have hsup := expectedFiniteSupremum_le_incrementSup X hXm hXint hcenter
      (admissibleAnchor A)
    have hz := finiteProcessIncrementSup_ae_zero_of_scale_zero
      X hXm d hd hd0 A hinc (Or.inl hK)
    have hint : (∫ ω, finiteProcessIncrementSup X (admissibleAnchor A) ω ∂μ) = 0 := by
      rw [integral_congr_ae hz]
      simp
    rw [hK]
    simp only [mul_zero, zero_mul]
    exact hsup.trans_eq hint
  · have hcpos : 0 < c := lt_of_le_of_ne hc (Ne.symm hc0)
    have hdiv : HDP.Chapter7.expectedFiniteSupremum μ X / c ≤
        (HDP.gamma2 (fun s t => ENNReal.ofReal (d s t))).toReal := by
      rw [HDP.gamma2, ENNReal.toReal_iInf
        (fun A => chainCost_ofReal_ne_top d hd A)]
      letI : Nonempty (HDP.FiniteAdmissibleChain T) :=
        ⟨HDP.canonicalFiniteAdmissibleChain T⟩
      apply le_ciInf
      intro A
      rw [chainCost_toReal_ofReal d hd A]
      apply (div_le_iff₀ hcpos).2
      calc
        HDP.Chapter7.expectedFiniteSupremum μ X ≤
            ∫ ω, finiteProcessIncrementSup X (admissibleAnchor A) ω ∂μ :=
          expectedFiniteSupremum_le_incrementSup X hXm hXint hcenter _
        _ ≤ 96 * Real.sqrt 5 * K * realChainCost d A :=
          genericChainingBoundForChain_safe X hXm d hd hsymm htri hd0 A hinc
        _ = realChainCost d A * c := by
          simp [c, genericChainingConstant, mul_comm]
    have := (div_le_iff₀ hcpos).mp hdiv
    simpa [c, mul_comm, mul_left_comm, mul_assoc] using this

/-! ## Pairwise and high-probability forms -/

/-- Integrability of the finite sample-path oscillation from coordinate
integrability.

**Lean implementation helper.** -/
theorem integrable_finiteProcessOscillation
    (X : HDP.RandomProcess T Ω) (hXint : ∀ t, Integrable (X t) μ) :
    Integrable (finiteProcessOscillation X) μ := by
  have hraw : Integrable
      ((Finset.univ.product Finset.univ).sup'
        (Finset.univ_nonempty.product Finset.univ_nonempty) fun p =>
          fun ω => |X p.1 ω - X p.2 ω|) μ :=
    Finset.sup'_induction
      (Finset.univ_nonempty.product Finset.univ_nonempty)
      (fun p : T × T => fun ω => |X p.1 ω - X p.2 ω|)
      (p := fun f : Ω → ℝ => Integrable f μ)
      (fun _ hf _ hg => hf.sup hg)
      (fun p _ => ((hXint p.1).sub (hXint p.2)).abs)
  have heq : ((Finset.univ.product Finset.univ).sup'
      (Finset.univ_nonempty.product Finset.univ_nonempty) fun p =>
        fun ω => |X p.1 ω - X p.2 ω|) = finiteProcessOscillation X := by
    funext ω
    simp only [finiteProcessOscillation, Finset.sup'_apply]
  rwa [heq] at hraw

/-- Pairwise expectation estimate for one admissible chain, including all
zero-scale branches.

**Lean implementation helper.** -/
theorem genericChainingPairwiseBoundForChain_safe [IsProbabilityMeasure μ]
    (X : HDP.RandomProcess T Ω) (hXm : ∀ t, Measurable (X t))
    (hXint : ∀ t, Integrable (X t) μ)
    (d : T → T → ℝ) (hd : ∀ s t, 0 ≤ d s t)
    (hsymm : ∀ s t, d s t = d t s)
    (htri : ∀ r s t, d r t ≤ d r s + d s t)
    (hd0 : ∀ t, d t t = 0)
    (A : HDP.FiniteAdmissibleChain T) {K : ℝ}
    (hinc : HDP.HasSubGaussianIncrementsWith X μ d K) :
    ∫ ω, finiteProcessOscillation X ω ∂μ ≤
      2 * genericChainingConstant * K * realChainCost d A := by
  have hanch := integrable_finiteProcessIncrementSup X (admissibleAnchor A) hXint
  have hosc := integrable_finiteProcessOscillation X hXint
  calc
    (∫ ω, finiteProcessOscillation X ω ∂μ) ≤
        ∫ ω, 2 * finiteProcessIncrementSup X (admissibleAnchor A) ω ∂μ :=
      integral_mono hosc (hanch.const_mul 2)
        (finiteProcessOscillation_le_two_incrementSup X (admissibleAnchor A))
    _ = 2 * ∫ ω, finiteProcessIncrementSup X (admissibleAnchor A) ω ∂μ := by
      rw [integral_const_mul]
    _ ≤ 2 * (96 * Real.sqrt 5 * K * realChainCost d A) := by
      gcongr
      exact genericChainingBoundForChain_safe
        X hXm d hd hsymm htri hd0 A hinc
    _ = 2 * genericChainingConstant * K * realChainCost d A := by
      dsimp [genericChainingConstant]
      ring

/-- Generic chaining bounds pairwise increment suprema without centering. The centeredness assumption disappears when one
estimates the supremum of pairwise increments.

**Book Remark 8.5.3.** -/
theorem genericChainingSupremumOfIncrements [IsProbabilityMeasure μ]
    (X : HDP.RandomProcess T Ω) (hXm : ∀ t, Measurable (X t))
    (hXint : ∀ t, Integrable (X t) μ)
    (d : T → T → ℝ) (hd : ∀ s t, 0 ≤ d s t)
    (hsymm : ∀ s t, d s t = d t s)
    (htri : ∀ r s t, d r t ≤ d r s + d s t)
    (hd0 : ∀ t, d t t = 0) {K : ℝ}
    (hinc : HDP.HasSubGaussianIncrementsWith X μ d K) :
    ∫ ω, finiteProcessOscillation X ω ∂μ ≤
      2 * genericChainingConstant * K *
        (HDP.gamma2 (fun s t => ENNReal.ofReal (d s t))).toReal := by
  let c := 2 * genericChainingConstant * K
  have hc : 0 ≤ c := by
    dsimp [c]
    exact mul_nonneg
      (mul_nonneg (by norm_num) genericChainingConstant_pos.le) hinc.1
  by_cases hc0 : c = 0
  · let A := HDP.canonicalFiniteAdmissibleChain T
    have hfixed := genericChainingPairwiseBoundForChain_safe
      X hXm hXint d hd hsymm htri hd0 A hinc
    have hKzero : K = 0 := by
      rcases mul_eq_zero.mp hc0 with hC | hK
      · nlinarith [genericChainingConstant_pos]
      · exact hK
    rw [hKzero]
    simpa [hKzero] using hfixed
  · have hcpos : 0 < c := lt_of_le_of_ne hc (Ne.symm hc0)
    have hdiv : (∫ ω, finiteProcessOscillation X ω ∂μ) / c ≤
        (HDP.gamma2 (fun s t => ENNReal.ofReal (d s t))).toReal := by
      rw [HDP.gamma2, ENNReal.toReal_iInf
        (fun A => chainCost_ofReal_ne_top d hd A)]
      letI : Nonempty (HDP.FiniteAdmissibleChain T) :=
        ⟨HDP.canonicalFiniteAdmissibleChain T⟩
      apply le_ciInf
      intro A
      rw [chainCost_toReal_ofReal d hd A]
      apply (div_le_iff₀ hcpos).2
      have hfixed := genericChainingPairwiseBoundForChain_safe
        X hXm hXint d hd hsymm htri hd0 A hinc
      simpa [c, mul_comm, mul_left_comm, mul_assoc] using hfixed
    have hmul := (div_le_iff₀ hcpos).mp hdiv
    simpa [c, mul_comm, mul_left_comm, mul_assoc] using hmul

/-- The event proof is the first-big-leap argument after an admissible chain has
been fixed; optimizing the deterministic chain cost gives the usual
gamma-two formulation.

**Book Remark 8.5.4.** -/
theorem genericChainingHighProbabilityBoundForChain [IsProbabilityMeasure μ]
    (X : HDP.RandomProcess T Ω) (hXm : ∀ t, Measurable (X t))
    (d : T → T → ℝ) (hd : ∀ s t, 0 ≤ d s t)
    (hsymm : ∀ s t, d s t = d t s)
    (htri : ∀ r s t, d r t ≤ d r s + d s t)
    (hd0 : ∀ t, d t t = 0)
    (A : HDP.FiniteAdmissibleChain T) {K u : ℝ}
    (hK : 0 < K) (hu : 1 ≤ u)
    (hinc : HDP.HasSubGaussianIncrementsWith X μ d K) :
    μ {ω | 48 * K * u * realChainCost d A < finiteProcessOscillation X ω} ≤
      ENNReal.ofReal (2 * Real.exp (-u ^ 2)) := by
  calc
    μ {ω | 48 * K * u * realChainCost d A < finiteProcessOscillation X ω} ≤
        μ {ω | 24 * K * u * realChainCost d A <
          finiteProcessIncrementSup X (admissibleAnchor A) ω} := by
      apply measure_mono
      intro ω hω
      change 48 * K * u * realChainCost d A < finiteProcessOscillation X ω at hω
      have hosc := finiteProcessOscillation_le_two_incrementSup
        X (admissibleAnchor A) ω
      have hdouble : 48 * K * u * realChainCost d A =
          2 * (24 * K * u * realChainCost d A) := by ring
      rw [hdouble] at hω
      change 24 * K * u * realChainCost d A <
        finiteProcessIncrementSup X (admissibleAnchor A) ω
      linarith
    _ ≤ ENNReal.ofReal (2 * Real.exp (-u ^ 2)) :=
      genericChain_incrementSup_tail X hXm d hd hsymm htri hd0 A hK hu hinc

/-! ### The first big leap -/

/-- Diameter of a finite real-valued pseudometric space.

**Lean implementation helper.** -/
def finiteDistanceDiameter (d : T → T → ℝ) : ℝ :=
  (Finset.univ.product Finset.univ).sup'
    (Finset.univ_nonempty.product Finset.univ_nonempty) fun p => d p.1 p.2

/-- Bounds the distance by the diameter induced by the supplied distance.

**Lean implementation helper.** -/
theorem distance_le_finiteDistanceDiameter (d : T → T → ℝ) (s t : T) :
    d s t ≤ finiteDistanceDiameter d := by
  exact Finset.le_sup' (fun p : T × T => d p.1 p.2)
    (show (s, t) ∈ Finset.univ.product Finset.univ by simp)

/-- Shows that the diameter induced by the supplied distance is nonnegative.

**Lean implementation helper.** -/
theorem finiteDistanceDiameter_nonneg (d : T → T → ℝ)
    (hd : ∀ s t, 0 ≤ d s t) : 0 ≤ finiteDistanceDiameter d := by
  let t : T := Classical.choice inferInstance
  exact (hd t t).trans (distance_le_finiteDistanceDiameter d t t)

/-- Bounds the distance anchor by the extended chain cost at one point.

**Lean implementation helper.** -/
private theorem distance_anchor_le_chainPointCost
    (d : T → T → ℝ) (hd : ∀ s t, 0 ≤ d s t)
    (hd0 : ∀ t, d t t = 0) (A : HDP.FiniteAdmissibleChain T) (t : T) :
    d t (admissibleAnchor A) ≤ realChainPointCost d A t := by
  have hdist : d t (admissibleAnchor A) = finiteSetDistance d
      (A.level ⟨0, Nat.zero_lt_succ _⟩)
      (A.level_nonempty ⟨0, Nat.zero_lt_succ _⟩) t := by
    calc
      d t (admissibleAnchor A) =
          d t (admissibleProjection d A ⟨0, Nat.zero_lt_succ _⟩ t) := by
        rw [admissibleProjection_zero]
      _ = _ := admissibleProjection_distance d hd0 hd A _ t
  rw [hdist]
  have hsplit := Fin.sum_univ_succ (fun j : Fin (A.terminal + 1) =>
    realGammaTwoWeight (j : ℕ) *
      finiteSetDistance d (A.level j) (A.level_nonempty j) t)
  rw [← realChainPointCost] at hsplit
  simp only [Fin.val_zero, realGammaTwoWeight_zero, one_mul] at hsplit
  rw [hsplit]
  exact le_add_of_nonneg_right (Finset.sum_nonneg fun i _ =>
    mul_nonneg (realGammaTwoWeight_nonneg _)
      (finiteSetDistance_nonneg d hd _ _))

/-- The level-zero term in every admissible chain already controls half the
diameter. This is the deterministic part of the first-big-leap proof.

**Lean implementation helper.** -/
theorem finiteDistanceDiameter_le_two_chainCost
    (d : T → T → ℝ) (hd : ∀ s t, 0 ≤ d s t)
    (hsymm : ∀ s t, d s t = d t s)
    (htri : ∀ r s t, d r t ≤ d r s + d s t)
    (hd0 : ∀ t, d t t = 0) (A : HDP.FiniteAdmissibleChain T) :
    finiteDistanceDiameter d ≤ 2 * realChainCost d A := by
  unfold finiteDistanceDiameter
  apply Finset.sup'_le
  intro p hp
  have hpa := (distance_anchor_le_chainPointCost d hd hd0 A p.1).trans
    (realChainPointCost_le_realChainCost d A p.1)
  have hqa := (distance_anchor_le_chainPointCost d hd hd0 A p.2).trans
    (realChainPointCost_le_realChainCost d A p.2)
  calc
    d p.1 p.2 ≤ d p.1 (admissibleAnchor A) +
        d (admissibleAnchor A) p.2 := htri _ _ _
    _ = d p.1 (admissibleAnchor A) +
        d p.2 (admissibleAnchor A) := by
      rw [hsymm (admissibleAnchor A) p.2]
    _ ≤ realChainCost d A + realChainCost d A := add_le_add hpa hqa
    _ = 2 * realChainCost d A := by ring

/-- Exercise 8.35 helper: gamma-two controls half the diameter.

**Book Exercise 8.35.** -/
theorem half_finiteDistanceDiameter_le_gamma2
    (d : T → T → ℝ) (hd : ∀ s t, 0 ≤ d s t)
    (hsymm : ∀ s t, d s t = d t s)
    (htri : ∀ r s t, d r t ≤ d r s + d s t)
    (hd0 : ∀ t, d t t = 0) :
    finiteDistanceDiameter d / 2 ≤
      (HDP.gamma2 (fun s t => ENNReal.ofReal (d s t))).toReal := by
  rw [HDP.gamma2, ENNReal.toReal_iInf
    (fun A => chainCost_ofReal_ne_top d hd A)]
  letI : Nonempty (HDP.FiniteAdmissibleChain T) :=
    ⟨HDP.canonicalFiniteAdmissibleChain T⟩
  apply le_ciInf
  intro A
  rw [chainCost_toReal_ofReal d hd A]
  linarith [finiteDistanceDiameter_le_two_chainCost d hd hsymm htri hd0 A]

/-- Shows that the real `γ₂` scale weight is monotone.

**Lean implementation helper.** -/
private theorem realGammaTwoWeight_mono {k l : ℕ} (hkl : k ≤ l) :
    realGammaTwoWeight k ≤ realGammaTwoWeight l := by
  unfold realGammaTwoWeight
  apply Real.sqrt_le_sqrt
  exact pow_le_pow_right₀ (by norm_num : (1 : ℝ) ≤ 2) hkl

/-- Some real `γ₂` weight is at least `max(1,u)`.

**Lean implementation helper.** -/
private theorem exists_realGammaTwoWeight_ge_maxOne (u : ℝ) :
    ∃ k : ℕ, max 1 u ≤ realGammaTwoWeight k := by
  let M := max 1 u
  have hM0 : 0 ≤ M := (by dsimp [M]; positivity)
  obtain ⟨n, hn⟩ := exists_nat_gt (M ^ 2)
  refine ⟨n, ?_⟩
  rw [← sq_le_sq₀ hM0 (realGammaTwoWeight_nonneg n), realGammaTwoWeight_sq]
  have hn2 : (n : ℝ) ≤ (2 : ℝ) ^ n := by
    exact_mod_cast nat_le_two_pow_self n
  exact hn.le.trans hn2

/-- The first dyadic chaining level whose weight reaches `max 1 u`.

**Lean implementation helper.** -/
noncomputable def firstBigLeapIndex (u : ℝ) : ℕ :=
  Nat.find (exists_realGammaTwoWeight_ge_maxOne u)

/-- The `γ₂` weight at the first big-leap index is at least `max(1,u)`.

**Lean implementation helper.** -/
theorem max_one_le_realGammaTwoWeight_firstBigLeapIndex (u : ℝ) :
    max 1 u ≤ realGammaTwoWeight (firstBigLeapIndex u) :=
  Nat.find_spec (exists_realGammaTwoWeight_ge_maxOne u)

/-- The `γ₂` weight at the first big-leap index is at most `2 max(1,u)`.

**Lean implementation helper.** -/
theorem realGammaTwoWeight_firstBigLeapIndex_le (u : ℝ) :
    realGammaTwoWeight (firstBigLeapIndex u) ≤ 2 * max 1 u := by
  let h := exists_realGammaTwoWeight_ge_maxOne u
  by_cases hk : firstBigLeapIndex u = 0
  · rw [hk, realGammaTwoWeight_zero]
    have : (1 : ℝ) ≤ max 1 u := le_max_left _ _
    linarith
  · let m := firstBigLeapIndex u - 1
    have hm : m < firstBigLeapIndex u := by
      dsimp [m]
      omega
    have hmnot := Nat.find_min h hm
    have hmlt : realGammaTwoWeight m < max 1 u := lt_of_not_ge hmnot
    have hsucc : m + 1 = firstBigLeapIndex u := by
      dsimp [m]
      omega
    rw [← hsucc]
    exact (realGammaTwoWeight_succ_le_two m).trans
      (mul_le_mul_of_nonneg_left hmlt.le (by norm_num))

/-- The source's first-big-leap level, capped at the terminal level of a finite
admissible chain.

**Lean implementation helper.** -/
def cappedFirstBigLeapIndex (A : HDP.FiniteAdmissibleChain T) (u : ℝ) : ℕ :=
  min (firstBigLeapIndex u) A.terminal

/-- Tail parameter used at the capped first leap.

**Lean implementation helper.** -/
def cappedFirstBigLeapScale (A : HDP.FiniteAdmissibleChain T) (u : ℝ) : ℝ :=
  max u (realGammaTwoWeight (cappedFirstBigLeapIndex A u))

/-- The first big-leap index capped at the chain length never exceeds the terminal level.

**Lean implementation helper.** -/
theorem cappedFirstBigLeapIndex_le_terminal
    (A : HDP.FiniteAdmissibleChain T) (u : ℝ) :
    cappedFirstBigLeapIndex A u ≤ A.terminal := min_le_right _ _

/-- Shows that the corresponding capped `γ₂` weight is nonnegative.

**Lean implementation helper.** -/
theorem cappedFirstBigLeapScale_nonneg
    (A : HDP.FiniteAdmissibleChain T) (u : ℝ) :
    0 ≤ cappedFirstBigLeapScale A u :=
  (realGammaTwoWeight_nonneg _).trans (le_max_right _ _)

/-- The capped first-big-leap scale is at least `1`.

**Lean implementation helper.** -/
theorem one_le_cappedFirstBigLeapScale
    (A : HDP.FiniteAdmissibleChain T) (u : ℝ) :
    1 ≤ cappedFirstBigLeapScale A u := by
  have hmono : realGammaTwoWeight 0 ≤
      realGammaTwoWeight (cappedFirstBigLeapIndex A u) :=
    realGammaTwoWeight_mono (Nat.zero_le _)
  rw [realGammaTwoWeight_zero] at hmono
  exact hmono.trans (le_max_right _ _)

/-- The capped first-big-leap scale is at most `2 max(1,u)`.

**Lean implementation helper.** -/
theorem cappedFirstBigLeapScale_le_two_max_one
    (A : HDP.FiniteAdmissibleChain T) (u : ℝ) :
    cappedFirstBigLeapScale A u ≤ 2 * max 1 u := by
  apply max_le
  · have hu : u ≤ max 1 u := le_max_right _ _
    have hM0 : 0 ≤ max 1 u := (le_max_left _ _).trans' (by norm_num)
    nlinarith
  · exact (realGammaTwoWeight_mono (min_le_left _ _)).trans
      (realGammaTwoWeight_firstBigLeapIndex_le u)

/-- The `γ₂` weight at the capped index is bounded by the associated capped scale.

**Lean implementation helper.** -/
theorem weight_cappedFirstBigLeapIndex_le_scale
    (A : HDP.FiniteAdmissibleChain T) (u : ℝ) :
    realGammaTwoWeight (cappedFirstBigLeapIndex A u) ≤
      cappedFirstBigLeapScale A u := le_max_right _ _

/-- The parameter `u` is bounded by the capped first-big-leap scale.

**Lean implementation helper.** -/
theorem u_le_cappedFirstBigLeapScale
    (A : HDP.FiniteAdmissibleChain T) (u : ℝ) :
    u ≤ cappedFirstBigLeapScale A u := le_max_left _ _

/-- When the cap is strictly below the terminal level, its `γ₂` weight is at least `max(1,u)`.

**Lean implementation helper.** -/
theorem max_one_le_weight_capped_of_lt_terminal
    (A : HDP.FiniteAdmissibleChain T) (u : ℝ)
    (hk : cappedFirstBigLeapIndex A u < A.terminal) :
    max 1 u ≤ realGammaTwoWeight (cappedFirstBigLeapIndex A u) := by
  have hfind : firstBigLeapIndex u ≤ A.terminal := by
    by_contra h
    have hterm : cappedFirstBigLeapIndex A u = A.terminal := by
      simp [cappedFirstBigLeapIndex, min_eq_right (le_of_not_ge h)]
    omega
  rw [cappedFirstBigLeapIndex, min_eq_left hfind]
  exact max_one_le_realGammaTwoWeight_firstBigLeapIndex u

/-- The double-exponential admissible-cardinality bound `2^(2^m)` is at most `exp(2^m)` after coercion to `ℝ`.

**Lean implementation helper.** -/
private theorem dyadicCardCast_le_exp (m : ℕ) :
    ((2 ^ (2 ^ m) : ℕ) : ℝ) ≤ Real.exp (((2 ^ m : ℕ) : ℝ)) := by
  have htwo : (2 : ℝ) ≤ Real.exp 1 := by
    nlinarith [Real.exp_one_gt_d9]
  norm_cast at htwo ⊢
  rw [show ((2 ^ (2 ^ m) : ℕ) : ℝ) = (2 : ℝ) ^ (2 ^ m) by norm_num]
  calc
    (2 : ℝ) ^ (2 ^ m) ≤ (Real.exp 1) ^ (2 ^ m) :=
      pow_le_pow_left₀ (by norm_num) htwo _
    _ = Real.exp (((2 ^ m : ℕ) : ℝ) * 1) :=
      (Real.exp_nat_mul 1 (2 ^ m)).symm
    _ = Real.exp (((2 ^ m : ℕ) : ℝ)) := by ring_nf

/-- The level-cardinality factor times the first-big-leap tail is at most `exp(-v²)`.

**Lean implementation helper.** -/
private theorem level_count_times_firstLeapTail_le
    (k : ℕ) {v : ℝ} (hv1 : 1 ≤ v)
    (hwv : realGammaTwoWeight k ≤ v) :
    ((2 ^ (2 ^ k) : ℕ) : ℝ) *
        (2 * Real.exp (-(64 * v) ^ 2)) ≤ Real.exp (-v ^ 2) := by
  have hv0 : 0 ≤ v := zero_le_one.trans hv1
  have hpowv : (((2 ^ k : ℕ) : ℝ)) ≤ v ^ 2 := by
    rw [show (((2 ^ k : ℕ) : ℝ)) = (2 : ℝ) ^ k by norm_num,
      ← realGammaTwoWeight_sq k]
    exact (sq_le_sq₀ (realGammaTwoWeight_nonneg k) hv0).2 hwv
  have hcount : ((2 ^ (2 ^ k) : ℕ) : ℝ) ≤ Real.exp (v ^ 2) :=
    (dyadicCardCast_le_exp k).trans (Real.exp_le_exp.mpr hpowv)
  have htwoexp : (2 : ℝ) ≤ Real.exp (v ^ 2) := by
    calc
      (2 : ℝ) ≤ Real.exp 1 := by nlinarith [Real.exp_one_gt_d9]
      _ ≤ Real.exp (v ^ 2) := Real.exp_le_exp.mpr (by nlinarith)
  calc
    ((2 ^ (2 ^ k) : ℕ) : ℝ) * (2 * Real.exp (-(64 * v) ^ 2)) ≤
        Real.exp (v ^ 2) * (2 * Real.exp (-(64 * v) ^ 2)) :=
      mul_le_mul_of_nonneg_right hcount (by positivity)
    _ = 2 * Real.exp (v ^ 2 - (64 * v) ^ 2) := by
      rw [show Real.exp (v ^ 2) * (2 * Real.exp (-(64 * v) ^ 2)) =
        2 * (Real.exp (v ^ 2) * Real.exp (-(64 * v) ^ 2)) by ring,
        ← Real.exp_add]
      congr 2
    _ ≤ Real.exp (v ^ 2) * Real.exp (v ^ 2 - (64 * v) ^ 2) :=
      mul_le_mul_of_nonneg_right htwoexp (Real.exp_pos _).le
    _ = Real.exp (2 * v ^ 2 - (64 * v) ^ 2) := by
      rw [← Real.exp_add]
      congr 1
      ring
    _ ≤ Real.exp (-v ^ 2) := by
      apply Real.exp_le_exp.mpr
      nlinarith [sq_nonneg v]

/-- The edge-cardinality factor times the fine-scale tail is at most `exp(-4·2^k)`.

**Lean implementation helper.** -/
private theorem edge_count_times_fineTail_le (k : ℕ) :
    ((2 ^ (2 ^ (k + 2)) : ℕ) : ℝ) *
        (2 * Real.exp (-(64 * realGammaTwoWeight (k + 1)) ^ 2)) ≤
      Real.exp (-4 * ((2 : ℝ) ^ k)) := by
  let a : ℝ := (2 : ℝ) ^ k
  have ha1 : 1 ≤ a := by
    dsimp [a]
    exact one_le_pow₀ (by norm_num)
  have hcount : ((2 ^ (2 ^ (k + 2)) : ℕ) : ℝ) ≤
      Real.exp (4 * a) := by
    calc
      ((2 ^ (2 ^ (k + 2)) : ℕ) : ℝ) ≤
          Real.exp (((2 ^ (k + 2) : ℕ) : ℝ)) :=
        dyadicCardCast_le_exp (k + 2)
      _ = Real.exp (4 * a) := by
        congr 2
        dsimp [a]
        push_cast
        rw [show k + 2 = k + 1 + 1 by omega, pow_succ, pow_succ]
        ring
  have htwoexp : (2 : ℝ) ≤ Real.exp a := by
    calc
      (2 : ℝ) ≤ Real.exp 1 := by nlinarith [Real.exp_one_gt_d9]
      _ ≤ Real.exp a := Real.exp_le_exp.mpr ha1
  have hw2 : realGammaTwoWeight (k + 1) ^ 2 = 2 * a := by
    rw [realGammaTwoWeight_sq]
    dsimp [a]
    rw [pow_succ]
    ring
  calc
    ((2 ^ (2 ^ (k + 2)) : ℕ) : ℝ) *
          (2 * Real.exp (-(64 * realGammaTwoWeight (k + 1)) ^ 2)) ≤
        Real.exp (4 * a) *
          (2 * Real.exp (-(64 * realGammaTwoWeight (k + 1)) ^ 2)) :=
      mul_le_mul_of_nonneg_right hcount (by positivity)
    _ = 2 * Real.exp (4 * a -
        (64 * realGammaTwoWeight (k + 1)) ^ 2) := by
      rw [show Real.exp (4 * a) * (2 * Real.exp
          (-(64 * realGammaTwoWeight (k + 1)) ^ 2)) =
        2 * (Real.exp (4 * a) * Real.exp
          (-(64 * realGammaTwoWeight (k + 1)) ^ 2)) by ring,
        ← Real.exp_add]
      congr 2
    _ ≤ Real.exp a * Real.exp (4 * a -
        (64 * realGammaTwoWeight (k + 1)) ^ 2) :=
      mul_le_mul_of_nonneg_right htwoexp (Real.exp_pos _).le
    _ = Real.exp (5 * a -
        (64 * realGammaTwoWeight (k + 1)) ^ 2) := by
      rw [← Real.exp_add]
      congr 1
      ring
    _ ≤ Real.exp (-4 * ((2 : ℝ) ^ k)) := by
      apply Real.exp_le_exp.mpr
      dsimp [a] at hw2 ⊢
      nlinarith [hw2]

/-- Bad first-leap increments from the level selected by the source proof.

**Lean implementation helper.** -/
def firstBigLeapBad (X : HDP.RandomProcess T Ω) (d : T → T → ℝ)
    (A : HDP.FiniteAdmissibleChain T) (K v : ℝ) (k : Fin (A.terminal + 1)) :
    Set Ω :=
  ⋃ s ∈ A.level k,
    {ω | 64 * K * v * finiteDistanceDiameter d <
      |edgeIncrement X (s, admissibleAnchor A) ω|}

/-- Bad fine-scale increments after the first big leap.

**Lean implementation helper.** -/
def genericFineBadAtScale (X : HDP.RandomProcess T Ω)
    (d : T → T → ℝ) (A : HDP.FiniteAdmissibleChain T)
    (K : ℝ) (k : ℕ) : Set Ω :=
  ⋃ p ∈ admissibleEdges d A k,
    {ω | 64 * K * realGammaTwoWeight (k + 1) * d p.1 p.2 <
      |edgeIncrement X p ω|}

/-- The event that some fine-scale chaining edge has an increment larger than its scale threshold.

**Lean implementation helper.** -/
def genericFineBad (X : HDP.RandomProcess T Ω)
    (d : T → T → ℝ) (A : HDP.FiniteAdmissibleChain T)
    (K : ℝ) (k₀ : ℕ) : Set Ω :=
  ⋃ k ∈ Finset.Ico k₀ A.terminal, genericFineBadAtScale X d A K k

/-- The first-big-leap failure event has probability at most `exp(-v²)`.

**Lean implementation helper.** -/
theorem measure_firstBigLeapBad [IsProbabilityMeasure μ]
    (X : HDP.RandomProcess T Ω) (hXm : ∀ t, Measurable (X t))
    (d : T → T → ℝ) (hd : ∀ s t, 0 ≤ d s t)
    (A : HDP.FiniteAdmissibleChain T) {K v : ℝ}
    (hK : 0 < K) (hv1 : 1 ≤ v)
    (hinc : HDP.HasSubGaussianIncrementsWith X μ d K)
    (k : Fin (A.terminal + 1))
    (hwv : realGammaTwoWeight (k : ℕ) ≤ v) :
    μ (firstBigLeapBad X d A K v k) ≤ ENNReal.ofReal (Real.exp (-v ^ 2)) := by
  let q : ℝ := 2 * Real.exp (-(64 * v) ^ 2)
  have hq0 : 0 ≤ q := by positivity
  have hv0 : 0 ≤ v := zero_le_one.trans hv1
  calc
    μ (firstBigLeapBad X d A K v k) ≤
        ∑ s ∈ A.level k,
          μ {ω | 64 * K * v * finiteDistanceDiameter d <
            |edgeIncrement X (s, admissibleAnchor A) ω|} :=
      measure_biUnion_finset_le _ _
    _ ≤ ∑ _s ∈ A.level k, ENNReal.ofReal q := by
      apply Finset.sum_le_sum
      intro s hs
      let p : T × T := (s, admissibleAnchor A)
      have hthreshold : 8 * K * (8 * v) * d p.1 p.2 ≤
          64 * K * v * finiteDistanceDiameter d := by
        have hdist := distance_le_finiteDistanceDiameter d p.1 p.2
        have hcoef : 0 ≤ 64 * K * v := by positivity
        calc
          8 * K * (8 * v) * d p.1 p.2 =
              (64 * K * v) * d p.1 p.2 := by ring
          _ ≤ (64 * K * v) * finiteDistanceDiameter d :=
            mul_le_mul_of_nonneg_left hdist hcoef
          _ = _ := by ring
      calc
        μ {ω | 64 * K * v * finiteDistanceDiameter d <
              |edgeIncrement X (s, admissibleAnchor A) ω|} ≤
            μ {ω | 8 * K * (8 * v) * d p.1 p.2 <
              |edgeIncrement X p ω|} := by
          apply measure_mono
          intro ω hω
          change 64 * K * v * finiteDistanceDiameter d <
            |edgeIncrement X p ω| at hω
          change 8 * K * (8 * v) * d p.1 p.2 < |edgeIncrement X p ω|
          exact hthreshold.trans_lt hω
        _ ≤ ENNReal.ofReal q := by
          dsimp [q]
          have htail := edgeIncrement_tail X hXm d hd
            (K := K) (u := 8 * v) hK (by positivity) hinc p
          simpa only [show 8 * (8 * v) = 64 * v by ring] using htail
    _ = ENNReal.ofReal (∑ _s ∈ A.level k, q) := by
      exact (ENNReal.ofReal_sum_of_nonneg (fun _ _ => hq0)).symm
    _ ≤ ENNReal.ofReal (Real.exp (-v ^ 2)) := by
      apply ENNReal.ofReal_le_ofReal
      have hcard : ((A.level k).card : ℝ) ≤
          ((2 ^ (2 ^ (k : ℕ)) : ℕ) : ℝ) := by
        exact_mod_cast A.level_card_le k
      calc
        (∑ _s ∈ A.level k, q) = ((A.level k).card : ℝ) * q := by simp
        _ ≤ ((2 ^ (2 ^ (k : ℕ)) : ℕ) : ℝ) * q :=
          mul_le_mul_of_nonneg_right hcard hq0
        _ ≤ Real.exp (-v ^ 2) :=
          level_count_times_firstLeapTail_le (k : ℕ) hv1 hwv

/-- The fine-edge failure event at scale `k` has probability at most `exp(-4·2^k)`.

**Lean implementation helper.** -/
theorem measure_genericFineBadAtScale [IsProbabilityMeasure μ]
    (X : HDP.RandomProcess T Ω) (hXm : ∀ t, Measurable (X t))
    (d : T → T → ℝ) (hd : ∀ s t, 0 ≤ d s t)
    (A : HDP.FiniteAdmissibleChain T) {K : ℝ}
    (hK : 0 < K) (hinc : HDP.HasSubGaussianIncrementsWith X μ d K)
    {k : ℕ} (hk : k < A.terminal) :
    μ (genericFineBadAtScale X d A K k) ≤
      ENNReal.ofReal (Real.exp (-4 * ((2 : ℝ) ^ k))) := by
  let q : ℝ := 2 * Real.exp (-(64 * realGammaTwoWeight (k + 1)) ^ 2)
  have hq0 : 0 ≤ q := by positivity
  calc
    μ (genericFineBadAtScale X d A K k) ≤
        ∑ p ∈ admissibleEdges d A k,
          μ {ω | 64 * K * realGammaTwoWeight (k + 1) * d p.1 p.2 <
            |edgeIncrement X p ω|} := measure_biUnion_finset_le _ _
    _ ≤ ∑ _p ∈ admissibleEdges d A k, ENNReal.ofReal q := by
      apply Finset.sum_le_sum
      intro p hp
      have htail := edgeIncrement_tail X hXm d hd
        (K := K) (u := 8 * realGammaTwoWeight (k + 1)) hK
        (mul_nonneg (by norm_num) (realGammaTwoWeight_nonneg _)) hinc p
      dsimp [q]
      simpa only [show 8 * K * (8 * realGammaTwoWeight (k + 1)) =
          64 * K * realGammaTwoWeight (k + 1) by ring,
        show 8 * (8 * realGammaTwoWeight (k + 1)) =
          64 * realGammaTwoWeight (k + 1) by ring] using htail
    _ = ENNReal.ofReal (∑ _p ∈ admissibleEdges d A k, q) := by
      exact (ENNReal.ofReal_sum_of_nonneg (fun _ _ => hq0)).symm
    _ ≤ ENNReal.ofReal (Real.exp (-4 * ((2 : ℝ) ^ k))) := by
      apply ENNReal.ofReal_le_ofReal
      have hcard : ((admissibleEdges d A k).card : ℝ) ≤
          ((2 ^ (2 ^ (k + 2)) : ℕ) : ℝ) := by
        exact_mod_cast card_admissibleEdges_le d A hk
      calc
        (∑ _p ∈ admissibleEdges d A k, q) =
            ((admissibleEdges d A k).card : ℝ) * q := by simp
        _ ≤ ((2 ^ (2 ^ (k + 2)) : ℕ) : ℝ) * q :=
          mul_le_mul_of_nonneg_right hcard hq0
        _ ≤ Real.exp (-4 * ((2 : ℝ) ^ k)) :=
          edge_count_times_fineTail_le k

/-- The fine-scale tail at level `k+1` is at most half the tail at level `k`.

**Lean implementation helper.** -/
private theorem fineTail_succ_le_half (k : ℕ) :
    Real.exp (-4 * ((2 : ℝ) ^ (k + 1))) ≤
      (1 / 2 : ℝ) * Real.exp (-4 * ((2 : ℝ) ^ k)) := by
  let a : ℝ := (2 : ℝ) ^ k
  have ha1 : 1 ≤ a := by
    dsimp [a]
    exact one_le_pow₀ (by norm_num)
  have hsmall : Real.exp (-4 * a) ≤ (1 / 2 : ℝ) := by
    have htwo : (2 : ℝ) ≤ Real.exp 1 := by
      nlinarith [Real.add_one_le_exp (1 : ℝ)]
    have hprod : 2 * Real.exp (-4 * a) ≤ 1 := by
      calc
        2 * Real.exp (-4 * a) ≤
            Real.exp 1 * Real.exp (-4 * a) :=
          mul_le_mul_of_nonneg_right htwo (Real.exp_pos _).le
        _ = Real.exp (1 - 4 * a) := by
          rw [← Real.exp_add]
          congr 1
          ring
        _ ≤ 1 := by
          simpa only [Real.exp_zero] using
            (Real.exp_le_exp.mpr (show 1 - 4 * a ≤ 0 by linarith))
    linarith
  have hstep : (2 : ℝ) ^ (k + 1) = 2 * a := by
    dsimp [a]
    rw [pow_succ]
    ring
  rw [hstep]
  calc
    Real.exp (-4 * (2 * a)) =
        Real.exp (-4 * a) * Real.exp (-4 * a) := by
      rw [← Real.exp_add]
      congr 1
      ring
    _ ≤ (1 / 2 : ℝ) * Real.exp (-4 * a) :=
      mul_le_mul_of_nonneg_right hsmall (Real.exp_pos _).le

/-- Shifting a fine-scale tail forward by `j` multiplies its upper bound by at most `2⁻ʲ`.

**Lean implementation helper.** -/
private theorem fineTail_shift_le (k j : ℕ) :
    Real.exp (-4 * ((2 : ℝ) ^ (k + j))) ≤
      Real.exp (-4 * ((2 : ℝ) ^ k)) * (1 / 2 : ℝ) ^ j := by
  induction j with
  | zero => simp
  | succ j ih =>
      calc
        Real.exp (-4 * ((2 : ℝ) ^ (k + (j + 1)))) =
            Real.exp (-4 * ((2 : ℝ) ^ ((k + j) + 1))) := by
              congr 3
        _ ≤ (1 / 2 : ℝ) *
            Real.exp (-4 * ((2 : ℝ) ^ (k + j))) :=
          fineTail_succ_le_half (k + j)
        _ ≤ (1 / 2 : ℝ) *
            (Real.exp (-4 * ((2 : ℝ) ^ k)) * (1 / 2 : ℝ) ^ j) :=
          mul_le_mul_of_nonneg_left ih (by norm_num)
        _ = Real.exp (-4 * ((2 : ℝ) ^ k)) *
            (1 / 2 : ℝ) ^ (j + 1) := by
          rw [pow_succ]
          ring

/-- The sum of fine-scale tails from `k₀` to `N` is at most `exp(-2·2^k₀)`.

**Lean implementation helper.** -/
private theorem sum_fineTails_Ico_le (k₀ N : ℕ) :
    (∑ k ∈ Finset.Ico k₀ N,
      Real.exp (-4 * ((2 : ℝ) ^ k))) ≤
        Real.exp (-2 * ((2 : ℝ) ^ k₀)) := by
  rw [Finset.sum_Ico_eq_sum_range]
  calc
    (∑ j ∈ Finset.range (N - k₀),
        Real.exp (-4 * ((2 : ℝ) ^ (k₀ + j)))) ≤
        ∑ j ∈ Finset.range (N - k₀),
          Real.exp (-4 * ((2 : ℝ) ^ k₀)) * (1 / 2 : ℝ) ^ j := by
      exact Finset.sum_le_sum fun j hj => fineTail_shift_le k₀ j
    _ = Real.exp (-4 * ((2 : ℝ) ^ k₀)) *
        ∑ j ∈ Finset.range (N - k₀), (1 / 2 : ℝ) ^ j := by
      rw [Finset.mul_sum]
    _ ≤ Real.exp (-4 * ((2 : ℝ) ^ k₀)) * 2 := by
      exact mul_le_mul_of_nonneg_left (sum_geometric_two_le _)
        (Real.exp_pos _).le
    _ ≤ Real.exp (-2 * ((2 : ℝ) ^ k₀)) := by
      let a : ℝ := (2 : ℝ) ^ k₀
      have ha1 : 1 ≤ a := by
        dsimp [a]
        exact one_le_pow₀ (by norm_num)
      have htwo : (2 : ℝ) ≤ Real.exp (2 * a) := by
        calc
          (2 : ℝ) ≤ Real.exp 1 := by
            nlinarith [Real.add_one_le_exp (1 : ℝ)]
          _ ≤ Real.exp (2 * a) := Real.exp_le_exp.mpr (by linarith)
      calc
        Real.exp (-4 * ((2 : ℝ) ^ k₀)) * 2 ≤
            Real.exp (-4 * a) * Real.exp (2 * a) := by
          dsimp [a]
          exact mul_le_mul_of_nonneg_left htwo (Real.exp_pos _).le
        _ = Real.exp (-2 * a) := by
          rw [← Real.exp_add]
          congr 1
          ring

/-- The union of fine-scale failure events from `k₀` onward has probability at most `exp(-2·2^k₀)`.

**Lean implementation helper.** -/
theorem measure_genericFineBad [IsProbabilityMeasure μ]
    (X : HDP.RandomProcess T Ω) (hXm : ∀ t, Measurable (X t))
    (d : T → T → ℝ) (hd : ∀ s t, 0 ≤ d s t)
    (A : HDP.FiniteAdmissibleChain T) {K : ℝ}
    (hK : 0 < K) (hinc : HDP.HasSubGaussianIncrementsWith X μ d K)
    (k₀ : ℕ) :
    μ (genericFineBad X d A K k₀) ≤
      ENNReal.ofReal (Real.exp (-2 * ((2 : ℝ) ^ k₀))) := by
  calc
    μ (genericFineBad X d A K k₀) ≤
        ∑ k ∈ Finset.Ico k₀ A.terminal,
          μ (genericFineBadAtScale X d A K k) :=
      measure_biUnion_finset_le _ _
    _ ≤ ∑ k ∈ Finset.Ico k₀ A.terminal,
        ENNReal.ofReal (Real.exp (-4 * ((2 : ℝ) ^ k))) := by
      apply Finset.sum_le_sum
      intro k hk
      exact measure_genericFineBadAtScale X hXm d hd A hK hinc
        (Finset.mem_Ico.mp hk).2
    _ = ENNReal.ofReal (∑ k ∈ Finset.Ico k₀ A.terminal,
        Real.exp (-4 * ((2 : ℝ) ^ k))) := by
      exact (ENNReal.ofReal_sum_of_nonneg (fun _ _ => (Real.exp_pos _).le)).symm
    _ ≤ ENNReal.ofReal (Real.exp (-2 * ((2 : ℝ) ^ k₀))) := by
      exact ENNReal.ofReal_le_ofReal (sum_fineTails_Ico_le k₀ A.terminal)

/-- Outside the fine-scale failure event, every scale-`k` edge increment is at most `64 K γ₂(k+1)` times its edge distance.

**Lean implementation helper.** -/
theorem edgeIncrement_le_of_notMem_genericFineBad
    (X : HDP.RandomProcess T Ω) (d : T → T → ℝ)
    (A : HDP.FiniteAdmissibleChain T) {K : ℝ} {k₀ : ℕ} {ω : Ω}
    (hgood : ω ∉ genericFineBad X d A K k₀)
    {k : ℕ} (hk : k ∈ Finset.Ico k₀ A.terminal) {p : T × T}
    (hp : p ∈ admissibleEdges d A k) :
    |edgeIncrement X p ω| ≤
      64 * K * realGammaTwoWeight (k + 1) * d p.1 p.2 := by
  by_contra hbad
  have hscale : ω ∈ genericFineBadAtScale X d A K k := by
    exact mem_iUnion_of_mem p (mem_iUnion_of_mem hp (by
      change 64 * K * realGammaTwoWeight (k + 1) * d p.1 p.2 <
        |edgeIncrement X p ω|
      exact lt_of_not_ge hbad))
  exact hgood (mem_iUnion_of_mem k (mem_iUnion_of_mem hk hscale))

/-- Outside the first-big-leap failure event, every anchor increment at that level is at most `64 K v` times the distance diameter.

**Lean implementation helper.** -/
theorem edgeIncrement_le_of_notMem_firstBigLeapBad
    (X : HDP.RandomProcess T Ω) (d : T → T → ℝ)
    (A : HDP.FiniteAdmissibleChain T) {K v : ℝ}
    {k : Fin (A.terminal + 1)} {ω : Ω}
    (hgood : ω ∉ firstBigLeapBad X d A K v k)
    {s : T} (hs : s ∈ A.level k) :
    |edgeIncrement X (s, admissibleAnchor A) ω| ≤
      64 * K * v * finiteDistanceDiameter d := by
  by_contra hbad
  exact hgood (mem_iUnion_of_mem s (mem_iUnion_of_mem hs (by
    change 64 * K * v * finiteDistanceDiameter d <
      |edgeIncrement X (s, admissibleAnchor A) ω|
    exact lt_of_not_ge hbad)))

/-- The weighted sum of distances between consecutive Dudley projections is at most three times the pointwise real chain cost.

**Lean implementation helper.** -/
private theorem weightedDudleyProjectionDistanceSum_le
    (d : T → T → ℝ) (hd : ∀ s t, 0 ≤ d s t)
    (hsymm : ∀ s t, d s t = d t s)
    (htri : ∀ r s t, d r t ≤ d r s + d s t)
    (hd0 : ∀ t, d t t = 0)
    (A : HDP.FiniteAdmissibleChain T) (t : T) :
    (∑ k ∈ Finset.range A.terminal,
      realGammaTwoWeight (k + 1) *
        d ((admissibleDudleyChain d A).projection (k + 1) t)
          ((admissibleDudleyChain d A).projection k t)) ≤
      3 * realChainPointCost d A t := by
  rw [← Fin.sum_univ_eq_sum_range]
  calc
    (∑ i : Fin A.terminal,
        realGammaTwoWeight ((i : ℕ) + 1) *
          d ((admissibleDudleyChain d A).projection ((i : ℕ) + 1) t)
            ((admissibleDudleyChain d A).projection (i : ℕ) t)) ≤
        ∑ i : Fin A.terminal,
          realGammaTwoWeight (i.succ : ℕ) *
            (finiteSetDistance d (A.level i.succ)
                (A.level_nonempty i.succ) t +
              finiteSetDistance d (A.level i.castSucc)
                (A.level_nonempty i.castSucc) t) := by
      apply Finset.sum_le_sum
      intro i hi
      have hsuccFin :
          (⟨(i : ℕ) + 1, by omega⟩ : Fin (A.terminal + 1)) = i.succ :=
        Fin.eq_of_val_eq rfl
      have hcastFin :
          (⟨(i : ℕ), by omega⟩ : Fin (A.terminal + 1)) = i.castSucc :=
        Fin.eq_of_val_eq rfl
      have htriangle :
          d (admissibleProjection d A i.succ t)
              (admissibleProjection d A i.castSucc t) ≤
            finiteSetDistance d (A.level i.succ)
                (A.level_nonempty i.succ) t +
              finiteSetDistance d (A.level i.castSucc)
                (A.level_nonempty i.castSucc) t := by
        calc
          d (admissibleProjection d A i.succ t)
              (admissibleProjection d A i.castSucc t) ≤
              d (admissibleProjection d A i.succ t) t +
                d t (admissibleProjection d A i.castSucc t) := htri _ t _
          _ = d t (admissibleProjection d A i.succ t) +
                d t (admissibleProjection d A i.castSucc t) := by rw [hsymm]
          _ = _ := by
            rw [admissibleProjection_distance d hd0 hd,
              admissibleProjection_distance d hd0 hd]
      have hrew :
          d ((admissibleDudleyChain d A).projection ((i : ℕ) + 1) t)
              ((admissibleDudleyChain d A).projection (i : ℕ) t) =
            d (admissibleProjection d A i.succ t)
              (admissibleProjection d A i.castSucc t) := by
        simp [admissibleDudleyChain, i.isLt, hsuccFin, hcastFin]
      rw [hrew]
      exact mul_le_mul_of_nonneg_left htriangle
        (realGammaTwoWeight_nonneg _)
    _ ≤ 3 * realChainPointCost d A t :=
      weightedProjectionDistanceSum_le d hd A t

/-- Summed increment control by chain cost. The fine part of the truncated telescope costs only the ordinary chain
cost; the tail parameter appears solely in the first big leap.

**Book Equation (8.50).** -/
theorem truncatedFineIncrement_le
    (X : HDP.RandomProcess T Ω) (d : T → T → ℝ)
    (hd : ∀ s t, 0 ≤ d s t) (hsymm : ∀ s t, d s t = d t s)
    (htri : ∀ r s t, d r t ≤ d r s + d s t)
    (hd0 : ∀ t, d t t = 0)
    (A : HDP.FiniteAdmissibleChain T) {K : ℝ} {k₀ : ℕ} {ω : Ω}
    (hK0 : 0 ≤ K) (hk₀ : k₀ ≤ A.terminal)
    (hgood : ω ∉ genericFineBad X d A K k₀) (t : T) :
    |X t ω - X (admissibleProjection d A
        ⟨k₀, Nat.lt_succ_of_le hk₀⟩ t) ω| ≤
      192 * K * realChainPointCost d A t := by
  let C := admissibleDudleyChain d A
  have htail : X t ω - X (admissibleProjection d A
        ⟨k₀, Nat.lt_succ_of_le hk₀⟩ t) ω =
      ∑ k ∈ Finset.Ico k₀ A.terminal,
        dudleyScaleIncrement C X k t ω := by
    have htel := Finset.sum_Ico_sub
      (fun k => X (C.projection k t) ω) hk₀
    have hproj : C.projection k₀ t =
        admissibleProjection d A ⟨k₀, Nat.lt_succ_of_le hk₀⟩ t := by
      dsimp [C, admissibleDudleyChain]
      rw [dif_pos (Nat.lt_succ_of_le hk₀)]
    rw [C.exact t, hproj] at htel
    simpa only [dudleyScaleIncrement] using htel.symm
  rw [htail]
  calc
    |∑ k ∈ Finset.Ico k₀ A.terminal,
        dudleyScaleIncrement C X k t ω| ≤
        ∑ k ∈ Finset.Ico k₀ A.terminal,
          |dudleyScaleIncrement C X k t ω| :=
      Finset.abs_sum_le_sum_abs _ _
    _ ≤ ∑ k ∈ Finset.Ico k₀ A.terminal,
        64 * K * realGammaTwoWeight (k + 1) *
          d (C.projection (k + 1) t) (C.projection k t) := by
      apply Finset.sum_le_sum
      intro k hk
      have hkterm := (Finset.mem_Ico.mp hk).2
      let p : T × T :=
        (admissibleProjection d A ⟨k + 1, Nat.succ_lt_succ hkterm⟩ t,
          admissibleProjection d A ⟨k, Nat.lt_trans hkterm (Nat.lt_succ_self _)⟩ t)
      have hp : p ∈ admissibleEdges d A k :=
        (mem_admissibleEdges d A hkterm).mpr ⟨t, rfl⟩
      have hedge := edgeIncrement_le_of_notMem_genericFineBad
        X d A hgood hk hp
      have hCsucc : C.projection (k + 1) t =
          admissibleProjection d A ⟨k + 1, Nat.succ_lt_succ hkterm⟩ t := by
        dsimp [C, admissibleDudleyChain]
        rw [dif_pos (Nat.succ_lt_succ hkterm)]
      have hC : C.projection k t =
          admissibleProjection d A
            ⟨k, Nat.lt_trans hkterm (Nat.lt_succ_self _)⟩ t := by
        dsimp [C, admissibleDudleyChain]
        rw [dif_pos (Nat.lt_succ_of_lt hkterm)]
      change |X (C.projection (k + 1) t) ω - X (C.projection k t) ω| ≤ _
      rw [hCsucc, hC]
      exact hedge
    _ = 64 * K * (∑ k ∈ Finset.Ico k₀ A.terminal,
        realGammaTwoWeight (k + 1) *
          d (C.projection (k + 1) t) (C.projection k t)) := by
      rw [Finset.mul_sum]
      apply Finset.sum_congr rfl
      intro k hk
      ring
    _ ≤ 64 * K * (∑ k ∈ Finset.range A.terminal,
        realGammaTwoWeight (k + 1) *
          d (C.projection (k + 1) t) (C.projection k t)) := by
      have hsubset : Finset.Ico k₀ A.terminal ⊆
          Finset.range A.terminal := by
        intro k hk
        exact Finset.mem_range.mpr (Finset.mem_Ico.mp hk).2
      have hsum : (∑ k ∈ Finset.Ico k₀ A.terminal,
          realGammaTwoWeight (k + 1) *
            d (C.projection (k + 1) t) (C.projection k t)) ≤
          ∑ k ∈ Finset.range A.terminal,
            realGammaTwoWeight (k + 1) *
              d (C.projection (k + 1) t) (C.projection k t) := by
        apply Finset.sum_le_sum_of_subset_of_nonneg hsubset
        intro k hk hnot
        exact mul_nonneg (realGammaTwoWeight_nonneg _) (hd _ _)
      exact mul_le_mul_of_nonneg_left hsum
        (mul_nonneg (by norm_num) hK0)
    _ ≤ 64 * K * (3 * realChainPointCost d A t) := by
      gcongr
      exact weightedDudleyProjectionDistanceSum_le
        d hd hsymm htri hd0 A t
    _ = 192 * K * realChainPointCost d A t := by ring

/-- Summed increment control by chain cost. Deterministic endpoint of the first-big-leap decomposition.

**Book Equation (8.50).** -/
theorem finiteProcessOscillation_le_of_firstBigLeap_good
    (X : HDP.RandomProcess T Ω) (d : T → T → ℝ)
    (hd : ∀ s t, 0 ≤ d s t) (hsymm : ∀ s t, d s t = d t s)
    (htri : ∀ r s t, d r t ≤ d r s + d s t)
    (hd0 : ∀ t, d t t = 0)
    (A : HDP.FiniteAdmissibleChain T) {K u : ℝ} {ω : Ω}
    (hK0 : 0 ≤ K) (hu0 : 0 ≤ u)
    (hfirst : ω ∉ firstBigLeapBad X d A K
      (cappedFirstBigLeapScale A u)
      ⟨cappedFirstBigLeapIndex A u,
        Nat.lt_succ_of_le (cappedFirstBigLeapIndex_le_terminal A u)⟩)
    (hfine : ω ∉ genericFineBad X d A K
      (cappedFirstBigLeapIndex A u)) :
    finiteProcessOscillation X ω ≤
      896 * K *
        (realChainCost d A + u * finiteDistanceDiameter d) := by
  let k₀ := cappedFirstBigLeapIndex A u
  let k : Fin (A.terminal + 1) :=
    ⟨k₀, Nat.lt_succ_of_le (cappedFirstBigLeapIndex_le_terminal A u)⟩
  let v := cappedFirstBigLeapScale A u
  have hk₀ : k₀ ≤ A.terminal := cappedFirstBigLeapIndex_le_terminal A u
  have hv : v ≤ 2 * (1 + u) := by
    calc
      v ≤ 2 * max 1 u := cappedFirstBigLeapScale_le_two_max_one A u
      _ ≤ 2 * (1 + u) := by
        gcongr
        exact max_le (by linarith) (by linarith)
  have hdiam := finiteDistanceDiameter_le_two_chainCost
    d hd hsymm htri hd0 A
  have hdiam0 := finiteDistanceDiameter_nonneg d hd
  have hcost0 := realChainCost_nonneg d hd A
  have hanchored : finiteProcessIncrementSup X (admissibleAnchor A) ω ≤
      448 * K * realChainCost d A +
        128 * K * u * finiteDistanceDiameter d := by
    unfold finiteProcessIncrementSup
    apply Finset.sup'_le
    intro t ht
    let s := admissibleProjection d A k t
    have hs : s ∈ A.level k := admissibleProjection_mem d A k t
    have hfirst_t : |X s ω - X (admissibleAnchor A) ω| ≤
        64 * K * v * finiteDistanceDiameter d := by
      have hraw :=
        edgeIncrement_le_of_notMem_firstBigLeapBad X d A hfirst hs
      change |X s ω - X (admissibleAnchor A) ω| ≤
        64 * K * v * finiteDistanceDiameter d at hraw
      exact hraw
    have hfine_t : |X t ω - X s ω| ≤
        192 * K * realChainPointCost d A t := by
      simpa [s, k, k₀] using truncatedFineIncrement_le
        X d hd hsymm htri hd0 A hK0 hk₀ hfine t
    have hpoint := realChainPointCost_le_realChainCost d A t
    calc
      |X t ω - X (admissibleAnchor A) ω| ≤
          |X t ω - X s ω| + |X s ω - X (admissibleAnchor A) ω| := by
        exact abs_sub_le _ _ _
      _ ≤ 192 * K * realChainPointCost d A t +
          64 * K * v * finiteDistanceDiameter d :=
        add_le_add hfine_t hfirst_t
      _ ≤ 192 * K * realChainCost d A +
          64 * K * v * finiteDistanceDiameter d := by
        gcongr
      _ ≤ 192 * K * realChainCost d A +
          128 * K * (1 + u) * finiteDistanceDiameter d := by
        have hv0 : 0 ≤ v := cappedFirstBigLeapScale_nonneg A u
        have hcoef : 64 * v ≤ 128 * (1 + u) := by nlinarith
        have hmul := mul_le_mul_of_nonneg_right
          (mul_le_mul_of_nonneg_right hcoef hK0) hdiam0
        nlinarith
      _ ≤ 448 * K * realChainCost d A +
          128 * K * u * finiteDistanceDiameter d := by
        nlinarith [mul_nonneg hK0 hdiam0,
          mul_nonneg hK0 hcost0]
  have hosc := finiteProcessOscillation_le_two_incrementSup
    X (admissibleAnchor A) ω
  calc
    finiteProcessOscillation X ω ≤
        2 * finiteProcessIncrementSup X (admissibleAnchor A) ω := hosc
    _ ≤ 2 * (448 * K * realChainCost d A +
        128 * K * u * finiteDistanceDiameter d) := by gcongr
    _ ≤ 896 * K *
        (realChainCost d A + u * finiteDistanceDiameter d) := by
      nlinarith [mul_nonneg hK0 hcost0,
        mul_nonneg (mul_nonneg hK0 hu0) hdiam0]

/-- This declaration formalizes the statement identified as Exercise 8.35 in the source.

**Book Exercise 8.35.** -/
theorem exercise_8_35_highProbability_forChain [IsProbabilityMeasure μ]
    (X : HDP.RandomProcess T Ω) (hXm : ∀ t, Measurable (X t))
    (d : T → T → ℝ) (hd : ∀ s t, 0 ≤ d s t)
    (hsymm : ∀ s t, d s t = d t s)
    (htri : ∀ r s t, d r t ≤ d r s + d s t)
    (hd0 : ∀ t, d t t = 0)
    (A : HDP.FiniteAdmissibleChain T) {K u : ℝ}
    (hK : 0 < K) (hu : 0 ≤ u)
    (hinc : HDP.HasSubGaussianIncrementsWith X μ d K) :
    μ {ω | 896 * K *
        (realChainCost d A + u * finiteDistanceDiameter d) <
          finiteProcessOscillation X ω} ≤
      ENNReal.ofReal (2 * Real.exp (-u ^ 2)) := by
  let k₀ := cappedFirstBigLeapIndex A u
  let k : Fin (A.terminal + 1) :=
    ⟨k₀, Nat.lt_succ_of_le (cappedFirstBigLeapIndex_le_terminal A u)⟩
  let v := cappedFirstBigLeapScale A u
  let B := firstBigLeapBad X d A K v k
  let F := genericFineBad X d A K k₀
  have hB : μ B ≤ ENNReal.ofReal (Real.exp (-u ^ 2)) := by
    calc
      μ B ≤ ENNReal.ofReal (Real.exp (-v ^ 2)) := by
        exact measure_firstBigLeapBad X hXm d hd A hK
          (one_le_cappedFirstBigLeapScale A u) hinc k
          (weight_cappedFirstBigLeapIndex_le_scale A u)
      _ ≤ ENNReal.ofReal (Real.exp (-u ^ 2)) := by
        apply ENNReal.ofReal_le_ofReal
        apply Real.exp_le_exp.mpr
        have hv0 := cappedFirstBigLeapScale_nonneg A u
        have huv := u_le_cappedFirstBigLeapScale A u
        nlinarith
  have hF : μ F ≤ ENNReal.ofReal (Real.exp (-u ^ 2)) := by
    by_cases hkterm : k₀ < A.terminal
    · calc
        μ F ≤ ENNReal.ofReal (Real.exp (-2 * ((2 : ℝ) ^ k₀))) :=
          measure_genericFineBad X hXm d hd A hK hinc k₀
        _ ≤ ENNReal.ofReal (Real.exp (-u ^ 2)) := by
          apply ENNReal.ofReal_le_ofReal
          apply Real.exp_le_exp.mpr
          have hwu : max 1 u ≤ realGammaTwoWeight k₀ := by
            simpa [k₀] using
              max_one_le_weight_capped_of_lt_terminal A u hkterm
          have huweight : u ≤ realGammaTwoWeight k₀ :=
            (le_max_right 1 u).trans hwu
          have hsq := realGammaTwoWeight_sq k₀
          have hu0' : 0 ≤ u := hu
          have hw0 := realGammaTwoWeight_nonneg k₀
          nlinarith
    · have hkEq : k₀ = A.terminal := by
        have hle := cappedFirstBigLeapIndex_le_terminal A u
        omega
      have hFempty : F = ∅ := by
        simp [F, genericFineBad, hkEq]
      rw [hFempty]
      simp
  calc
    μ {ω | 896 * K *
        (realChainCost d A + u * finiteDistanceDiameter d) <
          finiteProcessOscillation X ω} ≤ μ (B ∪ F) := by
      apply measure_mono
      intro ω hω
      by_contra hgood
      have hpair : ω ∉ B ∧ ω ∉ F := by
        simpa [Set.mem_union] using hgood
      have hnotB : ω ∉ B := hpair.1
      have hnotF : ω ∉ F := hpair.2
      have hle := finiteProcessOscillation_le_of_firstBigLeap_good
        X d hd hsymm htri hd0 A hK.le hu
        (by simpa [B, v, k, k₀] using hnotB)
        (by simpa [F, k₀] using hnotF)
      exact (not_lt_of_ge hle) hω
    _ ≤ μ B + μ F := MeasureTheory.measure_union_le _ _
    _ ≤ ENNReal.ofReal (Real.exp (-u ^ 2)) +
        ENNReal.ofReal (Real.exp (-u ^ 2)) := add_le_add hB hF
    _ = ENNReal.ofReal (2 * Real.exp (-u ^ 2)) := by
      rw [← ENNReal.ofReal_add (Real.exp_pos _).le (Real.exp_pos _).le]
      congr 1
      ring

/-- If the supplied distance vanishes identically, every admissible chain has zero real cost.

**Lean implementation helper.** -/
theorem realChainCost_eq_zero_of_distance_eq_zero
    (d : T → T → ℝ) (hd : ∀ s t, 0 ≤ d s t)
    (hzero : ∀ s t, d s t = 0)
    (A : HDP.FiniteAdmissibleChain T) :
    realChainCost d A = 0 := by
  have hfd (S : Finset T) (hS : S.Nonempty) (t : T) :
      finiteSetDistance d S hS t = 0 := by
    have hS' := hS
    obtain ⟨s, hs⟩ := hS
    apply le_antisymm
    · exact (Finset.inf'_le (d t) hs).trans_eq (hzero t s)
    · exact finiteSetDistance_nonneg d hd hS' t
  have hpoint (t : T) : realChainPointCost d A t = 0 := by
    unfold realChainPointCost
    apply Finset.sum_eq_zero
    intro i hi
    rw [hfd]
    simp
  apply le_antisymm
  · unfold realChainCost
    apply Finset.sup'_le
    intro t ht
    rw [hpoint]
  · exact realChainCost_nonneg d hd A

/-- If the increment scale or real chain cost vanishes, the finite-process oscillation is almost everywhere zero.

**Lean implementation helper.** -/
theorem finiteProcessOscillation_ae_zero_of_scale_zero
    [IsProbabilityMeasure μ]
    (X : HDP.RandomProcess T Ω) (hXm : ∀ t, Measurable (X t))
    (d : T → T → ℝ) (hd : ∀ s t, 0 ≤ d s t)
    (hd0 : ∀ t, d t t = 0) (A : HDP.FiniteAdmissibleChain T)
    {K : ℝ} (hinc : HDP.HasSubGaussianIncrementsWith X μ d K)
    (hzero : K = 0 ∨ realChainCost d A = 0) :
    finiteProcessOscillation X =ᵐ[μ] 0 := by
  have hanch := finiteProcessIncrementSup_ae_zero_of_scale_zero
    X hXm d hd hd0 A hinc hzero
  filter_upwards [hanch] with ω hω
  apply le_antisymm
  · have hle := finiteProcessOscillation_le_two_incrementSup
      X (admissibleAnchor A) ω
    simpa [hω] using hle
  · exact finiteProcessOscillation_nonneg X ω

/-- Universal numerical constant in the finite high-probability generic
chaining estimate.

**Lean implementation helper.** -/
def genericChainingHighProbabilityConstant : ℝ := 1792

/-- Shows that the generic chaining high probability constant is strictly positive.

**Lean implementation helper.** -/
theorem genericChainingHighProbabilityConstant_pos :
    0 < genericChainingHighProbabilityConstant := by
  norm_num [genericChainingHighProbabilityConstant]

/-- Generic chaining has a high-probability `gamma2 + u diam` bound. The first big
leap separates the ordinary gamma-two term from the deviation term involving
only the diameter.

**Book Remark 8.5.4.** -/
theorem exercise_8_35_highProbability [IsProbabilityMeasure μ]
    (X : HDP.RandomProcess T Ω) (hXm : ∀ t, Measurable (X t))
    (d : T → T → ℝ) (hd : ∀ s t, 0 ≤ d s t)
    (hsymm : ∀ s t, d s t = d t s)
    (htri : ∀ r s t, d r t ≤ d r s + d s t)
    (hd0 : ∀ t, d t t = 0) {K u : ℝ}
    (hu : 0 ≤ u)
    (hinc : HDP.HasSubGaussianIncrementsWith X μ d K) :
    μ {ω | genericChainingHighProbabilityConstant * K *
        ((HDP.gamma2 (fun s t => ENNReal.ofReal (d s t))).toReal +
          u * finiteDistanceDiameter d) < finiteProcessOscillation X ω} ≤
      ENNReal.ofReal (2 * Real.exp (-u ^ 2)) := by
  let g := (HDP.gamma2 (fun s t => ENNReal.ofReal (d s t))).toReal
  have hg0 : 0 ≤ g := ENNReal.toReal_nonneg
  have hdiam0 := finiteDistanceDiameter_nonneg d hd
  let A₀ := HDP.canonicalFiniteAdmissibleChain T
  by_cases hKzero : K = 0
  · have hz := finiteProcessOscillation_ae_zero_of_scale_zero
      X hXm d hd hd0 A₀ hinc (Or.inl hKzero)
    have hnull : μ {ω | 0 < finiteProcessOscillation X ω} = 0 := by
      rw [measure_eq_zero_iff_ae_notMem]
      filter_upwards [hz] with ω hω
      simp [hω]
    rw [hKzero]
    simpa using (show μ {ω | 0 < finiteProcessOscillation X ω} ≤
      ENNReal.ofReal (2 * Real.exp (-u ^ 2)) by rw [hnull]; exact bot_le)
  · have hK : 0 < K := lt_of_le_of_ne hinc.1 (Ne.symm hKzero)
    by_cases hgzero : g = 0
    · have hhalf := half_finiteDistanceDiameter_le_gamma2
        d hd hsymm htri hd0
      have hdiamzero : finiteDistanceDiameter d = 0 := by
        change finiteDistanceDiameter d / 2 ≤ g at hhalf
        linarith
      have hdall : ∀ s t, d s t = 0 := by
        intro s t
        apply le_antisymm
        · exact (distance_le_finiteDistanceDiameter d s t).trans_eq hdiamzero
        · exact hd s t
      have hcostzero : realChainCost d A₀ = 0 :=
        realChainCost_eq_zero_of_distance_eq_zero d hd hdall A₀
      have hz := finiteProcessOscillation_ae_zero_of_scale_zero
        X hXm d hd hd0 A₀ hinc (Or.inr hcostzero)
      have hnull : μ {ω | 0 < finiteProcessOscillation X ω} = 0 := by
        rw [measure_eq_zero_iff_ae_notMem]
        filter_upwards [hz] with ω hω
        simp [hω]
      change μ {ω | genericChainingHighProbabilityConstant * K *
          (g + u * finiteDistanceDiameter d) <
            finiteProcessOscillation X ω} ≤ _
      rw [hgzero, hdiamzero]
      simpa using (show μ {ω | 0 < finiteProcessOscillation X ω} ≤
        ENNReal.ofReal (2 * Real.exp (-u ^ 2)) by rw [hnull]; exact bot_le)
    · have hg : 0 < g := lt_of_le_of_ne hg0 (Ne.symm hgzero)
      have hrepr : g = ⨅ A : HDP.FiniteAdmissibleChain T,
          realChainCost d A := by
        dsimp [g]
        rw [HDP.gamma2, ENNReal.toReal_iInf
          (fun A => chainCost_ofReal_ne_top d hd A)]
        congr 1
        funext A
        exact chainCost_toReal_ofReal d hd A
      letI : Nonempty (HDP.FiniteAdmissibleChain T) := ⟨A₀⟩
      have hinf_lt : (⨅ A : HDP.FiniteAdmissibleChain T,
          realChainCost d A) < 2 * g := by
        rw [← hrepr]
        linarith
      obtain ⟨A, hA⟩ := exists_lt_of_ciInf_lt hinf_lt
      have hfixed := exercise_8_35_highProbability_forChain
        X hXm d hd hsymm htri hd0 A hK hu hinc
      have hthreshold : 896 * K *
          (realChainCost d A + u * finiteDistanceDiameter d) ≤
          genericChainingHighProbabilityConstant * K *
            (g + u * finiteDistanceDiameter d) := by
        have huD : 0 ≤ u * finiteDistanceDiameter d :=
          mul_nonneg hu hdiam0
        dsimp [genericChainingHighProbabilityConstant]
        nlinarith [mul_nonneg hK.le huD]
      calc
        μ {ω | genericChainingHighProbabilityConstant * K *
            ((HDP.gamma2 (fun s t => ENNReal.ofReal (d s t))).toReal +
              u * finiteDistanceDiameter d) < finiteProcessOscillation X ω} ≤
            μ {ω | 896 * K *
              (realChainCost d A + u * finiteDistanceDiameter d) <
                finiteProcessOscillation X ω} := by
          apply measure_mono
          intro ω hω
          change genericChainingHighProbabilityConstant * K *
            (g + u * finiteDistanceDiameter d) <
              finiteProcessOscillation X ω at hω
          exact hthreshold.trans_lt hω
        _ ≤ ENNReal.ofReal (2 * Real.exp (-u ^ 2)) := hfixed

